// JSON validator — recursive descent parser in Milo
// Validates JSON syntax per RFC 8259

fn is_ws(ch: u8): bool {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn is_digit(ch: u8): bool {
    return ch >= '0' && ch <= '9'
}

fn is_hex(ch: u8): bool {
    return is_digit(ch) || (ch >= 'A' && ch <= 'F') || (ch >= 'a' && ch <= 'f')
}

fn skip_ws(s: &string, pos: &mut i64) {
    while pos < s.len && is_ws(s[pos]) {
        pos = pos + 1
    }
}

fn parse_value(s: &string, pos: &mut i64): bool {
    skip_ws(s, pos)
    if pos >= s.len { return false }
    let ch = s[pos]
    if ch == '"' { return parse_string(s, pos) }
    if ch == '{' { return parse_object(s, pos) }
    if ch == '[' { return parse_array(s, pos) }
    if ch == 't' { return expect_chars(s, pos, "true") }
    if ch == 'f' { return expect_chars(s, pos, "false") }
    if ch == 'n' { return expect_chars(s, pos, "null") }
    if ch == '-' || is_digit(ch) { return parse_number(s, pos) }
    return false
}

fn parse_string(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '"' { return false }
    pos = pos + 1
    while pos < s.len {
        let ch = s[pos]
        if ch == '"' {
            pos = pos + 1
            return true
        } else if ch == '\\' {
            pos = pos + 1
            if pos >= s.len { return false }
            let esc = s[pos]
            if esc == 'u' {
                pos = pos + 1
                var i: i64 = 0
                while i < 4 {
                    if pos >= s.len || !is_hex(s[pos]) { return false }
                    pos = pos + 1
                    i = i + 1
                }
            } else if esc == '"' || esc == '\\' || esc == '/' || esc == 'b' || esc == 'f' || esc == 'n' || esc == 'r' || esc == 't' {
                pos = pos + 1
            } else {
                return false
            }
        } else {
            pos = pos + 1
        }
    }
    return false
}

fn parse_number(s: &string, pos: &mut i64): bool {
    if pos >= s.len { return false }
    if s[pos] == '-' {
        pos = pos + 1
        if pos >= s.len { return false }
    }
    if s[pos] == '0' {
        pos = pos + 1
    } else if is_digit(s[pos]) {
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    } else {
        return false
    }
    // fractional part
    if pos < s.len && s[pos] == '.' {
        pos = pos + 1
        if pos >= s.len || !is_digit(s[pos]) { return false }
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    }
    // exponent
    if pos < s.len && (s[pos] == 'e' || s[pos] == 'E') {
        pos = pos + 1
        if pos >= s.len { return false }
        if s[pos] == '+' || s[pos] == '-' {
            pos = pos + 1
        }
        if pos >= s.len || !is_digit(s[pos]) { return false }
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    }
    return true
}

fn parse_array(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '[' { return false }
    pos = pos + 1
    skip_ws(s, pos)
    if pos < s.len && s[pos] == ']' {
        pos = pos + 1
        return true
    }
    if !parse_value(s, pos) { return false }
    skip_ws(s, pos)
    while pos < s.len {
        if s[pos] == ']' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parse_value(s, pos) { return false }
            skip_ws(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parse_object(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '{' { return false }
    pos = pos + 1
    skip_ws(s, pos)
    if pos < s.len && s[pos] == '}' {
        pos = pos + 1
        return true
    }
    if !parse_kv(s, pos) { return false }
    skip_ws(s, pos)
    while pos < s.len {
        if s[pos] == '}' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parse_kv(s, pos) { return false }
            skip_ws(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parse_kv(s: &string, pos: &mut i64): bool {
    skip_ws(s, pos)
    if !parse_string(s, pos) { return false }
    skip_ws(s, pos)
    if pos >= s.len || s[pos] != ':' { return false }
    pos = pos + 1
    return parse_value(s, pos)
}

fn expect_chars(s: &string, pos: &mut i64, expected: &string): bool {
    var i: i64 = 0
    while i < expected.len {
        if pos >= s.len || s[pos] != expected[i] { return false }
        pos = pos + 1
        i = i + 1
    }
    return true
}

fn validate(json: string): bool {
    var pos: i64 = 0
    if !parse_value(json, pos) { return false }
    skip_ws(json, pos)
    return pos == json.len
}

fn test(label: string, json: string, expected: bool) {
    let result = validate(json)
    if result == expected {
        print("PASS: %s", label)
    } else {
        if expected {
            print("FAIL: %s (expected valid)", label)
        } else {
            print("FAIL: %s (expected invalid)", label)
        }
    }
}

fn main(): i32 {
    test("null", "null", true)
    test("true", "true", true)
    test("false", "false", true)
    test("zero", "0", true)
    test("integer", "42", true)
    test("negative", "-17", true)
    test("float", "3.14", true)
    test("exponent", "1e10", true)
    test("neg exponent", "2.5E-3", true)
    test("empty string", "\"\"", true)
    test("simple string", "\"hello\"", true)
    test("escaped string", "\"a\\nb\"", true)
    test("unicode escape", "\"\\u0041\"", true)
    test("empty array", "[]", true)
    test("number array", "[1, 2, 3]", true)
    test("nested array", "[[1], [2]]", true)
    test("empty object", "{}", true)
    test("simple object", "{\"a\": 1}", true)
    test("nested object", "{\"a\": {\"b\": 2}}", true)
    test("mixed", "{\"a\": [1, true, null]}", true)
    test("whitespace", "  { \"x\" : 42 }  ", true)

    test("empty", "", false)
    test("bare word", "hello", false)
    test("single quote", "'a'", false)
    test("trailing comma arr", "[1,]", false)
    test("trailing comma obj", "{\"a\":1,}", false)
    test("no colon", "{\"a\" 1}", false)
    test("bad escape", "\"\\q\"", false)
    test("unclosed string", "\"abc", false)
    test("unclosed array", "[1, 2", false)
    test("unclosed object", "{\"a\": 1", false)
    test("trailing garbage", "42 abc", false)
    test("leading zero", "01", false)

    return 0
}
