from "std/testing" import { assert, assertEqual }

fn testAddition(): void {
    assertEqual(2 + 2, 4)
    assertEqual(10 + 20, 30)
    assertEqual(0 + 0, 0)
}

fn testSubtraction(): void {
    assertEqual(10 - 3, 7)
    assertEqual(5 - 5, 0)
}

fn testMultiplication(): void {
    assertEqual(3 * 4, 12)
    assertEqual(7 * 0, 0)
    assertEqual(1 * 99, 99)
}

fn testAssert(): void {
    assert(true)
    assert(2 > 1)
    assert(10 != 20)
}

fn main(): i32 {
    testAddition()
    testSubtraction()
    testMultiplication()
    testAssert()
    print("all tests passed")
    return 0
}
