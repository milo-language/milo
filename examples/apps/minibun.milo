}

// Evaluate `code`; on an uncaught exception print it and return 1.
fn evalScript(ctx: *u8, code: string, sourceName: string): i32 {
    unsafe {
        let script = JSStringCreateWithUTF8CString(code)
        let url = JSStringCreateWithUTF8CString(sourceName)
        var exc: *u8 = 0 as *u8
        JSEvaluateScript(ctx, script, 0 as *u8, url, 1, (exc.addrOf()) as *u8)
        JSStringRelease(script)
        JSStringRelease(url)
        if exc as i64 != 0 {
            print("Uncaught " + jsToString(ctx, exc))
            return 1
        }
        return 0
    }
}

fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: minibun <file.js>")
        return 1
    }
    let path = argv[1]

    unsafe {
        let ctx = JSGlobalContextCreate(0 as *u8)
        let global = JSContextGetGlobalObject(ctx)

        installConsole(ctx, global)
        setGlobalFn(ctx, global, "__readFileSync", nativeReadFileSync as *u8)
        setGlobalFn(ctx, global, "__fileExists", nativeFileExists as *u8)
        setGlobalFn(ctx, global, "__getenv", nativeGetenv as *u8)
        setGlobalFn(ctx, global, "__isDir", nativeIsDir as *u8)
        setGlobalFn(ctx, global, "__fileSize", nativeFileSize as *u8)
        setGlobalFn(ctx, global, "__fetch", nativeFetch as *u8)

        // Hand the entry path to the bootstrap as a global, avoiding string-quoting in a
        // constructed launcher.
        let epName = JSStringCreateWithUTF8CString("__entryPath")
        JSObjectSetProperty(ctx, global, epName, jsString(ctx, path.clone()), 0 as u32, 0 as *u8)
        JSStringRelease(epName)

        var code = evalScript(ctx, moduleBootstrap(), "<bootstrap>")
        if code == 0 {
            code = evalScript(ctx, "try{ __runEntry(__entryPath); }catch(e){ console.log('Uncaught ' + (e && e.message ? e.message : e) + (e && e.stack ? '\\n' + e.stack : '')); throw e; }", path)
        }

        // If the entry registered an HTTP server (server.listen stores __mbServer and
        // returns instead of blocking), run its accept loop here — at the top level, so
        // async route handlers' microtasks drain between requests.
        if code == 0 {
            let serverObj = lookupGlobal(ctx, "__mbServer")
            if !JSValueIsUndefined(ctx, serverObj) {
                let port = (JSValueToNumber(ctx, getProp(ctx, serverObj, "port"), 0 as *u8)) as u16
                let handler = getProp(ctx, serverObj, "handler")
                let getRaw = lookupGlobal(ctx, "__mbGetRaw")
                serveMain(ctx, port, handler, getRaw)
            }
        }

        JSGlobalContextRelease(ctx)
        return code
    }
}
