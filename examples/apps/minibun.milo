// minibun — a minimal JavaScript runtime in Milo.
//
// JS runs on JavaScriptCore (the system framework on macOS — zero install), but the
// runtime host — the module loader, the `console.log` binding, the file/exists natives,
// the exception reporter — is memory-safe, bounds-checked Milo. bun's 82K LOC of C++ glue
// is for deep JSC integration; the public embedding API JSC exposes is plain C, which is
// exactly the seam Milo's FFI is built for.
//
// Roadmap: docs/minibun-roadmap.md. Working: CommonJS modules (require/cache/resolution),
// a builtin-module registry (events/path/util/assert/fs/os/http/net/stream/crypto/… — pure
// JS over a few thin Milo natives), process/global scaffolding, and an HTTP server whose
// accept loop is Milo and whose request/response semantics are JS.
//
// The server serves multiple sequential requests (the fd-0 accept bug was a std Drop-glue
// issue — fd guards closed fd 0 on zeroed moved-from slots — fixed in std; see
// docs/minibun-roadmap.md M6).
//
// Demo — a hand-written Express-style JSON API (routing, :params, persistent state):
//   milo run examples/apps/minibun.milo -- examples/apps/minibun-notes.js
//   curl localhost:8080/notes  ·  curl -X POST 'localhost:8080/notes?text=hi'
//
// Build + run (macOS):
//   milo run examples/apps/minibun.milo -- entry.js      (JSC auto-linked by detectLibs)

from "std/os" import {
    malloc, free, memcpy
}
from "std/io" import {
    readFile
}
from "std/fs" import {
    isFile, isDir, fileSizePath
}
from "std/net" import {
    TcpListener, fetchWith, FetchOptions, NetError, Response
}
from "std/args" import {
    args
}
from "std/cstr" import {
    CStr
}

// ── JavaScriptCore C API (public embedding surface — all opaque refs are `*u8`) ──

extern fn JSGlobalContextCreate(globalObjectClass: *u8): *u8

extern fn JSGlobalContextRelease(ctx: *u8): void

extern fn JSContextGetGlobalObject(ctx: *u8): *u8

extern fn JSEvaluateScript(ctx: *u8, script: *u8, thisObject: *u8, sourceURL: *u8, startingLineNumber: i32, exception: *u8): *u8

extern fn JSStringCreateWithUTF8CString(s: *u8): *u8

extern fn JSStringRelease(s: *u8): void

extern fn JSStringGetMaximumUTF8CStringSize(s: *u8): i64

extern fn JSStringGetUTF8CString(s: *u8, buffer: *u8, bufferSize: i64): i64

extern fn JSValueToStringCopy(ctx: *u8, value: *u8, exception: *u8): *u8

extern fn JSValueMakeUndefined(ctx: *u8): *u8

extern fn JSValueIsUndefined(ctx: *u8, value: *u8): bool

extern fn JSValueMakeString(ctx: *u8, s: *u8): *u8

extern fn JSValueMakeBoolean(ctx: *u8, boolean: bool): *u8

extern fn JSValueMakeNumber(ctx: *u8, number: f64): *u8

extern fn JSObjectMakeFunctionWithCallback(ctx: *u8, name: *u8, callAsFunction: *u8): *u8

extern fn JSObjectMake(ctx: *u8, jsClass: *u8, data: *u8): *u8

extern fn JSObjectSetProperty(ctx: *u8, object: *u8, propertyName: *u8, value: *u8, attributes: u32, exception: *u8): void

extern fn JSObjectCallAsFunction(ctx: *u8, object: *u8, thisObject: *u8, argumentCount: i64, arguments: *u8, exception: *u8): *u8

extern fn JSValueToNumber(ctx: *u8, value: *u8, exception: *u8): f64

extern fn JSValueProtect(ctx: *u8, value: *u8): void

extern fn JSObjectGetProperty(ctx: *u8, object: *u8, propertyName: *u8, exception: *u8): *u8

// libc getenv — backs process.env so node code reading JWT_SECRET/PORT/etc. sees the
// real environment the minibun process was launched with (minibun has no dotenv).
extern fn getenv(name: *u8): *u8

// Read a pointer out of a C array of pointers (the callback's `arguments[]`).
fn loadPtr(p: *u8): *u8 {
    unsafe {
        var out: *u8 = 0 as *u8
        memcpy((out.addrOf()) as *u8, p, 8)
        return out
    }
}

// A JSValue -> owned Milo string, via JSC's own toString. Reused everywhere a JS value
// must cross into Milo (console args, native fn args, exception text).
fn jsToString(ctx: *u8, val: *u8): string {
    unsafe {
        let jstr = JSValueToStringCopy(ctx, val, 0 as *u8)
        let cap = JSStringGetMaximumUTF8CStringSize(jstr)
        let buf = malloc(cap)
        JSStringGetUTF8CString(jstr, buf, cap)
        let out = CStr.wrap(buf)!.toString()
        free(buf)
        JSStringRelease(jstr)
        return out
    }
}

// A Milo string -> JS string value.
fn jsString(ctx: *u8, s: string): *u8 {
    unsafe {
        let jstr = JSStringCreateWithUTF8CString(s)
        let v = JSValueMakeString(ctx, jstr)
        JSStringRelease(jstr)
        return v
    }
}

// Call a 1-arg JS function; returns its result, or null on a thrown exception.
fn callJs1(ctx: *u8, func: *u8, arg: *u8): *u8 {
    unsafe {
        let argArr = malloc(8)
        var a = arg
        memcpy(argArr, (a.addrOf()) as *u8, 8)
        var exc: *u8 = 0 as *u8
        let r = JSObjectCallAsFunction(ctx, func, 0 as *u8, 1, argArr, (exc.addrOf()) as *u8)
        free(argArr)
        if exc as i64 != 0 {
            return 0 as *u8
        }
        return r
    }
}

// Read property `name` off a JS object.
fn getProp(ctx: *u8, obj: *u8, name: string): *u8 {
    unsafe {
        let n = JSStringCreateWithUTF8CString(name)
        let v = JSObjectGetProperty(ctx, obj, n, 0 as *u8)
        JSStringRelease(n)
        return v
    }
}

// Look up a global by name (a JS function/value on globalThis).
fn lookupGlobal(ctx: *u8, name: string): *u8 {
    unsafe {
        return getProp(ctx, JSContextGetGlobalObject(ctx), name)
    }
}

// ── native functions JSC calls directly (C ABI, same mechanism as std/runtime's
//    pthread trampoline) ──

// console.log(...args) — space-joins and prints one line.
fn consoleLog(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        var line = ""
        var i: i64 = 0
        while i < argCount {
            let argVal = loadPtr((arguments as i64 + i * 8) as *u8)
            if i > 0 {
                line = line + " "
            }
            line = line + jsToString(ctx, argVal)
            i = i + 1
        }
        print(line)
        return JSValueMakeUndefined(ctx)
    }
}

// __getenv(name) -> string | undefined. Backs process.env (see moduleBootstrap).
fn nativeGetenv(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        if argCount < 1 {
            return JSValueMakeUndefined(ctx)
        }
        let name = jsToString(ctx, loadPtr(arguments))
        let v = getenv(name)
        if v as i64 == 0 {
            return JSValueMakeUndefined(ctx)
        }
        return jsString(ctx, CStr.wrap(v)!.toString())
    }
}

// __readFileSync(path) -> string | undefined. The module loader's file access.
fn nativeReadFileSync(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        if argCount < 1 {
            return JSValueMakeUndefined(ctx)
        }
        let path = jsToString(ctx, loadPtr(arguments))
        let r = readFile(path)
        match r {
            Result.Ok(s) => {
                return jsString(ctx, s)
            }
            Result.Err(_e) => {
                return JSValueMakeUndefined(ctx)
            }
        }
    }
}

// __fileExists(path) -> bool. Backed by isFile so it is false for directories, which is
// what the resolver wants (directories are probed via /index.js and /package.json).
fn nativeFileExists(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        if argCount < 1 {
            return JSValueMakeBoolean(ctx, false)
        }
        let path = jsToString(ctx, loadPtr(arguments))
        return JSValueMakeBoolean(ctx, isFile(path))
    }
}

// __isDir(path) -> bool. Lets fs.stat report isDirectory correctly, which express.static/
// send need to decide between an index-file lookup and streaming a path as a file.
fn nativeIsDir(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        if argCount < 1 {
            return JSValueMakeBoolean(ctx, false)
        }
        return JSValueMakeBoolean(ctx, isDir(jsToString(ctx, loadPtr(arguments))))
    }
}

// __fileSize(path) -> number (bytes, or -1 if absent). Feeds fs.stat().size so send can set
// Content-Length; a 0 size (the old stub) made static responses empty.
fn nativeFileSize(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        if argCount < 1 {
            return JSValueMakeNumber(ctx, -1.0)
        }
        return JSValueMakeNumber(ctx, (fileSizePath(jsToString(ctx, loadPtr(arguments)))) as f64)
    }
}

fn netErrString(e: &NetError): string {
    match e {
        NetError.DnsFailure(m) => {
            return "dns: " + m.clone()
        }
        NetError.ConnectionFailed(m) => {
            return "connect: " + m.clone()
        }
        NetError.TlsError(m) => {
            return "tls: " + m.clone()
        }
        NetError.SendFailed(m) => {
            return "send: " + m.clone()
        }
        NetError.Other(m) => {
            return m.clone()
        }
    }
}

// Set one property on a JS object from Milo.
fn setObjProp(ctx: *u8, obj: *u8, name: string, val: *u8): void {
    unsafe {
        let n = JSStringCreateWithUTF8CString(name)
        JSObjectSetProperty(ctx, obj, n, val, 0 as u32, 0 as *u8)
        JSStringRelease(n)
    }
}

// __fetch(url, method, headers, body) -> { status, headers, body } | { status:0, error }.
// Blocking: does the whole HTTPS request synchronously via std/net (which links the system
// OpenSSL). The JS `fetch` shim wraps this in a Promise + Response — see moduleBootstrap.
fn nativeFetch(ctx: *u8, _function: *u8, _thisObject: *u8, argCount: i64, arguments: *u8, _exception: *u8): *u8 {
    unsafe {
        let obj = JSObjectMake(ctx, 0 as *u8, 0 as *u8)
        if argCount < 1 {
            setObjProp(ctx, obj, "status", JSValueMakeNumber(ctx, 0.0))
            setObjProp(ctx, obj, "error", jsString(ctx, "fetch: missing url"))
            return obj
        }
        let url = jsToString(ctx, loadPtr(arguments))
        var method = "GET"
        var headers = ""
        var body = ""
        if argCount >= 2 {
            method = jsToString(ctx, loadPtr((arguments as i64 + 8) as *u8))
        }
        if argCount >= 3 {
            headers = jsToString(ctx, loadPtr((arguments as i64 + 16) as *u8))
        }
        if argCount >= 4 {
            body = jsToString(ctx, loadPtr((arguments as i64 + 24) as *u8))
        }
        let opts = FetchOptions {
            method: method, headers: headers, body: body
        }
        match fetchWith(url, opts) {
            Result.Ok(resp) => {
                setObjProp(ctx, obj, "status", JSValueMakeNumber(ctx, (resp.status) as f64))
                setObjProp(ctx, obj, "headers", jsString(ctx, resp.headers.clone()))
                setObjProp(ctx, obj, "body", jsString(ctx, resp.body.clone()))
            }
            Result.Err(e) => {
                setObjProp(ctx, obj, "status", JSValueMakeNumber(ctx, 0.0))
                setObjProp(ctx, obj, "error", jsString(ctx, netErrString(e)))
            }
        }
        return obj
    }
}

// The server accept loop — run from main() at the TOP LEVEL (not nested inside the entry
// eval), so each `handler(reqText)` call is an outermost JSC API entry: JSC drains the
// microtask queue when it returns, running any async route continuations, so `__mbGetRaw`
// then sees the finished response. (A nested call — e.g. if listen() blocked here directly —
// would NOT drain, and async handlers would return empty bodies.) `handler` returns the JS
// `res` object; `getRaw` renders it to a raw HTTP response string.
fn serveMain(ctx: *u8, port: u16, handler: *u8, getRaw: *u8): void {
    let lr = TcpListener.bind(port)
    match lr {
        Result.Err(_e) => {
            // Silent return here reads as a mysterious clean exit right after "listening"
            // (usual cause: the port is already held by another process).
            print("minibun: failed to bind port " + port.toString() + " (already in use?)")
        }
        Result.Ok(listener) => {
            JSValueProtect(ctx, handler)
            JSValueProtect(ctx, getRaw)
            while true {
                let ar = listener.accept()
                match ar {
                    Result.Err(_e2) => {
                    }
                    Result.Ok(stream) => {
                        let reqText = stream.recvOnce()
                        let resObj = callJs1(ctx, handler, jsString(ctx, reqText))
                        var respText = "HTTP/1.1 500 Internal Server Error\r\nContent-Length: 0\r\nConnection: close\r\n\r\n"
                        if resObj as i64 != 0 {
                            let rawVal = callJs1(ctx, getRaw, resObj)
                            if rawVal as i64 != 0 {
                                respText = jsToString(ctx, rawVal)
                            }
                        }
                        let _ = stream.send(respText)
                    }
                }
            }
        }
    }
}

// Bind a native callback as a global function `name`.
fn setGlobalFn(ctx: *u8, global: *u8, name: string, cb: *u8): void {
    unsafe {
        let n = JSStringCreateWithUTF8CString(name)
        let f = JSObjectMakeFunctionWithCallback(ctx, n, cb)
        JSObjectSetProperty(ctx, global, n, f, 0 as u32, 0 as *u8)
        JSStringRelease(n)
    }
}

// Install `console.log` (nested under a `console` object) on the global.
fn installConsole(ctx: *u8, global: *u8): void {
    unsafe {
        let fnName = JSStringCreateWithUTF8CString("log")
        let logFn = JSObjectMakeFunctionWithCallback(ctx, fnName, consoleLog as *u8)
        let console = JSObjectMake(ctx, 0 as *u8, 0 as *u8)
        let logKey = JSStringCreateWithUTF8CString("log")
        JSObjectSetProperty(ctx, console, logKey, logFn, 0 as u32, 0 as *u8)
        let consoleKey = JSStringCreateWithUTF8CString("console")
        JSObjectSetProperty(ctx, global, consoleKey, console, 0 as u32, 0 as *u8)
        JSStringRelease(fnName)
        JSStringRelease(logKey)
        JSStringRelease(consoleKey)
    }
}

// The CommonJS module system, in JS over the two natives above. new Function() gives each
// module the (exports, require, module, __filename, __dirname) wrapper Node uses; resolve()
// probes .js/.json/index.js/package.json#main and walks node_modules for bare specifiers.
// Built as line-by-line concatenation (no multiline string literals) — one JS line per
// Milo line keeps it debuggable.
fn moduleBootstrap(): string {
    return "" +
    "(function(){\n" +
    "  var cache = {};\n" +
    "  function dirname(p){ var i = p.lastIndexOf('/'); if(i<0) return '.'; if(i===0) return '/'; return p.slice(0,i); }\n" +
    "  function normalize(p){ var abs = p.charAt(0)==='/'; var parts = p.split('/'); var out=[]; for(var k=0;k<parts.length;k++){ var s=parts[k]; if(s===''||s==='.') continue; if(s==='..'){ out.pop(); continue; } out.push(s); } return (abs?'/':'')+out.join('/'); }\n" +
    "  function join(a,b){ return normalize(a+'/'+b); }\n" +
    "  function tryFile(base){\n" +
    "    if(__fileExists(base)) return base;\n" +
    "    if(__fileExists(base+'.js')) return base+'.js';\n" +
    "    if(__fileExists(base+'.json')) return base+'.json';\n" +
    "    if(__fileExists(base+'/index.js')) return base+'/index.js';\n" +
    "    var pj=base+'/package.json';\n" +
    "    if(__fileExists(pj)){ try{ var m=JSON.parse(__readFileSync(pj)).main||'index.js'; var mf=join(base,m); if(__fileExists(mf)) return mf; if(__fileExists(mf+'.js')) return mf+'.js'; if(__fileExists(mf+'/index.js')) return mf+'/index.js'; }catch(e){} }\n" +
    "    return null;\n" +
    "  }\n" +
    "  function resolve(fromDir, req){\n" +
    "    var base;\n" +
    "    if(req.charAt(0)==='/'){ base=normalize(req); }\n" +
    "    else if(req.slice(0,2)==='./' || req.slice(0,3)==='../' || req==='.' || req==='..'){ base=join(fromDir,req); }\n" +
    "    else { var dir=fromDir; while(true){ var c=tryFile(join(dir,'node_modules/'+req)); if(c) return c; var par=dirname(dir); if(par===dir) break; dir=par; } throw new Error('Cannot find module ' + req); }\n" +
    "    var f=tryFile(base); if(f) return f;\n" +
    "    throw new Error('Cannot find module ' + req);\n" +
    "  }\n" +
    "  function loadModule(filename){\n" +
    "    if(cache[filename]) return cache[filename].exports;\n" +
    "    var module={exports:{},filename:filename,loaded:false};\n" +
    "    cache[filename]=module;\n" +
    "    var src=__readFileSync(filename);\n" +
    "    if(src===undefined) throw new Error('Cannot read module ' + filename);\n" +
    "    if(filename.slice(-5)==='.json'){ module.exports=JSON.parse(src); module.loaded=true; return module.exports; }\n" +
    "    var dir=dirname(filename);\n" +
    "    var req=function(r){ var nr = r.slice(0,5)==='node:' ? r.slice(5) : r; if(builtins.hasOwnProperty(nr)) return builtins[nr]; return loadModule(resolve(dir,r)); };\n" +
    "    req.resolve=function(r){ return resolve(dir,r); }; req.cache=cache; req.main=undefined; module.require=req;\n" +
    "    var fn=new Function('exports','require','module','__filename','__dirname', src + '\\n//# sourceURL=' + filename);\n" +
    "    fn.call(module.exports, module.exports, req, module, filename, dir);\n" +
    "    module.loaded=true;\n" +
    "    return module.exports;\n" +
    "  }\n" +
    "  function EventEmitter(){ this._ev={}; }\n" +
    "  EventEmitter.prototype.on=function(t,f){ if(!this._ev)this._ev={}; (this._ev[t]||(this._ev[t]=[])).push(f); return this; };\n" +
    "  EventEmitter.prototype.addListener=EventEmitter.prototype.on;\n" +
    "  EventEmitter.prototype.prependListener=function(t,f){ if(!this._ev)this._ev={}; (this._ev[t]||(this._ev[t]=[])).unshift(f); return this; };\n" +
    "  EventEmitter.prototype.once=function(t,f){ var s=this; function g(){ s.removeListener(t,g); return f.apply(this,arguments); } g.listener=f; return s.on(t,g); };\n" +
    "  EventEmitter.prototype.removeListener=function(t,f){ if(!this._ev)return this; var a=this._ev[t]; if(a){ var i=a.indexOf(f); if(i>=0) a.splice(i,1); } return this; };\n" +
    "  EventEmitter.prototype.off=EventEmitter.prototype.removeListener;\n" +
    "  EventEmitter.prototype.removeAllListeners=function(t){ if(!this._ev)this._ev={}; if(t) delete this._ev[t]; else this._ev={}; return this; };\n" +
    "  EventEmitter.prototype.emit=function(t){ if(!this._ev)this._ev={}; var a=this._ev[t]; var args=Array.prototype.slice.call(arguments,1); if(!a||!a.length){ if(t==='error') throw (args[0]||new Error('Unhandled error event')); return false; } var cp=a.slice(); for(var i=0;i<cp.length;i++) cp[i].apply(this,args); return true; };\n" +
    "  EventEmitter.prototype.listeners=function(t){ return ((this._ev&&this._ev[t])||[]).slice(); };\n" +
    "  EventEmitter.prototype.listenerCount=function(t){ return ((this._ev&&this._ev[t])||[]).length; };\n" +
    "  EventEmitter.prototype.setMaxListeners=function(){ return this; };\n" +
    "  EventEmitter.prototype.getMaxListeners=function(){ return 10; };\n" +
    "  EventEmitter.EventEmitter=EventEmitter; EventEmitter.defaultMaxListeners=10;\n" +
    "  var pathMod={ sep:'/', delimiter:':', dirname:dirname, normalize:normalize, join:function(){ return normalize(Array.prototype.slice.call(arguments).join('/')); }, basename:function(p,ext){ var b=p.slice(p.lastIndexOf('/')+1); if(ext&&b.length>=ext.length&&b.slice(-ext.length)===ext) b=b.slice(0,b.length-ext.length); return b; }, extname:function(p){ var b=p.slice(p.lastIndexOf('/')+1); var i=b.lastIndexOf('.'); return i>0?b.slice(i):''; }, isAbsolute:function(p){ return p.charAt(0)==='/'; }, resolve:function(){ var r=''; for(var i=0;i<arguments.length;i++){ var a=arguments[i]; if(!a) continue; r=(a.charAt(0)==='/')?a:(r?r+'/'+a:a); } if(r.charAt(0)!=='/') r='/'+r; return normalize(r); }, parse:function(p){ var d=dirname(p); var b=p.slice(p.lastIndexOf('/')+1); var i=b.lastIndexOf('.'); return { root:'/', dir:d, base:b, ext:i>0?b.slice(i):'', name:i>0?b.slice(0,i):b }; }, relative:function(from,to){ from=normalize(from||''); to=normalize(to||''); var fp=from.split('/').filter(Boolean); var tp=to.split('/').filter(Boolean); var i=0; while(i<fp.length&&i<tp.length&&fp[i]===tp[i]) i++; var up=[]; for(var j=i;j<fp.length;j++) up.push('..'); return up.concat(tp.slice(i)).join('/'); }, toNamespacedPath:function(p){ return p; }, format:function(o){ o=o||{}; var dir=o.dir||o.root||''; var base=o.base||((o.name||'')+(o.ext||'')); return dir?(dir+'/'+base):base; } };\n" +
    "  pathMod.posix=pathMod; pathMod.win32=pathMod;\n" +
    "  function inherits(c,s){ var proto=(s&&(typeof s==='function'||typeof s==='object')&&s.prototype)?s.prototype:Object.prototype; if(!s||!s.prototype) console.log('[minibun] inherits: super has no prototype (typeof '+typeof s+'), using Object.prototype'); c.super_=s; c.prototype=Object.create(proto); c.prototype.constructor=c; }\n" +
    "  var utilMod={ inherits:inherits, inspect:function(o){ try{ return typeof o==='string'?o:JSON.stringify(o); }catch(e){ return String(o); } }, format:function(){ var a=Array.prototype.slice.call(arguments); if(typeof a[0]!=='string') return a.map(function(x){ return typeof x==='string'?x:JSON.stringify(x); }).join(' '); var f=a.shift(); var i=0; var s=f.replace(/%[sdj%]/g,function(m){ if(m==='%%')return '%'; if(i>=a.length)return m; var x=a[i++]; if(m==='%d')return Number(x); if(m==='%j')return JSON.stringify(x); return String(x); }); for(;i<a.length;i++) s+=' '+(typeof a[i]==='string'?a[i]:JSON.stringify(a[i])); return s; }, isArray:Array.isArray, isBuffer:function(){ return false; }, promisify:function(fn){ return function(){ var args=Array.prototype.slice.call(arguments); var self=this; return new Promise(function(res,rej){ args.push(function(err,v){ if(err) rej(err); else res(v); }); fn.apply(self,args); }); }; }, deprecate:function(fn){ return fn; }, types:{ isDate:function(x){ return x instanceof Date; } } };\n" +
