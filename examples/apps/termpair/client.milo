// termpair client — share your terminal via an encrypted WebSocket.
//
// Drop-in for the termpair-rs share client. Opens a PTY, spawns your shell,
// connects to a termpair server (wss:// by default), and relays I/O. Terminal
// output is encrypted with AES-128-GCM (unix key); the key needed to decrypt it
// lives only in the URL fragment, so the server never sees plaintext.
//
// Read-only: browser→shell input (the `command` event) is intentionally ignored.

from "std/pty" import { Pty, WinSize, openAndSpawn }
from "std/ws" import { WsConn, wsConnect, wsConnectTls }
from "std/net" import { resolve }
from "std/term" import { enableRawMode, restoreTerminal, readKey }
from "std/os" import { ioctl, read, write }
from "std/io" import { writeStdout, readStdin }
from "std/sync" import { AtomicBool }
from "std/runtime" import { Task, schedulerYield, schedulerWaitRead, _schedulerTick }
from "std/event" import { setNonblocking }
from "std/platform" import { getErrno, eagain }
from "std/time" import { epochSecs, sleepMs }
from "std/argparse" import { newParser }
from "std/base64" import { base64Encode, base64UrlEncode }

from "./protocol" import { makeInitMessage, makeResizeMsg, makeNewOutput, parseEvent, parsePayloadStr }
from "./encryption" import { genKey, encryptWithKey, aesKeysMessage }

// ── Terminal size query ──

struct TermSize {
    rows: i64,
    cols: i64,
}

fn termSize(): TermSize {
    var ws = WinSize { rows: 24 as u16, cols: 80 as u16, xpixel: 0 as u16, ypixel: 0 as u16 }
    unsafe {
        // TIOCGWINSZ on macOS
        ioctl(1, 1074295912, (&ws) as *u8)
    }
    return TermSize { rows: ws.rows as i64, cols: ws.cols as i64 }
}

// ── Simple ISO timestamp ──

fn pad2(n: i64): string {
    if n < 10 { return "0" + n.toString() }
    return n.toString()
}

fn isoTimestamp(): string {
    let secs = epochSecs()
    // approximate — good enough for display
    let secsInDay: i64 = 86400
    let days = secs / secsInDay
    let timeOfDay = secs % secsInDay
    let hours = timeOfDay / 3600
    let minutes = (timeOfDay % 3600) / 60
    let seconds = timeOfDay % 60

    // days since epoch → year/month/day (simplified)
    var y: i64 = 1970
    var remaining = days
    while true {
        var daysInYear: i64 = 365
        if (y % 4 == 0 && y % 100 != 0) || y % 400 == 0 {
            daysInYear = 366
        }
        if remaining < daysInYear {
            break
        }
        remaining = remaining - daysInYear
        y = y + 1
    }

    let isLeap = (y % 4 == 0 && y % 100 != 0) || y % 400 == 0
    let febDays: i64 = if isLeap { 29 as i64 } else { 28 as i64 }
    let monthDays: [i64 ; 12] = [31, febDays, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31]
    var m: i64 = 0
    while m < 12 && remaining >= monthDays[m] {
        remaining = remaining - monthDays[m]
        m = m + 1
    }
    let d = remaining + 1
    m = m + 1

    return y.toString() + "-" + pad2(m) + "-" + pad2(d) + "T" + pad2(hours) + ":" + pad2(minutes) + ":" + pad2(seconds) + "Z"
}

// Build the plaintext new_output JSON: {"pty_output":"<base64 raw bytes>"}.
fn ptyOutputJson(raw: &string): string {
    return "{\"pty_output\":\"" + base64Encode(raw) + "\"}"
}

// ── Main ──

fn main(): i32 {
    var parser = newParser("termpair", "share your terminal")
    parser.addString("host", "h", "server host", "chadsmith.dev")
    parser.addI64("port", "p", "server port", 443)
    parser.addString("base", "", "server URL path prefix", "/termpair")
    parser.addString("shell", "s", "shell to spawn", "/bin/bash")
    parser.addBool("public", "", "public session (no encryption)")
    parser.addBool("plain", "", "use plain ws:// instead of wss:// (local servers)")
    let args = parser.parse()

    let host = args.getString("host")
    let port = args.getU16("port")
    let base = args.getString("base")
    let shell = args.getString("shell")
    let isPublic = args.getBool("public")
    // wss:// unless explicitly forced plain (e.g. a local milo server on :8000).
    let useTls = !args.getBool("plain")

    let connectPath = base + "/connect_to_terminal"
    let scheme = if useTls { "https" } else { "http" }

    // resolve server address
    var ip: u32 = 0
    match resolve(host) {
        Result.Ok(v) => { ip = v }
        Result.Err(e) => {
            print($"error: could not resolve host '{host}'")
            return 1
        }
    }

    // get terminal size
    let ts = termSize()
    let rows = ts.rows
    let cols = ts.cols

    // open PTY and spawn shell
    var shellArgs: Vec<string> = []
    var pty: Pty = Pty { masterFd: -1, slavePath: "", childPid: -1, _rows: 0 as u16, _cols: 0 as u16 }
    match openAndSpawn(shell, shellArgs) {
        Result.Ok(v) => { pty = v }
        Result.Err(e) => {
            print($"error: {e}")
            return 1
        }
    }

    // resize PTY to match terminal (minus 1 row for status)
    let ptyRows = if rows > 1 { rows - 1 } else { rows }
    pty.resize(ptyRows as u16, cols as u16)

    // connect to server
    var ws: WsConn = WsConn { fd: -1, ssl: 0, _ctx: 0, _closed: true, _isClient: true }
    if useTls {
        match wsConnectTls(ip, port, host, connectPath) {
            Result.Ok(v) => { ws = v }
            Result.Err(e) => {
                print($"error: could not connect to server: {e}")
                return 1
            }
        }
    } else {
        match wsConnect(ip, port, connectPath) {
            Result.Ok(v) => { ws = v }
            Result.Err(e) => {
                print($"error: could not connect to server: {e}")
                return 1
            }
        }
    }

    // generate session keys (private mode); the bootstrap key goes in the URL fragment
    let bootstrapKey = genKey()
    let unixKey = genKey()
    let browserKey = genKey()

    // send init message
    let startTime = isoTimestamp()
    let initMsg = makeInitMessage(ptyRows, cols, shell, startTime, isPublic)
    match ws.sendText(initMsg) {
        Result.Ok(_) => {}
        Result.Err(e) => {
            print($"error: failed to send init: {e}")
            return 1
        }
    }

    // read start_broadcast response
    var startPayload: string = ""
    match ws.recv() {
        Result.Ok(msg) => { startPayload = msg.payload }
        Result.Err(e) => {
            print($"error: no start_broadcast from server: {e}")
            return 1
        }
    }

    let event = parseEvent(startPayload)
    if event != "start_broadcast" {
        print($"error: expected start_broadcast, got {event}")
        return 1
    }

    let terminalId = parsePayloadStr(startPayload, "terminal_id")

    // print share URL
    if isPublic {
        print($"termpair — sharing terminal (public mode)")
        print($"open in browser: {scheme}://{host}{base}/s/{terminalId}")
    } else {
        let keyFragment = base64UrlEncode(bootstrapKey)
        print($"termpair — sharing terminal (AES-128-GCM, key in URL fragment)")
        print($"open in browser: {scheme}://{host}{base}/s/{terminalId}#{keyFragment}")
    }
    print("press ctrl-d to stop sharing")
    print("")

    let termState = enableRawMode()

    var done = AtomicBool.new(false)

    // extract raw values so each move-closure gets its own copy
    // (move zeroes the source — can't move the same var into multiple closures)
    let ptyFd1 = pty.masterFd
    let ptyFd2 = pty.masterFd
    let wsFd1 = ws.fd
    let wsFd3 = ws.fd
    let wsSsl1 = ws.ssl
    let wsSsl3 = ws.ssl
    let done1 = AtomicBool { _ptr: done._ptr }
    let done2 = AtomicBool { _ptr: done._ptr }
    let done3 = AtomicBool { _ptr: done._ptr }

    // per-thread key clones — no shared mutable crypto state (read-only, no rotation)
    let unixKeyA = unixKey.clone()
    let bootKeyB = bootstrapKey.clone()
    let unixKeyB = unixKey.clone()
    let browserKeyB = browserKey.clone()
    let isPublicA = isPublic
    let isPublicB = isPublic

    // set fds non-blocking before spawning green threads
    setNonblocking(ptyFd1)
    setNonblocking(wsFd1)
    setNonblocking(0)

    // task 1: PTY output → WebSocket (terminal → server → browsers)
    Task.spawn(move (): void => {
        var sendWs = WsConn { fd: wsFd1, ssl: wsSsl1, _ctx: 0, _closed: true, _isClient: true }
        var buf: [u8 ; 4096] = [0 ; 4096]
        var msgCount: i64 = 0
        while !done1.load() {
            unsafe {
                schedulerWaitRead(ptyFd1)
                let n = read(ptyFd1, buf as *u8, 4095)
                if n < 0 && getErrno() == eagain() { continue }
                if n <= 0 {
                    done1.store(true)
                    break
                }

                write(1, buf as *u8, n)

                var rawOutput: string = ""
                for i in 0..n {
                    rawOutput.push(buf[i])
                }
                let plaintext = ptyOutputJson(rawOutput)

                var payload: string = ""
                if isPublicA {
                    payload = base64Encode(plaintext)
                } else {
                    msgCount = msgCount + 1
                    match encryptWithKey(unixKeyA, msgCount, plaintext) {
                        Result.Ok(v) => { payload = v }
                        Result.Err(_) => { continue }
                    }
                }

                let msg = makeNewOutput(payload)
                match sendWs.sendText(msg) {
                    Result.Err(_) => {
                        done1.store(true)
                        break
                    }
                    _ => {}
                }
            }
        }
    })

    // task 2: stdin → PTY (local keyboard input → shell)
    Task.spawn(move (): void => {
        var buf: [u8 ; 256] = [0 ; 256]
        while !done2.load() {
            unsafe {
                schedulerWaitRead(0)
                let n = read(0, buf as *u8, 256)
                if n < 0 && getErrno() == eagain() { continue }
                // n == 0 from non-blocking terminal is not EOF, just no data yet
                if n < 0 {
                    done2.store(true)
                    break
                }
                if n > 0 {
                    write(ptyFd2, buf as *u8, n)
                }
            }
        }
    })

    // task 3: WebSocket → control handling (browser joins, resize requests)
    Task.spawn(move (): void => {
        var recvWs = WsConn { fd: wsFd3, ssl: wsSsl3, _ctx: 0, _closed: true, _isClient: true }
        var bootstrapCount: i64 = 0
        var browserCount: i64 = 0
        while !done3.load() {
            match recvWs.recv() {
                Result.Ok(msg) => {
                    let raw = msg.payload
                    let ev = parseEvent(raw)
                    if ev == "new_browser_connected" {
                        if !isPublicB {
                            // hand the unix/browser keys to the new browser, wrapped
                            // under the bootstrap key it derived from the URL fragment.
                            browserCount = browserCount + 1
                            let c1 = bootstrapCount + 1
                            let c2 = bootstrapCount + 2
                            bootstrapCount = bootstrapCount + 2
                            var eu: string = ""
                            var eb: string = ""
                            match encryptWithKey(bootKeyB, c1, unixKeyB) {
                                Result.Ok(v) => { eu = v }
                                Result.Err(_) => {}
                            }
                            match encryptWithKey(bootKeyB, c2, browserKeyB) {
                                Result.Ok(v) => { eb = v }
                                Result.Err(_) => {}
                            }
                            if eu.len > 0 && eb.len > 0 {
                                let km = aesKeysMessage(eu, eb, browserCount)
                                let _ = recvWs.sendText(km)
                            }
                        }
                    } else if ev == "request_terminal_dimensions" {
                        let ts2 = termSize()
                        let r2 = if ts2.rows > 1 { ts2.rows - 1 } else { ts2.rows }
                        let _ = recvWs.sendText(makeResizeMsg(r2, ts2.cols))
                    }
                    // `command` (browser input) and `request_key_rotation` ignored: read-only.
                }
                Result.Err(e) => {
                    done3.store(true)
                    break
                }
            }
        }
    })

    // drive scheduler from main thread until a task signals done
    while !done.load() {
        _schedulerTick()
    }

    restoreTerminal(termState)

    print("")
    print("termpair session ended")

    return 0
}
