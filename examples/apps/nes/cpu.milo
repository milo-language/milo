// MOS 6502 core (NES 2A03 variant — no decimal mode) + CPU memory bus.
// Cycle-accurate enough to match nestest.log register + cycle columns.
// Ref: https://www.nesdev.org/wiki/CPU, https://www.masswerk.at/6502/6502_instruction_set.html

from "./cartridge" import {
    Cartridge
}
from "./ppu" import {
    Ppu, newPpu, ppuRegRead, ppuRegWrite, mmc2InitMapper, mmc2SetChr
}
from "./apu" import {
    Apu, newApu, apuWrite, apuReadStatus, apuStep, dmcFill
}

// --- status flag bit masks (P register) ---
let FC: u8 = 0x01 // carry
let FZ: u8 = 0x02 // zero
let FI: u8 = 0x04 // interrupt disable
let FD: u8 = 0x08 // decimal (ignored on NES, still settable)
let FB: u8 = 0x10 // break (only in pushed copies)
let FU: u8 = 0x20 // unused, always 1
let FV: u8 = 0x40 // overflow
let FN: u8 = 0x80 // negative

// CPU-visible address space. Owns PRG-ROM and the PPU (which owns CHR/VRAM).
struct Bus {
    ram: [u8; 2048] // $0000-$07FF, mirrored through $1FFF
    wram: [u8; 8192] // $6000-$7FFF cartridge PRG-RAM (MMC3 scratch, etc.)
    prg: Vec<u8> // mapper-0 PRG, 16K or 32K
    prgMask: i64 // 0x3FFF (16K) or 0x7FFF (32K)
    ppu: Ppu
    apu: Apu
    ctrl1: u8 // $4016 controller-1 shift register (serial, drained LSB-first)
    strobe: u8 // $4016 strobe latch
    buttons: u8 // live controller-1 state: bit0 A,1 B,2 Select,3 Start,4 Up,5 Down,6 Left,7 Right
    mapper: i64 // iNES mapper number (0 = NROM, 2 = UxROM, 4 = MMC3)
    prgBanks: i64 // number of 16 KiB PRG banks
    prgBank: i64 // UxROM: switchable 16 KiB bank mapped at $8000-$BFFF
    mmc2Prg: i64 // MMC2 (mapper 9): switchable 8 KiB bank at $8000-$9FFF
    m227Lo: i64 // mapper 227 (multicart): 16 KiB bank at $8000-$BFFF
    m227Hi: i64 // mapper 227: 16 KiB bank at $C000-$FFFF

    // MMC3 (mapper 4): 8 bank registers, PRG/CHR modes, and a scanline IRQ.
    mmcSelect: i64 // last $8000 (even) write: bank index (0-7) + mode bits 6/7
    mmcR0: i64
    mmcR1: i64
    mmcR2: i64
    mmcR3: i64
    mmcR4: i64
    mmcR5: i64
    mmcR6: i64
    mmcR7: i64
    irqLatch: i64
    irqCounter: i64
    irqReload: bool
    irqEnabled: bool
    irqPending: bool // set when the scanline counter hits 0; consumed by the CPU
}

fn newBus(cart: Cartridge): Bus {
    let n = cart.prg.len
    // 16K carts mirror $C000-$FFFF onto $8000-$BFFF via a 0x3FFF mask.
    let mask: i64 = if n == 16384 {
        0x3FFF as i64
    } else {
        0x7FFF as i64
    }
    // Move CHR + mirroring into the PPU; PRG into the bus. (cart consumed.)
    let ppu = newPpu(cart.chr, cart.mirrorVertical)
    let banks = cart.prg16kBanks as i64
    var bus = Bus {
        ram: [0; 2048], wram: [0; 8192], prg: cart.prg, prgMask: mask, ppu: ppu, apu: newApu(), ctrl1: 0, strobe: 0, buttons: 0,
        mapper: cart.mapper as i64, prgBanks: banks, prgBank: 0, mmc2Prg: 0, m227Lo: 0, m227Hi: 0,
        mmcSelect: 0, mmcR0: 0, mmcR1: 0, mmcR2: 0, mmcR3: 0, mmcR4: 0, mmcR5: 0, mmcR6: 0, mmcR7: 0,
        irqLatch: 0, irqCounter: 0, irqReload: false, irqEnabled: false, irqPending: false
    }
    if bus.mapper == 4 {
        mmc3UpdateChr(bus) // establish the initial CHR window mapping
    }
    if bus.mapper == 9 {
        mmc2InitMapper(bus.ppu) // latch-driven CHR banking lives in the PPU
    }
    if bus.mapper == 227 {
        bus.m227Hi = bus.prg.len / 0x4000 - 1 // menu boots from the last bank at $C000
    }
    return bus
}

fn busRead(bus: &mut Bus, addr: u16): u8 {
    let a: i64 = addr as i64
    if a < 0x2000 {
        return bus.ram[a & 0x07FF]
    }
    if a < 0x4000 {
        // $2000-$3FFF: 8 PPU registers, mirrored every 8 bytes
        return ppuRegRead(bus.ppu, a & 0x07)
    }
    if a == 0x4016 {
        // controller 1: serial shift-out of the button state, LSB first.
        // While strobe is high the register is continuously reloaded from the
        // live state, so reads keep returning button A (bit 0).
        if (bus.strobe & 0x01) == 1 {
            bus.ctrl1 = bus.buttons
        }
        let bit = bus.ctrl1 & 0x01
        bus.ctrl1 = (bus.ctrl1 >> 1) | 0x80
        return bit | 0x40 // open-bus high bits read as 0x40 on real HW
    }
    if a == 0x4015 {
        return apuReadStatus(bus.apu)
    }
    if a >= 0x6000 && a < 0x8000 {
        return bus.wram[a - 0x6000]
    }
    if a >= 0x8000 {
        if bus.mapper == 4 {
            return bus.prg[mmc3PrgOffset(bus, a)]
        }
        if bus.mapper == 9 {
            // MMC2: $8000-$9FFF switchable 8 KiB; $A000-$FFFF = fixed last three.
            let n8k = bus.prg.len / 0x2000
            if a < 0xA000 {
                return bus.prg[bus.mmc2Prg * 0x2000 + (a - 0x8000)]
            }
            if a < 0xC000 {
                return bus.prg[(n8k - 3) * 0x2000 + (a - 0xA000)]
            }
            if a < 0xE000 {
                return bus.prg[(n8k - 2) * 0x2000 + (a - 0xC000)]
            }
            return bus.prg[(n8k - 1) * 0x2000 + (a - 0xE000)]
        }
        if bus.mapper == 227 {
            let n16 = bus.prg.len / 0x4000
            if a < 0xC000 {
                return bus.prg[(bus.m227Lo % n16) * 0x4000 + (a - 0x8000)]
            }
            return bus.prg[(bus.m227Hi % n16) * 0x4000 + (a - 0xC000)]
        }
        if bus.mapper == 2 {
            // UxROM: $8000-$BFFF = switchable bank, $C000-$FFFF = fixed last bank.
            if a < 0xC000 {
                return bus.prg[bus.prgBank * 0x4000 + (a - 0x8000)]
            }
            return bus.prg[(bus.prgBanks - 1) * 0x4000 + (a - 0xC000)]
        }
        return bus.prg[(a - 0x8000) & bus.prgMask] // NROM
    }
    return 0
}

fn busWrite(bus: &mut Bus, addr: u16, val: u8): void {
    let a: i64 = addr as i64
    if a < 0x2000 {
        bus.ram[a & 0x07FF] = val
        return
    }
    if a < 0x4000 {
        ppuRegWrite(bus.ppu, a & 0x07, val)
        return
    }
    if a == 0x4014 {
        // OAMDMA: copy 256 bytes from CPU page $xx00 into PPU OAM
        let page = (val as i64) << 8
        var i: i64 = 0
        while i < 256 {
            let b = busRead(bus, (page + i) as u16)
            ppuRegWrite(bus.ppu, 4, b) // write through OAMDATA (advances oamAddr)
            i = i + 1
        }
        return
    }
    if a == 0x4016 {
        bus.strobe = val & 0x01
        // Strobe going (or held) high latches the live button state for shift-out.
        if bus.strobe == 1 {
            bus.ctrl1 = bus.buttons
        }
        return
    }
    // APU + frame counter: $4000-$4013, $4015, $4017 ($4014/$4016 handled above).
    if a >= 0x4000 && a <= 0x4017 {
        apuWrite(bus.apu, a - 0x4000, val)
        return
    }
    if a >= 0x6000 && a < 0x8000 {
        bus.wram[a - 0x6000] = val
        return
    }
    if a >= 0x8000 {
        // UxROM bank select: low bits pick the 16 KiB bank at $8000-$BFFF.
        if bus.mapper == 2 {
            bus.prgBank = (val as i64) & (bus.prgBanks - 1)
            return
        }
        if bus.mapper == 4 {
            mmc3Write(bus, a, val)
            return
        }
        if bus.mapper == 9 {
            // MMC2 registers (only $A000-$FFFF; $8000-$9FFF is unmapped).
            if a < 0xA000 {
                return
            }
            if a < 0xB000 {
                bus.mmc2Prg = (val as i64) & 0x0F // PRG select
            } else if a < 0xC000 {
                mmc2SetChr(bus.ppu, 0, (val as i64) & 0x1F) // CHR $0xxx / FD
            } else if a < 0xD000 {
                mmc2SetChr(bus.ppu, 1, (val as i64) & 0x1F) // CHR $0xxx / FE
            } else if a < 0xE000 {
                mmc2SetChr(bus.ppu, 2, (val as i64) & 0x1F) // CHR $1xxx / FD
            } else if a < 0xF000 {
                mmc2SetChr(bus.ppu, 3, (val as i64) & 0x1F) // CHR $1xxx / FE
            } else {
                bus.ppu.mirrorVertical = (val & 1) == 0 // $F000: 0=vert,1=horiz
            }
            return
        }
        if bus.mapper == 227 {
            mapper227Write(bus, a)
            return
        }
        return
    }
    // other APU/IO writes ignored until modeled
}

// Mapper 227 (multicart, e.g. 1200-in-1): the *write address* is the register.
// Address bits: A2-A6 = PRG bank low, A7 = PRG bank high, A8 = 32 KiB mode, A9 =
// mirroring. In 16 KiB mode $8000 switches and $C000 stays fixed to the last bank
// (where the multicart menu lives, so its own bank-select writes don't unmap it).
fn mapper227Write(bus: &mut Bus, a: i64): void {
    let p = (a >> 2) & 0x1F
    let o = (a >> 7) & 1
    let s = (a >> 8) & 1 // 1 = 32 KiB (NROM-256), 0 = 16 KiB (NROM-128)
    let m = (a >> 9) & 1 // mirroring: 1 = horizontal, 0 = vertical
    let prg16 = (o << 5) | p
    let last = bus.prg.len / 0x4000 - 1
    if s == 1 {
        bus.m227Lo = prg16 & 0x3E
        bus.m227Hi = (prg16 & 0x3E) | 1
    } else {
        bus.m227Lo = prg16
        bus.m227Hi = last // $C000 fixed to the menu's bank
    }
    bus.ppu.mirrorVertical = m == 0
}

// MMC3 register file: even/odd address within each $2000 block selects the pair.
fn mmc3Write(bus: &mut Bus, a: i64, val: u8): void {
    let even = (a & 1) == 0
    let v = val as i64
    if a < 0xA000 {
        if even {
            bus.mmcSelect = v // bank select + PRG/CHR mode bits
        } else {
            let r = bus.mmcSelect & 7 // bank data -> selected register
            if r == 0 {
                bus.mmcR0 = v
            }
            if r == 1 {
                bus.mmcR1 = v
            }
            if r == 2 {
                bus.mmcR2 = v
            }
            if r == 3 {
                bus.mmcR3 = v
            }
            if r == 4 {
                bus.mmcR4 = v
            }
            if r == 5 {
                bus.mmcR5 = v
            }
            if r == 6 {
                bus.mmcR6 = v
            }
            if r == 7 {
                bus.mmcR7 = v
            }
            mmc3UpdateChr(bus)
        }
    } else if a < 0xC000 {
        if even {
            bus.ppu.mirrorVertical = (v & 1) == 0 // $A000 bit0: 0=vertical,1=horizontal
        }
        // odd ($A001): PRG-RAM protect — unmodeled
    } else if a < 0xE000 {
        if even {
            bus.irqLatch = v // $C000: IRQ reload value
        } else {
            bus.irqReload = true // $C001: reload on next clock
        }
    } else {
        if even {
            bus.irqEnabled = false // $E000: disable + acknowledge
            bus.irqPending = false
        } else {
            bus.irqEnabled = true // $E001: enable
        }
    }
}

struct Cpu {
    a: u8
    x: u8
    y: u8
    sp: u8
    p: u8
    pc: u16
    cyc: i64 // total elapsed CPU cycles
    extraCycles: i64 // page-cross / branch penalties accumulated this instr
}

// nestest's automated entry: PC=$C000, SP=$FD, P=$24 (I+U), 7 cycles already burned.
fn newCpuNestest(): Cpu {
    return Cpu {
        a: 0, x: 0, y: 0, sp: 0xFD, p: 0x24, pc: 0xC000, cyc: 7, extraCycles: 0
    }
}

// Power-on / reset: PC from the reset vector at $FFFC/$FFFD.
fn newCpuReset(bus: &mut Bus): Cpu {
    let lo = busRead(bus, 0xFFFC) as i64
    let hi = busRead(bus, 0xFFFD) as i64
    return Cpu {
        a: 0, x: 0, y: 0, sp: 0xFD, p: 0x24, pc: wrap16(lo | (hi << 8)), cyc: 0, extraCycles: 0
    }
}

// Non-maskable interrupt (PPU vblank): push PC + P, jump to $FFFA vector.
fn nmi(cpu: &mut Cpu, bus: &mut Bus): void {
    push16(cpu, bus, cpu.pc)
    push8(cpu, bus, (cpu.p & (~FB)) | FU)
    setFlag(cpu, FI, true)
    let lo = busRead(bus, 0xFFFA) as i64
    let hi = busRead(bus, 0xFFFB) as i64
    cpu.pc = wrap16(lo | (hi << 8))
    cpu.cyc = cpu.cyc + 7
}

// Maskable interrupt (MMC3 scanline IRQ): like nmi but gated on the I flag,
// vectored through $FFFE. The caller checks I; this always takes the interrupt.
fn irq(cpu: &mut Cpu, bus: &mut Bus): void {
    push16(cpu, bus, cpu.pc)
    push8(cpu, bus, (cpu.p & (~FB)) | FU)
    setFlag(cpu, FI, true)
    let lo = busRead(bus, 0xFFFE) as i64
    let hi = busRead(bus, 0xFFFF) as i64
    cpu.pc = wrap16(lo | (hi << 8))
    cpu.cyc = cpu.cyc + 7
}

// --- MMC3 (mapper 4) ---

// Recompute the eight 1 KiB CHR window offsets from R0-R5 and the CHR mode bit.
fn mmc3UpdateChr(bus: &mut Bus): void {
    let num1k = bus.ppu.chr.len / 0x400
    let mode = (bus.mmcSelect >> 7) & 1
    var w0: i64 = 0
    var w1: i64 = 0
    var w2: i64 = 0
    var w3: i64 = 0
    var w4: i64 = 0
    var w5: i64 = 0
    var w6: i64 = 0
    var w7: i64 = 0
    if mode == 0 {
        // $0000=R0(2K) $0800=R1(2K) $1000=R2 $1400=R3 $1800=R4 $1C00=R5 (1K)
        w0 = bus.mmcR0 & 0xFE
        w1 = (bus.mmcR0 & 0xFE) + 1
        w2 = bus.mmcR1 & 0xFE
        w3 = (bus.mmcR1 & 0xFE) + 1
        w4 = bus.mmcR2
        w5 = bus.mmcR3
        w6 = bus.mmcR4
        w7 = bus.mmcR5
    } else {
        // $0000=R2 $0400=R3 $0800=R4 $0C00=R5 (1K) $1000=R0(2K) $1800=R1(2K)
        w0 = bus.mmcR2
        w1 = bus.mmcR3
        w2 = bus.mmcR4
        w3 = bus.mmcR5
        w4 = bus.mmcR0 & 0xFE
        w5 = (bus.mmcR0 & 0xFE) + 1
        w6 = bus.mmcR1 & 0xFE
        w7 = (bus.mmcR1 & 0xFE) + 1
    }
    bus.ppu.chrBankOffset[0] = (w0 % num1k) * 0x400
    bus.ppu.chrBankOffset[1] = (w1 % num1k) * 0x400
    bus.ppu.chrBankOffset[2] = (w2 % num1k) * 0x400
    bus.ppu.chrBankOffset[3] = (w3 % num1k) * 0x400
    bus.ppu.chrBankOffset[4] = (w4 % num1k) * 0x400
    bus.ppu.chrBankOffset[5] = (w5 % num1k) * 0x400
    bus.ppu.chrBankOffset[6] = (w6 % num1k) * 0x400
    bus.ppu.chrBankOffset[7] = (w7 % num1k) * 0x400
}

// Byte offset into PRG for a $8000-$FFFF address under the current PRG mode.
// Windows: two switchable (R6,R7) and two fixed (second-last, last 8 KiB bank).
fn mmc3PrgOffset(bus: &Bus, a: i64): i64 {
    let num8k = bus.prg.len / 0x2000
    let last = num8k - 1
    let mode = (bus.mmcSelect >> 6) & 1
    var bank: i64 = 0
    if a < 0xA000 {
        bank = if mode == 0 {
            bus.mmcR6
        } else {
            last - 1
        }
    } else if a < 0xC000 {
        bank = bus.mmcR7
    } else if a < 0xE000 {
        bank = if mode == 0 {
            last - 1
        } else {
            bus.mmcR6
        }
    } else {
        bank = last
    }
    return (bank % num8k) * 0x2000 + (a & 0x1FFF)
}

// Clock the scanline IRQ counter once per rendered scanline (A12 approximation).
fn mmc3ClockIrq(bus: &mut Bus): void {
    if bus.irqCounter == 0 || bus.irqReload {
        bus.irqCounter = bus.irqLatch
        bus.irqReload = false
    } else {
        bus.irqCounter = bus.irqCounter - 1
    }
    if bus.irqCounter == 0 && bus.irqEnabled {
        bus.irqPending = true
    }
}

// Advance the PPU one dot and, for MMC3, clock its scanline IRQ at a fixed dot
// of each visible line while rendering is enabled.
// Advance the APU by `cycles` CPU cycles, then service any DMC sample-fetch it
// requested (the DMC reads CPU memory, which only the bus can do).
fn clockApu(bus: &mut Bus, cycles: i64): void {
    apuStep(bus.apu, cycles)
    if bus.apu.dmc.needsFetch {
        let addr = bus.apu.dmc.curAddr
        let b = busRead(bus, addr as u16)
        dmcFill(bus.apu.dmc, b as i64)
    }
}

fn clockPpu(bus: &mut Bus): void {
    ppuStep(bus.ppu)
    if bus.mapper == 4 && bus.ppu.dot == 260 && bus.ppu.scanline < 240 && (bus.ppu.mask & 0x18) != 0 {
        mmc3ClockIrq(bus)
    }
}

// --- flag helpers ---
fn cpuFlag(cpu: &Cpu, mask: u8): bool {
    return (cpu.p & mask) != 0
}

fn setFlag(cpu: &mut Cpu, mask: u8, on: bool): void {
    if on {
        cpu.p = cpu.p | mask
    } else {
        cpu.p = cpu.p & (~mask)
    }
}

fn setZN(cpu: &mut Cpu, v: u8): void {
    setFlag(cpu, FZ, v == 0)
    setFlag(cpu, FN, (v & 0x80) != 0)
}

// --- 16-bit / pc helpers (explicit masking NES arithmetic wraps) ---
fn wrap16(v: i64): u16
ensures(result as i64) == (v & 0xFFFF)
{
    return (v & 0xFFFF) as u16
}

fn read16(bus: &mut Bus, addr: u16): u16 {
    let lo: i64 = busRead(bus, addr) as i64
    let hi: i64 = busRead(bus, wrap16((addr as i64) + 1)) as i64
    return wrap16(lo | (hi << 8))
}

// 6502 indirect-JMP page-wrap bug: high byte reads from ($xxFF & $xx00), not +1 page.
fn read16Bug(bus: &mut Bus, addr: u16): u16 {
    let a: i64 = addr as i64
    let lo: i64 = busRead(bus, addr) as i64
    let hiAddr: i64 = (a & 0xFF00) | ((a + 1) & 0x00FF)
    let hi: i64 = busRead(bus, wrap16(hiAddr)) as i64
    return wrap16(lo | (hi << 8))
}

fn fetch8(cpu: &mut Cpu, bus: &mut Bus): u8 {
    let v = busRead(bus, cpu.pc)
    cpu.pc = wrap16((cpu.pc as i64) + 1)
    return v
}

fn fetch16(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let v = read16(bus, cpu.pc)
    cpu.pc = wrap16((cpu.pc as i64) + 2)
    return v
}

// --- stack ($0100-$01FF) ---
fn push8(cpu: &mut Cpu, bus: &mut Bus, v: u8): void {
    busWrite(bus, wrap16(0x0100 | (cpu.sp as i64)), v)
    cpu.sp = cpu.sp.wrappingSub(1)
}

fn pop8(cpu: &mut Cpu, bus: &mut Bus): u8 {
    cpu.sp = cpu.sp.wrappingAdd(1)
    return busRead(bus, wrap16(0x0100 | (cpu.sp as i64)))
}

fn push16(cpu: &mut Cpu, bus: &mut Bus, v: u16): void {
    push8(cpu, bus, (v >> 8) as u8) // high byte — genuine u16→u8 narrowing
    push8(cpu, bus, v as u8)
}

fn pop16(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let lo: i64 = pop8(cpu, bus) as i64
    let hi: i64 = pop8(cpu, bus) as i64
    return wrap16(lo | (hi << 8))
}

// Did adding an index cross a page boundary? (+1 cycle for read-index modes.)
fn pageCrossed(base: u16, eff: u16): bool {
    return ((base as i64) & 0xFF00) != ((eff as i64) & 0xFF00)
}

// --- addressing-mode resolvers: advance PC past operand, return effective addr.
// Indexed read modes stash a page-cross penalty in cpu.extraCycles only the
// read opcodes honor it (stores/RMW take fixed cycles).
fn read16ZP(bus: &mut Bus, z: i64): u16
requires 0 <= z && z <= 255 // zero-page pointer index; callers must pre-mask
{
    let lo: i64 = busRead(bus, (z & 0xFF) as u16) as i64
    let hi: i64 = busRead(bus, ((z + 1) & 0xFF) as u16) as i64
    return wrap16(lo | (hi << 8))
}

fn aImm(cpu: &mut Cpu): u16 {
    let a = cpu.pc
    cpu.pc = wrap16((cpu.pc as i64) + 1)
    return a
}

fn aZp(cpu: &mut Cpu, bus: &mut Bus): u16 {
    return fetch8(cpu, bus) as u16
}

fn aZpX(cpu: &mut Cpu, bus: &mut Bus): u16 {
    return (((fetch8(cpu, bus) as i64) + (cpu.x as i64)) & 0xFF) as u16
}

fn aZpY(cpu: &mut Cpu, bus: &mut Bus): u16 {
    return (((fetch8(cpu, bus) as i64) + (cpu.y as i64)) & 0xFF) as u16
}

fn aAbs(cpu: &mut Cpu, bus: &mut Bus): u16 {
    return fetch16(cpu, bus)
}

fn aAbsX(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let base = fetch16(cpu, bus)
    let eff = wrap16((base as i64) + (cpu.x as i64))
    if pageCrossed(base, eff) {
        cpu.extraCycles = 1
    }
    return eff
}

fn aAbsY(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let base = fetch16(cpu, bus)
    let eff = wrap16((base as i64) + (cpu.y as i64))
    if pageCrossed(base, eff) {
        cpu.extraCycles = 1
    }
    return eff
}

fn aIndX(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let z = ((fetch8(cpu, bus) as i64) + (cpu.x as i64)) & 0xFF
    return read16ZP(bus, z)
}

fn aIndY(cpu: &mut Cpu, bus: &mut Bus): u16 {
    let z = fetch8(cpu, bus) as i64
    let base = read16ZP(bus, z)
    let eff = wrap16((base as i64) + (cpu.y as i64))
    if pageCrossed(base, eff) {
        cpu.extraCycles = 1
    }
    return eff
}

// --- ALU primitives ---
fn adc(cpu: &mut Cpu, m: u8): void {
    let a: i64 = cpu.a as i64
    let carry: i64 = if cpuFlag(cpu, FC) {
        1 as i64
    } else {
        0 as i64
    }
    let sum: i64 = a + (m as i64) + carry
    let r: u8 = (sum & 0xFF) as u8
    setFlag(cpu, FC, sum > 0xFF)
    // overflow: operands share sign, result differs
    setFlag(cpu, FV, ((~(a ^ (m as i64))) & (a ^ (r as i64)) & 0x80) != 0)
    cpu.a = r
    setZN(cpu, r)
}

fn sbc(cpu: &mut Cpu, m: u8): void {
    adc(cpu, (m as i64 ^ 0xFF) as u8)
}

fn compare(cpu: &mut Cpu, reg: u8, m: u8): void {
    setFlag(cpu, FC, reg >= m)
    setZN(cpu, reg.wrappingSub(m)) // only the low byte feeds Z/N
}

fn bitTest(cpu: &mut Cpu, m: u8): void {
    setFlag(cpu, FZ, ((cpu.a as i64) & (m as i64)) == 0)
    setFlag(cpu, FN, (m & 0x80) != 0)
    setFlag(cpu, FV, (m & 0x40) != 0)
}

// shifts/rotates return the result and set C from the shifted-out bit.
fn aslV(cpu: &mut Cpu, m: u8): u8 {
    setFlag(cpu, FC, (m & 0x80) != 0)
    let r: u8 = m << 1 // u8 shift truncates the carried-out bit
    setZN(cpu, r)
    return r
}

fn lsrV(cpu: &mut Cpu, m: u8): u8 {
    setFlag(cpu, FC, (m & 0x01) != 0)
    let r: u8 = m >> 1
    setZN(cpu, r)
    return r
}

fn rolV(cpu: &mut Cpu, m: u8): u8 {
    let cin: u8 = if cpuFlag(cpu, FC) {
        1
    } else {
        0
    }
    setFlag(cpu, FC, (m & 0x80) != 0)
    let r: u8 = (m << 1) | cin
    setZN(cpu, r)
    return r
}

fn rorV(cpu: &mut Cpu, m: u8): u8 {
    let cin: u8 = if cpuFlag(cpu, FC) {
        0x80
    } else {
        0
    }
    setFlag(cpu, FC, (m & 0x01) != 0)
    let r: u8 = (m >> 1) | cin
    setZN(cpu, r)
    return r
}

// Conditional branch with taken/page-cross cycle penalties base 2 added by caller.
fn branch(cpu: &mut Cpu, bus: &mut Bus, cond: bool): void {
    var off: i64 = fetch8(cpu, bus) as i64
    if off >= 128 {
        off = off - 256
    }
    if cond {
        let pcNow = cpu.pc
        let target = wrap16((cpu.pc as i64) + off)
        cpu.cyc = cpu.cyc + 1
        if pageCrossed(pcNow, target) {
            cpu.cyc = cpu.cyc + 1
        }
        cpu.pc = target
    }
}

// --- trace formatting (self-contained strconv lacks decimal int->string) ---
fn appendStr(dst: &mut string, src: &string): void {
    var i: i64 = 0
    while i < src.len {
        dst.push(src[i]) i = i + 1
    }
}

fn hex2(v: i64): string {
    let d = "0123456789ABCDEF"
    var s = ""
    s.push(d[(v >> 4) & 0xF])
    s.push(d[v & 0xF])
    return s
}

fn hex4(v: i64): string {
    var s = hex2((v >> 8) & 0xFF)
    let lo = hex2(v & 0xFF)
    appendStr(s, lo)
    return s
}

fn decStr(n: i64): string {
    if n == 0 {
        return "0"
    }
    var v = n
    var buf = ""
    while v > 0 {
        buf.push(((v % 10) + 48) as u8) v = v / 10
    }
    var out = ""
    var i: i64 = buf.len - 1
    while i >= 0 {
        out.push(buf[i]) i = i - 1
    }
    return out
}

// nestest.log comparison columns: "PC A:.. X:.. Y:.. P:.. SP:.. CYC:.."
fn formatState(cpu: &Cpu): string {
    var s = hex4(cpu.pc as i64)
    let a = hex2(cpu.a as i64) appendStr(s, " A:") appendStr(s, a)
    let x = hex2(cpu.x as i64) appendStr(s, " X:") appendStr(s, x)
    let y = hex2(cpu.y as i64) appendStr(s, " Y:") appendStr(s, y)
    let p = hex2(cpu.p as i64) appendStr(s, " P:") appendStr(s, p)
    let sp = hex2(cpu.sp as i64) appendStr(s, " SP:") appendStr(s, sp)
    let c = decStr(cpu.cyc) appendStr(s, " CYC:") appendStr(s, c)
    return s
}

// --- unofficial ("illegal") opcode helpers, addr pre-resolved by caller ---
fn lax(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let v = busRead(bus, addr)
    cpu.a = v
    cpu.x = v
    setZN(cpu, v)
}

fn sax(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    busWrite(bus, addr, cpu.a & cpu.x)
}

fn dcp(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = busRead(bus, addr).wrappingSub(1)
    busWrite(bus, addr, m)
    compare(cpu, cpu.a, m)
}

fn isb(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = busRead(bus, addr).wrappingAdd(1)
    busWrite(bus, addr, m)
    sbc(cpu, m)
}

fn slo(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = aslV(cpu, busRead(bus, addr))
    busWrite(bus, addr, m)
    cpu.a = cpu.a | m
    setZN(cpu, cpu.a)
}

fn rla(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = rolV(cpu, busRead(bus, addr))
    busWrite(bus, addr, m)
    cpu.a = cpu.a & m
    setZN(cpu, cpu.a)
}

fn sre(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = lsrV(cpu, busRead(bus, addr))
    busWrite(bus, addr, m)
    cpu.a = cpu.a ^ m
    setZN(cpu, cpu.a)
}

fn rra(cpu: &mut Cpu, bus: &mut Bus, addr: u16): void {
    let m = rorV(cpu, busRead(bus, addr))
    busWrite(bus, addr, m)
    adc(cpu, m)
}

// Execute one instruction, advancing cyc by its total cost.
fn step(cpu: &mut Cpu, bus: &mut Bus): void {
    cpu.extraCycles = 0
    let op = fetch8(cpu, bus)
    match op {
        // ---- LDA ----
        0xA9 => {
            let v = busRead(bus, aImm(cpu)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        0xA5 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0xB5 => {
            let v = busRead(bus, aZpX(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xAD => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xBD => {
            let v = busRead(bus, aAbsX(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xB9 => {
            let v = busRead(bus, aAbsY(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xA1 => {
            let v = busRead(bus, aIndX(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 6
        }
        0xB1 => {
            let v = busRead(bus, aIndY(cpu, bus)) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        // ---- LDX ----
        0xA2 => {
            let v = busRead(bus, aImm(cpu)) cpu.x = v setZN(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        0xA6 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.x = v setZN(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0xB6 => {
            let v = busRead(bus, aZpY(cpu, bus)) cpu.x = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xAE => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.x = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xBE => {
            let v = busRead(bus, aAbsY(cpu, bus)) cpu.x = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        // ---- LDY ----
        0xA0 => {
            let v = busRead(bus, aImm(cpu)) cpu.y = v setZN(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        0xA4 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.y = v setZN(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0xB4 => {
            let v = busRead(bus, aZpX(cpu, bus)) cpu.y = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xAC => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.y = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xBC => {
            let v = busRead(bus, aAbsX(cpu, bus)) cpu.y = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        // ---- STA ----
        0x85 => {
            busWrite(bus, aZp(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 3
        }
        0x95 => {
            busWrite(bus, aZpX(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x8D => {
            busWrite(bus, aAbs(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x9D => {
            busWrite(bus, aAbsX(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 5
        }
        0x99 => {
            busWrite(bus, aAbsY(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 5
        }
        0x81 => {
            busWrite(bus, aIndX(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 6
        }
        0x91 => {
            busWrite(bus, aIndY(cpu, bus), cpu.a) cpu.cyc = cpu.cyc + 6
        }
        // ---- STX / STY ----
        0x86 => {
            busWrite(bus, aZp(cpu, bus), cpu.x) cpu.cyc = cpu.cyc + 3
        }
        0x96 => {
            busWrite(bus, aZpY(cpu, bus), cpu.x) cpu.cyc = cpu.cyc + 4
        }
        0x8E => {
            busWrite(bus, aAbs(cpu, bus), cpu.x) cpu.cyc = cpu.cyc + 4
        }
        0x84 => {
            busWrite(bus, aZp(cpu, bus), cpu.y) cpu.cyc = cpu.cyc + 3
        }
        0x94 => {
            busWrite(bus, aZpX(cpu, bus), cpu.y) cpu.cyc = cpu.cyc + 4
        }
        0x8C => {
            busWrite(bus, aAbs(cpu, bus), cpu.y) cpu.cyc = cpu.cyc + 4
        }
        // ---- transfers ----
        0xAA => {
            cpu.x = cpu.a setZN(cpu, cpu.x) cpu.cyc = cpu.cyc + 2
        }
        0xA8 => {
            cpu.y = cpu.a setZN(cpu, cpu.y) cpu.cyc = cpu.cyc + 2
        }
        0x8A => {
            cpu.a = cpu.x setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x98 => {
            cpu.a = cpu.y setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0xBA => {
            cpu.x = cpu.sp setZN(cpu, cpu.x) cpu.cyc = cpu.cyc + 2
        }
        0x9A => {
            cpu.sp = cpu.x cpu.cyc = cpu.cyc + 2
        }
        // ---- stack ----
        0x48 => {
            push8(cpu, bus, cpu.a) cpu.cyc = cpu.cyc + 3
        }
        0x68 => {
            let v = pop8(cpu, bus) cpu.a = v setZN(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0x08 => {
            push8(cpu, bus, cpu.p | FB | FU) cpu.cyc = cpu.cyc + 3
        }
        0x28 => {
            let v = pop8(cpu, bus) cpu.p = (v & (~FB)) | FU cpu.cyc = cpu.cyc + 4
        }
        // ---- logic ----
        0x29 => {
            let v = busRead(bus, aImm(cpu)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x25 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 3
        }
        0x35 => {
            let v = busRead(bus, aZpX(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x2D => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x3D => {
            let v = busRead(bus, aAbsX(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x39 => {
            let v = busRead(bus, aAbsY(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x21 => {
            let v = busRead(bus, aIndX(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 6
        }
        0x31 => {
            let v = busRead(bus, aIndY(cpu, bus)) cpu.a = cpu.a & v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        0x09 => {
            let v = busRead(bus, aImm(cpu)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x05 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 3
        }
        0x15 => {
            let v = busRead(bus, aZpX(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x0D => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x1D => {
            let v = busRead(bus, aAbsX(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x19 => {
            let v = busRead(bus, aAbsY(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x01 => {
            let v = busRead(bus, aIndX(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 6
        }
        0x11 => {
            let v = busRead(bus, aIndY(cpu, bus)) cpu.a = cpu.a | v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        0x49 => {
            let v = busRead(bus, aImm(cpu)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x45 => {
            let v = busRead(bus, aZp(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 3
        }
        0x55 => {
            let v = busRead(bus, aZpX(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x4D => {
            let v = busRead(bus, aAbs(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4
        }
        0x5D => {
            let v = busRead(bus, aAbsX(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x59 => {
            let v = busRead(bus, aAbsY(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x41 => {
            let v = busRead(bus, aIndX(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 6
        }
        0x51 => {
            let v = busRead(bus, aIndY(cpu, bus)) cpu.a = cpu.a ^ v setZN(cpu, cpu.a) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        // ---- ADC ----
        0x69 => {
            let v = busRead(bus, aImm(cpu)) adc(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        0x65 => {
            let v = busRead(bus, aZp(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0x75 => {
            let v = busRead(bus, aZpX(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0x6D => {
            let v = busRead(bus, aAbs(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0x7D => {
            let v = busRead(bus, aAbsX(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x79 => {
            let v = busRead(bus, aAbsY(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x61 => {
            let v = busRead(bus, aIndX(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 6
        }
        0x71 => {
            let v = busRead(bus, aIndY(cpu, bus)) adc(cpu, v) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        // ---- SBC ----
        0xE9 => {
            let v = busRead(bus, aImm(cpu)) sbc(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        0xE5 => {
            let v = busRead(bus, aZp(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0xF5 => {
            let v = busRead(bus, aZpX(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xED => {
            let v = busRead(bus, aAbs(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        0xFD => {
            let v = busRead(bus, aAbsX(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xF9 => {
            let v = busRead(bus, aAbsY(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xE1 => {
            let v = busRead(bus, aIndX(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 6
        }
        0xF1 => {
            let v = busRead(bus, aIndY(cpu, bus)) sbc(cpu, v) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        // ---- CMP / CPX / CPY ----
        0xC9 => {
            let v = busRead(bus, aImm(cpu)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 2
        }
        0xC5 => {
            let v = busRead(bus, aZp(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 3
        }
        0xD5 => {
            let v = busRead(bus, aZpX(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 4
        }
        0xCD => {
            let v = busRead(bus, aAbs(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 4
        }
        0xDD => {
            let v = busRead(bus, aAbsX(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xD9 => {
            let v = busRead(bus, aAbsY(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xC1 => {
            let v = busRead(bus, aIndX(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 6
        }
        0xD1 => {
            let v = busRead(bus, aIndY(cpu, bus)) compare(cpu, cpu.a, v) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        0xE0 => {
            let v = busRead(bus, aImm(cpu)) compare(cpu, cpu.x, v) cpu.cyc = cpu.cyc + 2
        }
        0xE4 => {
            let v = busRead(bus, aZp(cpu, bus)) compare(cpu, cpu.x, v) cpu.cyc = cpu.cyc + 3
        }
        0xEC => {
            let v = busRead(bus, aAbs(cpu, bus)) compare(cpu, cpu.x, v) cpu.cyc = cpu.cyc + 4
        }
        0xC0 => {
            let v = busRead(bus, aImm(cpu)) compare(cpu, cpu.y, v) cpu.cyc = cpu.cyc + 2
        }
        0xC4 => {
            let v = busRead(bus, aZp(cpu, bus)) compare(cpu, cpu.y, v) cpu.cyc = cpu.cyc + 3
        }
        0xCC => {
            let v = busRead(bus, aAbs(cpu, bus)) compare(cpu, cpu.y, v) cpu.cyc = cpu.cyc + 4
        }
        // ---- BIT ----
        0x24 => {
            let v = busRead(bus, aZp(cpu, bus)) bitTest(cpu, v) cpu.cyc = cpu.cyc + 3
        }
        0x2C => {
            let v = busRead(bus, aAbs(cpu, bus)) bitTest(cpu, v) cpu.cyc = cpu.cyc + 4
        }
        // ---- INC / DEC (memory) ----
        0xE6 => {
            let a = aZp(cpu, bus) let r = busRead(bus, a).wrappingAdd(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 5
        }
        0xF6 => {
            let a = aZpX(cpu, bus) let r = busRead(bus, a).wrappingAdd(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 6
        }
        0xEE => {
            let a = aAbs(cpu, bus) let r = busRead(bus, a).wrappingAdd(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 6
        }
        0xFE => {
            let a = aAbsX(cpu, bus) let r = busRead(bus, a).wrappingAdd(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 7
        }
        0xC6 => {
            let a = aZp(cpu, bus) let r = busRead(bus, a).wrappingSub(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 5
        }
        0xD6 => {
            let a = aZpX(cpu, bus) let r = busRead(bus, a).wrappingSub(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 6
        }
        0xCE => {
            let a = aAbs(cpu, bus) let r = busRead(bus, a).wrappingSub(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 6
        }
        0xDE => {
            let a = aAbsX(cpu, bus) let r = busRead(bus, a).wrappingSub(1) busWrite(bus, a, r) setZN(cpu, r) cpu.cyc = cpu.cyc + 7
        }
        // ---- INX/INY/DEX/DEY ----
        0xE8 => {
            cpu.x = cpu.x.wrappingAdd(1) setZN(cpu, cpu.x) cpu.cyc = cpu.cyc + 2
        }
        0xC8 => {
            cpu.y = cpu.y.wrappingAdd(1) setZN(cpu, cpu.y) cpu.cyc = cpu.cyc + 2
        }
        0xCA => {
            cpu.x = cpu.x.wrappingSub(1) setZN(cpu, cpu.x) cpu.cyc = cpu.cyc + 2
        }
        0x88 => {
            cpu.y = cpu.y.wrappingSub(1) setZN(cpu, cpu.y) cpu.cyc = cpu.cyc + 2
        }
        // ---- shifts / rotates: accumulator ----
        0x0A => {
            cpu.a = aslV(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x4A => {
            cpu.a = lsrV(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x2A => {
            cpu.a = rolV(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        0x6A => {
            cpu.a = rorV(cpu, cpu.a) cpu.cyc = cpu.cyc + 2
        }
        // ---- shifts / rotates: memory (zp / zp,X / abs / abs,X) ----
        0x06 => {
            let a = aZp(cpu, bus) let r = aslV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 5
        }
        0x16 => {
            let a = aZpX(cpu, bus) let r = aslV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x0E => {
            let a = aAbs(cpu, bus) let r = aslV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x1E => {
            let a = aAbsX(cpu, bus) let r = aslV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 7
        }
        0x46 => {
            let a = aZp(cpu, bus) let r = lsrV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 5
        }
        0x56 => {
            let a = aZpX(cpu, bus) let r = lsrV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x4E => {
            let a = aAbs(cpu, bus) let r = lsrV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x5E => {
            let a = aAbsX(cpu, bus) let r = lsrV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 7
        }
        0x26 => {
            let a = aZp(cpu, bus) let r = rolV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 5
        }
        0x36 => {
            let a = aZpX(cpu, bus) let r = rolV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x2E => {
            let a = aAbs(cpu, bus) let r = rolV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x3E => {
            let a = aAbsX(cpu, bus) let r = rolV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 7
        }
        0x66 => {
            let a = aZp(cpu, bus) let r = rorV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 5
        }
        0x76 => {
            let a = aZpX(cpu, bus) let r = rorV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x6E => {
            let a = aAbs(cpu, bus) let r = rorV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 6
        }
        0x7E => {
            let a = aAbsX(cpu, bus) let r = rorV(cpu, busRead(bus, a)) busWrite(bus, a, r) cpu.cyc = cpu.cyc + 7
        }
        // ---- jumps / subroutine ----
        0x4C => {
            cpu.pc = aAbs(cpu, bus) cpu.cyc = cpu.cyc + 3
        }
        0x6C => {
            let a = fetch16(cpu, bus) cpu.pc = read16Bug(bus, a) cpu.cyc = cpu.cyc + 5
        }
        0x20 => {
            let target = fetch16(cpu, bus) push16(cpu, bus, wrap16((cpu.pc as i64) - 1)) cpu.pc = target cpu.cyc = cpu.cyc + 6
        }
        0x60 => {
            cpu.pc = wrap16((pop16(cpu, bus) as i64) + 1) cpu.cyc = cpu.cyc + 6
        }
        0x40 => {
            let v = pop8(cpu, bus) cpu.p = (v & (~FB)) | FU cpu.pc = pop16(cpu, bus) cpu.cyc = cpu.cyc + 6
        }
        // ---- branches (base 2 branch() adds taken/page-cross) ----
        0x90 => {
            branch(cpu, bus,!cpuFlag(cpu, FC)) cpu.cyc = cpu.cyc + 2
        }
        0xB0 => {
            branch(cpu, bus, cpuFlag(cpu, FC)) cpu.cyc = cpu.cyc + 2
        }
        0xD0 => {
            branch(cpu, bus,!cpuFlag(cpu, FZ)) cpu.cyc = cpu.cyc + 2
        }
        0xF0 => {
            branch(cpu, bus, cpuFlag(cpu, FZ)) cpu.cyc = cpu.cyc + 2
        }
        0x10 => {
            branch(cpu, bus,!cpuFlag(cpu, FN)) cpu.cyc = cpu.cyc + 2
        }
        0x30 => {
            branch(cpu, bus, cpuFlag(cpu, FN)) cpu.cyc = cpu.cyc + 2
        }
        0x50 => {
            branch(cpu, bus,!cpuFlag(cpu, FV)) cpu.cyc = cpu.cyc + 2
        }
        0x70 => {
            branch(cpu, bus, cpuFlag(cpu, FV)) cpu.cyc = cpu.cyc + 2
        }
        // ---- flag ops ----
        0x18 => {
            setFlag(cpu, FC, false) cpu.cyc = cpu.cyc + 2
        }
        0x38 => {
            setFlag(cpu, FC, true) cpu.cyc = cpu.cyc + 2
        }
        0x58 => {
            setFlag(cpu, FI, false) cpu.cyc = cpu.cyc + 2
        }
        0x78 => {
            setFlag(cpu, FI, true) cpu.cyc = cpu.cyc + 2
        }
        0xB8 => {
            setFlag(cpu, FV, false) cpu.cyc = cpu.cyc + 2
        }
        0xD8 => {
            setFlag(cpu, FD, false) cpu.cyc = cpu.cyc + 2
        }
        0xF8 => {
            setFlag(cpu, FD, true) cpu.cyc = cpu.cyc + 2
        }
        // ---- NOP ----
        0xEA => {
            cpu.cyc = cpu.cyc + 2
        }
        // ---- unofficial NOPs ----
        // 1-byte implied NOPs (2 cyc)
        0x1A => {
            cpu.cyc = cpu.cyc + 2
        }
        0x3A => {
            cpu.cyc = cpu.cyc + 2
        }
        0x5A => {
            cpu.cyc = cpu.cyc + 2
        }
        0x7A => {
            cpu.cyc = cpu.cyc + 2
        }
        0xDA => {
            cpu.cyc = cpu.cyc + 2
        }
        0xFA => {
            cpu.cyc = cpu.cyc + 2
        }
        // 2-byte immediate NOPs (2 cyc): consume operand, discard
        0x80 => {
            let a = aImm(cpu) cpu.cyc = cpu.cyc + 2
        }
        0x82 => {
            let a = aImm(cpu) cpu.cyc = cpu.cyc + 2
        }
        0x89 => {
            let a = aImm(cpu) cpu.cyc = cpu.cyc + 2
        }
        0xC2 => {
            let a = aImm(cpu) cpu.cyc = cpu.cyc + 2
        }
        0xE2 => {
            let a = aImm(cpu) cpu.cyc = cpu.cyc + 2
        }
        // 2-byte zeropage NOPs (3 cyc)
        0x04 => {
            let a = aZp(cpu, bus) cpu.cyc = cpu.cyc + 3
        }
        0x44 => {
            let a = aZp(cpu, bus) cpu.cyc = cpu.cyc + 3
        }
        0x64 => {
            let a = aZp(cpu, bus) cpu.cyc = cpu.cyc + 3
        }
        // 2-byte zeropage,X NOPs (4 cyc)
        0x14 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        0x34 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        0x54 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        0x74 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        0xD4 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        0xF4 => {
            let a = aZpX(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        // 3-byte absolute NOP (4 cyc)
        0x0C => {
            let a = aAbs(cpu, bus) cpu.cyc = cpu.cyc + 4
        }
        // 3-byte absolute,X NOPs (4 cyc + page cross) — a read access
        0x1C => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x3C => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x5C => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0x7C => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xDC => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xFC => {
            let a = aAbsX(cpu, bus) let v = busRead(bus, a) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        // ---- LAX (load A and X) ----
        0xA7 => {
            lax(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 3
        }
        0xB7 => {
            lax(cpu, bus, aZpY(cpu, bus)) cpu.cyc = cpu.cyc + 4
        }
        0xAF => {
            lax(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 4
        }
        0xBF => {
            lax(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 4 + cpu.extraCycles
        }
        0xA3 => {
            lax(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0xB3 => {
            lax(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 5 + cpu.extraCycles
        }
        // ---- SAX (store A & X) ----
        0x87 => {
            sax(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 3
        }
        0x97 => {
            sax(cpu, bus, aZpY(cpu, bus)) cpu.cyc = cpu.cyc + 4
        }
        0x8F => {
            sax(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 4
        }
        0x83 => {
            sax(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        // ---- unofficial SBC (== official SBC imm) ----
        0xEB => {
            let v = busRead(bus, aImm(cpu)) sbc(cpu, v) cpu.cyc = cpu.cyc + 2
        }
        // ---- DCP (DEC + CMP) — RMW, fixed cycles (no page-cross add) ----
        0xC7 => {
            dcp(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0xD7 => {
            dcp(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0xCF => {
            dcp(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0xDF => {
            dcp(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0xDB => {
            dcp(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0xC3 => {
            dcp(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0xD3 => {
            dcp(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        // ---- ISB/ISC (INC + SBC) ----
        0xE7 => {
            isb(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0xF7 => {
            isb(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0xEF => {
            isb(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0xFF => {
            isb(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0xFB => {
            isb(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0xE3 => {
            isb(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0xF3 => {
            isb(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        // ---- SLO (ASL + ORA) ----
        0x07 => {
            slo(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0x17 => {
            slo(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x0F => {
            slo(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x1F => {
            slo(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x1B => {
            slo(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x03 => {
            slo(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0x13 => {
            slo(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        // ---- RLA (ROL + AND) ----
        0x27 => {
            rla(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0x37 => {
            rla(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x2F => {
            rla(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x3F => {
            rla(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x3B => {
            rla(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x23 => {
            rla(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0x33 => {
            rla(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        // ---- SRE (LSR + EOR) ----
        0x47 => {
            sre(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0x57 => {
            sre(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x4F => {
            sre(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x5F => {
            sre(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x5B => {
            sre(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x43 => {
            sre(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0x53 => {
            sre(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        // ---- RRA (ROR + ADC) ----
        0x67 => {
            rra(cpu, bus, aZp(cpu, bus)) cpu.cyc = cpu.cyc + 5
        }
        0x77 => {
            rra(cpu, bus, aZpX(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x6F => {
            rra(cpu, bus, aAbs(cpu, bus)) cpu.cyc = cpu.cyc + 6
        }
        0x7F => {
            rra(cpu, bus, aAbsX(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x7B => {
            rra(cpu, bus, aAbsY(cpu, bus)) cpu.cyc = cpu.cyc + 7
        }
        0x63 => {
            rra(cpu, bus, aIndX(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        0x73 => {
            rra(cpu, bus, aIndY(cpu, bus)) cpu.cyc = cpu.cyc + 8
        }
        _ => {
            // Unimplemented opcode: halt-ish. Caller detects no PC progress.
            cpu.cyc = cpu.cyc + 2
        }
    }
}
