// NES PPU (2C02): VRAM/OAM/palette memory, CPU register interface ($2000-$2007),
// dot/scanline timing with vblank + NMI, and a background+sprite framebuffer
// renderer. Ref: https://www.nesdev.org/wiki/PPU
//
// Simplifications (good enough for mapper-0 titles; refined later):
//   - frame rendered in one shot at vblank start (no mid-frame scroll splits)
//   - coarse + fine scroll from the v register; no cycle-exact fetch pipeline

from "./cartridge" import {
    Cartridge
}

struct Ppu {
    chr: Vec<u8> // pattern tables ($0000-$1FFF)
    chrBankOffset: [i64; 8] // byte offset into chr for each 1 KiB window (mapper CHR banking)
    vram: [u8; 2048] // 2 physical nametables ($2000-$2FFF, mirrored)
    palette: [u8; 32] // palette RAM ($3F00-$3F1F)
    oam: [u8; 256] // 64 sprites x 4 bytes

    mirrorVertical: bool // nametable mirroring from the cartridge

    ctrl: u8 // $2000 PPUCTRL
    mask: u8 // $2001 PPUMASK
    status: u8 // $2002 PPUSTATUS
    oamAddr: u8 // $2003

    // Loopy scroll registers
    v: u16 // current VRAM address
    t: u16 // temp VRAM address
    fineX: u8 // fine X scroll (0-7)
    w: u8 // write toggle (0/1)
    readBuffer: u8 // $2007 buffered-read latch

    scanline: i64 // 0-261
    dot: i64 // 0-340
    frame: i64
    nmiPending: bool // set at vblank when NMI enabled; consumed by CPU

    // Per-scanline scroll origin, set as each line is rendered (X from t, Y from
    // the live v register) so mid-frame scroll and CHR-bank splits are honored.
    scrollX: i64 // 0-511 pixel offset into the 2-wide nametable map
    scrollY: i64 // 0-479 pixel offset into the 2-tall nametable map

    // MMC2 (mapper 9): CHR banks are picked by a latch that flips when the PPU
    // fetches tile $FD or $FE from each pattern table — so the bank state lives
    // here where the fetches happen. latch = 0 (FD) or 1 (FE) per 4 KiB half.
    mmc2: bool
    mmc2Latch0: i64
    mmc2Latch1: i64
    mmc2ChrFD0: i64 // 4 KiB CHR bank for $0000-$0FFF when latch0 = FD
    mmc2ChrFE0: i64 // ... when latch0 = FE
    mmc2ChrFD1: i64 // 4 KiB CHR bank for $1000-$1FFF when latch1 = FD
    mmc2ChrFE1: i64 // ... when latch1 = FE

    fb: [u32; 61440] // 256x240 ARGB/ABGR framebuffer (R,G,B,A byte order)
}

fn newPpu(chr: Vec<u8>, mirrorVertical: bool): Ppu {
    // CHR-RAM carts report 0 CHR banks; give them 8 KiB of zeroed RAM.
    var c = chr
    if c.len == 0 {
        var i: i64 = 0
        while i < 8192 {
            c.push(0) i = i + 1
        }
    }
    return Ppu {
        chr: c, chrBankOffset: [0, 1024, 2048, 3072, 4096, 5120, 6144, 7168],
        vram: [0; 2048], palette: [0; 32], oam: [0; 256],
        mirrorVertical: mirrorVertical,
        ctrl: 0, mask: 0, status: 0, oamAddr: 0,
        v: 0, t: 0, fineX: 0, w: 0, readBuffer: 0,
        scanline: 0, dot: 0, frame: 0, nmiPending: false,
        scrollX: 0, scrollY: 0,
        mmc2: false, mmc2Latch0: 0, mmc2Latch1: 0,
        mmc2ChrFD0: 0, mmc2ChrFE0: 0, mmc2ChrFD1: 0, mmc2ChrFE1: 0,
        fb: [0; 61440],
    }
}

// --- MMC2 (mapper 9) CHR banking ---
// Recompute the 1 KiB CHR windows from the two 4 KiB bank selects (each chosen by
// its latch). Windows 0-3 cover $0000-$0FFF, windows 4-7 cover $1000-$1FFF.
fn mmc2UpdateChr(ppu: &mut Ppu): void {
    let n4k = ppu.chr.len / 4096
    let b0 = if ppu.mmc2Latch0 == 0 {
        ppu.mmc2ChrFD0
    } else {
        ppu.mmc2ChrFE0
    }
    let b1 = if ppu.mmc2Latch1 == 0 {
        ppu.mmc2ChrFD1
    } else {
        ppu.mmc2ChrFE1
    }
    var w: i64 = 0
    while w < 4 {
        ppu.chrBankOffset[w] = (b0 % n4k) * 4096 + w * 1024
        w = w + 1
    }
    while w < 8 {
        ppu.chrBankOffset[w] = (b1 % n4k) * 4096 + (w - 4) * 1024
        w = w + 1
    }
}

fn mmc2InitMapper(ppu: &mut Ppu): void {
    ppu.mmc2 = true
    mmc2UpdateChr(ppu)
}

// CPU-side CHR bank register write: which = 0:FD0 1:FE0 2:FD1 3:FE1.
fn mmc2SetChr(ppu: &mut Ppu, which: i64, bank: i64): void {
    if which == 0 {
        ppu.mmc2ChrFD0 = bank
    } else if which == 1 {
        ppu.mmc2ChrFE0 = bank
    } else if which == 2 {
        ppu.mmc2ChrFD1 = bank
    } else {
        ppu.mmc2ChrFE1 = bank
    }
    mmc2UpdateChr(ppu)
}

// Flip a latch when the PPU reads the high plane of tile $FD/$FE ($xFD8-$xFDF /
// $xFE8-$xFEF). The new bank affects subsequent fetches; recompute on change.
fn mmc2Latch(ppu: &mut Ppu, a: i64): void {
    var changed = false
    if a >= 0x0FD8 && a <= 0x0FDF {
        if ppu.mmc2Latch0 != 0 {
            ppu.mmc2Latch0 = 0
            changed = true
        }
    } else if a >= 0x0FE8 && a <= 0x0FEF {
        if ppu.mmc2Latch0 != 1 {
            ppu.mmc2Latch0 = 1
            changed = true
        }
    } else if a >= 0x1FD8 && a <= 0x1FDF {
        if ppu.mmc2Latch1 != 0 {
            ppu.mmc2Latch1 = 0
            changed = true
        }
    } else if a >= 0x1FE8 && a <= 0x1FEF {
        if ppu.mmc2Latch1 != 1 {
            ppu.mmc2Latch1 = 1
            changed = true
        }
    }
    if changed {
        mmc2UpdateChr(ppu)
    }
}

// --- nametable mirroring: map a $2000-$2FFF address into the 2 KiB VRAM ---
fn mirrorNT(ppu: &Ppu, addr: i64): i64 {
    let a = addr & 0x0FFF // offset within nametable region
    let table = a / 0x0400 // which of the 4 logical nametables (0-3)
    let off = a & 0x03FF
    var phys: i64 = 0
    if ppu.mirrorVertical {
        // vertical: NT0/NT2 share, NT1/NT3 share  -> use bit 0x400
        phys = (table & 1) * 0x0400 + off
    } else {
        // horizontal: NT0/NT1 share, NT2/NT3 share -> use bit 0x800
        phys = (table / 2) * 0x0400 + off
    }
    return phys
}

// Map a $0000-$1FFF pattern address through the 1 KiB CHR bank windows.
fn chrPhys(ppu: &Ppu, a: i64): i64 {
    return (ppu.chrBankOffset[a / 0x400] + (a & 0x3FF)) % ppu.chr.len
}

fn ppuMemRead(ppu: &Ppu, addr: u16): u8 {
    let a = (addr as i64) & 0x3FFF
    if a < 0x2000 {
        return ppu.chr[chrPhys(ppu, a)]
    }
    if a < 0x3F00 {
        return ppu.vram[mirrorNT(ppu, a)]
    }
    // palette: $3F00-$3F1F mirrored through $3FFF; $3F10/14/18/1C mirror $3F00/...
    var p = a & 0x1F
    if p == 0x10 {
        p = 0x00
    }
    if p == 0x14 {
        p = 0x04
    }
    if p == 0x18 {
        p = 0x08
    }
    if p == 0x1C {
        p = 0x0C
    }
    return ppu.palette[p]
}

fn ppuMemWrite(ppu: &mut Ppu, addr: u16, val: u8): void {
    let a = (addr as i64) & 0x3FFF
    if a < 0x2000 {
        ppu.chr[chrPhys(ppu, a)] = val // CHR-RAM (no-op effect for CHR-ROM carts)
        return
    }
    if a < 0x3F00 {
        ppu.vram[mirrorNT(ppu, a)] = val
        return
    }
    var p = a & 0x1F
    if p == 0x10 {
        p = 0x00
    }
    if p == 0x14 {
        p = 0x04
    }
    if p == 0x18 {
        p = 0x08
    }
    if p == 0x1C {
        p = 0x0C
    }
    ppu.palette[p] = val
}

// --- CPU-facing register interface ($2000-$2007, mirrored every 8) ---
fn ppuRegRead(ppu: &mut Ppu, reg: i64): u8 {
    if reg == 2 {
        // PPUSTATUS: top 3 bits + stale buffer; reading clears vblank and w latch
        let r = (ppu.status & 0xE0) | (ppu.readBuffer & 0x1F)
        ppu.status = ppu.status & 0x7F
        ppu.w = 0
        return r
    }
    if reg == 4 {
        return ppu.oam[ppu.oamAddr as i64]
    }
    if reg == 7 {
        let a = ppu.v
        var result: u8 = ppu.readBuffer
        ppu.readBuffer = ppuMemRead(ppu, a)
        // palette reads are not buffered
        if ((a as i64) & 0x3FFF) >= 0x3F00 {
            result = ppu.readBuffer
        }
        let inc: i64 = if (ppu.ctrl & 0x04) != 0 {
            32
        } else {
            1
        }
        ppu.v = ((ppu.v as i64 + inc) & 0x7FFF) as u16
        return result
    }
    return 0
}

fn ppuRegWrite(ppu: &mut Ppu, reg: i64, val: u8): void {
    if reg == 0 {
        ppu.ctrl = val
        // t: nametable select bits 10-11
        ppu.t = (((ppu.t as i64) & 0x73FF) | (((val as i64) & 0x03) << 10)) as u16
        return
    }
    if reg == 1 {
        ppu.mask = val return
    }
    if reg == 3 {
        ppu.oamAddr = val return
    }
    if reg == 4 {
        ppu.oam[ppu.oamAddr as i64] = val
        ppu.oamAddr = ((ppu.oamAddr as i64 + 1) & 0xFF) as u8
        return
    }
    if reg == 5 {
        if ppu.w == 0 {
            ppu.fineX = (val & 0x07)
            ppu.t = (((ppu.t as i64) & 0x7FE0) | ((val as i64) >> 3)) as u16
            ppu.w = 1
        } else {
            let hi = ((val as i64) & 0x07) << 12
            let lo = ((val as i64) & 0xF8) << 2
            ppu.t = (((ppu.t as i64) & 0x0C1F) | hi | lo) as u16
            ppu.w = 0
        }
        return
    }
    if reg == 6 {
        if ppu.w == 0 {
            ppu.t = (((ppu.t as i64) & 0x00FF) | (((val as i64) & 0x3F) << 8)) as u16
            ppu.w = 1
        } else {
            ppu.t = (((ppu.t as i64) & 0x7F00) | (val as i64)) as u16
            ppu.v = ppu.t
            ppu.w = 0
        }
        return
    }
    if reg == 7 {
        ppuMemWrite(ppu, ppu.v, val)
        let inc: i64 = if (ppu.ctrl & 0x04) != 0 {
            32
        } else {
            1
        }
        ppu.v = ((ppu.v as i64 + inc) & 0x7FFF) as u16
        return
    }
}

// Advance the loopy v register vertically at the end of a scanline (fine Y rolls
// into coarse Y; coarse Y wraps at 29, flipping the vertical nametable).
fn incrementY(ppu: &mut Ppu): void {
    var v = ppu.v as i64
    if (v & 0x7000) != 0x7000 {
        v = v + 0x1000 // increment fine Y
    } else {
        v = v & (~0x7000) // fine Y = 0
        var y = (v >> 5) & 0x1F // coarse Y
        if y == 29 {
            y = 0
            v = v ^ 0x0800 // switch vertical nametable
        } else if y == 31 {
            y = 0
        } else {
            y = y + 1
        }
        v = (v & (~0x03E0)) | (y << 5)
    }
    ppu.v = (v & 0x7FFF) as u16
}

// Advance one PPU dot. Renders the just-fetched visible scanline near the end of
// its fetch window using the *live* scroll (X from t, Y from v) and CHR banks, so
// mid-frame IRQ splits (scroll changes + CHR bank swaps) land on the right rows.
fn ppuStep(ppu: &mut Ppu): void {
    ppu.dot = ppu.dot + 1
    if ppu.dot > 340 {
        ppu.dot = 0
        ppu.scanline = ppu.scanline + 1
        if ppu.scanline > 261 {
            ppu.scanline = 0
            ppu.frame = ppu.frame + 1
        }
    }
    let rendering = (ppu.mask & 0x18) != 0
    if ppu.dot == 256 && ppu.scanline < 240 {
        renderScanline(ppu, ppu.scanline)
        if rendering {
            incrementY(ppu)
        }
    }
    // Pre-render line: reload v's vertical bits from t for the coming frame.
    if ppu.scanline == 261 && ppu.dot == 280 && rendering {
        let keepHoriz = (ppu.v as i64) & 0x041F
        let vert = (ppu.t as i64) & 0x7BE0
        ppu.v = (keepHoriz | vert) as u16
    }
    if ppu.scanline == 241 && ppu.dot == 1 {
        ppu.status = ppu.status | 0x80 // set vblank
        if (ppu.ctrl & 0x80) != 0 {
            ppu.nmiPending = true
        }
    }
    if ppu.scanline == 261 && ppu.dot == 1 {
        ppu.status = ppu.status & 0x1F // clear vblank, sprite0, overflow
    }
}

// --- NES master palette (0xRRGGBB), 2C02 canonical set ---
let NESPAL: [u32; 64] = [
0x545454, 0x001E74, 0x081090, 0x300088, 0x440064, 0x5C0030, 0x540400, 0x3C1800,
0x202A00, 0x083A00, 0x004000, 0x003C00, 0x00323C, 0x000000, 0x000000, 0x000000,
0x989698, 0x084CC4, 0x3032EC, 0x5C1EE4, 0x8814B0, 0xA01464, 0x982220, 0x783C00,
0x545A00, 0x287200, 0x087C00, 0x007628, 0x006678, 0x000000, 0x000000, 0x000000,
0xECEEEC, 0x4C9AEC, 0x787CEC, 0xB062EC, 0xE454EC, 0xEC58B4, 0xEC6A64, 0xD48820,
0xA0AA00, 0x74C400, 0x4CD020, 0x38CC6C, 0x38B4CC, 0x3C3C3C, 0x000000, 0x000000,
0xECEEEC, 0xA8CCEC, 0xBCBCEC, 0xD4B2EC, 0xECAEEC, 0xECAED4, 0xECB4B0, 0xE4C490,
0xCCD278, 0xB4DE78, 0xA8E290, 0x98E2B4, 0xA0D6E4, 0xA0A2A0, 0x000000, 0x000000,
]

// Convert a 6-bit NES color index to a framebuffer u32 (R,G,B,A byte order).
fn nesColor(idx: i64): u32
ensures(result & 0xFF000000) == 0xFF000000 // every emitted pixel is fully opaque
{
    let c = NESPAL[idx & 0x3F]as i64
    let r = (c >> 16) & 0xFF
    let g = (c >> 8) & 0xFF
    let b = c & 0xFF
    return (r | (g << 8) | (b << 16) | 0xFF000000) as u32
}

// Render one scanline: background (live scroll from t/v) then the sprites that
// intersect this line, with priority + sprite-0 hit resolved against the line's
// per-pixel background opacity.
fn renderScanline(ppu: &mut Ppu, sl: i64): void {
    var bgOpaque: [u8; 256] = [0; 256]
    let universal = ppuMemRead(ppu, 0x3F00) as i64
    if (ppu.mask & 0x08) != 0 {
        // X scroll comes from t (constant per line); Y from the live v register
        // (advanced by incrementY each line, reloaded from t at pre-render).
        let t = ppu.t as i64
        let v = ppu.v as i64
        ppu.scrollX = ((t >> 10) & 1) * 256 + (t & 0x1F) * 8 + (ppu.fineX as i64)
        ppu.scrollY = ((v >> 11) & 1) * 240 + ((v >> 5) & 0x1F) * 8 + ((v >> 12) & 7)
        let bgTable: i64 = if (ppu.ctrl & 0x10) != 0 {
            0x1000
        } else {
            0
        }
        // Fetch one tile at a time (not per pixel): each tile's pattern is read
        // once with the current CHR bank, then the MMC2 latch flips for the NEXT
        // tile — the only order that renders the mid-frame bank splits correctly.
        var lo: i64 = 0
        var hi: i64 = 0
        var palGroup: i64 = 0
        var x: i64 = 0
        while x < 256 {
            let wx = (ppu.scrollX + x) & 0x1FF
            if (wx & 7) == 0 || x == 0 {
                var wy = ppu.scrollY
                while wy >= 480 {
                    wy = wy - 480
                }
                let ntX = wx / 256
                let ntY = wy / 240
                let ntBase = 0x2000 + (ntY * 2 + ntX) * 0x400
                let lx = wx & 0xFF
                let ly = wy - ntY * 240
                let col = lx / 8
                let row = ly / 8
                let tile = ppuMemRead(ppu, (ntBase + row * 32 + col) as u16) as i64
                let atAddr = ntBase + 0x3C0 + (row / 4) * 8 + (col / 4)
                let at = ppuMemRead(ppu, atAddr as u16) as i64
                let shift = ((row & 2) * 2) + (col & 2)
                palGroup = (at >> shift) & 0x03
                let fy = ly & 7
                let patAddr = bgTable + tile * 16 + fy
                lo = ppuMemRead(ppu, patAddr as u16) as i64
                hi = ppuMemRead(ppu, (patAddr + 8) as u16) as i64
                if ppu.mmc2 {
                    mmc2Latch(ppu, patAddr + 8) // tile $FD/$FE high plane flips the latch
                }
            }
            let bit = 7 - (wx & 7)
            let px = ((lo >> bit) & 1) | (((hi >> bit) & 1) << 1)
            var colorIdx = universal
            if px != 0 {
                colorIdx = ppuMemRead(ppu, (0x3F00 + palGroup * 4 + px) as u16) as i64
                bgOpaque[x] = 1
            }
            ppu.fb[sl * 256 + x] = nesColor(colorIdx)
            x = x + 1
        }
    } else {
        var x: i64 = 0
        while x < 256 {
            ppu.fb[sl * 256 + x] = nesColor(universal)
            x = x + 1
        }
    }
    renderSpriteLine(ppu, sl, bgOpaque)
}

// Draw the sprites covering scanline sl. Back-to-front so lower OAM index wins;
// "behind background" sprites hide under opaque bg; sprite-0 opaque-on-opaque
// overlap raises the sprite-0 hit flag.
fn renderSpriteLine(ppu: &mut Ppu, sl: i64, bgOpaque: [u8; 256]): void {
    if (ppu.mask & 0x10) == 0 {
        return
    }
    let tall = (ppu.ctrl & 0x20) != 0
    let h: i64 = if tall {
        16
    } else {
        8
    }
    var i: i64 = 63
    while i >= 0 {
        let base = i * 4
        let row = sl - (ppu.oam[base]as i64 + 1) // OAM Y is top-minus-1
        if row >= 0 && row < h {
            let rawTile = ppu.oam[base + 1]as i64
            let attr = ppu.oam[base + 2]as i64
            let sx = ppu.oam[base + 3]as i64
            let palGroup = attr & 0x03
            let flipH = (attr & 0x40) != 0
            let flipV = (attr & 0x80) != 0
            let behind = (attr & 0x20) != 0
            let ry = if flipV {
                h - 1 - row
            } else {
                row
            }
            var patAddr: i64 = 0
            if tall {
                patAddr = (rawTile & 1) * 0x1000 + ((rawTile & 0xFE) + (ry / 8)) * 16 + (ry & 7)
            } else {
                let sprTable: i64 = if (ppu.ctrl & 0x08) != 0 {
                    0x1000
                } else {
                    0
                }
                patAddr = sprTable + rawTile * 16 + ry
            }
            let lo = ppuMemRead(ppu, patAddr as u16) as i64
            let hi = ppuMemRead(ppu, (patAddr + 8) as u16) as i64
            if ppu.mmc2 {
                mmc2Latch(ppu, patAddr + 8)
            }
            var fx: i64 = 0
            while fx < 8 {
                let rx = if flipH {
                    fx
                } else {
                    7 - fx
                }
                let px = ((lo >> rx) & 1) | (((hi >> rx) & 1) << 1)
                if px != 0 {
                    let x = sx + fx
                    if x < 256 {
                        let bgHere = bgOpaque[x] != 0
                        // Sprite-0 hit: opaque sprite-0 over opaque bg (never x==255).
                        if i == 0 && bgHere && x < 255 {
                            ppu.status = ppu.status | 0x40
                        }
                        if !(behind && bgHere) {
                            let colorIdx = ppuMemRead(ppu, (0x3F10 + palGroup * 4 + px) as u16) as i64
                            ppu.fb[sl * 256 + x] = nesColor(colorIdx)
                        }
                    }
                }
                fx = fx + 1
            }
        }
        i = i - 1
    }
}

// Background + sprites now render per-scanline inside ppuStep; the frame is
// already in fb by vblank, so this is a no-op kept for the frontend call site.
fn renderFrame(_ppu: &mut Ppu): void {
}
