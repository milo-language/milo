// Milo SNES — interactive SDL frontend. Loads a .sfc, runs the system
// frame-by-frame, and presents each rendered frame in a window with
// keyboard->joypad input. Mirrors the NES SDL pipeline.
// SDL2 is auto-linked via the @link attribute below — no -- flags needed.
//   milo build examples/apps/snes/snes.milo -o /tmp/snes-emu
//   /tmp/snes-emu roms/game.sfc
//
// Keys: arrows=D-pad, Z=B X=A A=Y S=X, Enter=Start, RShift=Select, Q=L W=R, Esc=quit.

from "std/argparse" import {
    newParser
}
from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, stepFrame, sramToString, sramFromString
}
from "std/io" import {
    readFile
}
from "std/fs" import {
    writeFile
}
from "./ppu" import {
    renderFrame
}
from "./spc" import {
    dspGenerate
}
from "./cartridge" import {
    loadCartridge
}
from "./savestate" import {
    saveState, loadState
}
from "std/datetime" import {
    dateTimeLocalNow, dateTimeFormatTime
}

// Dump the current 256x224 framebuffer (0xRRGGBB per pixel) as a binary PPM next to
// a save-state, so a state can be eyeballed without loading it in the debugger.
fn dumpPpm(fb: &Vec<i64>, path: &string): void {
    var out = String.withCapacity(200000)
    let hdr = "P6\n256 224\n255\n"
    var i: i64 = 0
    while i < hdr.len {
        out.push(hdr[i])
        i = i + 1
    }
    i = 0
    while i < 256 * 224 {
        let px = fb[i]
        out.push(((px >> 16) & 0xFF) as u8)
        out.push(((px >> 8) & 0xFF) as u8)
        out.push((px & 0xFF) as u8)
        i = i + 1
    }
    if let Result.Err(e) = writeFile(path, out) {
        eprint($"snes: screenshot write failed: {path}: {e}\n")
    }
}

// Synthesize one frame of audio (535 stereo samples @ ~32 kHz) from the S-DSP and
// queue it to SDL as interleaved S16LSB L,R.
fn queueAudio(m: &mut Mem, dev: u32): void {
    var samp: Vec<i64> = Vec.new()
    var i: i64 = 0
    while i < 535 * 2 {
        samp.push(0)
        i = i + 1
    }
    dspGenerate(m.apuMem, samp, 535)
    var buf: Vec<u8> = Vec.new()
    i = 0
    while i < 535 {
        let l = samp[i * 2]
        let r = samp[i * 2 + 1]
        buf.push((l & 0xFF) as u8)
        buf.push(((l >> 8) & 0xFF) as u8)
        buf.push((r & 0xFF) as u8)
        buf.push(((r >> 8) & 0xFF) as u8)
        i = i + 1
    }
    unsafe {
        SDL_QueueAudio(dev, buf.ptr() as *u8, buf.len as u32)
    }
}

@link("SDL2")
extern fn SDL_Init(flags: u32): i32

extern fn SDL_CreateWindow(title: *u8, x: i32, y: i32, w: i32, h: i32, flags: u32): *u8

extern fn SDL_CreateRenderer(win: *u8, index: i32, flags: u32): *u8

extern fn SDL_CreateTexture(ren: *u8, format: u32, access: i32, w: i32, h: i32): *u8

extern fn SDL_UpdateTexture(tex: *u8, rect: *u8, pixels: *u8, pitch: i32): i32

extern fn SDL_RenderClear(ren: *u8): i32

extern fn SDL_RenderCopy(ren: *u8, tex: *u8, src: *u8, dst: *u8): i32

// Maps the fixed 256x224 render onto whatever size the window is resized to,
// preserving aspect (letterbox) — lets the OS maximize/resize the window.
extern fn SDL_RenderSetLogicalSize(ren: *u8, w: i32, h: i32): i32

extern fn SDL_RenderPresent(ren: *u8): void

extern fn SDL_PollEvent(event: *u8): i32

extern fn SDL_GetKeyboardState(numkeys: *i32): *u8

extern fn SDL_NumJoysticks(): i32

extern fn SDL_IsGameController(index: i32): i32

extern fn SDL_GameControllerOpen(index: i32): *u8

extern fn SDL_GameControllerGetButton(gc: *u8, button: i32): u8

extern fn SDL_GameControllerClose(gc: *u8): void

extern fn SDL_Delay(ms: u32): void

extern fn SDL_GetTicks(): u32

extern fn SDL_OpenAudioDevice(device: *u8, iscapture: i32, desired: *u8, obtained: *u8, allowed: i32): u32

extern fn SDL_QueueAudio(dev: u32, data: *u8, len: u32): i32

extern fn SDL_PauseAudioDevice(dev: u32, pause_on: i32): void

extern fn SDL_GetQueuedAudioSize(dev: u32): u32

extern fn SDL_Quit(): void

let SDL_INIT_VIDEO: u32 = 0x20
let SDL_INIT_AUDIO: u32 = 0x10
let SDL_INIT_GAMECONTROLLER: u32 = 0x2000
// SDL_GameControllerButton ids.
let PAD_A: i32 = 0
let PAD_B: i32 = 1
let PAD_X: i32 = 2
let PAD_Y: i32 = 3
let PAD_BACK: i32 = 4
let PAD_START: i32 = 6
let PAD_LSHOULDER: i32 = 9
let PAD_RSHOULDER: i32 = 10
let PAD_DPAD_UP: i32 = 11
let PAD_DPAD_DOWN: i32 = 12
let PAD_DPAD_LEFT: i32 = 13
let PAD_DPAD_RIGHT: i32 = 14
// Controller hotplug events.
let SDL_CONTROLLERDEVICEADDED: u32 = 0x653
let SDL_CONTROLLERDEVICEREMOVED: u32 = 0x654
// Window events (SDL_WINDOWEVENT); the sub-event id is byte 12 of the event.
let SDL_WINDOWEVENT: u32 = 0x200
let SDL_WINDOWEVENT_MINIMIZED: u8 = 7
let SDL_WINDOWEVENT_RESTORED: u8 = 9
let SDL_WINDOWEVENT_FOCUS_GAINED: u8 = 12
let SDL_WINDOWEVENT_FOCUS_LOST: u8 = 13
let SDL_WINDOWPOS_CENTERED: i32 = 0x2FFF0000
let SDL_WINDOW_SHOWN: u32 = 0x4
let SDL_WINDOW_RESIZABLE: u32 = 0x20 // lets the OS maximize/resize the window
let SDL_TEXTUREACCESS_STREAMING: i32 = 1
let SDL_PIXELFORMAT_ABGR8888: u32 = 0x16762004
let SDL_QUIT: u32 = 0x100

// Game name from the cartridge header (LoROM $7FC0 / HiROM $FFC0, 21 bytes,
// space-padded). loadCartridge already strips any 512-byte SMC header. Returns
// "" if the region isn't a plausible ASCII title.
fn snesRomTitle(rom: &Vec<u8>, mapMode: i64): string {
    var base: i64 = 0
    if rom.len % 1024 == 512 {
        base = 512 // a copier's 512-byte SMC header survived (loadCartridge usually strips it)
    }
    let off: i64 = base + (if mapMode == 1 {
        0xFFC0
    } else {
        0x7FC0
    }
    )
    if off + 21 > rom.len {
        return ""
    }
    var end: i64 = 21
    while end > 0 {
        let c = rom[off + end - 1] as i64
        if c != 0x20 && c != 0x00 {
            break
        }
        end = end - 1
    }
    var s: string = ""
    var i: i64 = 0
    while i < end {
        let c = rom[off + i] as i64
        if c >= 0x20 && c <= 0x7E {
            s.push(c as u8)
        } else {
            s.push(0x20 as u8)
        }
        i = i + 1
    }
    return s
}

// Read a keyboard scancode's state from SDL's key array.
fn key(ks: *u8, sc: i64): i64 {
    unsafe {
        let base = ks as i64
        let ptr = (base + sc) as *u8
        return (*ptr) as i64
    }
}

// Open the n-th attached game controller (0 = player 1, 1 = player 2), or null.
// Re-run on hotplug so pads can be plugged/unplugged at any time; slot order
// follows SDL's joystick enumeration.
fn openPadN(n: i64): *u8 {
    unsafe {
        var found: i64 = 0
        var ji: i32 = 0
        while ji < SDL_NumJoysticks() {
            if SDL_IsGameController(ji) != 0 {
                if found == n {
                    return SDL_GameControllerOpen(ji)
                }
                found = found + 1
            }
            ji = ji + 1
        }
        return 0 as *u8
    }
}

fn main(): i32 {
    var parser = newParser("snes", "Milo SNES emulator (SDL2) — plays .sfc / .smc ROMs.")
    parser.addPositional("rom", "path to a .sfc or .smc ROM")
    let pargs = parser.parse() // auto-handles --help / -h; errors out when rom is missing
    let romPath = pargs.getString("rom")
    var rom: Vec<u8> = Vec.new()
    var mapMode: i64 = 0
    match loadCartridge(romPath) {
        Result.Ok(cart) => {
            rom = cart.rom
            mapMode = cart.map
            print("loaded " + romPath)
        }
        Result.Err(e) => {
            print("load failed: " + e)
            return 1
        }
    }

    let gameName = snesRomTitle(rom, mapMode) // before busNew moves `rom`
    var m = busNew(rom, mapMode)
    var cpu = newCpuReset(m)

    // Battery save: <rom>.srm holds the cartridge SRAM across runs. Load it now;
    // it's written back on quit so the game's own saves survive shutdown.
    let srmPath = romPath + ".srm"
    if let Result.Ok(data) = readFile(srmPath) {
        sramFromString(m, data)
        print("loaded save: " + srmPath)
    }

    if SDL_Init(SDL_INIT_VIDEO | SDL_INIT_AUDIO | SDL_INIT_GAMECONTROLLER) != 0 {
        print("SDL_Init failed")
        return 1
    }
    unsafe {
        var pad: *u8 = openPadN(0) // player 1
        var pad2: *u8 = openPadN(1) // player 2
        // Audio: 32000 Hz, S16LSB, stereo, 1024-sample buffer (SDL_AudioSpec is 32
        // bytes: freq@0, format@4, channels@6, samples@8). Matches the DSP's rate.
        var want: [u8; 32] = [0; 32]
        want[0] = 0x00
        want[1] = 0x7D // 32000 = 0x7D00
        want[4] = 0x10
        want[5] = 0x80 // AUDIO_S16LSB
        want[6] = 2 // stereo
        want[8] = 0x00
        want[9] = 0x04 // 1024 samples
        var got: [u8; 32] = [0; 32]
        let audioDev = SDL_OpenAudioDevice(0 as *u8, 0, want, got, 0)
        if audioDev != 0 {
            SDL_PauseAudioDevice(audioDev, 0)
        }
        // Window title = the game's own name (from the cart header), falling back
        // to "Milo SNES". Trailing NUL so the string is a valid C string for SDL.
        var title = "Milo SNES"
        if gameName.len > 0 {
            title = gameName + " - Milo SNES"
        }
        title.push(0 as u8)
        let win = SDL_CreateWindow(title, SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, 256 * 3, 224 * 3, SDL_WINDOW_SHOWN | SDL_WINDOW_RESIZABLE)
        let ren = SDL_CreateRenderer(win, -1, 0)
        // Scale the 256x224 frame to fill the (resizable) window, aspect-preserved.
        SDL_RenderSetLogicalSize(ren, 256, 224)
        let tex = SDL_CreateTexture(ren, SDL_PIXELFORMAT_ABGR8888, SDL_TEXTUREACCESS_STREAMING, 256, 224)
        if (win as i64) == 0 || (ren as i64) == 0 || (tex as i64) == 0 {
            print("SDL setup failed")
            return 2
        }

        var fb: Vec<i64> = Vec.new()
        var texBuf: Vec<u32> = Vec.new()
        var i: i64 = 0
        while i < 256 * 224 {
            fb.push(0)
            texBuf.push(0)
            i = i + 1
        }

        var ev: [u8; 64] = [0; 64]
        var quit = false
        var focused = true // false while backgrounded -> pause the emulator
        var prevSave = false // F5 = save-state, F7 = load-state (edge-detected)
        var prevLoad = false
        var saveSeq: i64 = 0 // F5 ring: cycle <rom>.state0..9 so saves don't clobber
        var comboFrames: i64 = 0 // Start+Select held -> quit to the menu
        // Autosave: flush SRAM to <rom>.srm periodically (not just on clean quit)
        // so a hard kill can't lose an in-game save. Guarded by a checksum so we
        // only write when the game actually changed SRAM.
        var saveTick: i64 = 0
        var lastSaveSum: i64 = -1
        let statePath = romPath + ".state"
        var fpsCarry: i64 = 0 // fractional-ms accumulator for exact 60 fps pacing
        while !quit {
            let frameStart = SDL_GetTicks() as i64
            if focused {
                stepFrame(cpu, m)
                if audioDev != 0 {
                    queueAudio(m, audioDev)
                }
            }
            renderFrame(m.ppu, fb)

            saveTick = saveTick + 1
            if srmPath.len > 0 && saveTick >= 180 { // ~3s at 60fps
                saveTick = 0
                var sum: i64 = 0
                var si: i64 = 0
                while si < m.sram.len {
                    sum = sum + (m.sram[si] as i64) * (si + 1)
                    si = si + 1
                }
                if sum != lastSaveSum {
                    lastSaveSum = sum
                    if let Result.Err(e) = writeFile(srmPath, sramToString(m)) {
                        eprint($"snes: SRAM save failed: {srmPath}: {e}\n")
                    }
                }
            }

            // Pack 0xRRGGBB -> ABGR8888 (LE bytes R,G,B,A).
            i = 0
            while i < 256 * 224 {
                let c = fb[i]
                let r = (c >> 16) & 0xFF
                let g = (c >> 8) & 0xFF
                let b = c & 0xFF
                texBuf[i] = (0xFF000000 | (b << 16) | (g << 8) | r) as u32
                i = i + 1
            }
            SDL_UpdateTexture(tex, 0 as *u8, texBuf.ptr() as *u8, 256 * 4)
            SDL_RenderClear(ren)
            SDL_RenderCopy(ren, tex, 0 as *u8, 0 as *u8)
            SDL_RenderPresent(ren)

            while SDL_PollEvent(ev) != 0 {
                let evType: u32 = (ev[0] as u32) | ((ev[1] as u32) << 8) | ((ev[2] as u32) << 16) | ((ev[3] as u32) << 24)
                if evType == SDL_QUIT {
                    quit = true
                }
                // Controller plugged in or removed: re-grab both slots so P1/P2
                // stay assigned as pads come and go at any time.
                if evType == SDL_CONTROLLERDEVICEADDED || evType == SDL_CONTROLLERDEVICEREMOVED {
                    if (pad as i64) != 0 {
                        SDL_GameControllerClose(pad)
                    }
                    if (pad2 as i64) != 0 {
                        SDL_GameControllerClose(pad2)
                    }
                    pad = openPadN(0)
                    pad2 = openPadN(1)
                }
                // Pause + go silent when backgrounded; resume on refocus.
                if evType == SDL_WINDOWEVENT {
                    let we = ev[12]
                    if we == SDL_WINDOWEVENT_FOCUS_LOST || we == SDL_WINDOWEVENT_MINIMIZED {
                        focused = false
                    }
                    if we == SDL_WINDOWEVENT_FOCUS_GAINED || we == SDL_WINDOWEVENT_RESTORED {
                        focused = true
                    }
                }
            }
            let ks = SDL_GetKeyboardState(0 as *i32)
            if key(ks, 41) != 0 {
                quit = true
            } // Escape
            // F5 = save state, F7 = load state (scancodes 62 / 64), edge-triggered.
            let sd = key(ks, 62) != 0
            if sd && !prevSave {
                // Ring buffer: keep the last 10 states (<rom>.state0..9) so repeated
                // F5s don't clobber earlier snapshots, plus the canonical <rom>.state
                // as the latest (what F7 and the headless dbg load by default).
                let blob = saveState(cpu, m)
                let slot = statePath + (saveSeq % 10).toString()
                let stamp = dateTimeFormatTime(dateTimeLocalNow())
                match writeFile(slot, blob.clone()) {
                    Result.Ok(n) => {
                        print("state saved -> " + slot + " (" + stamp + ")")
                    }
                    Result.Err(e) => {
                        print("state save failed")
                    }
                }
                dumpPpm(fb, slot + ".ppm") // screenshot alongside the state
                if let Result.Err(e) = writeFile(statePath, blob) {
                    eprint($"snes: state save failed: {statePath}: {e}\n")
                }
                saveSeq = saveSeq + 1
            }
            prevSave = sd
            let ld = key(ks, 64) != 0
            if ld && !prevLoad {
                match readFile(statePath) {
                    Result.Ok(data) => {
                        if loadState(cpu, m, data) {
                            print("state loaded <- " + statePath)
                        } else {
                            print("state file invalid")
                        }
                    }
                    Result.Err(e) => {
                        print("no state file")
                    }
                }
            }
            prevLoad = ld
            // Build the 16-bit auto-read joypad word (B Y Sel St Up Dn Lt Rt A X L R).
            var j: i64 = 0
            if key(ks, 29) != 0 {
                j = j | 0x8000
            } // Z -> B
            if key(ks, 4) != 0 {
                j = j | 0x4000
            } // A -> Y
            if key(ks, 229) != 0 {
                j = j | 0x2000
            } // RShift -> Select
            if key(ks, 40) != 0 {
                j = j | 0x1000
            } // Enter -> Start
            if key(ks, 82) != 0 {
                j = j | 0x0800
            } // Up
            if key(ks, 81) != 0 {
                j = j | 0x0400
            } // Down
            if key(ks, 80) != 0 {
                j = j | 0x0200
            } // Left
            if key(ks, 79) != 0 {
                j = j | 0x0100
            } // Right
            if key(ks, 27) != 0 {
                j = j | 0x0080
            } // X -> A
            if key(ks, 22) != 0 {
                j = j | 0x0040
            } // S -> X
            if key(ks, 20) != 0 {
                j = j | 0x0020
            } // Q -> L
            if key(ks, 26) != 0 {
                j = j | 0x0010
            } // W -> R
            // Overlay the game controller onto the same SNES joypad word.
            if (pad as i64) != 0 {
                if SDL_GameControllerGetButton(pad, PAD_B) != 0 {
                    j = j | 0x8000
                } // B
                if SDL_GameControllerGetButton(pad, PAD_Y) != 0 {
                    j = j | 0x4000
                } // Y
                if SDL_GameControllerGetButton(pad, PAD_BACK) != 0 {
                    j = j | 0x2000
                } // Select
                if SDL_GameControllerGetButton(pad, PAD_START) != 0 {
                    j = j | 0x1000
                } // Start
                if SDL_GameControllerGetButton(pad, PAD_DPAD_UP) != 0 {
                    j = j | 0x0800
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_DOWN) != 0 {
                    j = j | 0x0400
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_LEFT) != 0 {
                    j = j | 0x0200
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_RIGHT) != 0 {
                    j = j | 0x0100
                }
                if SDL_GameControllerGetButton(pad, PAD_A) != 0 {
                    j = j | 0x0080
                } // A
                if SDL_GameControllerGetButton(pad, PAD_X) != 0 {
                    j = j | 0x0040
                } // X
                if SDL_GameControllerGetButton(pad, PAD_LSHOULDER) != 0 {
                    j = j | 0x0020
                } // L
                if SDL_GameControllerGetButton(pad, PAD_RSHOULDER) != 0 {
                    j = j | 0x0010
                } // R
            }
            m.joy1 = j
            // Player 2 is the second controller only (no keyboard fallback).
            var j2: i64 = 0
            if (pad2 as i64) != 0 {
                if SDL_GameControllerGetButton(pad2, PAD_B) != 0 {
                    j2 = j2 | 0x8000
                }
                if SDL_GameControllerGetButton(pad2, PAD_Y) != 0 {
                    j2 = j2 | 0x4000
                }
                if SDL_GameControllerGetButton(pad2, PAD_BACK) != 0 {
                    j2 = j2 | 0x2000
                }
                if SDL_GameControllerGetButton(pad2, PAD_START) != 0 {
                    j2 = j2 | 0x1000
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_UP) != 0 {
                    j2 = j2 | 0x0800
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_DOWN) != 0 {
                    j2 = j2 | 0x0400
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_LEFT) != 0 {
                    j2 = j2 | 0x0200
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_RIGHT) != 0 {
                    j2 = j2 | 0x0100
                }
                if SDL_GameControllerGetButton(pad2, PAD_A) != 0 {
                    j2 = j2 | 0x0080
                }
                if SDL_GameControllerGetButton(pad2, PAD_X) != 0 {
                    j2 = j2 | 0x0040
                }
                if SDL_GameControllerGetButton(pad2, PAD_LSHOULDER) != 0 {
                    j2 = j2 | 0x0020
                }
                if SDL_GameControllerGetButton(pad2, PAD_RSHOULDER) != 0 {
                    j2 = j2 | 0x0010
                }
            }
            m.joy2 = j2
            // Start+Select held ~1s quits back to the menu.
            if (j & 0x3000) == 0x3000 {
                comboFrames = comboFrames + 1
                if comboFrames > 60 {
                    quit = true
                }
            } else {
                comboFrames = 0
            }
            // Pacing. With audio, the SDL queue is the clock: drain to ~3 frames of
            // latency (535 samples * 4 bytes * 3) so playback rate sets the speed and
            // A/V stay synced. No audio device -> fall back to delta-timing at 60fps
            // (sleep only the remainder to a 16.667ms target; 50/3-ms accumulator
            // keeps the average exact). Old code slept a fixed 16ms ON TOP of the
            // work -> ~55fps, visibly slow.
            if !focused {
                SDL_Delay(50)
            } else if audioDev != 0 {
                while SDL_GetQueuedAudioSize(audioDev) > (535 * 4 * 3) as u32 {
                    SDL_Delay(1)
                }
            } else {
                fpsCarry = fpsCarry + 50
                let target = fpsCarry / 3
                fpsCarry = fpsCarry - target * 3
                let elapsed = (SDL_GetTicks() as i64) - frameStart
                if elapsed < target {
                    SDL_Delay((target - elapsed) as u32)
                }
            }
        }
    }
    // Persist cartridge SRAM on exit so in-game saves survive.
    if srmPath.len > 0 {
        match writeFile(srmPath, sramToString(m)) {
            Result.Ok(n) => {
                print("wrote save: " + srmPath)
            }
            Result.Err(e) => {
                print("save write failed")
            }
        }
    }
    SDL_Quit()
    return 0
}
