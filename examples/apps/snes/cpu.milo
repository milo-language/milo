            bitMem(cpu, m, a, false)
        }

        // ---- branches ----
        0x10 => {
            branchIf(cpu, m, (cpu.p & FN) == 0)
        } // BPL
        0x30 => {
            branchIf(cpu, m, (cpu.p & FN) != 0)
        } // BMI
        0x50 => {
            branchIf(cpu, m, (cpu.p & FV) == 0)
        } // BVC
        0x70 => {
            branchIf(cpu, m, (cpu.p & FV) != 0)
        } // BVS
        0x90 => {
            branchIf(cpu, m, (cpu.p & FC) == 0)
        } // BCC
        0xB0 => {
            branchIf(cpu, m, (cpu.p & FC) != 0)
        } // BCS
        0xD0 => {
            branchIf(cpu, m, (cpu.p & FZ) == 0)
        } // BNE
        0xF0 => {
            branchIf(cpu, m, (cpu.p & FZ) != 0)
        } // BEQ
        0x80 => {
            branchIf(cpu, m, true)
        } // BRA
        0x82 => { // BRL — 16-bit relative
            let off = fetch16(cpu, m)
            let soff: i64 = if off >= 0x8000 {
                off - 0x10000
            } else {
                off
            }
            cpu.pc = (cpu.pc + soff) & 0xFFFF
        }

        // ---- jumps ----
        0x4C => {
            cpu.pc = fetch16(cpu, m)
        } // JMP abs
        0x5C => { // JML/JMP long
            let t = fetch24(cpu, m)
            cpu.pc = t & 0xFFFF
            cpu.pbr = (t >> 16) & 0xFF
        }
        0x6C => {
            let ptr = fetch16(cpu, m)
            cpu.pc = readPtr16(m, ptr)
        } // JMP (abs), ptr in bank 0
        0x7C => { // JMP (abs,X) — pointer read within the program bank
            let base = fetch16(cpu, m)
            let a0 = (base + cpu.x) & 0xFFFF
            let lo = memRead(m, (cpu.pbr << 16) | a0)
            let hi = memRead(m, (cpu.pbr << 16) | ((a0 + 1) & 0xFFFF))
            cpu.pc = lo | (hi << 8)
        }
        0xFC => { // JSR (abs,X) — push return, then jump through the pointer at
            // (abs+X) in the program bank. DKC's vblank dispatcher uses this; leaving
            // it unimplemented desynced PC and derailed the level load into $7003.
            let base = fetch16(cpu, m)
            push16(cpu, m, (cpu.pc - 1) & 0xFFFF)
            let a0 = (base + cpu.x) & 0xFFFF
            let lo = memRead(m, (cpu.pbr << 16) | a0)
            let hi = memRead(m, (cpu.pbr << 16) | ((a0 + 1) & 0xFFFF))
            cpu.pc = lo | (hi << 8)
        }
        0xDC => { // JML [abs] — 24-bit pointer in bank 0
            let ptr = fetch16(cpu, m)
            let t = readPtr24(m, ptr)
            cpu.pc = t & 0xFFFF
            cpu.pbr = (t >> 16) & 0xFF
        }

        // ---- subroutine call/return ----
        0x20 => { // JSR abs — push PC of last operand byte (return - 1)
            let target = fetch16(cpu, m)
            push16(cpu, m, (cpu.pc - 1) & 0xFFFF)
            cpu.pc = target
        }
        0x60 => { // RTS
            let addr = pull16(cpu, m)
            cpu.pc = (addr + 1) & 0xFFFF
        }
        0x22 => { // JSL long — push PBR then PC-1 (full 16-bit stack)
            let target = fetch24(cpu, m)
            push8f(cpu, m, cpu.pbr)
            push16f(cpu, m, (cpu.pc - 1) & 0xFFFF)
            clampEmuStack(cpu)
            cpu.pc = target & 0xFFFF
            cpu.pbr = (target >> 16) & 0xFF
        }
        0x6B => { // RTL — pull PC then PBR (full stack)
            let addr = pull16f(cpu, m)
            let bank = pull8f(cpu, m)
            clampEmuStack(cpu)
            cpu.pc = (addr + 1) & 0xFFFF
            cpu.pbr = bank & 0xFF
        }

        // ---- PEI / PER (push effective address; full 16-bit stack) ----
        0xD4 => { // PEI — push the 16-bit word at a direct-page pointer
            let ad = aDp(cpu, m)
            let v = readPtr16(m, ad)
            push16f(cpu, m, v)
            clampEmuStack(cpu)
        }
        0x62 => { // PER — push PC + 16-bit relative
            let off = fetch16(cpu, m)
            let soff: i64 = if off >= 0x8000 {
                off - 0x10000
            } else {
                off
            }
            push16f(cpu, m, (cpu.pc + soff) & 0xFFFF)
            clampEmuStack(cpu)
        }

        // ---- stack push/pull ----
        0x48 => { // PHA
            if m8(cpu) {
                push8(cpu, m, cpu.a)
            } else {
                push16(cpu, m, cpu.a)
            }
        }
        0x68 => { // PLA
            if m8(cpu) {
                let v = pull8(cpu, m)
                cpu.a = (cpu.a & 0xFF00) | v
                setNZ8(cpu, v)
            } else {
                cpu.a = pull16(cpu, m)
                setNZ16(cpu, cpu.a)
            }
        }
        0xDA => { // PHX
            if x8(cpu) {
                push8(cpu, m, cpu.x)
            } else {
                push16(cpu, m, cpu.x)
            }
        }
        0xFA => { // PLX
            if x8(cpu) {
                cpu.x = pull8(cpu, m)
                setNZ8(cpu, cpu.x)
            } else {
                cpu.x = pull16(cpu, m)
                setNZ16(cpu, cpu.x)
            }
        }
        0x5A => { // PHY
            if x8(cpu) {
                push8(cpu, m, cpu.y)
            } else {
                push16(cpu, m, cpu.y)
            }
        }
        0x7A => { // PLY
            if x8(cpu) {
                cpu.y = pull8(cpu, m)
                setNZ8(cpu, cpu.y)
            } else {
                cpu.y = pull16(cpu, m)
                setNZ16(cpu, cpu.y)
            }
        }
        0x08 => { // PHP — status pushed as-is (8-bit)
            push8(cpu, m, cpu.p)
        }
        0x28 => { // PLP
            cpu.p = pull8(cpu, m)
            applyEmulationConstraints(cpu) // e forces M/X set + truncates
            if (cpu.p & FX) != 0 { // native X=1 narrows index registers
                cpu.x = cpu.x & 0xFF
                cpu.y = cpu.y & 0xFF
            }
        }
        0x8B => { // PHB — data bank (full-stack op)
            push8f(cpu, m, cpu.dbr)
            clampEmuStack(cpu)
        }
        0xAB => { // PLB
            cpu.dbr = pull8f(cpu, m)
            clampEmuStack(cpu)
            setNZ8(cpu, cpu.dbr)
        }
        0x4B => { // PHK — program bank (full-stack op)
            push8f(cpu, m, cpu.pbr)
            clampEmuStack(cpu)
        }
        0x0B => { // PHD — direct-page register (always 16-bit, full stack)
            push16f(cpu, m, cpu.d)
            clampEmuStack(cpu)
        }
        0x2B => { // PLD
            cpu.d = pull16f(cpu, m)
            clampEmuStack(cpu)
            setNZ16(cpu, cpu.d)
        }
        0xF4 => { // PEA — push a 16-bit immediate (full stack)
            let v = fetch16(cpu, m)
            push16f(cpu, m, v)
            clampEmuStack(cpu)
        }

        // ---- software interrupts BRK / COP ----
        0x00 => {
            softInterrupt(cpu, m, 0xFFE6, 0xFFFE)
        } // BRK
        0x02 => {
            softInterrupt(cpu, m, 0xFFE4, 0xFFF4)
        } // COP
        0x40 => { // RTI
            cpu.p = pull8(cpu, m)
            let addr = pull16(cpu, m)
            if cpu.e == 0 {
                cpu.pbr = pull8(cpu, m)
            }
            cpu.pc = addr
            applyEmulationConstraints(cpu)
            if (cpu.p & FX) != 0 {
                cpu.x = cpu.x & 0xFF
                cpu.y = cpu.y & 0xFF
            }
        }

        // ---- block moves (one byte per step; PC rewinds until C wraps) ----
        0x54 => {
            blockMove(cpu, m, 1)
        } // MVN — ascending
        0x44 => {
            blockMove(cpu, m, -1)
        } // MVP — descending

        // ---- WDM (2-byte reserved no-op), WAI / STP (no interrupts in tests) ----
        0x42 => {
            let sig = fetch8(cpu, m)
        } // WDM consumes its signature byte
        0xCB => {
            cpuWaiting = true
        } // WAI — halt until the next interrupt (see stepFrame's active loop)
        0xDB => {
        } // STP

        _ => {
            // No opcode should reach here — all 256 are implemented. If a future
            // edit drops one, record it LOUDLY instead of silently no-op'ing: a
            // no-op leaves the operand bytes unconsumed, so PC desyncs and the CPU
            // derails hundreds of instructions later into unmapped RAM (this is how
            // the DKC $FC/JSR-(abs,X) gap hid for so long). Harnesses surface badOp.
            badOp = op
            badOpPc = (cpu.pbr << 16) | ((cpu.pc - 1) & 0xFFFF)
        } // unimplemented — see badOp/badOpPc
    }
}
