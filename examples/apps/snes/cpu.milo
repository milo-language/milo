// WDC 65C816 CPU core — SNES main CPU. Bring-up mirrors the NES 6502 build:
// validate per-opcode against Harte SingleStepTests (roms/harte-65816/v1) before
// any pixels. Ref: fullsnes (problemkaputt.de/fullsnes.htm), 65816 datasheet.
//
// Registers are held as i64 masked to their real width — sidesteps u8/u16
// wrapping-op friction and matches Harte's JSON (which gives plain ints). The
// M/X flags make A and X/Y switch between 8- and 16-bit at runtime, so operand
// width (and thus instruction length) is decided live via m8()/x8().

from "./spc" import {
    Spc, SpcMem, spcMemNew, spcMemReal, spcReset, spcStep, apuReadPort, apuWritePort
}
from "./ppu" import {
    Ppu, newPpu, ppuRegWrite, ppuRegReadPure, ppuCgram, ppuVram
}

// --- P status-register bit masks ---
let FC: i64 = 0x01 // carry
let FZ: i64 = 0x02 // zero
let FI: i64 = 0x04 // irq disable
let FD: i64 = 0x08 // decimal
let FX: i64 = 0x10 // index width: 1 = 8-bit X/Y (also B/break in emulation)
let FM: i64 = 0x20 // accumulator width: 1 = 8-bit A (also unused in emulation)
let FV: i64 = 0x40 // overflow
let FN: i64 = 0x80 // negative

// Manual serial joypad ($4016/$4017). The auto-joypad ($4218/$4219) covers most
// input, but DKC also reads the pad the old 6502 way: strobe $4016, then shift 16
// bits out of $4016 bit0 (B,Y,Select,Start,Up,Down,Left,Right,A,X,L,R, then 1s).
// Each read advances a bit cursor — but the CPU read path (memRead/mmioRead) is
// &Mem, so the cursor can't live in Mem. It lives in these module globals, which
// stay mutable regardless of the borrow. Latched from m.joy1/joy2 on the strobe.
var joyLatch1: i64 = 0
var joyCnt1: i64 = 0
var joyLatch2: i64 = 0
var joyCnt2: i64 = 0

// Set by the WAI opcode ($CB): the CPU is idling until the next interrupt. The
// per-frame active loop breaks as soon as this is set so NMI fires from the game's
// vblank-wait (where DBR=$80) rather than at an arbitrary instruction count deep
// inside a heavy routine (DBR=$BB) — the latter derailed DKC's boot and its level
// loads (the vblank handler saves A/X/Y but not DBR; see stepFrame/nmi).
var cpuWaiting: bool = false

// Set by step()'s default arm if an unimplemented opcode is ever executed (should
// never happen — all 256 are wired). Loud diagnostic so a dropped opcode surfaces
// immediately instead of silently desyncing PC. badOp = -1 means "none seen".
var badOp: i64 = -1
var badOpPc: i64 = 0

struct Cpu {
    a: i64 // 16-bit accumulator (low byte = A, high byte = B when M=1)
    x: i64 // 16-bit index
    y: i64 // 16-bit index
    s: i64 // 16-bit stack pointer (high byte forced 01 in emulation)
    d: i64 // 16-bit direct-page register
    pc: i64 // 16-bit program counter within pbr bank
    p: i64 // status flags
    dbr: i64 // data bank
    pbr: i64 // program bank
    e: i64 // emulation-mode latch (1 = 6502 emulation)
}

// CPU-visible 24-bit memory. Two backings behind one interface:
//  - testMode (Harte): sparse linear-scan assoc list, arbitrary read/write.
//  - real bus: 128 KiB WRAM ($7E-$7F + low mirror), LoROM/HiROM cartridge, and
//    an MMIO scratch store ($2000-$5FFF) stubbed for readback until the PPU/DMA
//    modules land.
struct Mem {
    addr: Vec<i64> // test-mode sparse RAM
    val: Vec<i64>
    testMode: bool
    wram: Vec<u8> // 128 KiB; empty in test mode
    rom: Vec<u8>
    romMask: i64
    sram: Vec<u8> // battery-backed save RAM (LoROM $70-7D:0-7FFF / HiROM $20-3F:6000-7FFF)
    sramMask: i64
    mapMode: i64 // 0 = LoROM, 1 = HiROM
    mmio: Vec<u8> // $2000-$5FFF scratch (0x4000 bytes)

    // CPU-side MMIO ($42xx) modeled state:
    nmitimen: i64 // $4200 NMI/IRQ/auto-joypad enable
    htime: i64 // $4207/$4208 H-counter IRQ target (0-339)
    vtime: i64 // $4209/$420A V-counter IRQ target (0-261)
    timeup: i64 // $4211 TIMEUP: bit7 = IRQ fired (cleared on read)
    wmadd: i64 // $2181-$2183 17-bit WRAM address for the $2180 data port
    wrmpya: i64 // $4202 multiplicand
    wrdiv: i64 // $4204/$4205 16-bit dividend
    rddiv: i64 // $4214/$4215 quotient
    rdmpy: i64 // $4216/$4217 product (after mul) or remainder (after div)
    vblankToggle: i64 // stub: flips so $4210/$4212 vblank-wait loops progress
    hcounter: i64 // free-running instr counter; drives the $4212 HBLANK-flag stub
    joy1: i64 // $4218/$4219 auto-read pad 1 (0 = nothing pressed)
    joy2: i64 // $421A/$421B auto-read pad 2 (0 = nothing pressed)

    // Audio subsystem (SPC700 + its RAM). $2140-$2143 bridge to its port latches.
    apuSpc: Spc
    apuMem: SpcMem
    ppu: Ppu // video memory + $2100-$213F registers
}

fn newApuSpc(): Spc {
    return Spc {
        a: 0, x: 0, y: 0, sp: 0, pc: 0, psw: 0
    }
}

fn memNew(): Mem {
    return Mem {
        addr: Vec.new(), val: Vec.new(), testMode: true,
        wram: Vec.new(), rom: Vec.new(), romMask: 0, sram: Vec.new(), sramMask: 0, mapMode: 0, mmio: Vec.new(),
        nmitimen: 0, htime: 0, vtime: 0, timeup: 0, wmadd: 0, wrmpya: 0, wrdiv: 0, rddiv: 0, rdmpy: 0, vblankToggle: 0, hcounter: 0, joy1: 0, joy2: 0,
        apuSpc: newApuSpc(), apuMem: spcMemNew(), ppu: newPpu()
    }
}

fn vecZeros(n: i64): Vec<u8> {
    var v: Vec<u8> = Vec.new()
    var i: i64 = 0
    while i < n {
        v.push(0)
        i = i + 1
    }
    return v
}

// Real-hardware bus over a loaded cartridge. mapMode: 0 LoROM, 1 HiROM.
fn busNew(rom: Vec<u8>, mapMode: i64): Mem {
    let len = rom.len
    var mask: i64 = 1
    while mask < len {
        mask = mask << 1
    }
    mask = mask - 1 // next-pow2 minus 1; ROM offsets are wrapped by this
    // SRAM size from the cartridge header ($xxD8: size = 1024<<N bytes, 0 = none).
    // The mask MUST match the real size: DKC's anti-piracy writes past its 2KB SRAM
    // and checks the write mirrored back (copiers give oversized, non-mirroring RAM);
    // a too-big mask fails that test and trips the "unauthorized device" screen.
    let hdrRam = if mapMode == 1 {
        0xFFD8
    } else {
        0x7FD8
    }
    var sramMask: i64 = 0x7FFF
    if hdrRam < len {
        let rs = rom[hdrRam] as i64
        if rs == 0 {
            sramMask = 0
        } else {
            var sz = 1024 << rs
            if sz > 0x8000 {
                sz = 0x8000
            }
            sramMask = sz - 1
        }
    }
    var mem = Mem {
        addr: Vec.new(), val: Vec.new(), testMode: false,
        wram: vecZeros(0x20000), rom: rom, romMask: mask,
        sram: vecZeros(0x8000), sramMask: sramMask, mapMode: mapMode,
        mmio: vecZeros(0x4000),
        nmitimen: 0, htime: 0, vtime: 0, timeup: 0, wmadd: 0, wrmpya: 0, wrdiv: 0, rddiv: 0, rdmpy: 0, vblankToggle: 0, hcounter: 0, joy1: 0, joy2: 0,
        apuSpc: newApuSpc(), apuMem: spcMemReal(), ppu: newPpu()
    }
    // Boot the SPC into its IPL. The reset vector ($FFFE) is fixed at $FFC0;
    // set it directly to avoid a split &mut/& borrow of two `mem` fields.
    mem.apuSpc.pc = 0xFFC0
    mem.apuSpc.sp = 0xEF
    mem.apuSpc.psw = 0x02
    return mem
}

// Co-run the SPC700 for n instructions (called from the system step loop).
fn runApu(m: &mut Mem, n: i64): void {
    if m.testMode {
        return
    }
    var i: i64 = 0
    while i < n {
        spcStep(m.apuSpc, m.apuMem)
        i = i + 1
    }
}

// Peek loaded video memory (tests / future renderer).
fn busReadCgram(m: &Mem, a: i64): i64 {
    return ppuCgram(m.ppu, a)
}

fn busReadVram(m: &Mem, a: i64): i64 {
    return ppuVram(m.ppu, a)
}

fn scratch(m: &Mem, addr: i64): i64 {
    return m.mmio[addr - 0x2000] as i64
}

fn setScratch(m: &mut Mem, addr: i64, v: i64): void {
    m.mmio[addr - 0x2000] = (v & 0xFF) as u8
}

// B-bus register offset within a DMA transfer (fullsnes transfer patterns).
fn dmaPatternOffset(pattern: i64, count: i64): i64 {
    if pattern == 0 {
        return 0
    }
    if pattern == 1 {
        return count & 1
    }
    if pattern == 2 {
        return 0
    }
    if pattern == 3 {
        return (count & 3) >> 1
    }
    if pattern == 4 {
        return count & 3
    }
    return count & 1
}

// General-purpose DMA: for each enabled channel, transfer DAS bytes between the
// A-bus (CPU memory bank:addr) and a B-bus PPU register ($2100|BBAD).
fn runDMA(m: &mut Mem, channels: i64): void {
    var ch: i64 = 0
    while ch < 8 {
        if ((channels >> ch) & 1) != 0 {
            let base = 0x4300 + ch * 0x10
            let dmap = scratch(m, base + 0)
            let bbad = scratch(m, base + 1)
            var aaddr = scratch(m, base + 2) | (scratch(m, base + 3) << 8)
            let abank = scratch(m, base + 4)
            var size = scratch(m, base + 5) | (scratch(m, base + 6) << 8)
            if size == 0 {
                size = 0x10000
            }
            let dir = (dmap >> 7) & 1 // 0 = A->B, 1 = B->A
            let pattern = dmap & 7
            let amode = (dmap >> 3) & 3
            let astep: i64 = if amode == 0 {
                1
            } else if amode == 2 {
                -1
            } else {
                0
            }
            var count: i64 = 0
            while count < size {
                let bAddr = 0x2100 | ((bbad + dmaPatternOffset(pattern, count)) & 0xFF)
                let aFull = (abank << 16) | (aaddr & 0xFFFF)
                if dir == 0 {
                    let v = memRead(m, aFull)
                    memWrite(m, bAddr, v)
                } else {
                    let v = memRead(m, bAddr)
                    memWrite(m, aFull, v)
                }
                aaddr = (aaddr + astep) & 0xFFFF
                count = count + 1
            }
            setScratch(m, base + 2, aaddr & 0xFF)
            setScratch(m, base + 3, (aaddr >> 8) & 0xFF)
            setScratch(m, base + 5, 0)
            setScratch(m, base + 6, 0)
        }
        ch = ch + 1
    }
}

// --- HDMA (per-scanline DMA to PPU registers) ---
// Games drive gradient skies (COLDATA $2132), brightness fades (INIDISP $2100),
// parallax and Mode7 perspective by streaming one write-unit per scanline from a
// table in CPU memory. We can't render mid-scanline, so hdmaWalkFrame walks each
// armed channel's table for all 224 visible lines once per frame (tables are
// stable by end-of-active-display) and records the values the renderer can use
// per-line (currently INIDISP brightness + COLDATA). Other targets advance the
// table pointers correctly but aren't yet consumed by the renderer.

// Bytes transferred per scanline for each DMA/HDMA transfer pattern.
fn hdmaUnitBytes(pattern: i64): i64 {
    if pattern == 0 {
        return 1
    }
    if pattern == 1 || pattern == 2 || pattern == 6 {
        return 2
    }
    return 4 // 3,4,5,7
}

// B-bus register offset (added to BBAD) for the j-th byte of a write-unit.
fn hdmaByteReg(pattern: i64, j: i64): i64 {
    if pattern == 1 {
        return j // r, r+1
    }
    if pattern == 4 {
        return j // r, r+1, r+2, r+3
    }
    if pattern == 5 {
        return j & 1 // r, r+1, r, r+1
    }
    if pattern == 3 || pattern == 7 {
        if j < 2 {
            return 0
        }
        return 1 // r, r, r+1, r+1
    }
    return 0 // patterns 0,2,6: single register
}

// Record one HDMA write into the per-line override arrays for the registers the
// renderer consumes. Uses hold semantics (arrays carry forward line-to-line), so
// only the plane a COLDATA write selects changes; others keep their prior value.
fn hdmaApplyReg(m: &mut Mem, line: i64, reg: i64, v: i64): void {
    if reg == 0x2100 { // INIDISP: brightness (force-blank line renders as bright 0)
        var b = v & 0x0F
        if (v & 0x80) != 0 {
            b = 0
        }
        m.ppu.lineBright[line] = b
        return
    }
    if reg == 0x2132 { // COLDATA: bit5=R bit6=G bit7=B select, bits0-4 intensity
        let inten = v & 0x1F
        if (v & 0x20) != 0 {
            m.ppu.lineColdR[line] = inten
        }
        if (v & 0x40) != 0 {
            m.ppu.lineColdG[line] = inten
        }
        if (v & 0x80) != 0 {
            m.ppu.lineColdB[line] = inten
        }
        return
    }
    if reg == 0x2126 { // WH0: window 1 left edge, per scanline
        m.ppu.lineWH0[line] = v & 0xFF
        return
    }
    if reg == 0x2127 { // WH1: window 1 right edge, per scanline
        m.ppu.lineWH1[line] = v & 0xFF
        return
    }
    // Scroll / Mode7 / other window HDMA targets: pointers already advanced;
    // renderer support pending.
}

fn hdmaWalkFrame(m: &mut Mem): void {
    let brightScalar = m.ppu.inidisp & 0x0F
    // Line 0 baseline = scalar registers; later lines carry forward (hold).
    m.ppu.lineBright[0] = brightScalar
    m.ppu.lineColdR[0] = m.ppu.coldR
    m.ppu.lineColdG[0] = m.ppu.coldG
    m.ppu.lineColdB[0] = m.ppu.coldB
    m.ppu.lineWH0[0] = m.ppu.wh0
    m.ppu.lineWH1[0] = m.ppu.wh1

    let en = scratch(m, 0x420C)
    if en == 0 {
        m.ppu.hdmaOn = false
        return
    }
    m.ppu.hdmaOn = true

    // Per-channel running state for the frame walk.
    var a2a: Vec<i64> = Vec.new() // running table address (16-bit)
    var a2b: Vec<i64> = Vec.new() // table bank (A1B)
    var lctr: Vec<i64> = Vec.new() // line counter (NTLR)
    var done: Vec<i64> = Vec.new()
    var indAddr: Vec<i64> = Vec.new() // indirect data pointer (16-bit)
    var ch: i64 = 0
    while ch < 8 {
        let base = 0x4300 + ch * 0x10
        a2a.push(scratch(m, base + 2) | (scratch(m, base + 3) << 8))
        a2b.push(scratch(m, base + 4))
        lctr.push(0) // 0 forces an entry reload on line 0
        done.push(0)
        indAddr.push(0)
        ch = ch + 1
    }

    var line: i64 = 0
    while line < 224 {
        if line > 0 { // carry forward held register state
            m.ppu.lineBright[line] = m.ppu.lineBright[line - 1]
            m.ppu.lineColdR[line] = m.ppu.lineColdR[line - 1]
            m.ppu.lineColdG[line] = m.ppu.lineColdG[line - 1]
            m.ppu.lineColdB[line] = m.ppu.lineColdB[line - 1]
            m.ppu.lineWH0[line] = m.ppu.lineWH0[line - 1]
            m.ppu.lineWH1[line] = m.ppu.lineWH1[line - 1]
        }
        ch = 0
        while ch < 8 {
            if ((en >> ch) & 1) != 0 && done[ch] == 0 {
                let base = 0x4300 + ch * 0x10
                let dmap = scratch(m, base + 0)
                let bbad = scratch(m, base + 1)
                let indirect = (dmap & 0x40) != 0
                let pattern = dmap & 7
                var doXfer = false
                var terminated = false
                if (lctr[ch] & 0x7F) == 0 { // load a new table entry (NTLR)
                    let bank = a2b[ch]
                    var ptr = a2a[ch]
                    let ntlr = memRead(m, (bank << 16) | ptr)
                    ptr = (ptr + 1) & 0xFFFF
                    if ntlr == 0 {
                        done[ch] = 1
                        terminated = true
                        a2a[ch] = ptr
                    } else {
                        lctr[ch] = ntlr
                        doXfer = true
                        if indirect {
                            let lo = memRead(m, (bank << 16) | ptr)
                            ptr = (ptr + 1) & 0xFFFF
                            let hi = memRead(m, (bank << 16) | ptr)
                            ptr = (ptr + 1) & 0xFFFF
                            indAddr[ch] = lo | (hi << 8)
                        }
                        a2a[ch] = ptr
                    }
                } else {
                    doXfer = (lctr[ch] & 0x80) != 0 // repeat bit: transfer every line
                }
                if !terminated {
                    if doXfer {
                        let nbytes = hdmaUnitBytes(pattern)
                        var j: i64 = 0
                        while j < nbytes {
                            let reg = 0x2100 | ((bbad + hdmaByteReg(pattern, j)) & 0xFF)
                            var v: i64 = 0
                            if indirect {
                                let dbank = scratch(m, base + 7)
                                v = memRead(m, (dbank << 16) | (indAddr[ch] & 0xFFFF))
                                indAddr[ch] = (indAddr[ch] + 1) & 0xFFFF
                            } else {
                                v = memRead(m, (a2b[ch] << 16) | a2a[ch])
                                a2a[ch] = (a2a[ch] + 1) & 0xFFFF
                            }
                            hdmaApplyReg(m, line, reg, v)
                            j = j + 1
                        }
                    }
                    lctr[ch] = (lctr[ch] - 1) & 0xFF
                }
            }
            ch = ch + 1
        }
        line = line + 1
    }
}

// CPU-side MMIO read ($2000-$5FFF). Pure (no read side effects yet): mul/div
// results, NMI/vblank status, auto-read joypad. Falls back to the scratch store.
// vblankToggle is driven by the system frame loop, not by reads (accurate
// RDNMI clear-on-read arrives with PPU timing in M4).
fn mmioRead(m: &Mem, off: i64): i64 {
    if off >= 0x2100 && off <= 0x213F {
        return ppuRegReadPure(m.ppu, off - 0x2100) // PPU registers
    }
    if off >= 0x2140 && off <= 0x2143 {
        return apuReadPort(m.apuMem, off - 0x2140) // APU ports $2140-$2143
    }
    if off == 0x2180 {
        return m.wram[m.wmadd & 0x1FFFF] as i64
    } // WMDATA read (auto-inc omitted on the &Mem read path)
    if off == 0x4210 {
        return m.vblankToggle | 0x02
    } // RDNMI: bit7 NMI, low = version 2
    if off == 0x4211 {
        return m.timeup
    } // TIMEUP (IRQ flag); cleared per-frame in stepFrame (read-clear needs &mut)
    if off == 0x4212 {
        // bit7 vblank (stub), bit0 auto-joypad-read (idle). bit6 HBLANK: we don't
        // model scanline dot timing, so pulse it off the free-running instruction
        // counter — SMW's level-init hard-waits on HBLANK (BIT $4212 / BVC) before
        // fading the screen in, and a never-set bit6 hangs it black forever.
        var hb: i64 = 0
        if (m.hcounter & 7) < 2 {
            hb = 0x40
        }
        return m.vblankToggle | hb
    } // HVBJOY: bit7 vblank, bit6 hblank
    if off == 0x4214 {
        return m.rddiv & 0xFF
    }
    if off == 0x4215 {
        return (m.rddiv >> 8) & 0xFF
    }
    if off == 0x4216 {
        return m.rdmpy & 0xFF
    }
    if off == 0x4217 {
        return (m.rdmpy >> 8) & 0xFF
    }
    if off == 0x4016 {
        // Serial pad-1 read: shift out one bit per read, MSB-first (B,Y,Select,
        // Start,...,R), then 1s once exhausted (open controller line reads high).
        var bit1: i64 = 1
        if joyCnt1 < 16 {
            bit1 = (joyLatch1 >> (15 - joyCnt1)) & 1
            joyCnt1 = joyCnt1 + 1
        }
        return bit1
    }
    if off == 0x4017 {
        var bit2: i64 = 1
        if joyCnt2 < 16 {
            bit2 = (joyLatch2 >> (15 - joyCnt2)) & 1
            joyCnt2 = joyCnt2 + 1
        }
        return bit2
    }
    if off == 0x4218 {
        return m.joy1 & 0xFF
    }
    if off == 0x4219 {
        return (m.joy1 >> 8) & 0xFF
    }
    if off == 0x421A {
        return m.joy2 & 0xFF
    }
    if off == 0x421B {
        return (m.joy2 >> 8) & 0xFF
    }
    return m.mmio[off - 0x2000] as i64
}

// CPU-side MMIO write ($2000-$5FFF). Writing $4203/$4206 latches mul/div results.
fn mmioWrite(m: &mut Mem, off: i64, val: i64): void {
    if off >= 0x2100 && off <= 0x213F {
        ppuRegWrite(m.ppu, off - 0x2100, val)
        return // PPU registers
    }
    if off >= 0x2140 && off <= 0x2143 {
        apuWritePort(m.apuMem, off - 0x2140, val)
        return // APU ports $2140-$2143
    }
    if off == 0x420B {
        m.mmio[off - 0x2000] = (val & 0xFF) as u8
        runDMA(m, val)
        return // MDMAEN: start general-purpose DMA on set channels
    }
    if off == 0x2180 { // WMDATA: write WRAM at the auto-incrementing address
        m.wram[m.wmadd & 0x1FFFF] = (val & 0xFF) as u8
        m.wmadd = (m.wmadd + 1) & 0x1FFFF
        return
    }
    if off == 0x2181 {
        m.wmadd = (m.wmadd & 0x1FF00) | val
        return
    }
    if off == 0x2182 {
        m.wmadd = (m.wmadd & 0x100FF) | (val << 8)
        return
    }
    if off == 0x2183 {
        m.wmadd = (m.wmadd & 0x0FFFF) | ((val & 1) << 16)
        return
    }
    if off == 0x4016 {
        // JOYSER0 strobe: latch the current pad state and reset the serial cursor.
        // Games pulse bit0 high then low before shifting; latching on any write
        // captures the state so the following $4016 reads shift it out in order.
        joyLatch1 = m.joy1
        joyCnt1 = 0
        joyLatch2 = m.joy2
        joyCnt2 = 0
        return
    }
    if off == 0x4200 {
        m.nmitimen = val
        return
    }
    if off == 0x4202 {
        m.wrmpya = val
        return
    }
    if off == 0x4203 {
        m.rdmpy = (m.wrmpya * val) & 0xFFFF
        return
    } // 8x8 -> 16 product
    if off == 0x4204 {
        m.wrdiv = (m.wrdiv & 0xFF00) | val
        return
    }
    if off == 0x4205 {
        m.wrdiv = (m.wrdiv & 0x00FF) | (val << 8)
        return
    }
    if off == 0x4206 { // 16/8 divide -> quotient + remainder
        if val == 0 {
            m.rddiv = 0xFFFF
            m.rdmpy = m.wrdiv
        } else {
            m.rddiv = (m.wrdiv / val) & 0xFFFF
            m.rdmpy = (m.wrdiv % val) & 0xFFFF
        }
        return
    }
    if off == 0x4207 {
        m.htime = (m.htime & 0x100) | val
        return
    }
    if off == 0x4208 {
        m.htime = ((val & 1) << 8) | (m.htime & 0xFF)
        return
    }
    if off == 0x4209 {
        m.vtime = (m.vtime & 0x100) | val
        return
    }
    if off == 0x420A {
        m.vtime = ((val & 1) << 8) | (m.vtime & 0xFF)
        return
    }
    m.mmio[off - 0x2000] = (val & 0xFF) as u8
}

// Clear all entries between test cases (reused across a whole file).
fn memReset(m: &mut Mem): void {
    m.addr = Vec.new()
    m.val = Vec.new()
}

// LoROM: each bank maps $8000-$FFFF to a 32 KiB ROM page.
// HiROM: each bank maps its full 64 KiB linearly from bank*0x10000.
fn romOffset(m: &Mem, bank: i64, off: i64): i64 {
    if m.mapMode == 1 {
        return (((bank & 0x3F) << 16) | off) & m.romMask
    }
    return (((bank & 0x7F) << 15) | (off & 0x7FFF)) & m.romMask
}

fn romByte(m: &Mem, bank: i64, off: i64): i64 {
    let o = romOffset(m, bank, off)
    if o < m.rom.len {
        return m.rom[o] as i64
    }
    return 0
}

// Linear SRAM index for a bank:offset, or -1 if the address isn't SRAM. LoROM
// maps SRAM into banks $70-$7D (mirror $F0-$FD), offset $0000-$7FFF; HiROM into
// banks $20-$3F (mirror $A0-$BF), offset $6000-$7FFF.
fn sramIndex(m: &Mem, bank: i64, off: i64): i64 {
    let b = bank & 0x7F
    if m.mapMode == 0 {
        if b >= 0x70 && b <= 0x7D && off < 0x8000 {
            return (((b - 0x70) << 15) | off) & m.sramMask
        }
        return -1
    }
    if b >= 0x20 && b <= 0x3F && off >= 0x6000 && off < 0x8000 {
        return (((b - 0x20) << 13) | (off - 0x6000)) & m.sramMask
    }
    return -1
}

// Serialize SRAM to a byte string for a .srm file.
fn sramToString(m: &Mem): string {
    var s = String.withCapacity(m.sram.len + 16)
    for b in m.sram {
        s.push(b)
    }
    return s
}

// Load a .srm byte string back into SRAM (truncated/padded to SRAM size).
fn sramFromString(m: &mut Mem, data: &string): void {
    var i: i64 = 0
    while i < m.sram.len && i < data.len {
        m.sram[i] = data[i]
        i = i + 1
    }
}

fn memRead(m: &Mem, a: i64): i64 {
    if m.testMode {
        var i: i64 = 0
        while i < m.addr.len {
            if m.addr[i] == a {
                return m.val[i]
            }
            i = i + 1
        }
        return 0 // open bus modeled as 0; unlisted reads shouldn't occur in tests
    }
    let bank = (a >> 16) & 0xFF
    let off = a & 0xFFFF
    if bank == 0x7E {
        return m.wram[off] as i64
    }
    if bank == 0x7F {
        return m.wram[0x10000 + off] as i64
    }
    let si = sramIndex(m, bank, off)
    if si >= 0 {
        return m.sram[si] as i64
    }
    let b = bank & 0x7F
    if b <= 0x3F {
        if off < 0x2000 {
            return m.wram[off] as i64 // low WRAM mirror
        }
        if off < 0x6000 {
            return mmioRead(m, off)
        }
        if off < 0x8000 {
            return 0 // unused
        }
        return romByte(m, bank, off)
    }
    return romByte(m, bank, off) // banks 40-7D / C0-FF: ROM
}

fn memWrite(m: &mut Mem, a: i64, v: i64): void {
    if m.testMode {
        var i: i64 = 0
        while i < m.addr.len {
            if m.addr[i] == a {
                m.val[i] = v & 0xFF
                return
            }
            i = i + 1
        }
        m.addr.push(a)
        m.val.push(v & 0xFF)
        return
    }
    let bank = (a >> 16) & 0xFF
    let off = a & 0xFFFF
    let bv = (v & 0xFF) as u8
    if bank == 0x7E {
        m.wram[off] = bv
        return
    }
    if bank == 0x7F {
        m.wram[0x10000 + off] = bv
        return
    }
    let si = sramIndex(m, bank, off)
    if si >= 0 {
        m.sram[si] = bv
        return
    }
    let b = bank & 0x7F
    if b <= 0x3F {
        if off < 0x2000 {
            m.wram[off] = bv
            return
        }
        if off < 0x6000 {
            mmioWrite(m, off, v)
            return
        }
        return // unused/ROM writes ignored
    }
    // ROM banks: writes ignored
}

// Power-on / reset: enter emulation mode, stack at $01FF, PC from the reset
// vector at $00:FFFC. P = M|X|I (emulation forces the 8-bit widths).
fn newCpuReset(m: &Mem): Cpu {
    let lo = memRead(m, 0xFFFC)
    let hi = memRead(m, 0xFFFD)
    return Cpu {
        a: 0, x: 0, y: 0, s: 0x01FF, d: 0, pc: lo | (hi << 8),
        p: 0x34, dbr: 0, pbr: 0, e: 1
    }
}

// Non-maskable interrupt (vblank). Pushes the return frame and vectors through
// $FFEA (native) / $FFFA (emulation). Cleared D + set I like a hardware IRQ.
fn nmi(cpu: &mut Cpu, m: &mut Mem): void {
    if cpu.e == 0 {
        push8(cpu, m, cpu.pbr)
        push16(cpu, m, cpu.pc)
        push8(cpu, m, cpu.p)
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        cpu.pc = memRead(m, 0xFFEA) | (memRead(m, 0xFFEB) << 8)
    } else {
        push16(cpu, m, cpu.pc)
        push8(cpu, m, cpu.p & (~0x10)) // hardware interrupt pushes break (bit4) clear
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        cpu.pc = memRead(m, 0xFFFA) | (memRead(m, 0xFFFB) << 8)
    }
}

// Maskable interrupt (H/V IRQ). Vectors through $FFEE (native) / $FFFE
// (emulation). Only taken when the I flag is clear.
fn irq(cpu: &mut Cpu, m: &mut Mem): void {
    if cpu.e == 0 {
        push8(cpu, m, cpu.pbr)
        push16(cpu, m, cpu.pc)
        push8(cpu, m, cpu.p)
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        cpu.pc = memRead(m, 0xFFEE) | (memRead(m, 0xFFEF) << 8)
    } else {
        push16(cpu, m, cpu.pc)
        push8(cpu, m, cpu.p & (~0x10))
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        cpu.pc = memRead(m, 0xFFFE) | (memRead(m, 0xFFFF) << 8)
    }
}

// Fire an H/V IRQ if $4200 enables it (bits 4/5) and the I flag is clear. Our
// frame has no real scanline counter, so a per-frame V-timed IRQ is raised once
// at the VTIME-proportional point during active display (below). Sets TIMEUP.
fn maybeIrq(cpu: &mut Cpu, m: &mut Mem): void {
    if (m.nmitimen & 0x30) == 0 {
        return
    }
    m.timeup = 0x80
    if (cpu.p & FI) == 0 {
        irq(cpu, m)
    }
}

// Run one video frame: the CPU during active display, then vblank (set the
// vblank flag, fire NMI if enabled, run the vblank handler), then clear it.
// Instruction budgets stand in for cycle-accurate scanline timing for now.
fn stepFrame(cpu: &mut Cpu, m: &mut Mem): void {
    // CPU and SPC must be finely interleaved: the boot handshake (and later
    // in-game audio commands) round-trips through $2140-$2143 many times, and a
    // handshake-locked transfer only advances one byte per CPU<->SPC switch. Run
    // the SPC every few CPU steps so uploads complete in a frame, not thousands.
    // activeSteps must exceed the *worst-case* main-thread work per frame, not the
    // average: the vblank NMI handler saves A/X/Y but NOT DBR (see nmi()/$80A97A in
    // DKC), so it only works if NMI fires while the main loop sits in its vblank-wait
    // (DBR=$80). On a heavy load frame DKC's object update spans ~15k instrs in bank
    // $BB (DBR=$BB); at the old 7600 budget NMI caught it mid-routine, the dispatcher
    // read its handler-pointer table through the wrong bank, and JMP'd into unmapped
    // RAM -> black-screen crash. 20k gives the heaviest frame room to reach the wait
    // loop first; light frames just idle-spin the surplus (harmless). APU stepping is
    // per-instruction so the CPU:SPC ratio is preserved regardless of this budget.
    let activeSteps: i64 = 20000
    let vblankSteps: i64 = 1400
    m.timeup = 0 // TIMEUP is read-cleared on hardware; approximate by per-frame reset
    // Scanline where a V-timed IRQ should fire, mapped into the active-instruction
    // window (VTIME 0-224 visible; clamp so it lands during active display).
    var irqAt: i64 = -1
    if (m.nmitimen & 0x30) != 0 {
        var vt = m.vtime
        if vt > 224 {
            vt = 224
        }
        irqAt = (vt * activeSteps) / 224
    }
    var fired = false
    cpuWaiting = false
    var i: i64 = 0
    while i < activeSteps {
        if !fired && irqAt >= 0 && i >= irqAt {
            maybeIrq(cpu, m)
            fired = true
        }
        step(cpu, m)
        if (i & 3) == 0 {
            runApu(m, 2)
        }
        // The game reached its vblank-wait (WAI). Stop early and fire NMI from here
        // (DBR=$80) instead of running the budget out mid-routine. Keeps NMI off the
        // heavy load/decompress paths that run with a different data bank.
        if cpuWaiting {
            cpuWaiting = false
            i = activeSteps
        } else {
            i = i + 1
        }
    }
    // Tables set up during (this frame's) active display are now stable; walk the
    // armed HDMA channels to produce the per-scanline PPU-register overrides the
    // renderer consumes (gradient skies, brightness fades).
    hdmaWalkFrame(m)
    m.vblankToggle = 0x80
    if (m.nmitimen & 0x80) != 0 {
        nmi(cpu, m)
    }
    i = 0
    while i < vblankSteps {
        step(cpu, m)
        if (i & 3) == 0 {
            runApu(m, 2)
        }
        i = i + 1
    }
    m.vblankToggle = 0
}

// --- register-width predicates (emulation forces both to 8-bit) ---
fn m8(cpu: &Cpu): bool {
    return cpu.e == 1 || (cpu.p & FM) != 0
}

fn x8(cpu: &Cpu): bool {
    return cpu.e == 1 || (cpu.p & FX) != 0
}

fn setBit(cpu: &mut Cpu, mask: i64, on: bool): void {
    if on {
        cpu.p = cpu.p | mask
    } else {
        cpu.p = cpu.p & (~mask)
    }
}

fn setNZ8(cpu: &mut Cpu, v: i64): void {
    setBit(cpu, FZ, (v & 0xFF) == 0)
    setBit(cpu, FN, (v & 0x80) != 0)
}

fn setNZ16(cpu: &mut Cpu, v: i64): void {
    setBit(cpu, FZ, (v & 0xFFFF) == 0)
    setBit(cpu, FN, (v & 0x8000) != 0)
}

// N/Z for a value in the accumulator's current width.
fn setNZa(cpu: &mut Cpu, v: i64): void {
    if m8(cpu) {
        setNZ8(cpu, v)
    } else {
        setNZ16(cpu, v)
    }
}

// N/Z for a value in the index registers' current width.
fn setNZx(cpu: &mut Cpu, v: i64): void {
    if x8(cpu) {
        setNZ8(cpu, v)
    } else {
        setNZ16(cpu, v)
    }
}

fn fetch8(cpu: &mut Cpu, m: &Mem): i64 {
    let a = (cpu.pbr << 16) | cpu.pc
    let v = memRead(m, a)
    cpu.pc = (cpu.pc + 1) & 0xFFFF // PC wraps within the program bank on fetch
    return v
}

// XCE aftermath and SEP/REP can force emulation constraints; apply them here.
fn applyEmulationConstraints(cpu: &mut Cpu): void {
    if cpu.e == 1 {
        cpu.p = cpu.p | FM | FX // M/X forced 8-bit
        cpu.x = cpu.x & 0xFF // index high bytes cleared
        cpu.y = cpu.y & 0xFF
        cpu.s = 0x0100 | (cpu.s & 0xFF) // stack fixed to page 1
    }
}

// --- stack (bank 0; emulation keeps S in page 1) ---
fn spDec(cpu: &mut Cpu): void {
    if cpu.e == 1 {
        cpu.s = 0x0100 | ((cpu.s - 1) & 0xFF)
    } else {
        cpu.s = (cpu.s - 1) & 0xFFFF
    }
}

fn spInc(cpu: &mut Cpu): void {
    if cpu.e == 1 {
        cpu.s = 0x0100 | ((cpu.s + 1) & 0xFF)
    } else {
        cpu.s = (cpu.s + 1) & 0xFFFF
    }
}

fn push8(cpu: &mut Cpu, m: &mut Mem, v: i64): void {
    memWrite(m, cpu.s, v & 0xFF)
    spDec(cpu)
}

fn pull8(cpu: &mut Cpu, m: &mut Mem): i64 {
    spInc(cpu)
    return memRead(m, cpu.s)
}

// 16-bit push writes high byte first, so the low byte lands at the lower address.
fn push16(cpu: &mut Cpu, m: &mut Mem, v: i64): void {
    push8(cpu, m, (v >> 8) & 0xFF)
    push8(cpu, m, v & 0xFF)
}

fn pull16(cpu: &mut Cpu, m: &mut Mem): i64 {
    let lo = pull8(cpu, m)
    let hi = pull8(cpu, m)
    return lo | (hi << 8)
}

fn fetch16(cpu: &mut Cpu, m: &Mem): i64 {
    let lo = fetch8(cpu, m)
    let hi = fetch8(cpu, m)
    return lo | (hi << 8)
}

// "New" 65816 stack ops (PEA/PEI/PER/PHD/PLD, and the bank pushes/pulls) use a
// full 16-bit stack pointer even in emulation — the byte accesses can leave page
// 1 — and only clamp SH back to 01 once the instruction finishes.
fn push8f(cpu: &mut Cpu, m: &mut Mem, v: i64): void {
    memWrite(m, cpu.s, v & 0xFF)
    cpu.s = (cpu.s - 1) & 0xFFFF
}

fn pull8f(cpu: &mut Cpu, m: &mut Mem): i64 {
    cpu.s = (cpu.s + 1) & 0xFFFF
    return memRead(m, cpu.s)
}

fn push16f(cpu: &mut Cpu, m: &mut Mem, v: i64): void {
    push8f(cpu, m, (v >> 8) & 0xFF)
    push8f(cpu, m, v & 0xFF)
}

fn pull16f(cpu: &mut Cpu, m: &mut Mem): i64 {
    let lo = pull8f(cpu, m)
    let hi = pull8f(cpu, m)
    return lo | (hi << 8)
}

fn clampEmuStack(cpu: &mut Cpu): void {
    if cpu.e == 1 {
        cpu.s = 0x0100 | (cpu.s & 0xFF)
    }
}

fn fetch24(cpu: &mut Cpu, m: &Mem): i64 {
    let lo = fetch8(cpu, m)
    let mid = fetch8(cpu, m)
    let hi = fetch8(cpu, m)
    return lo | (mid << 8) | (hi << 16)
}

// --- effective-address resolvers (advance PC past the operand) ---
// Direct-page modes live in bank 0 and wrap within it; DBR-relative and long
// modes are linear 24-bit.
fn aDp(cpu: &mut Cpu, m: &Mem): i64 {
    return (cpu.d + fetch8(cpu, m)) & 0xFFFF
}

// Direct-page indexed base. Emulation quirk: when DL (D low byte) is 0 the index
// wraps within the zero page instead of across bank 0.
fn dpIndexed(cpu: &Cpu, dp: i64, idx: i64): i64 {
    if cpu.e == 1 && (cpu.d & 0xFF) == 0 {
        return (cpu.d & 0xFF00) | ((dp + idx) & 0xFF)
    }
    return (cpu.d + dp + idx) & 0xFFFF
}

fn aDpX(cpu: &mut Cpu, m: &Mem): i64 {
    return dpIndexed(cpu, fetch8(cpu, m), cpu.x)
}

fn aDpY(cpu: &mut Cpu, m: &Mem): i64 {
    return dpIndexed(cpu, fetch8(cpu, m), cpu.y)
}

fn aAbs(cpu: &mut Cpu, m: &Mem): i64 {
    return (cpu.dbr << 16) | fetch16(cpu, m)
}

fn aAbsX(cpu: &mut Cpu, m: &Mem): i64 {
    return (((cpu.dbr << 16) | fetch16(cpu, m)) + cpu.x) & 0xFFFFFF
}

fn aAbsY(cpu: &mut Cpu, m: &Mem): i64 {
    return (((cpu.dbr << 16) | fetch16(cpu, m)) + cpu.y) & 0xFFFFFF
}

fn aLong(cpu: &mut Cpu, m: &Mem): i64 {
    return fetch24(cpu, m)
}

fn aLongX(cpu: &mut Cpu, m: &Mem): i64 {
    return (fetch24(cpu, m) + cpu.x) & 0xFFFFFF
}

// Read a 16-/24-bit pointer from bank 0 (direct-page/stack pointer storage),
// wrapping the increments within bank 0.
fn readPtr16(m: &Mem, addr: i64): i64 {
    let lo = memRead(m, addr & 0xFFFF)
    let hi = memRead(m, (addr + 1) & 0xFFFF)
    return lo | (hi << 8)
}

fn readPtr24(m: &Mem, addr: i64): i64 {
    let lo = memRead(m, addr & 0xFFFF)
    let mid = memRead(m, (addr + 1) & 0xFFFF)
    let hi = memRead(m, (addr + 2) & 0xFFFF)
    return lo | (mid << 8) | (hi << 16)
}

fn aDpIndX(cpu: &mut Cpu, m: &Mem): i64 { // (dp,X)
    let ptr = readPtr16(m, dpIndexed(cpu, fetch8(cpu, m), cpu.x))
    return (cpu.dbr << 16) | ptr
}

fn aDpIndY(cpu: &mut Cpu, m: &Mem): i64 { // (dp),Y
    let ptr = readPtr16(m, (cpu.d + fetch8(cpu, m)) & 0xFFFF)
    return (((cpu.dbr << 16) | ptr) + cpu.y) & 0xFFFFFF
}

fn aDpInd(cpu: &mut Cpu, m: &Mem): i64 { // (dp)
    let ptr = readPtr16(m, (cpu.d + fetch8(cpu, m)) & 0xFFFF)
    return ((cpu.dbr << 16) | ptr) & 0xFFFFFF
}

fn aDpLong(cpu: &mut Cpu, m: &Mem): i64 { // [dp]
    return readPtr24(m, (cpu.d + fetch8(cpu, m)) & 0xFFFF)
}

fn aDpLongY(cpu: &mut Cpu, m: &Mem): i64 { // [dp],Y
    return (readPtr24(m, (cpu.d + fetch8(cpu, m)) & 0xFFFF) + cpu.y) & 0xFFFFFF
}

fn aSr(cpu: &mut Cpu, m: &Mem): i64 { // sr,S — bank 0
    return (cpu.s + fetch8(cpu, m)) & 0xFFFF
}

fn aSrY(cpu: &mut Cpu, m: &Mem): i64 { // (sr,S),Y
    let ptr = readPtr16(m, (cpu.s + fetch8(cpu, m)) & 0xFFFF)
    return (((cpu.dbr << 16) | ptr) + cpu.y) & 0xFFFFFF
}

// Read a 16-bit operand. bank0wrap: dp/stack modes keep the +1 inside bank 0;
// linear modes (abs/long) advance the full 24-bit address.
fn read16w(m: &Mem, addr: i64, bank0wrap: bool): i64 {
    let lo = memRead(m, addr)
    let hiAddr = if bank0wrap {
        (addr & 0xFF0000) | ((addr + 1) & 0xFFFF)
    } else {
        (addr + 1) & 0xFFFFFF
    }
    let hi = memRead(m, hiAddr)
    return lo | (hi << 8)
}

fn write16w(m: &mut Mem, addr: i64, v: i64, bank0wrap: bool): void {
    memWrite(m, addr, v & 0xFF)
    let hiAddr = if bank0wrap {
        (addr & 0xFF0000) | ((addr + 1) & 0xFFFF)
    } else {
        (addr + 1) & 0xFFFFFF
    }
    memWrite(m, hiAddr, (v >> 8) & 0xFF)
}

// Store accumulator to a resolved address at the current width.
fn staTo(cpu: &Cpu, m: &mut Mem, addr: i64, bank0wrap: bool): void {
    if m8(cpu) {
        memWrite(m, addr, cpu.a & 0xFF)
    } else {
        write16w(m, addr, cpu.a, bank0wrap)
    }
}

// Load accumulator from a resolved address at the current width.
fn ldaFrom(cpu: &mut Cpu, m: &Mem, addr: i64, bank0wrap: bool): void {
    if m8(cpu) {
        let v = memRead(m, addr)
        cpu.a = (cpu.a & 0xFF00) | v
        setNZ8(cpu, v)
    } else {
        let v = read16w(m, addr, bank0wrap)
        cpu.a = v
        setNZ16(cpu, v)
    }
}

// --- generic operand readers + result writers at register width ---
fn readMval(cpu: &Cpu, m: &Mem, addr: i64, bank0wrap: bool): i64 {
    if m8(cpu) {
        return memRead(m, addr)
    }
    return read16w(m, addr, bank0wrap)
}

fn readXval(cpu: &Cpu, m: &Mem, addr: i64, bank0wrap: bool): i64 {
    if x8(cpu) {
        return memRead(m, addr)
    }
    return read16w(m, addr, bank0wrap)
}

fn immM(cpu: &mut Cpu, m: &Mem): i64 {
    if m8(cpu) {
        return fetch8(cpu, m)
    }
    return fetch16(cpu, m)
}

fn immX(cpu: &mut Cpu, m: &Mem): i64 {
    if x8(cpu) {
        return fetch8(cpu, m)
    }
    return fetch16(cpu, m)
}

// Write a result into A at accumulator width (high byte preserved when 8-bit).
fn setA(cpu: &mut Cpu, r: i64): void {
    if m8(cpu) {
        cpu.a = (cpu.a & 0xFF00) | (r & 0xFF)
        setNZ8(cpu, r)
    } else {
        cpu.a = r & 0xFFFF
        setNZ16(cpu, r)
    }
}

fn setXreg(cpu: &mut Cpu, r: i64): void {
    if x8(cpu) {
        cpu.x = r & 0xFF
        setNZ8(cpu, r)
    } else {
        cpu.x = r & 0xFFFF
        setNZ16(cpu, r)
    }
}

fn setYreg(cpu: &mut Cpu, r: i64): void {
    if x8(cpu) {
        cpu.y = r & 0xFF
        setNZ8(cpu, r)
    } else {
        cpu.y = r & 0xFFFF
        setNZ16(cpu, r)
    }
}

// Compare reg vs value: C if reg>=v, N/Z from the (masked) difference.
fn compareVals(cpu: &mut Cpu, reg: i64, v: i64, wide: bool): void {
    let mask: i64 = if wide {
        0xFFFF
    } else {
        0xFF
    }
    let signbit: i64 = if wide {
        0x8000
    } else {
        0x80
    }
    let a = reg & mask
    let b = v & mask
    setBit(cpu, FC, a >= b)
    let r = (a - b) & mask
    setBit(cpu, FZ, r == 0)
    setBit(cpu, FN, (r & signbit) != 0)
}

// --- op-from-resolved-address helpers (reuse for every addressing mode) ---
fn oraFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    setA(cpu, cpu.a | v)
}

fn andFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    setA(cpu, cpu.a & v)
}

fn eorFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    setA(cpu, cpu.a ^ v)
}

fn cmpFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    compareVals(cpu, cpu.a, v,!m8(cpu))
}

fn cpxFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readXval(cpu, m, addr, wrap)
    compareVals(cpu, cpu.x, v,!x8(cpu))
}

fn cpyFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readXval(cpu, m, addr, wrap)
    compareVals(cpu, cpu.y, v,!x8(cpu))
}

fn ldxFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readXval(cpu, m, addr, wrap)
    setXreg(cpu, v)
}

fn ldyFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readXval(cpu, m, addr, wrap)
    setYreg(cpu, v)
}

fn stxTo(cpu: &Cpu, m: &mut Mem, addr: i64, wrap: bool): void {
    if x8(cpu) {
        memWrite(m, addr, cpu.x & 0xFF)
    } else {
        write16w(m, addr, cpu.x, wrap)
    }
}

fn styTo(cpu: &Cpu, m: &mut Mem, addr: i64, wrap: bool): void {
    if x8(cpu) {
        memWrite(m, addr, cpu.y & 0xFF)
    } else {
        write16w(m, addr, cpu.y, wrap)
    }
}

fn stzTo(cpu: &Cpu, m: &mut Mem, addr: i64, wrap: bool): void {
    if m8(cpu) {
        memWrite(m, addr, 0)
    } else {
        write16w(m, addr, 0, wrap)
    }
}

// --- ADC/SBC (binary + decimal BCD, 8/16-bit) ---
// Decimal paths use Bruce Clark's nibble-adjust algorithm; on the 65C816 (unlike
// NMOS) N/V/Z are valid in decimal too. For SBC the flags come from the binary
// subtraction while only the stored result is BCD-adjusted.
fn doADC(cpu: &mut Cpu, v: i64): void {
    let wide = !m8(cpu)
    let mask: i64 = if wide {
        0xFFFF
    } else {
        0xFF
    }
    let signbit: i64 = if wide {
        0x8000
    } else {
        0x80
    }
    let carrybit: i64 = if wide {
        0x10000
    } else {
        0x100
    }
    let a = cpu.a & mask
    let b = v & mask
    let c = cpu.p & FC
    if (cpu.p & FD) != 0 {
        // Per-nibble BCD add: each nibble carries at most 1 (invalid input like
        // 0xA+0xF can't produce a carry of 2), and lower nibbles are preserved.
        let nib: i64 = if wide {
            4
        } else {
            2
        }
        var carry = c
        var r: i64 = 0
        var sTop: i64 = 0 // top-nibble raw sum, before its adjust, for V
        var i: i64 = 0
        while i < nib {
            let sh = i * 4
            var d = ((a >> sh) & 0xF) + ((b >> sh) & 0xF) + carry
            if i == nib - 1 {
                sTop = d
            }
            if d >= 0x0A {
                d = (d + 0x06) & 0xF
                carry = 1
            } else {
                carry = 0
            }
            r = r | (d << sh)
            i = i + 1
        }
        let topsh = (nib - 1) * 4
        let sV = (r & ((1 << topsh) - 1)) | (sTop << topsh)
        setBit(cpu, FV, ((~(a ^ b)) & (a ^ sV) & signbit) != 0)
        setBit(cpu, FC, carry != 0)
        let rr = r & mask
        setBit(cpu, FN, (rr & signbit) != 0) // N/Z from the final BCD result (65C816)
        setBit(cpu, FZ, rr == 0)
        if wide {
            cpu.a = rr
        } else {
            cpu.a = (cpu.a & 0xFF00) | rr
        }
    } else {
        let sum = a + b + c
        let r = sum & mask
        setBit(cpu, FC, sum >= carrybit)
        setBit(cpu, FV, ((a ^ r) & (b ^ r) & signbit) != 0)
        setBit(cpu, FZ, r == 0)
        setBit(cpu, FN, (r & signbit) != 0)
        if wide {
            cpu.a = r
        } else {
            cpu.a = (cpu.a & 0xFF00) | r
        }
    }
}

fn doSBC(cpu: &mut Cpu, v: i64): void {
    let wide = !m8(cpu)
    let mask: i64 = if wide {
        0xFFFF
    } else {
        0xFF
    }
    let signbit: i64 = if wide {
        0x8000
    } else {
        0x80
    }
    let carrybit: i64 = if wide {
        0x10000
    } else {
        0x100
    }
    let a = cpu.a & mask
    let b = v & mask
    let c = cpu.p & FC
    // Binary subtraction sets all flags (valid for decimal too on 65C816).
    let comp = b ^ mask
    let sum = a + comp + c
    let rbin = sum & mask
    setBit(cpu, FC, sum >= carrybit)
    setBit(cpu, FV, ((a ^ rbin) & (comp ^ rbin) & signbit) != 0)
    setBit(cpu, FN, (rbin & signbit) != 0)
    setBit(cpu, FZ, rbin == 0)
    var r = rbin
    if (cpu.p & FD) != 0 {
        // Per-nibble BCD subtract; flags stay from the binary result above except
        // N/Z, which reflect the BCD result on the 65C816.
        let nib: i64 = if wide {
            4
        } else {
            2
        }
        var borrow = 1 - c
        var dr: i64 = 0
        var i: i64 = 0
        while i < nib {
            let sh = i * 4
            var d = ((a >> sh) & 0xF) - ((b >> sh) & 0xF) - borrow
            if d < 0 {
                d = (d - 0x06) & 0xF
                borrow = 1
            } else {
                d = d & 0xF
                borrow = 0
            }
            dr = dr | (d << sh)
            i = i + 1
        }
        r = dr & mask
        setBit(cpu, FN, (r & signbit) != 0)
        setBit(cpu, FZ, r == 0)
    }
    if wide {
        cpu.a = r
    } else {
        cpu.a = (cpu.a & 0xFF00) | r
    }
}

fn adcFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    doADC(cpu, v)
}

fn sbcFrom(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    doSBC(cpu, v)
}

// --- RMW value transforms (accumulator width; set C + N/Z) ---
fn accMask(cpu: &Cpu): i64 {
    if m8(cpu) {
        return 0xFF
    }
    return 0xFFFF
}

fn aslVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    let signbit: i64 = if m8(cpu) {
        0x80
    } else {
        0x8000
    }
    setBit(cpu, FC, (v & signbit) != 0)
    let r = (v << 1) & mask
    setNZa(cpu, r)
    return r
}

fn lsrVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    setBit(cpu, FC, (v & 1) != 0)
    let r = (v & mask) >> 1
    setNZa(cpu, r)
    return r
}

fn rolVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    let signbit: i64 = if m8(cpu) {
        0x80
    } else {
        0x8000
    }
    let oldC = cpu.p & FC
    setBit(cpu, FC, (v & signbit) != 0)
    let r = ((v << 1) | oldC) & mask
    setNZa(cpu, r)
    return r
}

fn rorVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    let topbit: i64 = if m8(cpu) {
        0x80
    } else {
        0x8000
    }
    let oldC = cpu.p & FC
    setBit(cpu, FC, (v & 1) != 0)
    var r = (v & mask) >> 1
    if oldC != 0 {
        r = r | topbit
    }
    setNZa(cpu, r)
    return r
}

fn incVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    let r = (v + 1) & mask
    setNZa(cpu, r)
    return r
}

fn decVal(cpu: &mut Cpu, v: i64): i64 {
    let mask = accMask(cpu)
    let r = (v - 1) & mask
    setNZa(cpu, r)
    return r
}

fn writeAccW(cpu: &mut Cpu, r: i64): void {
    if m8(cpu) {
        cpu.a = (cpu.a & 0xFF00) | (r & 0xFF)
    } else {
        cpu.a = r & 0xFFFF
    }
}

fn accASL(cpu: &mut Cpu): void {
    let v = cpu.a & accMask(cpu)
    let r = aslVal(cpu, v)
    writeAccW(cpu, r)
}

fn accLSR(cpu: &mut Cpu): void {
    let v = cpu.a & accMask(cpu)
    let r = lsrVal(cpu, v)
    writeAccW(cpu, r)
}

fn accROL(cpu: &mut Cpu): void {
    let v = cpu.a & accMask(cpu)
    let r = rolVal(cpu, v)
    writeAccW(cpu, r)
}

fn accROR(cpu: &mut Cpu): void {
    let v = cpu.a & accMask(cpu)
    let r = rorVal(cpu, v)
    writeAccW(cpu, r)
}

fn rmwWrite(cpu: &Cpu, m: &mut Mem, addr: i64, wrap: bool, r: i64): void {
    if m8(cpu) {
        memWrite(m, addr, r & 0xFF)
    } else {
        write16w(m, addr, r, wrap)
    }
}

// Read-modify-write on memory. kind: 0 ASL 1 LSR 2 ROL 3 ROR 4 INC 5 DEC.
fn rmwMem(cpu: &mut Cpu, m: &mut Mem, addr: i64, wrap: bool, kind: i64): void {
    let v = readMval(cpu, m, addr, wrap)
    var r: i64 = 0
    if kind == 0 {
        r = aslVal(cpu, v)
    } 
    else if kind == 1 {
        r = lsrVal(cpu, v)
    } 
    else if kind == 2 {
        r = rolVal(cpu, v)
    } 
    else if kind == 3 {
        r = rorVal(cpu, v)
    } 
    else if kind == 4 {
        r = incVal(cpu, v)
    } 
    else {
        r = decVal(cpu, v)
    }
    rmwWrite(cpu, m, addr, wrap, r)
}

// TSB/TRB: Z from (A & M); write A|M (set) or M&~A (reset).
fn tsbMem(cpu: &mut Cpu, m: &mut Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    let a = cpu.a & accMask(cpu)
    setBit(cpu, FZ, (a & v) == 0)
    rmwWrite(cpu, m, addr, wrap, v | a)
}

fn trbMem(cpu: &mut Cpu, m: &mut Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    let a = cpu.a & accMask(cpu)
    setBit(cpu, FZ, (a & v) == 0)
    rmwWrite(cpu, m, addr, wrap, v & (~a))
}

// BIT: Z from (A & M); N/V from M's top two bits. Immediate form sets only Z.
fn bitMem(cpu: &mut Cpu, m: &Mem, addr: i64, wrap: bool): void {
    let v = readMval(cpu, m, addr, wrap)
    let signbit: i64 = if m8(cpu) {
        0x80
    } else {
        0x8000
    }
    let ovbit: i64 = if m8(cpu) {
        0x40
    } else {
        0x4000
    }
    setBit(cpu, FZ, ((cpu.a & accMask(cpu)) & v) == 0)
    setBit(cpu, FN, (v & signbit) != 0)
    setBit(cpu, FV, (v & ovbit) != 0)
}

fn bitImm(cpu: &mut Cpu, v: i64): void {
    setBit(cpu, FZ, ((cpu.a & accMask(cpu)) & v) == 0)
}

// --- control flow ---
// Relative 8-bit branch: fetch signed offset, apply if cond (PC already past it).
fn branchIf(cpu: &mut Cpu, m: &Mem, cond: bool): void {
    let off = fetch8(cpu, m)
    let soff: i64 = if off >= 0x80 {
        off - 0x100
    } else {
        off
    }
    if cond {
        cpu.pc = (cpu.pc + soff) & 0xFFFF
    }
}

// BRK/COP: push return frame, vector through the native or emulation vector.
// BRK/COP have a signature byte, so the return address skips it (PC + 1).
fn softInterrupt(cpu: &mut Cpu, m: &mut Mem, nativeVec: i64, emuVec: i64): void {
    let ret = (cpu.pc + 1) & 0xFFFF
    if cpu.e == 0 {
        push8(cpu, m, cpu.pbr)
        push16(cpu, m, ret)
        push8(cpu, m, cpu.p)
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        let lo = memRead(m, nativeVec)
        let hi = memRead(m, nativeVec + 1)
        cpu.pc = lo | (hi << 8)
    } else {
        push16(cpu, m, ret)
        push8(cpu, m, cpu.p | 0x10) // emulation sets B in the pushed status
        setBit(cpu, FI, true)
        setBit(cpu, FD, false)
        cpu.pbr = 0
        let lo = memRead(m, emuVec)
        let hi = memRead(m, emuVec + 1)
        cpu.pc = lo | (hi << 8)
    }
}

// MVN/MVP block move: copy C+1 bytes from srcbank:X to destbank:Y, stepping X/Y
// by dir (+1 MVN ascending, -1 MVP descending). Operand bytes are
// [destbank][srcbank]; DBR becomes destbank; the counter is the full 16-bit C.
// Done atomically per instruction (correct for emulation; the Harte MVN/MVP
// files instead capture cycle-bounded *partial* state and are excluded — an
// instruction-stepped core can't reproduce a mid-move snapshot).
fn blockMove(cpu: &mut Cpu, m: &mut Mem, dir: i64): void {
    let destbank = fetch8(cpu, m)
    let srcbank = fetch8(cpu, m)
    cpu.dbr = destbank
    var guard: i64 = 0
    while true {
        let v = memRead(m, (srcbank << 16) | (cpu.x & 0xFFFF))
        memWrite(m, (destbank << 16) | (cpu.y & 0xFFFF), v)
        if x8(cpu) {
            cpu.x = (cpu.x + dir) & 0xFF
            cpu.y = (cpu.y + dir) & 0xFF
        } else {
            cpu.x = (cpu.x + dir) & 0xFFFF
            cpu.y = (cpu.y + dir) & 0xFFFF
        }
        let last = cpu.a == 0
        cpu.a = (cpu.a - 1) & 0xFFFF
        if last {
            break
        }
        guard = guard + 1
        if guard > 0x10000 {
            break
        } // 64K-byte safety bound
    }
}

// Execute one instruction. Register/flag/transfer/immediate + stack push/pull
// batches are wired; other memory-operand opcodes fall through to the no-op
// default and register as failures against Harte until implemented.
fn step(cpu: &mut Cpu, m: &mut Mem): void {
    m.hcounter = m.hcounter + 1 // drives the $4212 HBLANK-flag stub
    let op = fetch8(cpu, m)
    match op {
        // ---- NOP ----
        0xEA => {
        }

        // ---- flag set/clear ----
        0x18 => {
            setBit(cpu, FC, false)
        }
        0x38 => {
            setBit(cpu, FC, true)
        }
        0x58 => {
            setBit(cpu, FI, false)
        }
        0x78 => {
            setBit(cpu, FI, true)
        }
        0xB8 => {
            setBit(cpu, FV, false)
        }
        0xD8 => {
            setBit(cpu, FD, false)
        }
        0xF8 => {
            setBit(cpu, FD, true)
        }

        // ---- XCE: swap carry and emulation latches ----
        0xFB => {
            let oldC = cpu.p & FC
            let oldE = cpu.e
            cpu.e = oldC
            setBit(cpu, FC, oldE != 0)
            applyEmulationConstraints(cpu)
        }

        // ---- REP / SEP: clear / set P bits from an immediate mask ----
        0xC2 => {
            let mask = fetch8(cpu, m)
            cpu.p = cpu.p & (~mask)
            applyEmulationConstraints(cpu) // can't clear M/X while emulating
        }
        0xE2 => {
            let mask = fetch8(cpu, m)
            cpu.p = cpu.p | mask
            if (cpu.p & FX) != 0 { // narrowing X → truncate index high bytes
                cpu.x = cpu.x & 0xFF
                cpu.y = cpu.y & 0xFF
            }
        }

        // ---- register-to-register transfers ----
        0xAA => { // TAX
            let v = if x8(cpu) {
                cpu.a & 0xFF
            } else {
                cpu.a & 0xFFFF
            }
            cpu.x = v
            setNZx(cpu, v)
        }
        0xA8 => { // TAY
            let v = if x8(cpu) {
                cpu.a & 0xFF
            } else {
                cpu.a & 0xFFFF
            }
            cpu.y = v
            setNZx(cpu, v)
        }
        0x8A => { // TXA
            if m8(cpu) {
                cpu.a = (cpu.a & 0xFF00) | (cpu.x & 0xFF)
                setNZ8(cpu, cpu.x)
            } else {
                cpu.a = cpu.x & 0xFFFF
                setNZ16(cpu, cpu.x)
            }
        }
        0x98 => { // TYA
            if m8(cpu) {
                cpu.a = (cpu.a & 0xFF00) | (cpu.y & 0xFF)
                setNZ8(cpu, cpu.y)
            } else {
                cpu.a = cpu.y & 0xFFFF
                setNZ16(cpu, cpu.y)
            }
        }
        0xBA => { // TSX
            let v = if x8(cpu) {
                cpu.s & 0xFF
            } else {
                cpu.s & 0xFFFF
            }
            cpu.x = v
            setNZx(cpu, v)
        }
        0x9A => { // TXS — no flags; emulation forces SH=01
            if cpu.e == 1 {
                cpu.s = 0x0100 | (cpu.x & 0xFF)
            } else {
                cpu.s = cpu.x & 0xFFFF
            }
        }
        0x9B => { // TXY
            let v = if x8(cpu) {
                cpu.x & 0xFF
            } else {
                cpu.x & 0xFFFF
            }
            cpu.y = v
            setNZx(cpu, v)
        }
        0xBB => { // TYX
            let v = if x8(cpu) {
                cpu.y & 0xFF
            } else {
                cpu.y & 0xFFFF
            }
            cpu.x = v
            setNZx(cpu, v)
        }
        0x1B => { // TCS — 16-bit C→S always; emulation forces SH=01, no flags
            if cpu.e == 1 {
                cpu.s = 0x0100 | (cpu.a & 0xFF)
            } else {
                cpu.s = cpu.a & 0xFFFF
            }
        }
        0x3B => { // TSC — 16-bit S→C, 16-bit flags
            cpu.a = cpu.s & 0xFFFF
            setNZ16(cpu, cpu.a)
        }
        0x5B => { // TCD — 16-bit A→D, 16-bit flags
            cpu.d = cpu.a & 0xFFFF
            setNZ16(cpu, cpu.d)
        }
        0x7B => { // TDC — 16-bit D→C, 16-bit flags
            cpu.a = cpu.d & 0xFFFF
            setNZ16(cpu, cpu.a)
        }

        // ---- XBA: swap A's two bytes; N/Z from the new low byte (8-bit) ----
        0xEB => {
            let lo = cpu.a & 0xFF
            let hi = (cpu.a >> 8) & 0xFF
            cpu.a = (lo << 8) | hi
            setNZ8(cpu, hi)
        }

        // ---- INC/DEC on registers ----
        0xE8 => { // INX
            if x8(cpu) {
                cpu.x = (cpu.x + 1) & 0xFF
            } else {
                cpu.x = (cpu.x + 1) & 0xFFFF
            }
            setNZx(cpu, cpu.x)
        }
        0xC8 => { // INY
            if x8(cpu) {
                cpu.y = (cpu.y + 1) & 0xFF
            } else {
                cpu.y = (cpu.y + 1) & 0xFFFF
            }
            setNZx(cpu, cpu.y)
        }
        0xCA => { // DEX
            if x8(cpu) {
                cpu.x = (cpu.x - 1) & 0xFF
            } else {
                cpu.x = (cpu.x - 1) & 0xFFFF
            }
            setNZx(cpu, cpu.x)
        }
        0x88 => { // DEY
            if x8(cpu) {
                cpu.y = (cpu.y - 1) & 0xFF
            } else {
                cpu.y = (cpu.y - 1) & 0xFFFF
            }
            setNZx(cpu, cpu.y)
        }
        0x1A => { // INC A
            if m8(cpu) {
                let lo = (cpu.a + 1) & 0xFF
                cpu.a = (cpu.a & 0xFF00) | lo
                setNZ8(cpu, lo)
            } else {
                cpu.a = (cpu.a + 1) & 0xFFFF
                setNZ16(cpu, cpu.a)
            }
        }
        0x3A => { // DEC A
            if m8(cpu) {
                let lo = (cpu.a - 1) & 0xFF
                cpu.a = (cpu.a & 0xFF00) | lo
                setNZ8(cpu, lo)
            } else {
                cpu.a = (cpu.a - 1) & 0xFFFF
                setNZ16(cpu, cpu.a)
            }
        }

        // ---- immediate loads (operand width = register width) ----
        0xA9 => { // LDA #
            if m8(cpu) {
                let v = fetch8(cpu, m)
                cpu.a = (cpu.a & 0xFF00) | v
                setNZ8(cpu, v)
            } else {
                let lo = fetch8(cpu, m)
                let hi = fetch8(cpu, m)
                cpu.a = lo | (hi << 8)
                setNZ16(cpu, cpu.a)
            }
        }
        0xA2 => { // LDX #
            if x8(cpu) {
                let v = fetch8(cpu, m)
                cpu.x = v
                setNZ8(cpu, v)
            } else {
                let lo = fetch8(cpu, m)
                let hi = fetch8(cpu, m)
                cpu.x = lo | (hi << 8)
                setNZ16(cpu, cpu.x)
            }
        }
        0xA0 => { // LDY #
            if x8(cpu) {
                let v = fetch8(cpu, m)
                cpu.y = v
                setNZ8(cpu, v)
            } else {
                let lo = fetch8(cpu, m)
                let hi = fetch8(cpu, m)
                cpu.y = lo | (hi << 8)
                setNZ16(cpu, cpu.y)
            }
        }

        // ---- LDA (memory addressing modes; immediate A9 handled above) ----
        0xA5 => {
            ldaFrom(cpu, m, aDp(cpu, m), true)
        } // dp
        0xB5 => {
            ldaFrom(cpu, m, aDpX(cpu, m), true)
        } // dp,X
        0xAD => {
            ldaFrom(cpu, m, aAbs(cpu, m), false)
        } // abs
        0xBD => {
            ldaFrom(cpu, m, aAbsX(cpu, m), false)
        } // abs,X
        0xB9 => {
            ldaFrom(cpu, m, aAbsY(cpu, m), false)
        } // abs,Y
        0xAF => {
            ldaFrom(cpu, m, aLong(cpu, m), false)
        } // long
        0xBF => {
            ldaFrom(cpu, m, aLongX(cpu, m), false)
        } // long,X
        0xA1 => {
            ldaFrom(cpu, m, aDpIndX(cpu, m), false)
        } // (dp,X)
        0xB1 => {
            ldaFrom(cpu, m, aDpIndY(cpu, m), false)
        } // (dp),Y
        0xB2 => {
            ldaFrom(cpu, m, aDpInd(cpu, m), false)
        } // LDA (dp)
        0xA7 => {
            ldaFrom(cpu, m, aDpLong(cpu, m), false)
        } // [dp]
        0xB7 => {
            ldaFrom(cpu, m, aDpLongY(cpu, m), false)
        } // [dp],Y
        0xA3 => {
            ldaFrom(cpu, m, aSr(cpu, m), true)
        } // sr,S
        0xB3 => {
            ldaFrom(cpu, m, aSrY(cpu, m), false)
        } // (sr,S),Y

        // ---- STA (store A; address resolved first to sequence the borrows) ----
        0x85 => {
            let a = aDp(cpu, m)
            staTo(cpu, m, a, true)
        }
        0x95 => {
            let a = aDpX(cpu, m)
            staTo(cpu, m, a, true)
        }
        0x8D => {
            let a = aAbs(cpu, m)
            staTo(cpu, m, a, false)
        }
        0x9D => {
            let a = aAbsX(cpu, m)
            staTo(cpu, m, a, false)
        }
        0x99 => {
            let a = aAbsY(cpu, m)
            staTo(cpu, m, a, false)
        }
        0x8F => {
