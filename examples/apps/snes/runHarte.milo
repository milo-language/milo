// Harte SingleStepTests runner for the 65C816 core, over the flat integer
// stream produced by harteConv.ts (std/json clones subtrees and blows memory on
// the 3.8 MB source files). Applies each case's initial CPU+RAM state, executes
// one instruction, and compares final registers + touched RAM against golden.
//   bun run examples/apps/snes/harteConv.ts roms/harte-65816/v1/ea.e.json /tmp/ea.flat
//   milo run examples/apps/snes/runHarte.milo /tmp/ea.flat [maxCases]
// Driver over many opcodes: examples/apps/snes/harte.sh

from "std/args" import {
    args
}
from "std/io" import {
    readFile
}
from "./cpu" import {
    Cpu, Mem, memNew, memReset, memRead, memWrite, step
}

// Whitespace-separated decimal integer stream cursor.
struct Toks {
    s: string
    pos: i64
}

fn nextTok(t: &mut Toks): i64 {
    while t.pos < t.s.len {
        let c = t.s[t.pos]as i64
        if c == 32 || c == 10 || c == 13 || c == 9 {
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    var v: i64 = 0
    while t.pos < t.s.len {
        let c = t.s[t.pos]as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    return v
}

// Read one state record's 10 registers into cpu, then ramN (addr,val) pairs
// into memory. Field order matches harteConv.ts emitState.
fn loadRegs(cpu: &mut Cpu, m: &mut Mem, t: &mut Toks): void {
    cpu.a = nextTok(t) cpu.x = nextTok(t) cpu.y = nextTok(t)
    cpu.s = nextTok(t) cpu.d = nextTok(t) cpu.pc = nextTok(t)
    cpu.p = nextTok(t) cpu.dbr = nextTok(t) cpu.pbr = nextTok(t)
    cpu.e = nextTok(t)
    if cpu.e == 1 {
        cpu.s = 0x0100 | (cpu.s & 0xFF) // emulation forces stack high byte to 01
    }
    let ramN = nextTok(t)
    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let val = nextTok(t)
        memWrite(m, addr, val)
        j = j + 1
    }
}

// Compare cpu/memory against the "final" record; consume it either way.
// Returns "" on match or a description of the first mismatch.
fn checkFinal(cpu: &Cpu, m: &Mem, t: &mut Toks): string {
    let fa = nextTok(t) let fx = nextTok(t) let fy = nextTok(t)
    let fs = nextTok(t) let fd = nextTok(t) let fpc = nextTok(t)
    let fp = nextTok(t) let fdbr = nextTok(t) let fpbr = nextTok(t)
    let fe = nextTok(t)
    let ramN = nextTok(t)

    var mismatch = ""
    if cpu.a != fa && mismatch == "" {
        mismatch = "A got " + hex(cpu.a) + " want " + hex(fa)
    }
    if cpu.x != fx && mismatch == "" {
        mismatch = "X got " + hex(cpu.x) + " want " + hex(fx)
    }
    if cpu.y != fy && mismatch == "" {
        mismatch = "Y got " + hex(cpu.y) + " want " + hex(fy)
    }
    if cpu.s != fs && mismatch == "" {
        mismatch = "S got " + hex(cpu.s) + " want " + hex(fs)
    }
    if cpu.d != fd && mismatch == "" {
        mismatch = "D got " + hex(cpu.d) + " want " + hex(fd)
    }
    if cpu.pc != fpc && mismatch == "" {
        mismatch = "PC got " + hex(cpu.pc) + " want " + hex(fpc)
    }
    if cpu.p != fp && mismatch == "" {
        mismatch = "P got " + hex(cpu.p) + " want " + hex(fp)
    }
    if cpu.dbr != fdbr && mismatch == "" {
        mismatch = "DBR got " + hex(cpu.dbr) + " want " + hex(fdbr)
    }
    if cpu.pbr != fpbr && mismatch == "" {
        mismatch = "PBR got " + hex(cpu.pbr) + " want " + hex(fpbr)
    }
    if cpu.e != fe && mismatch == "" {
        mismatch = "E got " + hex(cpu.e) + " want " + hex(fe)
    }

    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let want = nextTok(t)
        let got = memRead(m, addr)
        if got != want && mismatch == "" {
            mismatch = "RAM[" + hex(addr) + "] got " + hex(got) + " want " + hex(want)
        }
        j = j + 1
    }
    return mismatch
}

fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: runHarte <op.flat> [maxCases]")
        return 1
    }
    var maxCases: i64 = 100000000
    if argv.len >= 3 {
        maxCases = strToI(argv[2])
    }

    var raw = ""
    match readFile(argv[1]) {
        Result.Ok(s) => {
            raw = s
        }
        Result.Err(e) => {
            print("cannot read " + argv[1]) return 1
        }
    }

    var t = Toks {
        s: raw, pos: 0
    }
    let total = nextTok(t)
    var cpu = Cpu {
        a: 0, x: 0, y: 0, s: 0, d: 0, pc: 0, p: 0, dbr: 0, pbr: 0, e: 0
    }
    var m = memNew()
    var passed: i64 = 0
    var failed: i64 = 0
    var firstFail = ""
    var i: i64 = 0
    while i < total {
        if i >= maxCases {
            break
        }
        memReset(m)
        loadRegs(cpu, m, t)
        step(cpu, m)
        let mismatch = checkFinal(cpu, m, t)
        if mismatch == "" {
            passed = passed + 1
        } else {
            failed = failed + 1
            if firstFail == "" {
                firstFail = "case " + itoa(i) + ": " + mismatch
            }
        }
        i = i + 1
    }

    print("passed " + itoa(passed) + " / " + itoa(passed + failed) + "  (file has " + itoa(total) + " cases)")
    if firstFail != "" {
        print("first fail: " + firstFail)
    }
    if failed == 0 {
        return 0
    }
    return 1
}

// --- tiny formatting helpers ---
fn itoa(n: i64): string {
    if n == 0 {
        return "0"
    }
    var v = n
    var s = ""
    while v > 0 {
        s = digitStr(v % 10) + s
        v = v / 10
    }
    return s
}

fn digitStr(d: i64): string {
    var s = ""
    s.push((48 + d) as u8)
    return s
}

fn hex(n: i64): string {
    let v = n & 0xFFFFFFFF
    var s = "0x"
    var i: i64 = 28
    var lead = true
    while i >= 0 {
        let nib = (v >> i) & 0xF
        if nib != 0 {
            lead = false
        }
        if !lead || i == 0 {
            s = s + hexNib(nib)
        }
        i = i - 4
    }
    return s
}

fn hexNib(n: i64): string {
    var s = ""
    if n < 10 {
        s.push((48 + n) as u8)
    } else {
        s.push((87 + n) as u8)
    }
    return s
}

fn strToI(s: &string): i64 {
    var v: i64 = 0
    for ch in s {
        let c = ch as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
        }
    }
    return v
}
