// SNES S-PPU — video memory + register interface. This first slice is the
// memory model and the $2100-$213F register path (VRAM/CGRAM/OAM ports, scroll,
// BG/OBJ control) that DMA and CPU writes push graphics data through. Actual
// scanline rendering (Mode 1 backgrounds + sprites) lands next. Ref: fullsnes.

struct Ppu {
    vram: Vec<u8> // 64 KiB (32K 16-bit words)
    cgram: Vec<u8> // 512 bytes = 256 BGR555 colors
    oam: Vec<u8> // real OAM is 544B (512 + 32 high); over-allocated to 0x400 so the
    // 9-bit word address (byte addr masked &0x3FF) can't index out of bounds

    inidisp: i64 // $2100: bit7 force-blank, bits0-3 master brightness
    obsel: i64 // $2101: OBJ size + name base
    oamaddr: i64 // $2102/$2103 word address (byte addr = oamaddr*2)
    oamLatch: i64
    oamHi: bool // writing the high (odd) byte of an OAM word

    bgmode: i64 // $2105
    bgsc0: i64
    bgsc1: i64
    bgsc2: i64
    bgsc3: i64 // $2107-$210A tilemap base/size
    bg12nba: i64
    bg34nba: i64 // $210B/$210C char base

    // BG1-4 H/V scroll ($210D-$2114), each written twice (low then high 3 bits)
    bghofs: Vec<i64>
    bgvofs: Vec<i64>
    scrollLatch: i64
    scrollHi: i64

    vmain: i64 // $2115 increment mode
    vmaddr: i64 // $2116/$2117 word address
    vmLatch: i64

    cgaddr: i64 // $2121 color word address
    cgLatch: i64
    cgHi: bool // writing the high byte of a color word
    tm: i64 // $212C main-screen layer enable (bit0-3 = BG1-4, bit4 = OBJ)
    ts: i64 // $212D sub-screen layer enable

    // Color math ($2131 CGADSUB: bit7 sub/add, bit6 half, bit5 backdrop, bit4 OBJ,
    // bits0-3 BG1-4) + fixed color ($2132 COLDATA, 5-bit BGR). SMW paints level
    // skies by adding the fixed color to the (black) backdrop.
    cgadsub: i64
    coldR: i64
    coldG: i64
    coldB: i64

    // Mode 7 affine state. Matrix A/D/B/C are signed 8.8 fixed ($211B-$211E);
    // center X/Y ($211F/$2120) and scroll ($210D/$210E) are 13-bit signed. All
    // write-twice (low then high) through the shared m7Latch byte.
    m7a: i64
    m7b: i64
    m7c: i64
    m7d: i64
    m7x: i64
    m7y: i64
    m7hofs: i64
    m7vofs: i64
    m7sel: i64
    m7Latch: i64

    // Per-scanline HDMA overrides (populated by hdmaWalkFrame in cpu.milo before
    // render; consumed by the renderer via lineBrightAt/backdropColorLine). When
    // hdmaOn is false the renderer uses the scalar registers exactly as before, so
    // non-HDMA games are byte-identical. Arrays are 224 entries (visible lines).
    hdmaOn: bool
    lineBright: Vec<i64> // INIDISP $2100 brightness bits0-3 per line
    lineColdR: Vec<i64> // COLDATA $2132 fixed-color R per line (0-31)
    lineColdG: Vec<i64>
    lineColdB: Vec<i64>
}

fn ppuZeros(n: i64): Vec<u8> {
    var v: Vec<u8> = Vec.new()
    var i: i64 = 0
    while i < n {
        v.push(0)
        i = i + 1
    }
    return v
}

fn ppuZerosI64(n: i64): Vec<i64> {
    var v: Vec<i64> = Vec.new()
    var i: i64 = 0
    while i < n {
        v.push(0)
        i = i + 1
    }
    return v
}

fn newPpu(): Ppu {
    return Ppu {
        vram: ppuZeros(0x10000), cgram: ppuZeros(0x200), oam: ppuZeros(0x400),
        inidisp: 0, obsel: 0, oamaddr: 0, oamLatch: 0, oamHi: false,
        bgmode: 0, bgsc0: 0, bgsc1: 0, bgsc2: 0, bgsc3: 0, bg12nba: 0, bg34nba: 0,
        bghofs: ppuZerosI64(4), bgvofs: ppuZerosI64(4), scrollLatch: 0, scrollHi: 0,
        vmain: 0, vmaddr: 0, vmLatch: 0, cgaddr: 0, cgLatch: 0, cgHi: false, tm: 0x1F, ts: 0,
        m7a: 0x100, m7b: 0, m7c: 0, m7d: 0x100, m7x: 0, m7y: 0, m7hofs: 0, m7vofs: 0,
        m7sel: 0, m7Latch: 0,
        cgadsub: 0, coldR: 0, coldG: 0, coldB: 0,
        hdmaOn: false, lineBright: ppuZerosI64(224), lineColdR: ppuZerosI64(224),
        lineColdG: ppuZerosI64(224), lineColdB: ppuZerosI64(224)
    }
}

// VRAM address increment after a data-port access (VMAIN bits 0-1: 1/32/128).
fn vramStep(p: &Ppu): i64 {
    let s = p.vmain & 0x03
    if s == 0 {
        return 1
    }
    if s == 1 {
        return 32
    }
    return 128
}

// Register write for $2100-$213F (reg = low byte of the address).
fn ppuRegWrite(p: &mut Ppu, reg: i64, val: i64): void {
    let v = val & 0xFF
    if reg == 0x00 {
        p.inidisp = v
        return
    }
    if reg == 0x01 {
        p.obsel = v
        return
    }
    if reg == 0x02 {
        p.oamaddr = (p.oamaddr & 0x100) | v
        p.oamHi = false return
    }
    if reg == 0x03 {
        p.oamaddr = ((v & 1) << 8) | (p.oamaddr & 0xFF)
        p.oamHi = false return
    }
    if reg == 0x04 { // OAMDATA — 16-bit latch on even, commit on odd
        let a = (p.oamaddr * 2) & 0x3FF
        if !p.oamHi {
            p.oamLatch = v
            p.oam[a] = v as u8
            p.oamHi = true
        } else {
            p.oam[(a + 1) & 0x3FF] = v as u8
            p.oamaddr = (p.oamaddr + 1) & 0x1FF
            p.oamHi = false
        }
        return
    }
    if reg == 0x05 {
        p.bgmode = v
        return
    }
    if reg == 0x07 {
        p.bgsc0 = v
        return
    }
    if reg == 0x08 {
        p.bgsc1 = v
        return
    }
    if reg == 0x09 {
        p.bgsc2 = v
        return
    }
    if reg == 0x0A {
        p.bgsc3 = v
        return
    }
    if reg == 0x0B {
        p.bg12nba = v
        return
    }
    if reg == 0x0C {
        p.bg34nba = v
        return
    }
    if reg >= 0x0D && reg <= 0x14 {
        let idx = (reg - 0x0D) / 2
        let isV = ((reg - 0x0D) & 1) == 1
        // write-twice: low byte then high 3 bits (shared BG scroll latch)
        if isV {
            p.bgvofs[idx] = ((v << 8) | (p.scrollLatch & 0xF8) | (p.scrollHi & 0x07)) & 0x3FF
        } else {
            p.bghofs[idx] = ((v << 8) | (p.scrollLatch & 0xF8) | (p.scrollHi & 0x07)) & 0x3FF
        }
        // $210D/$210E double as Mode 7 BG1 scroll (13-bit signed, m7 latch).
        if reg == 0x0D {
            p.m7hofs = m7Ext13(((v << 8) | p.m7Latch) & 0x1FFF)
            p.m7Latch = v
        }
        if reg == 0x0E {
            p.m7vofs = m7Ext13(((v << 8) | p.m7Latch) & 0x1FFF)
            p.m7Latch = v
        }
        p.scrollHi = p.scrollLatch
        p.scrollLatch = v
        return
    }
    if reg == 0x15 {
        p.vmain = v
        return
    }
    if reg == 0x16 {
        p.vmaddr = (p.vmaddr & 0x7F00) | v
        return
    }
    if reg == 0x17 {
        p.vmaddr = ((v & 0x7F) << 8) | (p.vmaddr & 0xFF)
        return
    }
    if reg == 0x18 { // VMDATAL
        let a = (p.vmaddr * 2) & 0xFFFF
        p.vram[a] = v as u8
        if (p.vmain & 0x80) == 0 {
            p.vmaddr = (p.vmaddr + vramStep(p)) & 0x7FFF
        }
        return
    }
    if reg == 0x19 { // VMDATAH
        let a = ((p.vmaddr * 2) + 1) & 0xFFFF
        p.vram[a] = v as u8
        if (p.vmain & 0x80) != 0 {
            p.vmaddr = (p.vmaddr + vramStep(p)) & 0x7FFF
        }
        return
    }
    if reg == 0x21 {
        p.cgaddr = v
        p.cgHi = false return
    }
    if reg == 0x22 { // CGDATA — low byte then high byte, then addr++
        if !p.cgHi {
            p.cgLatch = v
            p.cgHi = true
        } else {
            let a = (p.cgaddr * 2) & 0x1FF
            p.cgram[a] = p.cgLatch as u8
            p.cgram[(a + 1) & 0x1FF] = v as u8
            p.cgaddr = (p.cgaddr + 1) & 0xFF
            p.cgHi = false
        }
        return
    }
    if reg == 0x1A {
        p.m7sel = v
        return
    }
    if reg == 0x1B { // M7A — signed 8.8 fixed
        p.m7a = m7Ext16((v << 8) | p.m7Latch)
        p.m7Latch = v
        return
    }
    if reg == 0x1C {
        p.m7b = m7Ext16((v << 8) | p.m7Latch)
        p.m7Latch = v
        return
    }
    if reg == 0x1D {
        p.m7c = m7Ext16((v << 8) | p.m7Latch)
        p.m7Latch = v
        return
    }
    if reg == 0x1E {
        p.m7d = m7Ext16((v << 8) | p.m7Latch)
        p.m7Latch = v
        return
    }
    if reg == 0x1F { // M7X — 13-bit signed center
        p.m7x = m7Ext13(((v << 8) | p.m7Latch) & 0x1FFF)
        p.m7Latch = v
        return
    }
    if reg == 0x20 {
        p.m7y = m7Ext13(((v << 8) | p.m7Latch) & 0x1FFF)
        p.m7Latch = v
        return
    }
    if reg == 0x2C {
        p.tm = v
        return
    } // main-screen layer enable
    if reg == 0x2D {
        p.ts = v
        return
    } // sub-screen layer enable
    if reg == 0x31 {
        p.cgadsub = v
        return
    } // color math control
    if reg == 0x32 { // COLDATA: bit7=B bit6=G bit5=R select, bits0-4 intensity
        let inten = v & 0x1F
        if (v & 0x20) != 0 {
            p.coldR = inten
        }
        if (v & 0x40) != 0 {
            p.coldG = inten
        }
        if (v & 0x80) != 0 {
            p.coldB = inten
        }
        return
    }
    // remaining regs (windows, color math, mosaic, mode7, ...) modeled later
}

// Register read for $2134-$213F (readable PPU registers). Data ports auto-inc.
fn ppuRegRead(p: &mut Ppu, reg: i64): i64 {
    if reg == 0x38 { // OAMDATAREAD
        let a = (p.oamaddr * 2) & 0x3FF
        let r = p.oam[a] as i64
        p.oamaddr = (p.oamaddr + 1) & 0x1FF
        return r
    }
    if reg == 0x39 { // VMDATALREAD
        let a = (p.vmaddr * 2) & 0xFFFF
        return p.vram[a] as i64
    }
    if reg == 0x3A { // VMDATAHREAD
        let a = ((p.vmaddr * 2) + 1) & 0xFFFF
        return p.vram[a] as i64
    }
    if reg == 0x3B { // CGDATAREAD
        let a = (p.cgaddr * 2) & 0x1FF
        let r = p.cgram[a] as i64
        p.cgaddr = (p.cgaddr + 1) & 0xFF
        return r
    }
    return 0
}

// Pure register read (no auto-increment) for the CPU's &Mem read path.
fn ppuRegReadPure(p: &Ppu, reg: i64): i64 {
    if reg == 0x38 {
        return p.oam[(p.oamaddr * 2) & 0x3FF] as i64
    }
    if reg == 0x39 {
        return p.vram[(p.vmaddr * 2) & 0xFFFF] as i64
    }
    if reg == 0x3A {
        return p.vram[((p.vmaddr * 2) + 1) & 0xFFFF] as i64
    }
    if reg == 0x3B {
        return p.cgram[(p.cgaddr * 2) & 0x1FF] as i64
    }
    return 0
}

// Sign-extend a 16-bit / 13-bit two's-complement value (Mode 7 fixed-point regs).
fn m7Ext16(v: i64): i64 {
    let x = v & 0xFFFF
    return if x >= 0x8000 {
        x - 0x10000
    } else {
        x
    }
}

fn m7Ext13(v: i64): i64 {
    let x = v & 0x1FFF
    return if x >= 0x1000 {
        x - 0x2000
    } else {
        x
    }
}

fn vramWord(p: &Ppu, waddr: i64): i64 {
    let b = (waddr * 2) & 0xFFFF
    return (p.vram[b] as i64) | ((p.vram[(b + 1) & 0xFFFF] as i64) << 8)
}

// 4bpp planar tile pixel (0-15). charBase/tileNum in words; px/py 0-7.
fn tile4bpp(p: &Ppu, charBase: i64, tileNum: i64, px: i64, py: i64): i64 {
    let tb = ((charBase + tileNum * 16) * 2) & 0xFFFF // 16 words = 32 bytes/tile
    let r0 = (tb + py * 2) & 0xFFFF
    let p0 = p.vram[r0] as i64
    let p1 = p.vram[(r0 + 1) & 0xFFFF] as i64
    let p2 = p.vram[(r0 + 16) & 0xFFFF] as i64
    let p3 = p.vram[(r0 + 17) & 0xFFFF] as i64
    let bit = 7 - px
    return ((p0 >> bit) & 1) | (((p1 >> bit) & 1) << 1) | (((p2 >> bit) & 1) << 2) | (((p3 >> bit) & 1) << 3)
}

// 8bpp planar tile pixel (0-255). 32 words = 64 bytes/tile; 8 planes in 4 pairs.
fn tile8bpp(p: &Ppu, charBase: i64, tileNum: i64, px: i64, py: i64): i64 {
    let tb = ((charBase + tileNum * 32) * 2) & 0xFFFF
    let r0 = (tb + py * 2) & 0xFFFF
    let bit = 7 - px
    var ci: i64 = 0
    var plane: i64 = 0
    while plane < 4 {
        let a = (r0 + plane * 16) & 0xFFFF
        let lo = p.vram[a] as i64
        let hi = p.vram[(a + 1) & 0xFFFF] as i64
        ci = ci | (((lo >> bit) & 1) << (plane * 2)) | (((hi >> bit) & 1) << (plane * 2 + 1))
        plane = plane + 1
    }
    return ci
}

// CGRAM BGR555 color -> 0xRRGGBB, scaled by master brightness (0-15).
// Effective brightness for scanline y: the HDMA per-line override if HDMA drove
// INIDISP this frame, else the scalar register. Keeps non-HDMA output identical.
fn lineBrightAt(p: &Ppu, y: i64, deflt: i64): i64 {
    if p.hdmaOn {
        return p.lineBright[y]
    }
    return deflt
}

fn cgToRgb(p: &Ppu, idx: i64, bright: i64): i64 {
    let a = (idx * 2) & 0x1FF
    let w = (p.cgram[a] as i64) | ((p.cgram[(a + 1) & 0x1FF] as i64) << 8)
    var r = (w & 0x1F) << 3
    var g = ((w >> 5) & 0x1F) << 3
    var b = ((w >> 10) & 0x1F) << 3
    r = (r * bright) / 15
    g = (g * bright) / 15
    b = (b * bright) / 15
    return (r << 16) | (g << 8) | b
}

// Render OBJ (sprites) on top of the background. 4bpp, palettes 8-15 (CGRAM
// 128-255). Supports 8x8 / 16x16 (OBSEL size selector 0). Drawn back-to-front so
// low sprite indices win. Priority-vs-BG not yet modeled (sprites over BG).
fn renderSprites(p: &Ppu, fb: &mut Vec<i64>, bright: i64): void {
    let objBase = (p.obsel & 0x07) << 13 // name base (words)
    var s: i64 = 127
    while s >= 0 {
        let oa = s * 4
        let xl = p.oam[oa] as i64
        let y = p.oam[oa + 1] as i64
        let tileL = p.oam[oa + 2] as i64
        let attr = p.oam[oa + 3] as i64
        let ht = p.oam[0x200 + (s >> 2)] as i64
        let shift = (s & 3) * 2
        let xhi = (ht >> shift) & 1
        let large = (ht >> (shift + 1)) & 1
        var sx = xl | (xhi << 8)
        if sx >= 256 {
            sx = sx - 512
        } // 9-bit signed X
        let dim: i64 = if large != 0 {
            16
        } else {
            8
        }
        let pal = (attr >> 1) & 0x07
        let hflip = (attr >> 6) & 1
        let vflip = (attr >> 7) & 1
        let tileNum = tileL | ((attr & 1) << 8)

        var oy: i64 = 0
        while oy < dim {
            let scrY = y + oy
            if scrY >= 0 && scrY < 224 {
                var ox: i64 = 0
                while ox < dim {
                    let scrX = sx + ox
                    if scrX >= 0 && scrX < 256 {
                        var tx = ox
                        var ty = oy
                        if hflip != 0 {
                            tx = dim - 1 - ox
                        }
                        if vflip != 0 {
                            ty = dim - 1 - oy
                        }
                        // 16x16 = 2x2 tiles laid out 16-wide in VRAM.
                        let t = tileNum + (ty >> 3) * 16 + (tx >> 3)
                        let ci = tile4bpp(p, objBase, t & 0x1FF, tx & 7, ty & 7)
                        if ci != 0 {
                            fb[scrY * 256 + scrX] = cgToRgb(p, 128 + pal * 16 + ci, lineBrightAt(p, scrY, bright))
                        }
                    }
                    ox = ox + 1
                }
            }
            oy = oy + 1
        }
        s = s - 1
    }
}

// 2bpp planar tile pixel (0-3). 8 words = 16 bytes/tile.
fn tile2bpp(p: &Ppu, charBase: i64, tileNum: i64, px: i64, py: i64): i64 {
    let tb = ((charBase + tileNum * 8) * 2) & 0xFFFF
    let r0 = (tb + py * 2) & 0xFFFF
    let p0 = p.vram[r0] as i64
    let p1 = p.vram[(r0 + 1) & 0xFFFF] as i64
    let bit = 7 - px
    return ((p0 >> bit) & 1) | (((p1 >> bit) & 1) << 1)
}

// Tilemap word for a tile coord, honoring the screen-size layout ($400-word
// screens tiled 1x1 / 2x1 / 1x2 / 2x2 by the size bits).
fn bgEntryAddr(tmBase: i64, sc: i64, tileX: i64, tileY: i64): i64 {
    let nh: i64 = if (sc & 1) != 0 {
        2
    } else {
        1
    }
    let sx: i64 = if tileX >= 32 {
        1
    } else {
        0
    }
    let sy: i64 = if tileY >= 32 {
        1
    } else {
        0
    }
    let quad = sx + sy * nh
    return tmBase + quad * 0x400 + (tileY & 31) * 32 + (tileX & 31)
}

// Composite one BG layer onto fb (transparent where the pixel index is 0).
// sc = the BGnSC register: base in bits2-7, screen size in bits0-1.
// bpp 4 -> 16 colors/palette; bpp 2 -> 4 colors/palette (BG3).
fn renderBGLayer(p: &Ppu, fb: &mut Vec<i64>, bright: i64, sc: i64, chBase: i64, hofs: i64, vofs: i64, bpp: i64, palBase: i64): void {
    let palW: i64 = if bpp == 4 {
        16
    } else {
        4
    }
    let tmBase = (sc & 0xFC) << 8
    let maskX: i64 = if (sc & 1) != 0 {
        0x1FF
    } else {
        0xFF
    }
    let maskY: i64 = if (sc & 2) != 0 {
        0x1FF
    } else {
        0xFF
    }
    var y: i64 = 0
    while y < 224 {
        var x: i64 = 0
        while x < 256 {
            let ex = (x + hofs) & maskX
            let ey = (y + vofs) & maskY
            let entry = vramWord(p, bgEntryAddr(tmBase, sc, ex >> 3, ey >> 3))
            let tileNum = entry & 0x3FF
            let pal = (entry >> 10) & 0x07
            var px = ex & 7
            var py = ey & 7
            if ((entry >> 14) & 1) != 0 {
                px = 7 - px
            }
            if ((entry >> 15) & 1) != 0 {
                py = 7 - py
            }
            let ci: i64 = if bpp == 8 {
                tile8bpp(p, chBase, tileNum, px, py)
            } else if bpp == 4 {
                tile4bpp(p, chBase, tileNum, px, py)
            } else {
                tile2bpp(p, chBase, tileNum, px, py)
            }
            if ci != 0 {
                // 8bpp indexes CGRAM directly; lower bpp uses palette groups.
                let colorIdx: i64 = if bpp == 8 {
                    ci
                } else {
                    palBase + pal * palW + ci
                }
                fb[y * 256 + x] = cgToRgb(p, colorIdx, lineBrightAt(p, y, bright))
            }
            x = x + 1
        }
        y = y + 1
    }
}

// Mode 7 render: one 128x128 tilemap of 8bpp tiles, transformed by the affine
// matrix. VRAM is byte-interleaved — even byte = tilemap entry, odd byte = tile
// graphics. Plane coord = (M * (screen + scroll - center)) >> 8 + center. Screen
// -over modes 0/1 wrap the 1024px plane; 2/3 (transparent / tile0 fill) TODO.
fn renderMode7(p: &Ppu, fb: &mut Vec<i64>, bright: i64): void {
    let ox = p.m7hofs - p.m7x
    let oy = p.m7vofs - p.m7y
    var sy: i64 = 0
    while sy < 224 {
        var sx: i64 = 0
        while sx < 256 {
            let dx = ox + sx
            let dy = oy + sy
            let vx = ((p.m7a * dx + p.m7b * dy) >> 8) + p.m7x
            let vy = ((p.m7c * dx + p.m7d * dy) >> 8) + p.m7y
            let px = vx & 1023
            let py = vy & 1023
            let tileX = px >> 3
            let tileY = py >> 3
            let mapN = tileY * 128 + tileX
            let tile = p.vram[(mapN * 2) & 0xFFFF] as i64
            let gAddr = ((tile * 64 + (py & 7) * 8 + (px & 7)) * 2 + 1) & 0xFFFF
            let ci = p.vram[gAddr] as i64
            if ci != 0 {
                fb[sy * 256 + sx] = cgToRgb(p, ci, lineBrightAt(p, sy, bright))
            }
            sx = sx + 1
        }
        sy = sy + 1
    }
}

// Render the mode's BG layers whose bit is set in `enable` (a $212C/$212D mask),
// back-to-front, compositing onto fb by transparency.
fn renderScreenBGs(p: &Ppu, fb: &mut Vec<i64>, bright: i64, enable: i64): void {
    let ch1 = (p.bg12nba & 0x0F) << 12
    let ch2 = ((p.bg12nba >> 4) & 0x0F) << 12
    let ch3 = (p.bg34nba & 0x0F) << 12
    let ch4 = ((p.bg34nba >> 4) & 0x0F) << 12
    let mode = p.bgmode & 0x07
    let en1 = (enable & 0x01) != 0
    let en2 = (enable & 0x02) != 0
    let en3 = (enable & 0x04) != 0
    let en4 = (enable & 0x08) != 0
    if mode == 0 {
        // Mode 0: four 2bpp BGs; palette groups at cgram 0/32/64/96.
        if en4 {
            renderBGLayer(p, fb, bright, p.bgsc3, ch4, p.bghofs[3], p.bgvofs[3], 2, 96)
        }
        if en3 {
            renderBGLayer(p, fb, bright, p.bgsc2, ch3, p.bghofs[2], p.bgvofs[2], 2, 64)
        }
        if en2 {
            renderBGLayer(p, fb, bright, p.bgsc1, ch2, p.bghofs[1], p.bgvofs[1], 2, 32)
        }
        if en1 {
            renderBGLayer(p, fb, bright, p.bgsc0, ch1, p.bghofs[0], p.bgvofs[0], 2, 0)
        }
    } else if mode == 7 {
        if en1 {
            renderMode7(p, fb, bright)
        }
    } else if mode == 3 {
        // Mode 3: BG1 8bpp (direct 256-color), BG2 4bpp.
        if en2 {
            renderBGLayer(p, fb, bright, p.bgsc1, ch2, p.bghofs[1], p.bgvofs[1], 4, 0)
        }
        if en1 {
            renderBGLayer(p, fb, bright, p.bgsc0, ch1, p.bghofs[0], p.bgvofs[0], 8, 0)
        }
    } else {
        // Mode 1 (and a reasonable default for 2/4-7): BG3 2bpp, BG2/BG1 4bpp.
        if en3 {
            renderBGLayer(p, fb, bright, p.bgsc2, ch3, p.bghofs[2], p.bgvofs[2], 2, 0)
        }
        if en2 {
            renderBGLayer(p, fb, bright, p.bgsc1, ch2, p.bghofs[1], p.bgvofs[1], 4, 0)
        }
        if en1 {
            renderBGLayer(p, fb, bright, p.bgsc0, ch1, p.bghofs[0], p.bgvofs[0], 4, 0)
        }
    }
}

// Clamp a 5-bit color component to 0-31.
fn clamp5(v: i64): i64 {
    if v < 0 {
        return 0
    }
    if v > 31 {
        return 31
    }
    return v
}

// Backdrop color (CGRAM index 0) with color math ($2131 bit5) applied: add or
// subtract the fixed COLDATA color, optionally halved. This is how SMW fills a
// level's sky — the raw backdrop is black and the fixed color paints it.
fn backdropColor(p: &Ppu, bright: i64): i64 {
    let w = (p.cgram[0] as i64) | ((p.cgram[1] as i64) << 8)
    var r = w & 0x1F
    var g = (w >> 5) & 0x1F
    var b = (w >> 10) & 0x1F
    // Only ADD (paint) the fixed color onto the backdrop. Subtract/half on the
    // backdrop would DARKEN it — and since we don't model the full window/clip
    // conditions, applying those risks blacking out a level whose raw backdrop
    // (cgram0) is the real sky. Add-only can only brighten: strictly safe, and it
    // covers SMW's sky (black backdrop + fixed color).
    if (p.cgadsub & 0x20) != 0 && (p.cgadsub & 0x80) == 0 {
        r = clamp5(r + p.coldR)
        g = clamp5(g + p.coldG)
        b = clamp5(b + p.coldB)
    }
    let rr = (((r << 3) * bright) / 15) & 0xFF
    let gg = (((g << 3) * bright) / 15) & 0xFF
    let bb = (((b << 3) * bright) / 15) & 0xFF
    return (rr << 16) | (gg << 8) | bb
}

// Backdrop for scanline y using the HDMA per-line brightness + fixed color. Same
// add-only color-math policy as backdropColor. Used when hdmaOn (gradient skies).
fn backdropColorLine(p: &Ppu, y: i64, deflt: i64): i64 {
    let bright = lineBrightAt(p, y, deflt)
    let w = (p.cgram[0] as i64) | ((p.cgram[1] as i64) << 8)
    var r = w & 0x1F
    var g = (w >> 5) & 0x1F
    var b = (w >> 10) & 0x1F
    if (p.cgadsub & 0x20) != 0 && (p.cgadsub & 0x80) == 0 {
        r = clamp5(r + p.lineColdR[y])
        g = clamp5(g + p.lineColdG[y])
        b = clamp5(b + p.lineColdB[y])
    }
    let rr = (((r << 3) * bright) / 15) & 0xFF
    let gg = (((g << 3) * bright) / 15) & 0xFF
    let bb = (((b << 3) * bright) / 15) & 0xFF
    return (rr << 16) | (gg << 8) | bb
}

// Render a full frame. The sub-screen ($212D TS) layers are drawn first as the
// base and the main-screen ($212C TM) layers on top — an approximation of color
// math (no per-pixel add/half blending on layers yet, but the backdrop gets it
// via backdropColor). Surfaces sub-screen backgrounds (SMW overworld map) too.
fn renderFrame(p: &Ppu, fb: &mut Vec<i64>): void {
    let bright = p.inidisp & 0x0F
    let forceBlank = (p.inidisp & 0x80) != 0

    // Fill per scanline: the backdrop is constant across a line, so compute it
    // once per line (or once total when neither force-blank nor HDMA varies it).
    let constBackdrop: i64 = if forceBlank {
        0
    } else {
        backdropColor(p, bright)
    }
    var y: i64 = 0
    while y < 224 {
        let bd: i64 = if !forceBlank && p.hdmaOn {
            backdropColorLine(p, y, bright)
        } else {
            constBackdrop
        }
        var x: i64 = 0
        while x < 256 {
            fb[y * 256 + x] = bd
            x = x + 1
        }
        y = y + 1
    }
    if forceBlank {
        return
    }

    if p.ts != 0 {
        renderScreenBGs(p, fb, bright, p.ts)
    }
    renderScreenBGs(p, fb, bright, p.tm)
    if ((p.tm | p.ts) & 0x10) != 0 {
        renderSprites(p, fb, bright)
    }
}

// Direct byte accessors (used by DMA / tests to peek loaded graphics memory).
fn ppuVram(p: &Ppu, a: i64): i64 {
    return p.vram[a & 0xFFFF] as i64
}

fn ppuCgram(p: &Ppu, a: i64): i64 {
    return p.cgram[a & 0x1FF] as i64
}
