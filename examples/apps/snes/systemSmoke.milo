// M2 smoke test: synthesize a tiny LoROM, boot the CPU from its reset vector,
// execute a short program, and verify bus mapping (ROM fetch + WRAM store).
//   milo run examples/apps/snes/systemSmoke.milo
//
// Program at $00:8000 (LoROM ROM offset 0):
//   A9 42     LDA #$42
//   8D 00 00  STA $0000     ; -> WRAM $00:0000 (low mirror)
//   A2 07     LDX #$07
//   E8        INX           ; X = 8
//   EA        NOP
// Reset vector at $00:FFFC = $8000.

from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, step, memRead, vecZeros
}

fn hex2(v: i64): string {
    let d = "0123456789ABCDEF"
    var s = ""
    s.push(d[(v >> 4) & 0xF]) s.push(d[v & 0xF])
    return s
}

fn main(): i32 {
    var rom = vecZeros(0x8000) // 32 KiB LoROM
    let prog = [0xA9, 0x42, 0x8D, 0x00, 0x00, 0xA2, 0x07, 0xE8, 0xEA]
    var i: i64 = 0
    while i < (prog.len as i64) {
        rom[i] = prog[i]as u8 i = i + 1
    }
    rom[0x7FFC] = 0x00 as u8 // reset vector low
    rom[0x7FFD] = 0x80 as u8 // reset vector high -> $8000

    var m = busNew(rom, 0)
    var cpu = newCpuReset(m)

    print("reset PC = $" + hex2((cpu.pc >> 8) & 0xFF) + hex2(cpu.pc & 0xFF))
    var n: i64 = 0
    while n < 5 {
        step(cpu, m) n = n + 1
    }

    print("A  = $" + hex2(cpu.a & 0xFF))
    print("X  = $" + hex2(cpu.x & 0xFF))
    print("WRAM[$0000] = $" + hex2(memRead(m, 0x000000)))
    print("PC = $" + hex2((cpu.pc >> 8) & 0xFF) + hex2(cpu.pc & 0xFF))

    if (cpu.a & 0xFF) == 0x42 && (cpu.x & 0xFF) == 0x08 && memRead(m, 0) == 0x42 {
        print("OK: rom fetch + wram store working")
        return 0
    }
    print("FAIL")
    return 1
}
