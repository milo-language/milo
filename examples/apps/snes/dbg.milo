// Headless SNES debug harness — the agent-facing tool for diagnosing rendering
// bugs (black screens, garbled layers, missing effects) without SDL or a human.
// See .claude/skills/emu-debug/SKILL.md for the triage methodology this serves.
//
//   milo run examples/apps/snes/dbg.milo <rom.sfc> [flags]
//     --frames N            run N frames (default 8)
//     --state <file>        load a save-state after reset (F5 in the SDL emu writes <rom>.state)
//     --press <btn>@<a>-<b> hold a button during frames [a,b] (repeatable);
//                           btns: start select a b x y l r up down left right
//     --shot <f>            dump composite frame + reg summary at frame f (repeatable)
//     --layers              after the run, render each enabled layer in isolation
//     --forcebright         override INIDISP to full brightness (see graphics behind a black fade)
//     --probe               after the run, print a hot-PC histogram (spot CPU wait-loops)
//     --oam                 after the run, dump on-screen OAM sprites (pos/tile/size/pal/prio)
//     --out <prefix>        output path prefix (default /tmp/snes/dbg)
//
// Each reg dump also prints a `wram:` line of key low-WRAM vars ($13/$14 frame
// counters, $94 player X, $1A/$1B scroll) — if these advance the game logic is
// running even when the screen looks frozen (isolates "stuck" from "just slow").
//
// Outputs <prefix>.ppm (final composite), <prefix>_f<N>.ppm (shots),
// <prefix>_bg1..4.ppm/_obj.ppm (layers). View: ffmpeg -y -i x.ppm x.png

from "std/args" import {
    args
}
from "std/fs" import {
    writeFile, makeDir
}
from "std/io" import {
    readFile
}
from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, stepFrame, step, scratch, lastBadOp, lastBadOpPc
}
from "./spc" import {
    dspGenerate
}
from "./ppu" import {
    Ppu, renderFrame
}
from "./cartridge" import {
    loadCartridge
}
from "./savestate" import {
    loadState
}

fn atoi(s: &string): i64 {
    var v: i64 = 0
    for ch in s {
        let c = ch as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
        }
    }
    return v
}

fn hex2(v: i64): string {
    let d = "0123456789ABCDEF"
    var s = ""
    s.push(d[((v >> 4) & 0xF) as i64])
    s.push(d[(v & 0xF) as i64])
    return s
}

fn hex4(v: i64): string {
    return hex2((v >> 8) & 0xFF) + hex2(v & 0xFF)
}

// Auto-joypad bit for a button name (0 = unknown). Matches snes.milo's layout:
// B Y Sel St Up Dn Lt Rt A X L R from bit15 down.
fn buttonBit(name: &string): i64 {
    if name == "b" {
        return 0x8000
    }
    if name == "y" {
        return 0x4000
    }
    if name == "select" {
        return 0x2000
    }
    if name == "start" {
        return 0x1000
    }
    if name == "up" {
        return 0x0800
    }
    if name == "down" {
        return 0x0400
    }
    if name == "left" {
        return 0x0200
    }
    if name == "right" {
        return 0x0100
    }
    if name == "a" {
        return 0x0080
    }
    if name == "x" {
        return 0x0040
    }
    if name == "l" {
        return 0x0020
    }
    if name == "r" {
        return 0x0010
    }
    return 0
}

fn writePpm(fb: &Vec<i64>, path: &string): void {
    var out = String.withCapacity(200000)
    let hdr = "P6\n256 224\n255\n"
    var i: i64 = 0
    while i < hdr.len {
        out.push(hdr[i])
        i = i + 1
    }
    i = 0
    while i < 256 * 224 {
        let px = fb[i]
        out.push(((px >> 16) & 0xFF) as u8)
        out.push(((px >> 8) & 0xFF) as u8)
        out.push((px & 0xFF) as u8)
        i = i + 1
    }
    match writeFile(path, out) {
        Result.Ok(n) => {
            print("wrote " + path)
        }
        Result.Err(e) => {
            print("write failed: " + path)
        }
    }
}

fn layerNames(bits: i64): string {
    var s = ""
    if (bits & 0x01) != 0 {
        s = s + " BG1"
    }
    if (bits & 0x02) != 0 {
        s = s + " BG2"
    }
    if (bits & 0x04) != 0 {
        s = s + " BG3"
    }
    if (bits & 0x08) != 0 {
        s = s + " BG4"
    }
    if (bits & 0x10) != 0 {
        s = s + " OBJ"
    }
    if s == "" {
        s = " (none)"
    }
    return s
}

// Print the full PPU + MMIO picture with the "why is my screen wrong" bits
// called out explicitly. This is the first thing to read on any visual bug.
fn dumpRegs(m: &Mem, frame: i64): void {
    print("== regs @ frame " + frame.toString() + " ==")
    let bright = m.ppu.inidisp & 0x0F
    let fblank = (m.ppu.inidisp & 0x80) != 0
    var line = "INIDISP=$" + hex2(m.ppu.inidisp) + " brightness=" + bright.toString()
    if fblank {
        line = line + " FORCE-BLANK"
    }
    if bright == 0 || fblank {
        line = line + "   <<< SCREEN IS BLACK because of this register"
    }
    print(line)
    let mode = m.ppu.bgmode & 0x07
    print("BGMODE=$" + hex2(m.ppu.bgmode) + " mode=" + mode.toString())
    print("TM=$" + hex2(m.ppu.tm) + layerNames(m.ppu.tm) + "   TS=$" + hex2(m.ppu.ts) + layerNames(m.ppu.ts))
    var cm = "CGADSUB=$" + hex2(m.ppu.cgadsub)
    if (m.ppu.cgadsub & 0x80) != 0 {
        cm = cm + " SUBTRACT"
    } else {
        cm = cm + " add"
    }
    if (m.ppu.cgadsub & 0x40) != 0 {
        cm = cm + " half"
    }
    cm = cm + " on:" + layerNames(m.ppu.cgadsub & 0x1F)
    if (m.ppu.cgadsub & 0x20) != 0 {
        cm = cm + " backdrop"
    }
    print(cm + "   COLDATA r=" + m.ppu.coldR.toString() + " g=" + m.ppu.coldG.toString() + " b=" + m.ppu.coldB.toString())
    // CGRAM entry 0 = backdrop color (BGR555)
    let c0 = (m.ppu.cgram[0] as i64) | ((m.ppu.cgram[1] as i64) << 8)
    print("backdrop CGRAM[0]=$" + hex4(c0) + " (r=" + (c0 & 0x1F).toString() + " g=" + ((c0 >> 5) & 0x1F).toString() + " b=" + ((c0 >> 10) & 0x1F).toString() + ")")
    var bg: i64 = 0
    while bg < 4 {
        var sc = m.ppu.bgsc0
        if bg == 1 {
            sc = m.ppu.bgsc1
        }
        if bg == 2 {
            sc = m.ppu.bgsc2
        }
        if bg == 3 {
            sc = m.ppu.bgsc3
        }
        var nba = m.ppu.bg12nba
        if bg >= 2 {
            nba = m.ppu.bg34nba
        }
        var chBase = (nba & 0x0F) << 12
        if bg == 1 || bg == 3 {
            chBase = ((nba >> 4) & 0x0F) << 12
        }
        print("BG" + (bg + 1).toString() + ": map=$" + hex4((sc >> 2) << 10) + " size=" + (sc & 3).toString() + " char=$" + hex4(chBase) + " hofs=" + m.ppu.bghofs[bg].toString() + " vofs=" + m.ppu.bgvofs[bg].toString())
        bg = bg + 1
    }
    print("OBSEL=$" + hex2(m.ppu.obsel))
    if m.ppu.tmw != 0 || m.ppu.tsw != 0 || m.ppu.w12sel != 0 || m.ppu.w34sel != 0 {
        print("WIN: W12SEL=$" + hex2(m.ppu.w12sel) + " W34SEL=$" + hex2(m.ppu.w34sel) + " TMW=$" + hex2(m.ppu.tmw) + layerNames(m.ppu.tmw) + " TSW=$" + hex2(m.ppu.tsw) + " WH0=" + m.ppu.wh0.toString() + " WH1=" + m.ppu.wh1.toString())
    }
    if mode == 7 {
        print("M7: a=" + m.ppu.m7a.toString() + " b=" + m.ppu.m7b.toString() + " c=" + m.ppu.m7c.toString() + " d=" + m.ppu.m7d.toString() + " x=" + m.ppu.m7x.toString() + " y=" + m.ppu.m7y.toString() + " hofs=" + m.ppu.m7hofs.toString() + " vofs=" + m.ppu.m7vofs.toString())
    }
    let hdmaen = scratch(m, 0x420C)
    print("NMITIMEN=$" + hex2(m.nmitimen) + " HDMAEN($420C)=$" + hex2(hdmaen))
    if hdmaen != 0 {
        var ch: i64 = 0
        while ch < 8 {
            if ((hdmaen >> ch) & 1) != 0 {
                let base = 0x4300 + ch * 0x10
                let dmap = scratch(m, base + 0)
                let bbad = scratch(m, base + 1)
                let tab = scratch(m, base + 2) | (scratch(m, base + 3) << 8)
                let tbank = scratch(m, base + 4)
                let indirect = if (dmap & 0x40) != 0 {
                    " indirect"
                } else {
                    " direct"
                }
                print("  HDMA ch" + ch.toString() + " -> $" + hex4(0x2100 | bbad) + " pattern=" + (dmap & 7).toString() + indirect + " table=$" + hex2(tbank) + hex4(tab))
                ch = ch + 1
            } else {
                ch = ch + 1
            }
        }
    }
}

// forceBright: override INIDISP to full brightness (clears force-blank) before
// rendering — reveals whether the VRAM/layers are actually populated when the
// game is holding the screen black (fade stall vs genuinely-empty graphics).
fn renderTo(m: &mut Mem, fb: &mut Vec<i64>, path: &string, forceBright: bool): void {
    if forceBright {
        m.ppu.inidisp = 0x0F
        m.ppu.hdmaOn = false // ignore per-line HDMA brightness overrides too
    }
    var i: i64 = 0
    while i < 256 * 224 {
        fb[i] = 0
        i = i + 1
    }
    renderFrame(m.ppu, fb)
    writePpm(fb, path)
}

// Dump on-screen OAM sprites (X/Y in range) with decoded size/tile/pal/prio, so a
// missing or misplaced sprite is obvious. OBSEL bits 5-7 pick the size PAIR; the
// per-sprite high-table bit selects small vs large within it.
fn dumpOam(m: &Mem): void {
    let sizeSel = (m.ppu.obsel >> 5) & 0x07
    print("OAM (OBSEL=$" + hex2(m.ppu.obsel) + " sizeSel=" + sizeSel.toString() + "):")
    var shown: i64 = 0
    var s: i64 = 0
    while s < 128 {
        let oa = s * 4
        let xl = m.ppu.oam[oa] as i64
        let y = m.ppu.oam[oa + 1] as i64
        let tileL = m.ppu.oam[oa + 2] as i64
        let attr = m.ppu.oam[oa + 3] as i64
        let ht = m.ppu.oam[0x200 + (s >> 2)] as i64
        let shift = (s & 3) * 2
        let xhi = (ht >> shift) & 1
        let large = (ht >> (shift + 1)) & 1
        var sx = xl | (xhi << 8)
        if sx >= 256 {
            sx = sx - 512
        }
        if y < 224 && shown < 24 {
            print("  #" + s.toString() + " x=" + sx.toString() + " y=" + y.toString() + " tile=$" + hex4(tileL | ((attr & 1) << 8)) + " large=" + large.toString() + " pal=" + ((attr >> 1) & 7).toString() + " prio=" + ((attr >> 4) & 3).toString() + " flip=" + ((attr >> 6) & 3).toString())
            shown = shown + 1
        }
        s = s + 1
    }
    print("  (" + shown.toString() + " shown of on-screen sprites)")
    var raw = "  high-table[512..527]:"
    var h: i64 = 0
    while h < 16 {
        raw = raw + " " + hex2(m.ppu.oam[0x200 + h] as i64)
        h = h + 1
    }
    print(raw)
    var lo = "  sprite0-3 raw (x,y,t,a):"
    var b: i64 = 0
    while b < 16 {
        lo = lo + " " + hex2(m.ppu.oam[b] as i64)
        b = b + 1
    }
    print(lo)
}

// Dump a few low-WRAM bytes ($00xxxx mirror = m.wram[off]). Useful to check
// whether per-frame game variables (frame counters, player position, scroll) are
// advancing when the screen looks frozen.
fn peekWram(m: &Mem, addrs: &Vec<i64>): void {
    var s = "wram:"
    for a in addrs {
        s = s + " $" + hex2(a & 0xFF) + "=" + hex2(m.wram[a & 0x1FFFF] as i64)
    }
    print(s)
}

// Single-step N instructions from the current state and report the most-visited
// PCs. A tiny hot set spanning a few bytes = the CPU is spinning in a wait loop
// (fade/handshake stall); a broad spread = it's executing normally.
fn probeLoop(cpu: &mut Cpu, m: &mut Mem, n: i64): void {
    var pcs: Vec<i64> = Vec.new()
    var cnts: Vec<i64> = Vec.new()
    var k: i64 = 0
    while k < n {
        let full = (cpu.pbr << 16) | cpu.pc
        var idx: i64 = -1
        var t: i64 = 0
        while t < pcs.len {
            if pcs[t] == full {
                idx = t
                t = pcs.len
            } else {
                t = t + 1
            }
        }
        if idx >= 0 {
            cnts[idx] = cnts[idx] + 1
        } else {
            pcs.push(full)
            cnts.push(1)
        }
        step(cpu, m)
        k = k + 1
    }
    print("== probe: " + n.toString() + " instrs, " + pcs.len.toString() + " distinct PCs ==")
    var shown: i64 = 0
    while shown < 12 && shown < pcs.len {
        var best: i64 = -1
        var bestC: i64 = -1
        var u: i64 = 0
        while u < pcs.len {
            if cnts[u] > bestC {
                bestC = cnts[u]
                best = u
            }
            u = u + 1
        }
        if best >= 0 {
            print("  $" + hex2((pcs[best] >> 16) & 0xFF) + hex4(pcs[best] & 0xFFFF) + "  x" + bestC.toString())
            cnts[best] = -1
        }
        shown = shown + 1
    }
}

fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: dbg <rom.sfc> [--frames N] [--state f] [--press btn@a-b] [--shot f] [--layers] [--out prefix]")
        return 1
    }
    var frames: i64 = 8
    var statePath = ""
    var outPrefix = "/tmp/snes/dbg"
    var doLayers = false
    var forceBright = false
    var doProbe = false
    var doOam = false
    var doAudio = false
    var pressBits: Vec<i64> = Vec.new()
    var pressFrom: Vec<i64> = Vec.new()
    var pressTo: Vec<i64> = Vec.new()
    var shots: Vec<i64> = Vec.new()

    var ai: i64 = 2
    while ai < argv.len {
        let a = argv[ai].clone()
        if a == "--frames" && ai + 1 < argv.len {
            frames = atoi(argv[ai + 1])
            ai = ai + 2
        } else if a == "--state" && ai + 1 < argv.len {
            statePath = argv[ai + 1].clone()
            ai = ai + 2
        } else if a == "--out" && ai + 1 < argv.len {
            outPrefix = argv[ai + 1].clone()
            ai = ai + 2
        } else if a == "--shot" && ai + 1 < argv.len {
            shots.push(atoi(argv[ai + 1]))
            ai = ai + 2
        } else if a == "--layers" {
            doLayers = true
            ai = ai + 1
        } else if a == "--forcebright" {
            forceBright = true
            ai = ai + 1
        } else if a == "--probe" {
            doProbe = true
            ai = ai + 1
        } else if a == "--oam" {
            doOam = true
            ai = ai + 1
        } else if a == "--audio" {
            doAudio = true
            ai = ai + 1
        } else if a == "--press" && ai + 1 < argv.len {
            // parse btn@a-b
            let spec = argv[ai + 1].clone()
            var name = ""
            var lo = ""
            var hi = ""
            var part: i64 = 0
            for ch in spec {
                let c = ch as i64
                if c == 64 { // @
                    part = 1
                } else if c == 45 && part == 1 { // -
                    part = 2
                } else if part == 0 {
                    name.push(ch)
                } else if part == 1 {
                    lo.push(ch)
                } else {
                    hi.push(ch)
                }
            }
            let bit = buttonBit(name)
            if bit == 0 {
                print("unknown button: " + name)
                return 1
            }
            pressBits.push(bit)
            pressFrom.push(atoi(lo))
            pressTo.push(atoi(hi))
            ai = ai + 2
        } else {
            print("unknown flag: " + a)
            return 1
        }
    }

    let _ = makeDir("/tmp/snes", 493)

    var rom: Vec<u8> = Vec.new()
    var mapMode: i64 = 0
    match loadCartridge(argv[1]) {
        Result.Ok(cart) => {
            rom = cart.rom
            mapMode = cart.map
            print("loaded " + argv[1] + " (" + (if cart.map == 1 {
                "HiROM"
            } else {
                "LoROM"
            }
            ) + ")")
        }
        Result.Err(e) => {
            print("load failed: " + e)
            return 1
        }
    }

    var m = busNew(rom, mapMode)
    var cpu = newCpuReset(m)

    if statePath != "" {
        match readFile(statePath) {
            Result.Ok(data) => {
                if loadState(cpu, m, data) {
                    print("state loaded <- " + statePath)
                } else {
                    print("state file invalid: " + statePath)
                    return 1
                }
            }
            Result.Err(e) => {
                print("cannot read state: " + statePath)
                return 1
            }
        }
    }

    // SMW-useful low-WRAM vars: $13/$14 frame counters, $10 game-mode/NMI flag,
    // $94/$95 player X, $1A/$1B layer-1 scroll. Advancing = game logic is running.
    var peekAddrs: Vec<i64> = Vec.new()
    peekAddrs.push(0x10)
    peekAddrs.push(0x13)
    peekAddrs.push(0x14)
    peekAddrs.push(0x94)
    peekAddrs.push(0x1A)
    peekAddrs.push(0x1B)

    var fb: Vec<i64> = Vec.new()
    var i: i64 = 0
    while i < 256 * 224 {
        fb.push(0)
        i = i + 1
    }

    var f: i64 = 0
    while f < frames {
        var j: i64 = 0
        var pi: i64 = 0
        while pi < pressBits.len {
            if f >= pressFrom[pi] && f <= pressTo[pi] {
                j = j | pressBits[pi]
            }
            pi = pi + 1
        }
        m.joy1 = j
        stepFrame(cpu, m)
        for s in shots {
            if s == f {
                dumpRegs(m, f)
                peekWram(m, peekAddrs)
                renderTo(m, fb, outPrefix + "_f" + f.toString() + ".ppm", forceBright)
            }
        }
        f = f + 1
    }

    dumpRegs(m, frames)
    peekWram(m, peekAddrs)
    if doOam {
        dumpOam(m)
    }
    if doAudio {
        var abuf: Vec<i64> = Vec.new()
        var ai2: i64 = 0
        while ai2 < 535 * 2 {
            abuf.push(0)
            ai2 = ai2 + 1
        }
        dspGenerate(m.apuMem, abuf, 535)
        var amin: i64 = 0
        var amax: i64 = 0
        var anz: i64 = 0
        var k: i64 = 0
        while k < 535 * 2 {
            let s = abuf[k]
            if s != 0 {
                anz = anz + 1
            }
            if s < amin {
                amin = s
            }
            if s > amax {
                amax = s
            }
            k = k + 1
        }
        print("AUDIO: 535 samples, nonzero=" + anz.toString() + " min=" + amin.toString() + " max=" + amax.toString())
    }
    if lastBadOp() >= 0 {
        print("!! UNIMPLEMENTED OPCODE $" + hex2(lastBadOp()) + " at $" + hex2((lastBadOpPc() >> 16) & 0xFF) + hex4(lastBadOpPc() & 0xFFFF) + " — CPU derailed here")
    }
    if doProbe {
        probeLoop(cpu, m, 6000)
    }
    renderTo(m, fb, outPrefix + ".ppm", forceBright)

    if doLayers {
        // Isolate each layer by overriding TM/TS and re-rendering — reuses the
        // exact compositing path, so what you see is what the composite used.
        let savedTm = m.ppu.tm
        let savedTs = m.ppu.ts
        let enabled = savedTm | savedTs
        var bit: i64 = 0
        while bit < 5 {
            if (enabled & (1 << bit)) != 0 {
                m.ppu.tm = 1 << bit
                m.ppu.ts = 0
                let suffix = if bit == 4 {
                    "_obj"
                } else {
                    "_bg" + (bit + 1).toString()
                }
                renderTo(m, fb, outPrefix + suffix + ".ppm", forceBright)
            }
            bit = bit + 1
        }
        m.ppu.tm = savedTm
        m.ppu.ts = savedTs
    }
    return 0
}
