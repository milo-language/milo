// Capstone: a synthesized ROM whose CPU code DMAs a palette + tile into the PPU
// and configures BG1, run through the frame loop, then the rendered frame is
// written as a PPM. Exercises the whole stack: 65816 exec -> DMA -> PPU -> render.
//   milo run examples/apps/snes/romGfxDemo.milo   then open /tmp/snes_rom.ppm

from "std/fs" import {
    writeFile, makeDir
}
from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, stepFrame, vecZeros
}
from "./ppu" import {
    renderFrame
}

// Emit "LDA #imm ; STA $addr" (5 bytes); return the next offset.
fn ldaSta(rom: &mut Vec<u8>, o: i64, imm: i64, addr: i64): i64 {
    rom[o] = 0xA9 as u8
    rom[o + 1] = (imm & 0xFF) as u8
    rom[o + 2] = 0x8D as u8
    rom[o + 3] = (addr & 0xFF) as u8
    rom[o + 4] = ((addr >> 8) & 0xFF) as u8
    return o + 5
}

// Configure DMA channel 0 and fire it.
fn dma(rom: &mut Vec<u8>, o: i64, dmap: i64, bbad: i64, src: i64, size: i64): i64 {
    var p = o
    p = ldaSta(rom, p, dmap, 0x4300)
    p = ldaSta(rom, p, bbad, 0x4301)
    p = ldaSta(rom, p, src & 0xFF, 0x4302)
    p = ldaSta(rom, p, (src >> 8) & 0xFF, 0x4303)
    p = ldaSta(rom, p, 0x00, 0x4304)
    p = ldaSta(rom, p, size & 0xFF, 0x4305)
    p = ldaSta(rom, p, (size >> 8) & 0xFF, 0x4306)
    p = ldaSta(rom, p, 0x01, 0x420B)
    return p
}

fn main(): i32 {
    var rom = vecZeros(0x8000)
    var o: i64 = 0
    // CGADD=0 then DMA 32B palette ($8200) -> CGDATA ($2122)
    o = ldaSta(rom, o, 0x00, 0x2121)
    o = dma(rom, o, 0x00, 0x22, 0x8200, 0x20)
    // VMAIN=$80, VMADD=0, DMA 32B tile ($8300) -> VMDATA ($2118/$2119)
    o = ldaSta(rom, o, 0x80, 0x2115)
    o = ldaSta(rom, o, 0x00, 0x2116)
    o = ldaSta(rom, o, 0x00, 0x2117)
    o = dma(rom, o, 0x01, 0x18, 0x8300, 0x20)
    // BG1: mode 1, tilemap base word $0400, char base word 0, brightness 15
    o = ldaSta(rom, o, 0x01, 0x2105) // BGMODE
    o = ldaSta(rom, o, 0x04, 0x2107) // BG1SC -> tilemap word $0400
    o = ldaSta(rom, o, 0x00, 0x210B) // BG12NBA -> char base 0
    o = ldaSta(rom, o, 0x0F, 0x2100) // INIDISP brightness 15
    rom[o] = 0xEA as u8 // NOP (loop)
    rom[o + 1] = 0x80 as u8
    rom[o + 2] = 0xFD as u8 // BRA -3

    // Palette at $8200: color0 black; 1 red, 2 green, 3 blue, 4 yellow (BGR555).
    let pal = [0x00, 0x00, 0x1F, 0x00, 0xE0, 0x03, 0x00, 0x7C, 0xFF, 0x03]
    var i: i64 = 0
    while i < (pal.len as i64) {
        rom[0x200 + i] = pal[i] as u8
        i = i + 1
    }

    // Tile at $8300: horizontal 4-color stripes (rows cycle index 1,2,3,4).
    // plane0/1 (bytes 0-15), plane2/3 (bytes 16-31).
    let idx = [1, 2, 3, 4, 1, 2, 3, 4]
    var row: i64 = 0
    while row < 8 {
        let k = idx[row] as i64
        rom[0x300 + row * 2] = (if (k & 1) != 0 {
            0xFF
        } else {
            0x00
        }
        ) as u8
        rom[0x300 + row * 2 + 1] = (if (k & 2) != 0 {
            0xFF
        } else {
            0x00
        }
        ) as u8
        rom[0x300 + 16 + row * 2] = (if (k & 4) != 0 {
            0xFF
        } else {
            0x00
        }
        ) as u8
        rom[0x300 + 16 + row * 2 + 1] = 0x00 as u8
        row = row + 1
    }

    rom[0x7FFC] = 0x00 as u8
    rom[0x7FFD] = 0x80 as u8 // reset -> $8000

    var m = busNew(rom, 0)
    var cpu = newCpuReset(m)
    var f: i64 = 0
    while f < 3 {
        stepFrame(cpu, m)
        f = f + 1
    }

    var fb: Vec<i64> = Vec.new()
    i = 0
    while i < 256 * 224 {
        fb.push(0)
        i = i + 1
    }
    renderFrame(m.ppu, fb)

    var out = String.withCapacity(200000)
    let hdr = "P6\n256 224\n255\n"
    i = 0
    while i < hdr.len {
        out.push(hdr[i])
        i = i + 1
    }
    i = 0
    while i < 256 * 224 {
        let px = fb[i]
        out.push(((px >> 16) & 0xFF) as u8)
        out.push(((px >> 8) & 0xFF) as u8)
        out.push((px & 0xFF) as u8)
        i = i + 1
    }
    let _ = makeDir("/tmp/snes", 493)
    match writeFile("/tmp/snes/frame.ppm", out) {
        Result.Ok(n) => {
            print("OK: ran a ROM (CPU->DMA->PPU->frame) -> /tmp/snes/frame.ppm")
            return 0
        }
        Result.Err(e) => {
            print("write failed")
            return 1
        }
    }
}
