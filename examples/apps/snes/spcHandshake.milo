// M3 handshake smoke: boot the SPC700 into its IPL ROM and confirm it posts the
// $AA (port 0) / $BB (port 1) ready signal the main CPU polls at $2140/$2141.
//   milo run examples/apps/snes/spcHandshake.milo

from "./spc" import {
    Spc, SpcMem, spcMemReal, spcReset, spcStep, apuReadPort
}

fn hex2(v: i64): string {
    let d = "0123456789ABCDEF"
    var s = ""
    s.push(d[(v >> 4) & 0xF]) s.push(d[v & 0xF])
    return s
}

fn main(): i32 {
    var m = spcMemReal()
    var spc = Spc {
        a: 0, x: 0, y: 0, sp: 0, pc: 0, psw: 0
    }
    spcReset(spc, m)
    print("SPC reset PC = $" + hex2((spc.pc >> 8) & 0xFF) + hex2(spc.pc & 0xFF) + " (want $FFC0)")

    // Run the IPL until it posts the ready bytes (or give up).
    var i: i64 = 0
    while i < 200000 {
        spcStep(spc, m)
        if apuReadPort(m, 0) == 0xAA && apuReadPort(m, 1) == 0xBB {
            break
        }
        i = i + 1
    }

    let p0 = apuReadPort(m, 0)
    let p1 = apuReadPort(m, 1)
    print("port0 ($2140) = $" + hex2(p0) + "  port1 ($2141) = $" + hex2(p1) + "  after " + hex2(i & 0xFF) + "xx steps")
    if p0 == 0xAA && p1 == 0xBB {
        print("OK: SPC700 IPL handshake ready ($AA/$BB posted)")
        return 0
    }
    print("FAIL")
    return 1
}
