extern fn usleep(usec: u32): i32

// NOTE: module-scope string initializers are NYI in Milo and silently produce
// "" — every one of these is assigned in main() before any request is served.
var binPath: string = ""
var srcPath: string = ""
var adapterCmd: string = "" // full command line, first token resolved via PATH
var adapterKind: string = "" // dialect kind (lldb|python|node|go) — selects launch/init dialect, see Dialect registry
var stopAtMain: bool = false // per-run (set from the run cmd): break at main / first user line
var excFiltersJson: string = "" // JSON array of selected exception filter ids ("" = none)
var launchExtra: string = "" // JSON object merged verbatim into the launch/attach request
// config = a VS Code launch-configuration object. Meta keys
// (type/request/name/source/dapPath/stopAtMain/program/port/host) are extracted
// into globals; every other key lowers verbatim into launchExtra (the DAP body).
var gConfigStopAtMain: bool = false // stopAtMain persisted from config (run cmd can override)
var gRequest: string = "" // "launch" (default, incl. "") | "attach" — selects the DAP command
var gConfigName: string = "" // optional launch-config "name" label — shown in history
var gDapPathRaw: string = "" // user's explicit "dapPath" verbatim ("" = probed) — config echo only
var gDapHost: string = "" // TCP transport host (gDapPort>0); "" = stdio spawn
var gDapPort: i64 = 0 // TCP transport port; 0 = spawn adapterCmd over stdio
// A force-run's config, applied after the old session's teardown completes
// (D's terminated cleanup consumes it; "" = rerun the current config).
var gPendingConfig: string = ""
var gPendingStopAtMain: bool = false // the force-run's per-run stopAtMain
var gHistory: string = "" // config history JSON array, newest first, cap 10 — persisted to XDG state (init "[]" in main)
var gRestored: bool = false // booted idle and staged history[0] (banner hint)
// Set when a forced run must kill+rerun (a new config can't ride a live
// adapter). D's terminated cleanup honors it by re-spawning once the old
// debuggee is gone.
var gPendingRun: bool = false

// Shared session: ONE debug session per server process, any number of WS
// peers (browser tabs + MCP co-debugger) all seeing identical broadcast state.
// Green runtime = one OS thread, cooperative scheduling — plain globals are
// race-free at yield-point granularity (same argument as the config globals).
// All assigned in main() before any request is served (module init NYI).
var gStarted: bool = false
var gDapIn: i32 = -1
var gPtyFd: i32 = -1
var gOddSeq: i64 = -1 // +2 per R send → 1, 3, 5, … (D's DapClient uses even)
var gStdinBuf: string = "" // keystrokes typed before the pty exists
// Recent adapter stderr, captured off the DAP stream (see startArgs). Surfaced
// only when the adapter dies before the handshake completes — otherwise silence.
// Bounded to the first chunk that matters (a startup traceback); reset each run.
var gAdapterStderr: string = ""
var gCapsMsg: string = "" // last capabilities push — replayed to late joiners
var gStopMsg: string = "" // last stopped push while still stopped — replayed
var gThreadsMsg: string = "" // last threads push while stopped — replayed
var gRegionsMsg: string = "" // last memory-region push while stopped — replayed (region colors)
// recent terminal output (debugger console + program stdout/stderr),
// replayed to a joining tab so startup chatter and history survive reload /
// late join. Bounded — a non-pty adapter routes ALL program output here.
var gOutputLog: Vec<OutLine> = []
let OUTLOG_MAX: i64 = 400
var gNextClient: i64 = 1
var gBps: Vec<Bp> = [] // shared breakpoint set (was per-connection before the shared session)
var gSessionId: string = "" // uuid in hello — a reloaded tab detects same-vs-new session
var gPeers: i64 = 0 // attached WS peers (browser tabs + MCP co-debuggers)
var gLastDetachMs: i64 = 0 // epochMillis when the last peer left — idle-ttl clock
var gIdleTtlSecs: i64 = 0 // --idle-ttl; 0 = never reap
var gTickWr: i32 = -1 // reaper pipe write end (ticker OS thread → green task)
var gTickUsecs: i64 = 0
var webroot: string = "" // UI bundle dir served from disk (--webroot)
var Q: string = ""
// lifecycle log. 0 = --quiet (banner only), 1 = normal, 2 = --verbose
// (adds per-stop lines). Runtime events go to stdout — a server should read
// like a server; stderr stays for errors.
var gLogLevel: i64 = 0
var gRunStartMs: i64 = 0 // epochMillis at adapter spawn — run duration
var gLastExit: i64 = -1 // debuggee exitCode from the "exited" event; -1 = unknown

// A browser-set breakpoint. Keyed by (path, line); empty
// condition/hitCondition/logMessage mean a plain breakpoint — the keys are
// omitted from the DAP request.
struct Bp {
    path: string,
    line: i64,
    condition: string,
    hitCondition: string,
    logMessage: string,
    // Disabled bps stay in the list (and in bpSync) but are omitted from the
    // DAP request — DAP has no per-bp enable, absence IS disable.
    enabled: bool,
}

// one buffered terminal line for late-join replay.
struct OutLine {
    text: string,
    category: string,
}

fn cloneBp(b: &Bp): Bp {
    return Bp {
        path: b.path.clone(),
        line: b.line,
        condition: b.condition.clone(),
        hitCondition: b.hitCondition.clone(),
        logMessage: b.logMessage.clone(),
        enabled: b.enabled,
    }
}

fn bpPaths(bps: &Vec<Bp>, fallback: &string): Vec<string> {
    var out: Vec<string> = []
    for bp in bps {
        var seen = false
        for p in out {
            if p == bp.path {
                seen = true
            }
        }
        if !seen {
            out.push(bp.path.clone())
        }
    }
    // Always at least one setBreakpoints per session so clearing the last bp
    // live actually clears it adapter-side.
    if out.len == 0 {
        out.push(fallback.clone())
    }
    return out
}

// A request R sent whose response D must route back to the browser.
struct Pending {
    seq: i64,
    kind: string, // initialize | eval | expand | bpLive | (D-internal: launch, sbInit, st, sc, vars)
    id: i64, // browser correlation id for eval/expand
    extra: string, // initialize: the setBreakpoints args JSON built from R's list
}

// ── JSON helpers ──

fn firstThreadId(raw: &string): i64 {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(b) = doc.get("body") {
            if let Option.Some(ts) = b.get("threads") {
                if let Option.Some(t) = ts.at(0) {
                    return t.i64("id") ?? (-1 as i64)
                }
            }
        }
    }
    return -1 as i64
}

// stackTrace body → [{"id":..,"name":..,"line":..,"path":..}] for the UI.
// path may be "" (no debug info / synthetic frame) — the UI skips navigation.
fn framesJson(raw: &string): string {
    var arr = jsonArr()
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            if let Option.Some(framesArr) = body.get("stackFrames") {
                let n = framesArr.len()
                var i: i64 = 0
                while i < n {
                    if let Option.Some(f) = framesArr.at(i) {
                        var path: string = ""
                        if let Option.Some(src) = f.get("source") {
                            path = src.str("path") ?? ""
                        }
                        arr = arr.obj(jsonObj().int("id", f.i64("id") ?? (0 as i64)).str("name", f.str("name") ?? "?").int("line", f.i64("line") ?? (0 as i64)).str("path", path).str("ipRef", f.str("instructionPointerReference") ?? ""))
                    }
                    i = i + 1
                }
            }
        }
    }
    return arr.build()
}

// variables body → [{"name":..,"value":..,"ref":..}] (ref>0 ⇒ expandable).
// Parse `memory region --all` console text → [{s,e,p,n}] (start/end hex kept as
// strings so the client parses them; p = perms "rw-", n = segment name if lldb
// gave one, e.g. "__TEXT"/"__DATA_CONST", else ""). Line shape:
//   [0x0000000100000000-0x0000000100004000) r-x __TEXT
// The client bins each region into a type (stack/heap/code/const/data) — it
// needs sp for the stack case, which only it has.
fn regionsJson(txt: &string): string {
    var arr = jsonArr()
    let lines = strSplit(txt.clone(), "\n")
    var li: i64 = 0
    while li < lines.len {
        let line = strTrim(lines[li].clone())
        li = li + 1
        if !strStartsWith(line, "[0x") {
            continue
        }
        let dash = strIndexOf(line, "-")
        let close = strIndexOf(line, ")")
        if dash < 0 || close < 0 {
            continue
        }
        let start = line.substr(1, dash) // drop leading '['
        let end = line.substr(dash + 1, close)
        let rest = strTrim(line.substr(close + 1, line.len)) // "r-x __TEXT" | "rw-" | "---"
        let toks = strSplitWhitespace(rest)
        if toks.len == 0 {
            continue
        }
        var name: string = ""
        if toks.len > 1 {
            name = toks[1].clone()
        }
        arr = arr.obj(jsonObj().str("s", start).str("e", end).str("p", toks[0].clone()).str("n", name))
    }
    return arr.build()
}

fn localsJson(raw: &string): string {
    var arr = jsonArr()
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            let n = body.childLen("variables")
            var i: i64 = 0
            while i < n {
                arr = arr.obj(jsonObj().str("name", body.childStrAt("variables", i, "name") ?? "?").str("value", body.childStrAt("variables", i, "value") ?? "?")
                // DWARF-derived type (e.g. "int", "Node *", "double") when the
                // adapter supplies it; "" for register scopes and untyped values.
                    .str("type", body.childStrAt("variables", i, "type") ?? "").int("ref", body.childI64At("variables", i, "variablesReference") ?? (0 as i64)).str("mref", body.childStrAt("variables", i, "memoryReference") ?? ""))
                i = i + 1
            }
        }
    }
    return arr.build()
}

// disassemble body → [{"addr":..,"text":..,"sym":..}] for the asm pane.
fn disasmJson(raw: &string): string {
    var arr = jsonArr()
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            let n = body.childLen("instructions")
            var i: i64 = 0
            while i < n {
                arr = arr.obj(jsonObj().str("addr", body.childStrAt("instructions", i, "address") ?? "").str("text", body.childStrAt("instructions", i, "instruction") ?? "").str("sym", body.childStrAt("instructions", i, "symbol") ?? "").int("line", body.childI64At("instructions", i, "line") ?? (0 as i64)))
                i = i + 1
            }
        }
    }
    return arr.build()
}

// completions body → [{"label":..,"text":..}] (text falls back to label).
fn completionsJson(raw: &string): string {
    var arr = jsonArr()
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            let n = body.childLen("targets")
            var i: i64 = 0
            while i < n {
                let label = body.childStrAt("targets", i, "label") ?? ""
                var text = body.childStrAt("targets", i, "text") ?? ""
                if text.len == 0 {
                    text = label.clone()
                }
                arr = arr.obj(jsonObj().str("label", label).str("text", text))
                i = i + 1
            }
        }
    }
    return arr.build()
}

// threads body → [{"id":..,"name":..}] for the threads panel.
fn threadsJson(raw: &string): string {
    var arr = jsonArr()
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            let n = body.childLen("threads")
            var i: i64 = 0
            while i < n {
                arr = arr.obj(jsonObj().int("id", body.childI64At("threads", i, "id") ?? (0 as i64)).str("name", body.childStrAt("threads", i, "name") ?? "?"))
                i = i + 1
            }
        }
    }
    return arr.build()
}

// The register scope's variablesReference, or 0 if the adapter exposes none.
// lldb-dap tags it presentationHint "registers"; debugpy has no such scope, so
// a 0 here is what gates the UI's Registers panel (no register-cap flag in DAP).
fn registersScopeRef(raw: &string): i64 {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(body) = doc.get("body") {
            let n = body.childLen("scopes")
            var i: i64 = 0
            while i < n {
                let hint = body.childStrAt("scopes", i, "presentationHint") ?? ""
                let name = body.childStrAt("scopes", i, "name") ?? ""
                if hint == "registers" || name == "Registers" {
                    return body.childI64At("scopes", i, "variablesReference") ?? (0 as i64)
                }
                i = i + 1
            }
        }
    }
    return 0 as i64
}

// ── Inbound browser command fields ──

fn jStr(raw: &string, key: &string): string {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        return doc.str(key) ?? ""
    }
    return ""
}

fn jBool(raw: &string, key: &string, fallback: bool): bool {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        return doc.bool(key) ?? fallback
    }
    return fallback
}

fn jI64(raw: &string, key: &string, fallback: i64): i64 {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        return doc.i64(key) ?? fallback
    }
    return fallback
}

// `key`'s value as raw JSON if it's an object, else "" (run's inline config).
fn jObjRaw(raw: &string, key: &string): string {
    if let Result.Ok(doc) = jsonParse(raw.clone()) {
        if let Option.Some(v) = doc.get(key) {
            if v.isObject() {
                return v.rawStr()
            }
        }
    }
    return ""
}

// ── Lifecycle log ──

// One line per session event: `HH:MM:SS <event> <details>`. Event column
// padded so details align.
fn logEvent(event: &string, details: &string): void {
    if gLogLevel < 1 {
        return
    }
    let dt = dateTimeLocalNow()
    print($"{dateTimeFormatTime(dt)} {strPadEnd(event, 18, " ")}{details}")
    flush()
}

fn peerCountStr(): string {
    if gPeers == 1 {
        return "(1 peer)"
    }
    return $"({gPeers} peers)"
}

// ── Outbound WS funnel ──

// Enqueue and poke the writer awake via the self-pipe. trySend so a stuffed
// channel can never block (and stall) the scheduler; drops are loud.
fn wsPush(ch: &Channel<string>, wakeWr: i32, msg: string): void {
    if ch.trySend(msg) {
        var one: [u8; 1] = [110; 1]
        unsafe {
            let _n = write(wakeWr, one as *u8, 1)
        }
    } else {
        eprint("[srv] ws out channel full, dropping frame\n")
    }
}

// W: sole socket writer. Parks on the wake pipe, drains the channel.
fn wsWriterLoop(fd: i32, ch: Channel<string>, wakeRd: i32): void {
    // Borrowed copy of the conn: _closed=true so Drop skips teardown (R owns
    // the real one). sendText itself doesn't consult _closed.
    var conn = WsConn {
        fd: fd, ssl: 0, _ctx: 0, _closed: true, _isClient: false
    }
    var buf: [u8; 64] = [0; 64]
    while true {
        var n: i64 = 0
        unsafe {
            schedulerWaitRead(wakeRd)
            n = read(wakeRd, buf as *u8, 64)
        }
        if n <= 0 {
            break
        } // R closed the wake pipe: session over
        while true {
            match ch.tryRecv() {
                Option.Some(m) => {
                    let _r = conn.sendText(m)
                }
                Option.None => {
                    break
                }
            }
        }
    }
    unsafe {
        close(wakeRd)
    }
}

// one broadcaster fans the session bus out to every connected peer. Peers
// register/unregister through regCh (alive=false unregisters by id); both the
// bus and regCh share busWake. Dead peers just fill a bounded channel until
// their unregister lands — trySend keeps that harmless.
struct Sink {
    id: i64,
    ch: Channel<string>,
    wakeWr: i32,
    alive: bool,
}

fn broadcastLoop(bus: Channel<string>, busWakeRd: i32, regCh: Channel<Sink>): void {
    var sinks: Vec<Sink> = []
    var buf: [u8; 64] = [0; 64]
    while true {
        var n: i64 = 0
        unsafe {
            schedulerWaitRead(busWakeRd)
            n = read(busWakeRd, buf as *u8, 64)
        }
        if n <= 0 {
            break
        }
        while true {
            match regCh.tryRecv() {
                Option.Some(s) => {
                    if s.alive {
                        sinks.push(s)
                    } else {
                        // Sole writer at unregister time — safe to close the
                        // departed peer's wake fd here (EOFs its writer task).
                        unsafe {
                            close(s.wakeWr)
                        }
                        var keep: Vec<Sink> = []
                        var i: i64 = 0
                        while i < sinks.len {
                            if sinks[i].id != s.id {
                                keep.push(Sink {
                                    id: sinks[i].id, ch: sinks[i].ch, wakeWr: sinks[i].wakeWr, alive: true
                                }
                                )
                            }
                            i = i + 1
                        }
                        sinks = keep
                    }
                }
                Option.None => {
                    break
                }
            }
        }
        while true {
            match bus.tryRecv() {
                Option.Some(m) => {
                    for sink in sinks {
                        wsPush(sink.ch, sink.wakeWr, m.clone())
                    }
                }
                Option.None => {
                    break
                }
            }
        }
    }
}

// P: pty master → browser terminal. fdChannel owns the read/EAGAIN pump; we just
// wrap each chunk and forward.
fn ptyPumpLoop(master: i32, ch: Channel<string>, wakeWr: i32): void {
    for chunk in fdChannel(master) {
        wsPush(ch, wakeWr, jsonObj().str("type", "ptyData").str("data", chunk).build())
    }
}

// Drain the adapter's stderr so the pipe never fills (mergeStderr=false) and
// stash the head of it for the pre-handshake death diagnostic. Cap at 8 KB —
// a Python traceback / lldb-dap gripe fits; a chatty adapter can't grow it
// unbounded. Also echoed to the server log so it's visible there too.
fn adapterStderrPump(errFd: i32): void {
    for chunk in fdChannel(errFd) {
        eprint("[adapter] " + chunk)
        if gAdapterStderr.len < 8192 {
            gAdapterStderr = gAdapterStderr + chunk
        }
    }
}

// ── Simple outbound messages ──

fn helloMsg(): string {
    // `config` is THE canonical launch-config object (what the editor shows and
    // resolveConfig accepts back verbatim); program/adapterCmd ride alongside as
    // display conveniences (toolbar span, ⓘ adapter line).
    var b = jsonObj().str("type", "hello")
        .str("program", binPath.clone())
        .str("sourcePath", srcPath.clone())
        .str("adapterCmd", adapterCmd.clone())
        .str("adapterId", adapterId())
        .str("sessionId", gSessionId.clone())
        .raw("config", specConfigJson(curSpec(), true, 0 as i64))
    // late joiners need to know a session is live (kill-confirm on Run etc.);
    // a replayed stopped snapshot then refines running → stopped.
    if gStarted {
        b = b.str("phase", "running")
    }
    b = b.raw("history", gHistory.clone())
    if gRestored {
        b = b.bool("restored", true)
    }
    return b.build()
}

// full bp state for a late-joining peer (acks are optimistic client-side).
fn bpSyncMsg(b: &Bp): string {
    return jsonObj().str("type", "bpSync")
        .str("path", b.path.clone()).int("line", b.line)
        .str("condition", b.condition.clone())
        .str("hitCondition", b.hitCondition.clone())
        .str("logMessage", b.logMessage.clone())
        .bool("enabled", b.enabled)
        .build()
}

fn configErrMsg(err: &string): string {
    return jsonObj().str("type", "configError").str("error", err.clone()).build()
}

fn sourceMsg(path: &string): string {
    var content: string = ""
    match readFile(path) {
        Result.Ok(text) => {
            content = text
        }
        Result.Err(_e) => {
            // Frames without debug info (libc, dyld) report symbol pseudo-paths
            // like "/usr/lib/dyld`dyld4::...". Show a friendly placeholder
            // until the disassembly view exists.
            content = "// no source available for this frame:\n//   " + path.clone()
            + "\n// (no debug info — try `disassemble --frame` in the Debug Console)"
        }
    }
    return jsonObj().str("type", "source")
        .str("path", path.clone())
        .str("content", content)
        .build()
}

fn terminatedMsg(): string {
    return jsonObj().str("type", "terminated").build()
}

fn bpAckMsg(line: i64, set: bool): string {
    return jsonObj().str("type", "breakpoint").int("line", line).bool("set", set).build()
}

fn outputMsg(raw: &string): string {
    // DAP category ("stdout"/"stderr"/"console"/"important"/…) lets the merged
    // terminal color program output apart from debugger chatter.
    return jsonObj().str("type", "output")
        .str("text", bodyStr(raw, "output"))
        .str("category", bodyStr(raw, "category"))
        .build()
}

// ── DAP request framing for R (odd seqs; D's DapClient uses even) ──

fn sendReqFd(fd: i32, seq: i64, command: &string, argsJson: &string): void {
    let payload = jsonObj().int("seq", seq).str("type", "request")
        .str("command", command.clone()).raw("arguments", argsJson.clone()).build()
    let _w = writeFrameFd(fd, payload)
}

// setBreakpoints args for one file (breakpoints are per-source in DAP).
fn buildBpArgsForPath(bps: &Vec<Bp>, path: &string): string {
    var arr = jsonArr()
    for bp in bps {
        if bp.path == path && bp.enabled {
            var o = jsonObj().int("line", bp.line)
            if bp.condition.len > 0 {
                o = o.str("condition", bp.condition.clone())
            }
            if bp.hitCondition.len > 0 {
                o = o.str("hitCondition", bp.hitCondition.clone())
            }
            if bp.logMessage.len > 0 {
                o = o.str("logMessage", bp.logMessage.clone())
            }
            arr = arr.obj(o)
        }
    }
    return jsonObj()
        .obj("source", jsonObj().str("path", path.clone()))
        .arr("breakpoints", arr)
        .build()
}

// Session-init bundle: [{"args": <setBreakpoints-json>}] — one entry per file
// with bps. D replays these during the initialized event (kind sbInit each).
fn buildAllBpArgs(bps: &Vec<Bp>): string {
    var arr = jsonArr()
    let paths = bpPaths(bps, srcPath)
    for path in paths {
        arr = arr.obj(jsonObj().str("args", buildBpArgsForPath(bps, path)))
    }
    return arr.build()
}

// setExceptionBreakpoints args from the selected filter ids.
fn excArgs(): string {
    var filters: string = "[]"
    if excFiltersJson.len > 0 {
        filters = excFiltersJson.clone()
    }
    return jsonObj().raw("filters", filters).build()
}

// Session config + adapter dialect + launch/init bodies live in ../dap/session
// (shared with standalone mcp). These wrappers bind the shared, value-based fns
// to this driver's session globals.
fn adapterId(): string {
    return adapterIdForKind(adapterKind)
}

fn initArgs(): string {
    return initArgsFor(adapterKind)
}

fn launchRequest(): string {
    return launchRequestOf(curSpec())
}

// snapshot the session globals as the value the shared launch builders consume.
fn curSpec(): LaunchSpec {
    return LaunchSpec {
        binPath: binPath.clone(), srcPath: srcPath.clone(),
        adapterCmd: adapterCmd.clone(), adapterKind: adapterKind.clone(),
        launchExtra: launchExtra.clone(), stopAtMain: gConfigStopAtMain,
        request: gRequest.clone(), host: gDapHost.clone(), port: gDapPort,
        name: gConfigName.clone(), dapPath: gDapPathRaw.clone(),
    }
}

// Apply a config (VS Code launch-configuration object) into this session while
// idle: resolve to a LaunchSpec via the shared module, commit into the session
// globals, and reset per-session state. Returns "" on success or a user-facing
// error. Caller broadcasts hello/source. Running sessions stage instead (see
// setConfig handler); this must only run single-threaded on the green runtime.
fn applyConfig(raw: string, selectName: string): string {
    match resolveConfig(raw, selectName) {
        Result.Ok(spec) => {
            binPath = spec.binPath.clone()
            srcPath = spec.srcPath.clone()
            adapterCmd = spec.adapterCmd.clone()
            adapterKind = spec.adapterKind.clone()
            launchExtra = spec.launchExtra.clone()
            gConfigStopAtMain = spec.stopAtMain
            gRequest = spec.request.clone()
            gConfigName = spec.name.clone()
            gDapPathRaw = spec.dapPath.clone()
            gDapHost = spec.host.clone()
            gDapPort = spec.port
            gBps = []
            gOutputLog = []
            return ""
        }
        Result.Err(e) => {
            return e
        }
    }
}

// Gap-fill CLI flags into a --launch config object: --program/--source fill in
// when the config lacks them, so `--launch '{"args":[...]}' --program /x` still
// composes. A {version, configurations:[...]} wrapper is a self-contained
// launch.json file and passes through untouched.
fn mergeCliDefaults(text: string, prog: &string, src: &string): string {
    match jsonParseJsonc(text.clone()) {
        Result.Ok(d) => {
            if !d.isObject() {
                return text
            }
            if let Option.Some(_c) = d.get("configurations") {
                return text
            }
            var hasProg = false
            var hasSrc = false
            var b = jsonObj()
            let ks = d.keys()
            for k in ks {
                if k == "program" {
                    hasProg = true
                }
                if k == "source" {
                    hasSrc = true
                }
                match d.get(k) {
                    Option.Some(v) => {
                        b = b.raw(k.clone(), v.rawStr())
                    }
                    Option.None => {
                    }
                }
            }
            if !hasProg && prog.len > 0 {
                b = b.str("program", prog.clone())
            }
            if !hasSrc && src.len > 0 {
                b = b.str("source", src.clone())
            }
            return b.build()
        }
        Result.Err(_e) => {
            return text
        }
    }
}

// ── Config history (server-side, single-writer; §4) ──
//
// The server is the ONE writer: it appends on a successful run launch, persists
// to XDG state, and broadcasts historyChanged. Clients only read (via hello +
// the broadcast), which kills the old client-local dupe (drawer + hello both
// saved). $XDG_STATE_HOME/hades/history.json, default ~/.local/state/hades.

fn histDir(): string {
    if let Option.Some(x) = getEnv("XDG_STATE_HOME") {
        if x.len > 0 {
            return x + "/hades"
        }
    }
    return getEnvOr("HOME", "") + "/.local/state/hades"
}

fn histFilePath(): string {
    return histDir() + "/history.json"
}

// mkdir -p: create each ancestor in turn, ignoring already-exists errors (0755).
fn ensureDir(path: &string): void {
    var cur: string = ""
    for ch in path {
        if ch == '/' {
            if cur.len > 0 {
                let _r = makeDir(cur.clone(), 493 as i32)
            }
            cur.push(ch)
        } else {
            cur.push(ch)
        }
    }
    if cur.len > 0 {
        let _r = makeDir(cur.clone(), 493 as i32)
    }
}

// Read history at boot. Missing/corrupt file → empty (never fatal).
fn loadHistory(): void {
    let p = histFilePath()
    if !pathExists(p) {
        gHistory = "[]"
        return
    }
    gHistory = "[]"
    if let Result.Ok(s) = readFile(p) {
        if let Result.Ok(d) = jsonParse(s.clone()) {
            if d.isArray() {
                gHistory = s
            }
        }
    }
}

fn persistHistory(): void {
    ensureDir(histDir())
    let _r = writeFile(histFilePath(), gHistory)
}

// Append the current session config to history on a launch (dedup + cap 10),
// persist, and return the broadcast so the caller can push it to all peers.
fn appendHistory(): string {
    gHistory = histInsert(gHistory, histEntryFor(curSpec(), epochMillis()), 10 as i64)
    persistHistory()
    return historyChangedMsg()
}

fn historyChangedMsg(): string {
    return jsonObj().str("type", "historyChanged").raw("history", gHistory.clone()).build()
}

// history[0] as a re-appliable config object, or None if history is empty.
fn firstHistoryConfig(): Option<string> {
    if let Result.Ok(d) = jsonParse(gHistory.clone()) {
        if d.isArray() && d.len() > 0 {
            if let Option.Some(el) = d.at(0 as i64) {
                return Option.Some(el.rawStr())
            }
        }
    }
    return Option.None
}

// launch/init bodies + adapter argv come from the shared session module; these
// bind them to this driver's globals (stopAtMain is the per-run override).
fn launchArgs(): string {
    return launchArgsFor(curSpec(), stopAtMain)
}

fn adapterArgv(): Vec<string> {
    return adapterArgvOf(adapterCmd)
}

// ── D: the DAP-reader task ──

fn removePending(pend: &Vec<Pending>, idx: i64): Vec<Pending> {
    var keep: Vec<Pending> = []
    var i: i64 = 0
    while i < pend.len {
        if i != idx {
            keep.push(Pending {
                seq: pend[i].seq, kind: pend[i].kind.clone(),
                id: pend[i].id, extra: pend[i].extra.clone(),
            }
            )
        }
        i = i + 1
    }
    return keep
}

// runInTerminal reverse request → spawn debuggee in a std/pty, reply with the
// pid, start the pump. env vars are honored by exec'ing through /usr/bin/env
// (lldb-dap's launcher handshake rides on env vars, so dropping them breaks it).
fn handleRunInTerminal(cl: &mut DapClient, raw: &string, reqSeq: i64, ch: Channel<string>, wakeWr: i32): i32 {
    var argv: Vec<string> = []
    var envs: Vec<string> = []
    match jsonParse(raw.clone()) {
        Result.Ok(doc) => {
            match doc.get("arguments") {
                Option.Some(a) => {
                    match a.get("args") {
                        Option.Some(arr) => {
                            let n = arr.len()
                            var i: i64 = 0
                            while i < n {
                                match arr.at(i) {
                                    Option.Some(el) => {
                                        argv.push(el.asStr() ?? "")
                                    }
                                    Option.None => {
                                    }
                                }
                                i = i + 1
                            }
                        }
                        Option.None => {
                        }
                    }
                    match a.get("env") {
                        Option.Some(env) => {
                            let keys = env.keys()
                            for key in keys {
                                let v = env.str(key) ?? ""
                                envs.push(key.clone() + "=" + v)
                            }
                        }
                        Option.None => {
                        }
                    }
                }
                Option.None => {
                }
            }
        }
        Result.Err(_e) => {
        }
    }
    if argv.len == 0 {
        return -1
    }

    var program: string = argv[0].clone()
    var args: Vec<string> = []
    if envs.len > 0 {
        program = "/usr/bin/env"
        for e in envs {
            args.push(e.clone())
        }
        for a in argv {
            args.push(a.clone())
        }
    } else {
        var i: i64 = 1
        while i < argv.len {
            args.push(argv[i].clone())
            i = i + 1
        }
    }

    match Pty.open() {
        Result.Ok(p) => {
            var pty = p
            match pty.spawn(program, args) {
                Result.Ok(pid) => {
                    logEvent("debuggee spawned", $"pid {pid}")
                    cl.respond(reqSeq, "runInTerminal", jsonObj().int("processId", pid as i64).build())
                    let master = pty.masterFd
                    // direct global set (same scheduler thread) — and flush
                    // any keystrokes typed while the adapter was launching.
                    gPtyFd = master
                    if gStdinBuf.len > 0 {
                        unsafe {
                            let _n = write(master, gStdinBuf, gStdinBuf.len)
                        }
                        gStdinBuf = ""
                    }
                    Task.spawn(move(): void => {
                        ptyPumpLoop(master, ch, wakeWr)
                    }
                    )
                    return master
                }
                Result.Err(e) => {
                    eprint($"[srv] pty spawn failed: {e}\n")
                    return -1
                }
            }
        }
        Result.Err(e) => {
            eprint($"[srv] pty open failed: {e}\n")
            return -1
        }
    }
    return -1
}

fn dapReaderLoop(client: DapClient, ch: Channel<string>, wakeWr: i32, pendCh: Channel<Pending>): void {
    var cl = client
    var pend: Vec<Pending> = []
    var tid: i64 = -1 as i64
    var framesJs: string = "[]"
    var stopLine: i64 = 0
    var frame0: i64 = 0
    var regRef: i64 = 0 // register scope ref for the current stop (0 = adapter has none)
    var lastSrc: string = srcPath.clone() // browser already has the main source
    var bpArgs: string = "[]" // per-file bundle from buildAllBpArgs
    var sbLeft: i64 = 0 // sbInit responses still outstanding
    var ptyMaster: i32 = -1
    var initOk = false // adapter answered `initialize` (handshake reached)

    while true {
        var msg = DapMsg {
            kind: "", seq: 0, requestSeq: -1 as i64, command: "", event: "", success: false, raw: ""
        }
        match cl.recv() {
            Result.Ok(m) => {
                msg = m
            }
            Result.Err(_e) => {
                // An adapter that dies before answering `initialize` never really
                // started (bad dapPath, missing module, crash on launch). A bare
                // "terminated" reads like a clean program exit, so surface the real
                // cause — the captured stderr — as a configError instead.
                if !initOk {
                    var em = "adapter exited before the handshake — it never started."
                    if gAdapterStderr.len > 0 {
                        em = em + "\n\n" + gAdapterStderr
                    }
                    wsPush(ch, wakeWr, configErrMsg(em))
                }
                wsPush(ch, wakeWr, terminatedMsg())
                break
            }
        }

        // Adopt R's registered pendings AFTER recv, before matching: R registers
        // before it sends (and D was parked in recv while the adapter replied),
        // so draining here guarantees the entry exists when its response lands.
        // Draining before recv instead loses any pending R registers while D is
        // parked — the response arrives unmatched and is dropped.
        while true {
            match pendCh.tryRecv() {
                Option.Some(p) => {
                    if p.kind == "initialize" {
                        bpArgs = p.extra.clone()
                    }
                    pend.push(p)
                }
                Option.None => {
                    break
                }
            }
        }

        if msg.kind == "response" {
            var idx: i64 = -1 as i64
            var i: i64 = 0
            while i < pend.len {
                if pend[i].seq == msg.requestSeq {
                    idx = i
                }
                i = i + 1
            }
            var kind: string = ""
            var pid: i64 = 0
            var pextra: string = ""
            if idx >= 0 {
                kind = pend[idx].kind.clone()
                pid = pend[idx].id
                pextra = pend[idx].extra.clone()
                pend = removePending(pend, idx)
            }

            if !msg.success {
                if kind == "eval" {
                    let emsg = jStr(msg.raw, "message")
                    wsPush(ch, wakeWr, jsonObj().str("type", "evalResult").int("id", pid).str("value", emsg).int("ref", 0).bool("error", true).build())
                } else if kind == "fsc" || kind == "fvars" {
                    wsPush(ch, wakeWr, jsonObj().str("type", "frameLocals").int("id", pid).raw("vars", "[]").build())
                } else if kind == "disasm" {
                    wsPush(ch, wakeWr, jsonObj().str("type", "disasm").int("id", pid).raw("instructions", "[]").build())
                } else if kind == "setv" {
                    wsPush(ch, wakeWr, jsonObj().str("type", "setVarResult").int("id", pid).str("value", jStr(msg.raw, "message")).int("ref", 0).bool("error", true).build())
                } else if kind == "ebInit" {
                    // Exception filters rejected — still finish configuration
                    // or the session never launches.
                    let s = cl.send("configurationDone", "{}")
                    pend.push(Pending {
                        seq: s, kind: "cfgDone", id: 0, extra: ""
                    }
                    )
                } else if kind == "cmpl" {
                    wsPush(ch, wakeWr, jsonObj().str("type", "completions").int("id", pid).raw("targets", "[]").build())
                } else if kind == "tst" {
                    var t: string = "0"
                    if pextra.len > 0 {
                        t = pextra.clone()
                    }
                    wsPush(ch, wakeWr, jsonObj().str("type", "threadStack").int("id", pid).raw("tid", t).raw("frames", "[]").build())
                } else if kind == "readmem" {
                    wsPush(ch, wakeWr, jsonObj().str("type", "memory").int("id", pid).str("address", "").str("data", "").str("error", jStr(msg.raw, "message")).build())
                } else if kind == "restartR" {
                    // Adapter without restart support (e.g. debugpy): tell the
                    // UI so it falls back to kill+rerun. lldb-dap handles
                    // restart but never advertises supportsRestartRequest, so
                    // try-then-fallback beats capability gating here.
                    wsPush(ch, wakeWr, jsonObj().str("type", "restartFailed").build())
                } else if kind == "initialize" || kind == "launch" || kind == "sbInit" {
                    eprint($"[srv] {msg.command} failed: {msg.raw}\n")
                    wsPush(ch, wakeWr, terminatedMsg())
                    break
                }
            } else if kind == "initialize" {
                initOk = true
                // Forward the adapter's capabilities verbatim; the UI digs out
                // .body and gates features on it.
                gCapsMsg = jsonObj().str("type", "capabilities").str("raw", msg.raw.clone()).build()
                wsPush(ch, wakeWr, gCapsMsg.clone())
                let s = cl.send(launchRequest(), launchArgs())
                pend.push(Pending {
                    seq: s, kind: "launch", id: 0, extra: ""
                }
                )
            } else if kind == "launch" {
                // running; next signal is a stopped/terminated event.
                // Launch ack'd: this config actually ran, so record it (single
                // writer — clients never save) and tell every peer.
                wsPush(ch, wakeWr, appendHistory())
            } else if kind == "thrPause" {
                // Pause with no known tid (attach before first stop): pause
                // the first thread the adapter reports.
                let t = firstThreadId(msg.raw)
                if t >= 0 {
                    let _s = cl.send("pause", jsonObj().int("threadId", t).build())
                }
            } else if kind == "sbInit" {
                sbLeft = sbLeft - 1
                if sbLeft <= 0 {
                    let s = cl.send("setExceptionBreakpoints", excArgs())
                    pend.push(Pending {
                        seq: s, kind: "ebInit", id: 0, extra: ""
                    }
                    )
                }
            } else if kind == "ebInit" {
                let cd: string = "{}"
                let s = cl.send("configurationDone", cd)
                pend.push(Pending {
                    seq: s, kind: "cfgDone", id: 0, extra: ""
                }
                )
            } else if kind == "st" {
                framesJs = framesJson(msg.raw)
                stopLine = frame0Field(msg.raw, "line")
                frame0 = frame0Field(msg.raw, "id")
                let path = frame0Path(msg.raw)
                if path.len > 0 && path != lastSrc {
                    wsPush(ch, wakeWr, sourceMsg(path))
                    lastSrc = path
                }
                let scArgs = jsonObj().int("frameId", frame0).build()
                let s = cl.send("scopes", scArgs)
                pend.push(Pending {
                    seq: s, kind: "sc", id: 0, extra: ""
                }
                )
                // Memory map for region-coloring — lldb only (python/go repl has
                // no `memory region`). Fired alongside scopes; reply → "regions".
                if adapterKind == "lldb" {
                    let rArgs = jsonObj().str("expression", "memory region --all")
                        .str("context", "repl").int("frameId", frame0).build()
                    let rs = cl.send("evaluate", rArgs)
                    pend.push(Pending {
                        seq: rs, kind: "regions", id: 0, extra: ""
                    }
                    )
                }
            } else if kind == "sc" {
                let ref = scopes0Ref(msg.raw)
                regRef = registersScopeRef(msg.raw)
                let vArgs = jsonObj().int("variablesReference", ref).build()
                let s = cl.send("variables", vArgs)
                // scope ref rides along: setVariable needs the parent
                // container ref, and for top-level locals that's the scope.
                pend.push(Pending {
                    seq: s, kind: "vars", id: 0, extra: ref.toString()
                }
                )
            } else if kind == "vars" {
                var scopeRef: string = "0"
                if pextra.len > 0 {
                    scopeRef = pextra.clone()
                }
                gStopMsg = jsonObj().str("type", "stopped")
                    .int("line", stopLine).str("path", lastSrc.clone()).int("tid", tid)
                    .raw("scopeRef", scopeRef)
                    .int("registersRef", regRef)
                    .raw("frames", framesJs.clone())
                    .raw("locals", localsJson(msg.raw)).build()
                wsPush(ch, wakeWr, gStopMsg.clone())
            } else if kind == "regions" {
                // Cached + replayed like gStopMsg so a tab that reloads mid-stop
                // keeps its region colors instead of going grey until the next step.
                gRegionsMsg = jsonObj().str("type", "regions")
                    .raw("regions", regionsJson(bodyStr(msg.raw, "result"))).build()
                wsPush(ch, wakeWr, gRegionsMsg.clone())
            } else if kind == "eval" {
                wsPush(ch, wakeWr, jsonObj().str("type", "evalResult").int("id", pid).str("value", bodyStr(msg.raw, "result")).int("ref", bodyI64(msg.raw, "variablesReference", 0 as i64)).build())
            } else if kind == "expand" {
                wsPush(ch, wakeWr, jsonObj().str("type", "children").int("id", pid).raw("vars", localsJson(msg.raw)).build())
            } else if kind == "fsc" {
                // Frame navigation: scopes for a non-top frame the user
                // clicked; chains into fvars like the stop-time sc → vars pair.
                let ref = scopes0Ref(msg.raw)
                let vArgs = jsonObj().int("variablesReference", ref).build()
                let s = cl.send("variables", vArgs)
                pend.push(Pending {
                    seq: s, kind: "fvars", id: pid, extra: ref.toString()
                }
                )
            } else if kind == "fvars" {
                var scopeRef: string = "0"
                if pextra.len > 0 {
                    scopeRef = pextra.clone()
                }
                wsPush(ch, wakeWr, jsonObj().str("type", "frameLocals").int("id", pid).raw("scopeRef", scopeRef).raw("vars", localsJson(msg.raw)).build())
            } else if kind == "setv" {
                // setVariable: body carries the adapter-formatted new
                // value (+ a fresh children ref for containers).
                wsPush(ch, wakeWr, jsonObj().str("type", "setVarResult").int("id", pid).str("value", bodyStr(msg.raw, "value")).int("ref", bodyI64(msg.raw, "variablesReference", 0 as i64)).build())
            } else if kind == "disasm" {
                wsPush(ch, wakeWr, jsonObj().str("type", "disasm").int("id", pid).raw("instructions", disasmJson(msg.raw)).build())
            } else if kind == "cmpl" {
                wsPush(ch, wakeWr, jsonObj().str("type", "completions").int("id", pid).raw("targets", completionsJson(msg.raw)).build())
            } else if kind == "readmem" {
                // readMemory body: address + base64 data; UI decodes.
                wsPush(ch, wakeWr, jsonObj().str("type", "memory").int("id", pid).str("address", bodyStr(msg.raw, "address")).str("data", bodyStr(msg.raw, "data")).build())
            } else if kind == "thr" {
                // threads at this stop; "current" is the stopping thread.
                gThreadsMsg = jsonObj().str("type", "threads").int("current", tid)
                    .raw("threads", threadsJson(msg.raw)).build()
                wsPush(ch, wakeWr, gThreadsMsg.clone())
                // lldb-dap fills its thread list lazily after a stop — the
                // immediate response usually carries only the stopping thread.
                // Re-poll a few times (attempt count rides in the id field);
                // the requests go through R's odd-seq path since D owns cl.
                if pid < 3 {
                    let att = pid + 1
                    Task.spawn(move(): void => {
                        sleepMs(300)
                        if gStopMsg.len > 0 && gDapIn >= 0 {
                            gOddSeq = gOddSeq + 2
                            let _p = pendCh.trySend(Pending {
                                seq: gOddSeq, kind: "thr", id: att, extra: ""
                            }
                            )
                            sendReqFd(gDapIn, gOddSeq, "threads", "{}")
                        }
                    }
                    )
                }
            } else if kind == "tst" {
                // stack for a user-selected thread; tid rides in extra.
                var t: string = "0"
                if pextra.len > 0 {
                    t = pextra.clone()
                }
                wsPush(ch, wakeWr, jsonObj().str("type", "threadStack").int("id", pid).raw("tid", t).raw("frames", framesJson(msg.raw)).build())
            }
            // bpLive / cfgDone / unmatched: nothing to route
        } else if msg.kind == "event" {
            if msg.event == "initialized" {
                // "Stop at main" for native targets = a function breakpoint
                // (plain stopOnEntry would strand the user at dyld's entry with
                // no source). Python uses launch stopOnEntry instead — see
                // launchArgs(). Failure is tolerated: fbInit response is a no-op.
                if stopAtMain && adapterKind != "python" {
                    let fb = jsonObj().arr("breakpoints", jsonArr().obj(jsonObj().str("name", mainSymbolFor(adapterKind)))).build()
                    let fs = cl.send("setFunctionBreakpoints", fb)
                    pend.push(Pending {
                        seq: fs, kind: "fbInit", id: 0, extra: ""
                    }
                    )
                }
                // One setBreakpoints per file with bps; configurationDone
                // is deferred until the last sbInit + ebInit round-trips.
                sbLeft = 0
                match jsonParse(bpArgs.clone()) {
                    Result.Ok(doc) => {
                        let n = doc.len()
                        var i: i64 = 0
                        while i < n {
                            match doc.at(i) {
                                Option.Some(el) => {
                                    let a = el.str("args") ?? "{}"
                                    let s = cl.send("setBreakpoints", a)
                                    pend.push(Pending {
                                        seq: s, kind: "sbInit", id: 0, extra: ""
                                    }
                                    )
                                    sbLeft = sbLeft + 1
                                }
                                Option.None => {
                                }
                            }
                            i = i + 1
                        }
                    }
                    Result.Err(_e) => {
                    }
                }
                if sbLeft == 0 {
                    let s = cl.send("setExceptionBreakpoints", excArgs())
                    pend.push(Pending {
                        seq: s, kind: "ebInit", id: 0, extra: ""
                    }
                    )
                }
            } else if msg.event == "output" {
                // Buffer for late-join replay — skip telemetry (adapter-internal,
                // never displayed). Bounded FIFO; a non-pty adapter floods here.
                let ocat = bodyStr(msg.raw, "category")
                if ocat != "telemetry" {
                    gOutputLog.push(OutLine {
                        text: bodyStr(msg.raw, "output"), category: ocat.clone()
                    }
                    )
                    if gOutputLog.len > OUTLOG_MAX {
                        let _d = gOutputLog.remove(0)
                    }
                }
                wsPush(ch, wakeWr, outputMsg(msg.raw))
            } else if msg.event == "exited" {
                // Not session end (restart emits it for the old process) —
                // just remember the code for the run-exited log line.
                gLastExit = bodyI64(msg.raw, "exitCode", -1 as i64)
            } else if msg.event == "stopped" {
                if gLogLevel >= 2 {
                    logEvent("stopped", $"thread {bodyI64(msg.raw, "threadId", -1 as i64)}  reason {bodyStr(msg.raw, "reason")}")
                }
                tid = bodyI64(msg.raw, "threadId", -1 as i64)
                let stArgs = jsonObj().int("threadId", tid)
                    .int("startFrame", 0).int("levels", 20).build()
                let s = cl.send("stackTrace", stArgs)
                pend.push(Pending {
                    seq: s, kind: "st", id: 0, extra: ""
                }
                )
                // every stop also refreshes the threads panel.
                let ts = cl.send("threads", "{}")
                pend.push(Pending {
                    seq: ts, kind: "thr", id: 0, extra: ""
                }
                )
            } else if msg.event == "terminated" {
                wsPush(ch, wakeWr, terminatedMsg())
                break
            }
            // "exited" alone is NOT session end: a native restart kills
            // the old process and emits exited for it. Real session end always
            // arrives as terminated or adapter EOF (recv error above).
        } else if msg.kind == "request" {
            if msg.command == "runInTerminal" {
                let m = handleRunInTerminal(cl, msg.raw, msg.seq, ch, wakeWr)
                if m >= 0 {
                    // Restart replaces the pty: the old child is already dead
                    // (its pump saw EIO), so close the stale master or it leaks.
                    if ptyMaster >= 0 {
                        unsafe {
                            close(ptyMaster)
                        }
                    }
                    ptyMaster = m
                }
            }
        }
    }

    if ptyMaster >= 0 {
        unsafe {
            close(ptyMaster)
        }
    }
    cl.close()
    var durSecs = (epochMillis() - gRunStartMs) / 1000
    if gLastExit >= 0 {
        logEvent("run exited", $"code {gLastExit}  ({durSecs}s)")
    } else {
        // No exited event: killed, detached from an attach, or adapter EOF.
        logEvent("run ended", $"({durSecs}s)")
    }
    // Session over: re-arm `run` directly (globals, same scheduler
    // thread). Stale pendings must not collide with the next adapter's seq
    // numbers, which restart at 1.
    gStarted = false
    gDapIn = -1
    gPtyFd = -1
    gStdinBuf = ""
    gOddSeq = -1 as i64
    gStopMsg = ""
    gThreadsMsg = ""
    gRegionsMsg = ""
    gCapsMsg = ""
    while true {
        match pendCh.tryRecv() {
            Option.Some(_p) => {
            }
            Option.None => {
                break
            }
        }
    }
    // A forced run killed the old debuggee; auto-rerun here with its config
    // (a new config can't ride a live adapter — it caches launch args).
    if gPendingRun {
        gPendingRun = false
        var err: string = ""
        if gPendingConfig.len > 0 {
            // .clone(): passing the global by value would move its buffer into
            // applyConfig and the reassignment below would double-free it (the
            // checker doesn't track moves out of globals).
            err = applyConfig(gPendingConfig.clone(), "")
            gPendingConfig = ""
            if err.len == 0 {
                wsPush(ch, wakeWr, helloMsg())
                if srcPath.len > 0 {
                    wsPush(ch, wakeWr, sourceMsg(srcPath))
                }
            }
        }
        if err.len > 0 {
            wsPush(ch, wakeWr, configErrMsg(err))
        } else if binPath.len > 0 || gRequest == "attach" {
            stopAtMain = gPendingStopAtMain
            let _ok = startRun(ch, wakeWr, pendCh)
        }
    }
}

// spawn the DAP adapter for the current config and drive the handshake.
// Shared by the run command (R) and restart-with-staged auto-rerun (D). Assumes
// binPath set and !gStarted. Broadcasts terminated and returns false if the
// adapter fails to spawn. bus/busWakeWr are the broadcast channel + wake fd.
fn startRun(bus: Channel<string>, busWakeWr: i32, pendCh: Channel<Pending>): bool {
    gStarted = true
    // Transport: TCP connects to a running adapter (gDapPort>0); stdio spawns
    // the resolved adapter command. Both yield a DapClient whose child.stdinFd
    // is the DAP write fd — the rest of the handshake is identical.
    var startRes: Result<DapClient> = Result.Err("uninitialized")
    var label: string = ""
    if gDapPort > 0 {
        label = $"tcp {gDapHost}:{gDapPort}"
        startRes = DapClient.startTcp(gDapHost, gDapPort)
    } else {
        var argv = adapterArgvOf(adapterCmd)
        // adapterCmd is always set by config-apply before a stdio run reaches here.
        if argv.len == 0 {
            eprint("[srv] no adapter configured\n")
            gStarted = false
            wsPush(bus, busWakeWr, terminatedMsg())
            return false
        }
        var prog: string = argv[0].clone()
        var rest: Vec<string> = []
        var ai: i64 = 1
        while ai < argv.len {
            rest.push(argv[ai].clone())
            ai = ai + 1
        }
        label = $"adapter {pathBasename(prog)}"
        startRes = DapClient.startArgs(prog, rest)
    }
    match startRes {
        Result.Ok(client) => {
            var cl = client
            gRunStartMs = epochMillis()
            gLastExit = -1 as i64
            logEvent("run started", $"{binPath}  {label} pid {cl.child.pid}")
            gDapIn = cl.child.stdinFd
            // Drain + capture adapter stderr (stdio spawns only; TCP has no child
            // stderr, errFd -1). Must start before cl moves into the reader task.
            gAdapterStderr = ""
            let errFd = cl.child.stderrFd
            if errFd >= 0 {
                Task.spawn(move(): void => {
                    adapterStderrPump(errFd)
                }
                )
            }
            gOddSeq = gOddSeq + 2
            let _p = pendCh.trySend(Pending {
                seq: gOddSeq, kind: "initialize", id: 0, extra: buildAllBpArgs(gBps),
            }
            )
            sendReqFd(gDapIn, gOddSeq, "initialize", initArgs())
            Task.spawn(move(): void => {
                dapReaderLoop(cl, bus, busWakeWr, pendCh)
            }
            )
            return true
        }
        Result.Err(e) => {
            eprint($"[srv] adapter spawn failed: {e}\n")
            gStarted = false
            wsPush(bus, busWakeWr, terminatedMsg())
            return false
        }
    }
    return false
}

// ── R: the WS-reader task (entry point per debug WebSocket) ──

fn handleDebugWs(ws: WsConn, peerKind: string, bus: Channel<string>, busWakeWr: i32, pendCh: Channel<Pending>, regCh: Channel<Sink>): void {
    var conn = ws

    let ch = Channel<string>.new(256)!
    var wake: [i32; 2] = [0; 2]
    unsafe {
        if pipe(wake as *u8) != 0 {
            return
        }
    }
    let wakeRd = wake[0]
    let wakeWr = wake[1]
    let wfd = conn.fd
    // Channels are @send handle structs — captured by copy, shared safely.
    Task.spawn(move(): void => {
        wsWriterLoop(wfd, ch, wakeRd)
    }
    )

    // join the shared session. Register with the broadcaster, then replay
    // current state directly onto our own sink — no yield point in between,
    // so the replay is ordered before any subsequent broadcast fanout.
    let clientId = gNextClient
    gNextClient = gNextClient + 1
    let _r = regCh.trySend(Sink {
        id: clientId, ch: ch, wakeWr: wakeWr, alive: true
    }
    )
    gPeers = gPeers + 1
    logEvent("peer connected", $"{peerKind}  {peerCountStr()}")
    var one: [u8; 1] = [110; 1]
    unsafe {
        let _w1 = write(busWakeWr, one as *u8, 1)
    }

    wsPush(ch, wakeWr, helloMsg())
    if srcPath.len > 0 {
        wsPush(ch, wakeWr, sourceMsg(srcPath))
    }
    if gCapsMsg.len > 0 {
        wsPush(ch, wakeWr, gCapsMsg.clone())
    }
    for bp in gBps {
        wsPush(ch, wakeWr, bpSyncMsg(bp))
    }
    if gStopMsg.len > 0 {
        wsPush(ch, wakeWr, gStopMsg.clone())
    }
    if gThreadsMsg.len > 0 {
        wsPush(ch, wakeWr, gThreadsMsg.clone())
    }
    if gRegionsMsg.len > 0 {
        wsPush(ch, wakeWr, gRegionsMsg.clone())
    }
    // replay buffered terminal history. Flagged so a same-session reconnect
    // (which kept its scrollback) can drop it; a fresh/new-session tab renders it.
    for outLine in gOutputLog {
        wsPush(ch, wakeWr, jsonObj().str("type", "output").str("text", outLine.text.clone()).str("category", outLine.category.clone()).bool("replay", true).build())
    }

    while true {
        var payload: string = ""
        match conn.recv() {
            Result.Ok(m) => {
                payload = m.payload
            }
            Result.Err(_e) => {
                break
            }
        }

        let c = jStr(payload, "cmd")
        if c == "setBreakpoint" || c == "clearBreakpoint" {
            let line = jI64(payload, "line", 0 as i64)
            var path = jStr(payload, "path")
            if path.len == 0 {
                path = srcPath.clone()
            }
            // Upsert: drop any existing bp at (path, line), then re-add for
            // "set" (a condition edit is a set on an existing line).
            var keep: Vec<Bp> = []
            for bp in gBps {
                if bp.line != line || bp.path != path {
                    keep.push(cloneBp(bp))
                }
            }
            gBps = keep
            if c == "setBreakpoint" {
                gBps.push(Bp {
                    path: path.clone(),
                    line: line,
                    condition: jStr(payload, "condition"),
                    hitCondition: jStr(payload, "hitCondition"),
                    logMessage: jStr(payload, "logMessage"),
                    enabled: jBool(payload, "enabled", true),
                }
                )
            }
            wsPush(bus, busWakeWr, bpAckMsg(line, c == "setBreakpoint"))
            if gStarted && gDapIn >= 0 {
                gOddSeq = gOddSeq + 2
                // Register before sending (here and below): D drains pendings
                // after each recv, so the entry must exist before the adapter
                // can possibly reply or the response is dropped unmatched.
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "bpLive", id: 0, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "setBreakpoints", buildBpArgsForPath(gBps, path))
            }
        } else if c == "run" {
            // The editor is the source of truth: an inline `config` object rides
            // the run and is applied just before launch — no staging. A live
            // session requires force:true (the client confirms with the user),
            // which kills it and reruns with the new config after teardown.
            let cfgRaw = jObjRaw(payload, "config")
            if gStarted {
                if jBool(payload, "force", false) && gDapIn >= 0 {
                    gPendingRun = true
                    gPendingConfig = cfgRaw
                    gPendingStopAtMain = jBool(payload, "stopAtMain", gConfigStopAtMain)
                    logEvent("run killed", $"forced by {peerKind} peer — relaunching")
                    gOddSeq = gOddSeq + 2
                    let _p = pendCh.trySend(Pending {
                        seq: gOddSeq, kind: "disc", id: 0, extra: ""
                    }
                    )
                    sendReqFd(gDapIn, gOddSeq, "disconnect", jsonObj().bool("terminateDebuggee", true).build())
                } else {
                    wsPush(bus, busWakeWr, configErrMsg("a debug session is already active — run with force:true to kill and relaunch"))
                }
            } else {
                var cfgErr: string = ""
                if cfgRaw.len > 0 {
                    cfgErr = applyConfig(cfgRaw, "")
                    if cfgErr.len == 0 {
                        logEvent("target changed", $"{binPath}  (by {peerKind} peer)")
                        wsPush(bus, busWakeWr, helloMsg())
                        if srcPath.len > 0 {
                            wsPush(bus, busWakeWr, sourceMsg(srcPath))
                        }
                    }
                }
                if cfgErr.len > 0 {
                    wsPush(bus, busWakeWr, configErrMsg(cfgErr))
                } else if binPath.len == 0 && gRequest != "attach" {
                    // Booted idle with no target: nudge to the config drawer instead
                    // of spawning the adapter with an empty program path.
                    wsPush(bus, busWakeWr, configErrMsg("no program configured — set a debug target (⚙) before running"))
                } else {
                    stopAtMain = jBool(payload, "stopAtMain", gConfigStopAtMain)
                    let _ok = startRun(bus, busWakeWr, pendCh)
                }
            }
        } else if c == "continue" || c == "stepOver" || c == "stepIn" || c == "stepOut" || c == "pause" {
            if c != "pause" {
                gStopMsg = ""
                gThreadsMsg = ""
                gRegionsMsg = ""
            } // resumed: snapshots are stale for late joiners
            if gDapIn >= 0 {
                var dapCmd: string = "continue"
                if c == "stepOver" {
                    dapCmd = "next"
                } 
                else if c == "stepIn" {
                    dapCmd = "stepIn"
                } 
                else if c == "stepOut" {
                    dapCmd = "stepOut"
                } 
                else if c == "pause" {
                    dapCmd = "pause"
                }
                let t = jI64(payload, "tid", 1 as i64)
                if c == "pause" && t < 0 {
                    // Attach flow: Pause can arrive before any stop, so
                    // there's no tid yet — ask for threads and pause the first.
                    gOddSeq = gOddSeq + 2
                    let _p = pendCh.trySend(Pending {
                        seq: gOddSeq, kind: "thrPause", id: 0, extra: ""
                    }
                    )
                    sendReqFd(gDapIn, gOddSeq, "threads", "{}")
                } else {
                    var b = jsonObj().int("threadId", t)
                    // instruction-granularity stepping from the asm pane.
                    let gran = jStr(payload, "granularity")
                    if gran.len > 0 {
                        b = b.str("granularity", gran)
                    }
                    gOddSeq = gOddSeq + 2
                    sendReqFd(gDapIn, gOddSeq, dapCmd, b.build())
                }
            }
        } else if c == "restart" {
            gStopMsg = ""
            gThreadsMsg = ""
            gRegionsMsg = ""
            // native restart — adapter re-launches with the same launch
            // config; gBps and the stop-at-main function bp persist. UI gates
            // this on supportsRestartRequest (kill+rerun is its fallback). A
            // config change is a Run (force-kills), not a restart.
            if gDapIn >= 0 {
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "restartR", id: 0, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "restart", jsonObj().build())
            }
        } else if c == "kill" {
            // End the session: adapter tears down the debuggee and exits; the
            // reader loop's terminated/EOF path re-arms `run` via endCh.
            logEvent("kill requested", $"(by {peerKind} peer)")
            if gDapIn >= 0 {
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "disc", id: 0, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "disconnect", jsonObj().bool("terminateDebuggee", true).build())
            }
        } else if c == "evaluate" {
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                let frameId = jI64(payload, "frameId", -1 as i64)
                var b = jsonObj().str("expression", jStr(payload, "expr"))
                    .str("context", jStr(payload, "context"))
                if frameId >= 0 {
                    b = b.int("frameId", frameId)
                }
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "eval", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "evaluate", b.build())
            }
        } else if c == "expand" {
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "expand", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "variables", jsonObj().int("variablesReference", jI64(payload, "ref", 0 as i64)).build())
            }
        } else if c == "threadStack" {
            // stack for a clicked thread; the UI then drives frameScopes
            // for its locals like any other frame selection.
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                let t = jI64(payload, "tid", 1 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "tst", id: id, extra: t.toString()
                }
                )
                sendReqFd(gDapIn, gOddSeq, "stackTrace", jsonObj().int("threadId", t).int("startFrame", 0).int("levels", 20).build())
            }
        } else if c == "frameScopes" {
            // locals for a user-selected stack frame.
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "fsc", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "scopes", jsonObj().int("frameId", jI64(payload, "frameId", 0 as i64)).build())
            }
        } else if c == "setExceptions" {
            // selected exception filter ids. Stored globally so session
            // init applies them; live-applied when a session is running.
            var arr = jsonArr()
            match jsonParse(payload.clone()) {
                Result.Ok(doc) => {
                    match doc.get("filters") {
                        Option.Some(f) => {
                            let n = f.len()
                            var i: i64 = 0
                            while i < n {
                                match f.at(i) {
                                    Option.Some(el) => {
                                        arr = arr.str(el.asStr() ?? "")
                                    }
                                    Option.None => {
                                    }
                                }
                                i = i + 1
                            }
                        }
                        Option.None => {
                        }
                    }
                }
                Result.Err(_e) => {
                }
            }
            excFiltersJson = arr.build()
            if gStarted && gDapIn >= 0 {
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "ebLive", id: 0, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "setExceptionBreakpoints", excArgs())
            }
        } else if c == "complete" {
            // debug-console completions.
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                let frameId = jI64(payload, "frameId", -1 as i64)
                var b = jsonObj().str("text", jStr(payload, "text"))
                    .int("column", jI64(payload, "column", 1 as i64))
                if frameId >= 0 {
                    b = b.int("frameId", frameId)
                }
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "cmpl", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "completions", b.build())
            }
        } else if c == "readMem" {
            // raw memory window. memoryReference is whatever the UI got
            // from a value/ipRef; lldb-dap accepts plain hex addresses.
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "readmem", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "readMemory", jsonObj().str("memoryReference", jStr(payload, "memoryReference")).int("offset", jI64(payload, "offset", 0 as i64)).int("count", jI64(payload, "count", 256 as i64)).build())
            }
        } else if c == "setVar" {
            // edit a variable. ref = parent container (scope ref for
            // top-level locals, the variable's own ref for expanded children).
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "setv", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "setVariable", jsonObj().int("variablesReference", jI64(payload, "ref", 0 as i64)).str("name", jStr(payload, "name")).str("value", jStr(payload, "value")).build())
            }
        } else if c == "disassemble" {
            // window of instructions around a frame's pc (memoryReference =
            // the frame's instructionPointerReference from stackTrace).
            if gDapIn >= 0 {
                let id = jI64(payload, "id", 0 as i64)
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "disasm", id: id, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "disassemble", jsonObj().str("memoryReference", jStr(payload, "memoryReference")).int("instructionOffset", -16).int("instructionCount", 64).bool("resolveSymbols", true).build())
            }
        } else if c == "openSource" {
            // show the file a clicked frame lives in. sourceMsg itself
            // handles unreadable pseudo-paths (dyld etc.) with a placeholder.
            let p = jStr(payload, "path")
            if p.len > 0 {
                wsPush(bus, busWakeWr, sourceMsg(p))
            }
        } else if c == "stdin" {
            let data = jStr(payload, "data")
            if gPtyFd >= 0 {
                unsafe {
                    let _n = write(gPtyFd, data, data.len)
                }
            } else {
                gStdinBuf = gStdinBuf + data
            }
        } else if c == "setConfig" {
            // config = a VS Code launch-configuration object (see applyConfig).
            // The browser applies configs inline on Run; setConfig is the
            // programmatic path (MCP peers). Idle-only — a live session must be
            // force-run to change target (setConfig never kills a debuggee).
            if gStarted {
                wsPush(bus, busWakeWr, configErrMsg("a debug session is active — stop it (or Run with force) to change the target"))
            } else {
                let err = applyConfig(payload, "")
                if err.len > 0 {
                    wsPush(bus, busWakeWr, configErrMsg(err))
                } else {
                    logEvent("target changed", $"{binPath}  (by {peerKind} peer)")
                    wsPush(bus, busWakeWr, helloMsg())
                    if srcPath.len > 0 {
                        wsPush(bus, busWakeWr, sourceMsg(srcPath))
                    }
                }
            }
        } else if c == "importHistory" {
            // One-shot localStorage migration: fold the client's legacy entries
            // into the server store, then the client stops sending (server is the
            // sole writer thereafter). Idempotent — dedup collapses re-imports.
            match jsonParse(payload.clone()) {
                Result.Ok(d) => {
                    match d.get("entries") {
                        Option.Some(e) => {
                            if e.isArray() {
                                gHistory = histMergeMany(gHistory, e.rawStr(), 10 as i64)
                                persistHistory()
                                wsPush(bus, busWakeWr, historyChangedMsg())
                            }
                        }
                        Option.None => {
                        }
                    }
                }
                Result.Err(_e) => {
                }
            }
        } else if c == "newSession" {
            // Deliberate fresh start (a reload reconnects to the live session
            // by design): end any running debuggee via the kill path, drop bps
            // and the late-join replay snapshots, mint a new id, and re-hello
            // every peer — each resets its client state on the id change.
            // Target config survives; the ⚙ drawer changes it.
            if gStarted && gDapIn >= 0 {
                gOddSeq = gOddSeq + 2
                let _p = pendCh.trySend(Pending {
                    seq: gOddSeq, kind: "disc", id: 0, extra: ""
                }
                )
                sendReqFd(gDapIn, gOddSeq, "disconnect", jsonObj().bool("terminateDebuggee", true).build())
            }
            gBps = []
            gStopMsg = ""
            gThreadsMsg = ""
            gRegionsMsg = ""
            gOutputLog = []
            gSessionId = uuidV4()
            logEvent("session reset", $"new session {gSessionId}")
            wsPush(bus, busWakeWr, helloMsg())
            if srcPath.len > 0 {
                wsPush(bus, busWakeWr, sourceMsg(srcPath))
            }
        }
    }

    // Leave the shared session. The broadcaster closes our wake fd when the
    // unregister lands (it is the sole writer by then — closing here would
    // race fd reuse against its next wake poke).
    let _u = regCh.trySend(Sink {
        id: clientId, ch: ch, wakeWr: wakeWr, alive: false
    }
    )
    unsafe {
        let _w2 = write(busWakeWr, one as *u8, 1)
    }
    gPeers = gPeers - 1
    gLastDetachMs = epochMillis()
    logEvent("peer disconnected", $"{peerKind}  {peerCountStr()}")
}

// ── Idle TTL (session GC) ──

// OS-thread ticker: the green scheduler blocks in kevent with no timeout, so
// time-based wakeups need an external poke. Raw usleep + pipe write only — no
// runtime calls here (the scheduler pointer is a plain global, not
// thread-local, so std sleep/yield on a foreign thread would corrupt it).
fn tickerMain(): i64 {
    while true {
        unsafe {
            let _s = usleep((gTickUsecs & 0xffffffff) as u32)
            var one: [u8; 1] = [116; 1]
            let _w = write(gTickWr, one as *u8, 1)
        }
    }
    return 0
}

// Green task: parks on the tick pipe; a session with no peers for the TTL is
// ended via the same disconnect(terminateDebuggee) path as the kill command —
// D's terminated/EOF handling resets session state for a later fresh run.
fn reaperLoop(tickRd: i32, pendCh: Channel<Pending>): void {
    var buf: [u8; 8] = [0; 8]
    while true {
        var n: i64 = 0
        unsafe {
            schedulerWaitRead(tickRd)
            n = read(tickRd, buf as *u8, 8)
        }
        if n <= 0 {
            break
        }
        if !gStarted || gPeers > 0 || gDapIn < 0 {
            continue
        }
        if epochMillis() - gLastDetachMs < gIdleTtlSecs * 1000 {
            continue
        }
        logEvent("session idle", $"no peers for {gIdleTtlSecs}s — terminating debuggee")
        gOddSeq = gOddSeq + 2
        let _p = pendCh.trySend(Pending {
            seq: gOddSeq, kind: "disc", id: 0, extra: ""
        }
        )
        sendReqFd(gDapIn, gOddSeq, "disconnect", jsonObj().bool("terminateDebuggee", true).build())
    }
}

// ── HTTP plumbing ──

fn sendHttp(fd: i32, status: i32, contentType: &string, body: &string): void {
    var statusText: string = "200 OK"
    if status == 404 {
        statusText = "404 Not Found"
    }
    var resp: string = "HTTP/1.1 " + statusText + "\r\n"
    resp = resp + "Content-Type: " + contentType + "\r\n"
    resp = resp + "Content-Length: " + body.len.toString() + "\r\n"
    resp = resp + "Connection: close\r\n\r\n"
    resp = resp + body
    // Accepted fds are non-blocking under the green runtime: a single write()
    // stops at the socket buffer (~half a MB of app.js got dropped this way).
    // Loop with scheduler parking until the whole response is out.
    var sent: i64 = 0
    while sent < resp.len {
        let chunk = resp.substr(sent, resp.len)
        var n: i64 = 0
        unsafe {
            n = write(fd, chunk, chunk.len)
        }
        if n < 0 {
            if getErrno() == eagain() {
                schedulerWaitWrite(fd)
                continue
            }
            return
        }
        sent = sent + n
    }
}

// UI assets are served from disk (--webroot) rather than embedFile: the Monaco
// bundle is ~4.5MB and embedFile's byte-array emission dominates compile time
// (papercut #7). Bonus: UI iteration is build.sh + refresh, no server rebuild.
fn mimeFor(path: &string): string {
    var ext: string = ""
    var i: i64 = path.len - 1
    while i >= 0 && path[i] != '/' {
        if path[i] == '.' {
            ext = path.substr(i, path.len)
            break
        }
        i = i - 1
    }
    if ext == ".html" {
        return "text/html; charset=utf-8"
    }
    if ext == ".js" {
        return "application/javascript"
    }
    if ext == ".css" {
        return "text/css"
    }
    if ext == ".map" || ext == ".json" {
        return "application/json"
    }
    if ext == ".svg" {
        return "image/svg+xml"
    }
    if ext == ".png" {
        return "image/png"
    }
    if ext == ".wasm" {
        return "application/wasm"
    }
    if ext == ".ttf" {
        return "font/ttf"
    }
    return "application/octet-stream"
}

fn lowerByte(c: u8): u8 {
    if c >= 'A' && c <= 'Z' {
        return c + 32
    }
    return c
}

// Value of an HTTP header (name must be lowercase); "" if absent.
fn headerVal(raw: &string, name: &string): string {
    var i: i64 = 0
    while i < raw.len {
        var j: i64 = 0
        var m = true
        while j < name.len {
            if i + j >= raw.len || lowerByte(raw[i + j]) != name[j] {
                m = false break
            }
            j = j + 1
        }
        if m && i + j < raw.len && raw[i + j] == ':' {
            var k = i + j + 1
            while k < raw.len && raw[k] == ' ' {
                k = k + 1
            }
            var v: string = ""
            while k < raw.len && raw[k] != '\r' && raw[k] != '\n' {
                v.push(raw[k])
                k = k + 1
            }
            return v
        }
        while i < raw.len && raw[i] != '\n' {
            i = i + 1
        }
        i = i + 1
    }
    return ""
}

fn replaceAll(s: &string, needle: &string, repl: &string): string {
    var out: string = ""
    var i: i64 = 0
    while i < s.len {
        var m = false
        if i + needle.len <= s.len {
            m = true
            var j: i64 = 0
            while j < needle.len {
                if s[i + j] != needle[j] {
                    m = false break
                }
                j = j + 1
            }
        }
        if m {
            out = out + repl
            i = i + needle.len
        } else {
            out.push(s[i])
            i = i + 1
        }
    }
    return out
}

fn serveStatic(fd: i32, reqPath: &string, origin: &string): void {
    var p = reqPath.clone()
    var qi: i64 = 0
    while qi < p.len {
        if p[qi] == '?' {
            p = p.substr(0, qi)
            break
        }
        qi = qi + 1
    }
    if p == "/" {
        p = "/index.html"
    }
    // No parent traversal out of the webroot.
    var di: i64 = 0
    while di + 1 < p.len {
        if p[di] == '.' && p[di + 1] == '.' {
            sendHttp(fd, 404, "text/plain", "not found")
            return
        }
        di = di + 1
    }
    match readFile(webroot + p) {
        Result.Ok(body) => {
            if p == "/index.html" {
                // og:image/og:url need absolute URLs (unfurlers reject
                // relative) but the host varies (localhost/LAN/tunnel):
                // inject the request's own origin.
                sendHttp(fd, 200, mimeFor(p), replaceAll(body, "__ORIGIN__", origin))
            } else {
                sendHttp(fd, 200, mimeFor(p), body)
            }
        }
        Result.Err(_e) => {
            sendHttp(fd, 404, "text/plain", "not found")
        }
    }
}

struct RequestLine {
    method: string, path: string
}

fn parseRequestLine(raw: &string): RequestLine {
    var i: i64 = 0
    while i < raw.len && raw[i] != ' ' {
        i = i + 1
    }
    let method = raw.substr(0, i)
    while i < raw.len && raw[i] == ' ' {
        i = i + 1
    }
    let uriStart = i
    while i < raw.len && raw[i] != ' ' {
        i = i + 1
    }
    let path = raw.substr(uriStart, i)
    return RequestLine {
        method: method, path: path
    }
}

fn handleConnection(fd: i32, bus: Channel<string>, busWakeWr: i32, pendCh: Channel<Pending>, regCh: Channel<Sink>): void {
    var buf: [u8; 8192] = [0; 8192]
    unsafe {
        schedulerWaitRead(fd)
        let n = read(fd, buf as *u8, 8192)
        if n <= 0 {
            close(fd)
            return
        }
        var raw: string = ""
        for i in 0..n {
            raw.push(buf[i])
        }

        let rl = parseRequestLine(raw)
        if isWsUpgrade(raw) {
            // Peer kind rides the upgrade path's query string: browsers
            // hit /ws bare, `hades mcp --attach` hits /ws?client=mcp — known
            // before the first frame, so connect logs carry the right kind.
            var wsPath = rl.path.clone()
            var query: string = ""
            var qi2: i64 = 0
            while qi2 < wsPath.len {
                if wsPath[qi2] == '?' {
                    query = wsPath.substr(qi2 + 1, wsPath.len)
                    wsPath = wsPath.substr(0, qi2)
                    break
                }
                qi2 = qi2 + 1
            }
            if wsPath == "/ws" {
                var kind: string = "browser"
                if query == "client=mcp" {
                    kind = "mcp"
                }
                match wsAccept(fd, raw) {
                    Result.Ok(ws) => {
                        handleDebugWs(ws, kind, bus, busWakeWr, pendCh, regCh)
                    }
                    Result.Err(_e) => {
                        close(fd)
                    }
                }
            } else {
                close(fd)
            }
            return
        }

        if rl.method == "GET" {
            var host = headerVal(raw, "host")
            if host.len == 0 {
                host = "localhost"
            }
            // Tunnels (cloudflared/ngrok) terminate TLS and set this.
            var proto = headerVal(raw, "x-forwarded-proto")
            if proto.len == 0 {
                proto = "http"
            }
            serveStatic(fd, rl.path, proto + "://" + host)
        } else {
            sendHttp(fd, 404, "text/plain", "not found")
        }
        close(fd)
    }
}

fn acceptLoop(listener: TcpListener, bus: Channel<string>, busWakeWr: i32, pendCh: Channel<Pending>, regCh: Channel<Sink>): void {
    var l = listener
    while true {
        match l.accept() {
            Result.Ok(conn) => {
                var c = conn
                let fd = c.take()
                Task.spawn(move(): void => {
                    handleConnection(fd, bus, busWakeWr, pendCh, regCh)
                }
                )
            }
            Result.Err(_e) => {
                schedulerYield()
            }
        }
    }
}

// Best-effort: pop the default browser open at the served URL. Fire-and-forget —
// a headless box (no xdg-open/open, or HADES_NO_OPEN set) just skips silently.
// The whole thing is backgrounded inside the shell so sh returns instantly and
// wait() reaps it without stalling startup; the real opener reparents to init.
fn openBrowser(url: &string): void {
    if getEnvOr("HADES_NO_OPEN", "").len > 0 {
        return
    }
    var args: Vec<string> = []
    args.push("-c")
    // xdg-open on Linux, open on macOS — whichever exists.
    args.push($"command -v xdg-open >/dev/null 2>&1 && xdg-open '{url}' || open '{url}' >/dev/null 2>&1 &")
    match Child.spawn("sh", args, true) {
        Result.Ok(child) => {
            let _ = child.wait()
        }
        Result.Err(_e) => {
        }
    }
}

// Subcommand entrypoint: dispatched from src/main.milo as `hades web ...`.
// argv[0] is the display name (skipped by parseFrom); the rest are the web flags.
fn webMain(argv: Vec<string>): i32 {
    ignoreSignal(SIGPIPE)
    Q = "\""
    var parser = newParser("hades web", "web UI for any DAP debugger. Serves a shared session: any number of browser tabs plus AI co-debug peers (hades mcp --attach host:port) see and drive the same debuggee.")
    // No default target: boot idle and let the browser configure it (⚙ drawer).
    parser.addString("program", "p", "path to the debuggee binary (optional; configure in the browser if omitted)", "")
    // optional — the debuggee's DWARF knows its sources; the first stop's
    // frame path fills the editor. The flag only pre-loads a file for
    // before-launch breakpoints.
    parser.addString("source", "s", "main source file (optional; auto-detected from the first stop)", "")
    parser.addString("dapPath", "a", "DAP adapter command (stdio); a launch config's \"dapPath\" overrides", "lldb-dap")
    parser.addI64("port", "", "listen port", 8080)
    parser.addI64("idle-ttl", "", "end the debug session after this many seconds with no ws peers attached (0 = never)", 86400)
    parser.addString("webroot", "w", "UI bundle dir (build with src/web/ui/build.sh)", "src/web/ui/dist")
    parser.addBool("quiet", "q", "suppress session event log lines (banner only)")
    parser.addBool("verbose", "v", "log stops and steps too (noisy)")
    // A full VS Code launch configuration (inline JSON object or a file path —
    // a single config or a whole {version, configurations:[...]} launch.json).
    parser.addString("launch", "l", "launch configuration (inline JSON object or path to a JSON file): a VS Code launch config — \"type\"/\"request\"/\"program\"/\"args\"/\"env\"/\"cwd\" plus any adapter-specific keys, or a full {version, configurations:[...]} launch.json", "")
    parser.addString("config", "c", "configuration name to select when --launch is a {configurations:[...]} file (default: first entry)", "")
    let args = parser.parseFrom(argv)
    binPath = args.getString("program")
    srcPath = args.getString("source")
    webroot = args.getString("webroot")
    gLogLevel = 1
    if args.getBool("quiet") {
        gLogLevel = 0
    }
    if args.getBool("verbose") {
        gLogLevel = 2
    }
    // Read + syntax-check --launch now (fail fast); applied via applyConfig
    // after the session globals are initialized below.
    let launchArg = args.getString("launch")
    var launchText: string = ""
    if launchArg.len > 0 {
        launchText = launchArg.clone()
        if launchArg[0] != '{' {
            match readFile(launchArg) {
                Result.Ok(t) => {
                    launchText = t
                }
                Result.Err(_e) => {
                    eprint($"error: --launch file not readable: {launchArg}\n")
                    return 1
                }
            }
        }
        match jsonParseJsonc(launchText.clone()) {
            Result.Ok(doc) => {
                if !doc.isObject() {
                    eprint("error: --launch must be a JSON object\n")
                    return 1
                }
            }
            Result.Err(e) => {
                eprint($"error: --launch is not valid JSON: {e}\n")
                return 1
            }
        }
    }
    if !pathExists(webroot + "/index.html") {
        eprint($"error: {webroot}/index.html not found — run src/web/ui/build.sh or pass --webroot\n")
        return 1
    }
    let adapterArg = args.getString("dapPath")
    let sel = resolveAdapterCmd(adapterArg)
    adapterCmd = sel.cmd
    adapterKind = sel.kind
    let port = args.getI64("port")

    // Shared session: one bus, one broadcaster, any number of peers.
    gStarted = false
    gHistory = "[]"
    gRestored = false
    gDapIn = -1
    gPtyFd = -1
    gOddSeq = -1 as i64
    gStdinBuf = ""
    gCapsMsg = ""
    gStopMsg = ""
    gThreadsMsg = ""
    gRegionsMsg = ""
    gNextClient = 1
    gBps = []
    gPendingConfig = ""
    gPendingStopAtMain = false
    gPendingRun = false
    gConfigStopAtMain = false
    gConfigName = ""
    gDapPathRaw = ""
    gRequest = ""
    gDapHost = ""
    gDapPort = 0
    gSessionId = uuidV4()
    gPeers = 0
    gLastDetachMs = epochMillis()
    gIdleTtlSecs = args.getI64("idle-ttl")

    // Apply a --launch config through the same path as every other config
    // (wrapper unwrap + --config name select + validation), CLI flags gap-filled.
    if launchText.len > 0 {
        let err = applyConfig(mergeCliDefaults(launchText, binPath, srcPath), args.getString("config"))
        if err.len > 0 {
            eprint($"error: --launch: {err}\n")
            return 1
        }
    }

    // History always loads (hello carries it). Boot restore, unconditional: with
    // no --program, stage history[0] as the session config (idle, not launched) so
    // a fresh browser lands on the last thing debugged. Best-effort — a restored
    // entry whose program/adapter is gone just leaves the session idle.
    loadHistory()
    if binPath.len == 0 {
        match firstHistoryConfig() {
            Option.Some(cfg) => {
                if applyConfig(cfg, "").len == 0 {
                    gRestored = true
                }
            }
            Option.None => {
            }
        }
    }
    let bus = Channel<string>.new(1024)!
    let pendCh = Channel<Pending>.new(64)!
    let regCh = Channel<Sink>.new(16)!
    var busWake: [i32; 2] = [0; 2]
    unsafe {
        if pipe(busWake as *u8) != 0 {
            eprint("error: pipe failed\n")
            return 1
        }
    }
    let busWakeRd = busWake[0]
    let busWakeWr = busWake[1]
    Task.spawn(move(): void => {
        broadcastLoop(bus, busWakeRd, regCh)
    }
    )

    if gIdleTtlSecs > 0 {
        // 1s ticks for short (test) TTLs, 30s otherwise — reap latency ≤ ttl + tick.
        gTickUsecs = 30000000
        if gIdleTtlSecs <= 60 {
            gTickUsecs = 1000000
        }
        var tick: [i32; 2] = [0; 2]
        unsafe {
            if pipe(tick as *u8) != 0 {
                eprint("error: pipe failed\n")
                return 1
            }
        }
        let tickRd = tick[0]
        gTickWr = tick[1]
        Task.spawn(move(): void => {
            reaperLoop(tickRd, pendCh)
        }
        )
        // real OS thread (see tickerMain): fire-and-forget, never returns
        let _ticker = Promise<i64>.blocking(move(): i64 => {
            return tickerMain()
        }
        )
    }

    match TcpListener.bind(port as u16) {
        Result.Ok(listener) => {
            var l = listener
            print($"hades web UI → http://localhost:{port}")
            if binPath.len > 0 {
                if gRestored {
                    print($"  target:   {binPath}   ({adapterKind})   (restored — Run to launch)")
                } else {
                    print($"  target:   {binPath}   ({adapterKind})")
                }
                if srcPath.len > 0 {
                    print($"  source:   {srcPath}")
                }
            } else {
                print("  target:   (none — configure in the browser via the ⚙ drawer)")
            }
            print($"  co-debug: hades mcp --attach localhost:{port}   (AI joins this session)")
            if gLogLevel >= 1 {
                print("")
            }
            flush()
            openBrowser($"http://localhost:{port}")
            Task.spawn(move(): void => {
                acceptLoop(l, bus, busWakeWr, pendCh, regCh)
            }
            )
        }
        Result.Err(_e) => {
            print($"error: could not bind port {port}")
            return 1
        }
    }
    // Go exit semantics (milo dropped the implicit end-of-main scheduler drain):
    // drive the scheduler so the accept/broadcast/reaper loops keep running.
    // The server blocks here until the process is signalled.
    schedulerRunToCompletion()
    return 0
}
