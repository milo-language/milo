// Zilog Z80 CPU core (Genesis sound CPU). Functional, validated against the
// SingleStepTests z80 vectors. 8-bit data, 16-bit address (64 KB). Flags F:
// bit7 S, 6 Z, 5 Y, 4 H, 3 X, 2 P/V, 1 N, 0 C. The undocumented X/Y bits copy
// bits 5/3 of the result. R (refresh) increments its low 7 bits on each fetch.
//
// This is the first slice: register file, memory, the 8-bit LD matrix, the ALU
// group (ADD/ADC/SUB/SBC/AND/XOR/OR/CP), INC/DEC r, immediate loads, NOP/HALT.
// Prefixes (CB/ED/DD/FD), 16-bit ops, block ops, I/O, and interrupts follow.

// --- flag bit masks ---
let FC: i64 = 0x01
let FN: i64 = 0x02
let FPV: i64 = 0x04
let FX: i64 = 0x08
let FH: i64 = 0x10
let FY: i64 = 0x20
let FZ: i64 = 0x40
let FS: i64 = 0x80

struct Z80 {
    a: i64
    b: i64
    c: i64
    d: i64
    e: i64
    h: i64
    l: i64
    f: i64
    i: i64
    r: i64
    pc: i64
    sp: i64
    ix: i64
    iy: i64
    af_: i64 // shadow AF'
    bc_: i64
    de_: i64
    hl_: i64
    iff1: bool
    iff2: bool
    im: i64
    wz: i64 // internal MEMPTR
    halted: bool
    mem: Vec<u8>
    // --- Genesis integration (gen=true routes device accesses; the Harte harness
    // leaves it false so mem stays a flat 64 KB array) ---
    gen: bool
    bank: i64 // $6000 bank register: top 9 bits of the 68k window base
    ymAddr0: i64 // YM2612 part-I latched register address ($4000)
    ymAddr1: i64 // YM2612 part-II latched register address ($4002)
    ym: [i64; 512] // YM2612 register file (part I 0..255, part II 256..511)
    psgLatch: i64 // last SN76489 latched channel/type
    psg: [i64; 8] // PSG registers (4 channels x tone/vol)
    fmKey: [bool; 6] // per-FM-channel key-on, latched on every $28 write
    rom: Vec<u8> // 68k ROM copy, for the $8000-$FFFF bank window (DAC samples)
    dac: [i64; 4096] // DAC sample ring (ch6), written via reg $2A
    dacW: i64 // DAC ring write index
    dacR: i64 // DAC ring read index (advanced by the synth)
    // YM2612 timers. Many sound drivers (Aladdin's among them) pace playback by
    // polling the Timer A/B overflow flags in the $4000 status byte; without them
    // the driver spins forever waiting for an overflow that never comes. Modeled in
    // emulated-microseconds: the harness runs the Z80 at ~1.02M steps/emulated-sec
    // (130 instr/line, half 68k rate), so 1 step ~= 1 us, and the real HW periods
    // (Timer A = 18*(1024-NA) us, Timer B = 288*(256-NB) us) apply almost directly.
    ymStatus: i64 // status byte read at $4000: bit0 = Timer A overflow, bit1 = Timer B
    timerACnt: i64 // Timer A elapsed-us counter
    timerARun: bool
    timerBCnt: i64 // Timer B elapsed-us counter
    timerBRun: bool
}

fn newZ80(): Z80 {
    var mem: Vec<u8> = Vec.new()
    var i: i64 = 0
    while i < 0x10000 {
        mem.push(0)
        i = i + 1
    }
    return Z80 {
        a: 0, b: 0, c: 0, d: 0, e: 0, h: 0, l: 0, f: 0, i: 0, r: 0,
        pc: 0, sp: 0, ix: 0, iy: 0, af_: 0, bc_: 0, de_: 0, hl_: 0,
        iff1: false, iff2: false, im: 0, wz: 0, halted: false, mem: mem,
        gen: false, bank: 0, ymAddr0: 0, ymAddr1: 0, ym: [0; 512],
        psgLatch: 0, psg: [0; 8], fmKey: [false, false, false, false, false, false],
        rom: Vec.new(), dac: [0; 4096], dacW: 0, dacR: 0,
        ymStatus: 0, timerACnt: 0, timerARun: false, timerBCnt: 0, timerBRun: false,
    }
}

// Advance the YM2612 timers by `us` emulated-microseconds, setting the overflow
// flags in the status byte when a period elapses. Enable bits (reg $27 bit2/bit3)
// gate whether an overflow actually latches into the status byte.
fn ymTimerTick(cpu: &mut Z80, us: i64) {
    if cpu.timerARun {
        cpu.timerACnt = cpu.timerACnt + us
        let na = ((cpu.ym[0x24] & 0xFF) << 2) | (cpu.ym[0x25] & 0x3)
        let periodA = 18 * (1024 - na)
        if periodA > 0 && cpu.timerACnt >= periodA {
            cpu.timerACnt = cpu.timerACnt - periodA
            if (cpu.ym[0x27] & 0x04) != 0 {
                cpu.ymStatus = cpu.ymStatus | 0x01
            }
        }
    }
    if cpu.timerBRun {
        cpu.timerBCnt = cpu.timerBCnt + us
        let nb = cpu.ym[0x26] & 0xFF
        let periodB = 288 * (256 - nb)
        if periodB > 0 && cpu.timerBCnt >= periodB {
            cpu.timerBCnt = cpu.timerBCnt - periodB
            if (cpu.ym[0x27] & 0x08) != 0 {
                cpu.ymStatus = cpu.ymStatus | 0x02
            }
        }
    }
}

fn rd(cpu: &Z80, addr: i64): i64 {
    let a = addr & 0xFFFF
    if cpu.gen {
        if a < 0x4000 {
            return cpu.mem[a & 0x1FFF] as i64 // 8 KB RAM mirrored across $0000-$3FFF
        }
        if a >= 0x8000 {
            // $8000-$FFFF: banked window into 68k address space (bank reg << 15).
            let src = ((cpu.bank << 15) | (a & 0x7FFF)) & 0xFFFFFF
            if src < cpu.rom.len {
                return cpu.rom[src] as i64
            }
            return 0
        }
        if a >= 0x4000 && a <= 0x4003 {
            return cpu.ymStatus // bit0/1 = Timer A/B overflow; bit7 (busy) = 0 = ready
        }
        return 0 // $6000/$7Fxx read 0
    }
    return cpu.mem[a] as i64
}

fn wr(cpu: &mut Z80, addr: i64, val: i64) {
    let a = addr & 0xFFFF
    if cpu.gen {
        z80DevWrite(cpu, a, val & 0xFF)
        return
    }
    cpu.mem[a] = (val & 0xFF) as u8
}

// Z80-side Genesis memory map: 8 KB RAM ($0000-$1FFF, mirrored to $3FFF),
// YM2612 ($4000-$4003), bank register ($6000), PSG ($7F11).
fn z80DevWrite(cpu: &mut Z80, a: i64, val: i64) {
    if a < 0x4000 {
        cpu.mem[a & 0x1FFF] = val as u8
        return
    }
    if a == 0x4000 {
        cpu.ymAddr0 = val
        return
    }
    if a == 0x4001 {
        let reg = cpu.ymAddr0 & 0xFF
        cpu.ym[reg] = val
        if reg == 0x2A {
            // DAC sample write: append to the ch6 DAC ring.
            cpu.dac[cpu.dacW & 4095] = val
            cpu.dacW = cpu.dacW + 1
        }
        if reg == 0x27 {
            // Timer control: bit0/1 = load (run) Timer A/B, bit4/5 = reset overflow
            // flag. Drivers poll the flag then strobe reset to re-arm the next tick.
            cpu.timerARun = (val & 0x01) != 0
            cpu.timerBRun = (val & 0x02) != 0
            if (val & 0x10) != 0 {
                cpu.ymStatus = cpu.ymStatus & ~0x01
            }
            if (val & 0x20) != 0 {
                cpu.ymStatus = cpu.ymStatus & ~0x02
            }
        }
        if reg == 0x28 {
            // key on/off: %oooo0ccc (op mask + channel; ccc: 0-2 = ch0-2, 4-6 = ch3-5)
            let sel = val & 0x7
            var ch = sel
            if sel >= 4 {
                ch = sel - 1
            }
            if ch < 6 {
                cpu.fmKey[ch] = (val & 0xF0) != 0
            }
        }
        return
    }
    if a == 0x4002 {
        cpu.ymAddr1 = val
        return
    }
    if a == 0x4003 {
        cpu.ym[256 + (cpu.ymAddr1 & 0xFF)] = val
        return
    }
    if a == 0x6000 {
        // serial bank register: shift the low bit into the 68k window base
        cpu.bank = ((cpu.bank >> 1) | ((val & 1) << 8)) & 0x1FF
        return
    }
    if a == 0x7F11 {
        psgWrite(cpu, val)
        return
    }
}

// SN76489 PSG register write (latch/data protocol).
fn psgWrite(cpu: &mut Z80, val: i64) {
    if (val & 0x80) != 0 {
        // latch byte %1cctdddd
        let reg = (val >> 4) & 0x7
        cpu.psgLatch = reg
        cpu.psg[reg] = (cpu.psg[reg] & 0x3F0) | (val & 0xF)
    } else {
        // data byte %0.dddddd
        let reg = cpu.psgLatch
        if (reg & 1) == 0 {
            cpu.psg[reg] = (cpu.psg[reg] & 0xF) | ((val & 0x3F) << 4)
        } else {
            cpu.psg[reg] = val & 0xF
        }
    }
}

// Opcode/operand fetch. Only opcode fetches bump R; use zfetch8 for operands.
fn fetchOp(cpu: &mut Z80): i64 {
    let op = rd(cpu, cpu.pc)
    cpu.pc = (cpu.pc + 1) & 0xFFFF
    cpu.r = (cpu.r & 0x80) | ((cpu.r + 1) & 0x7F)
    return op
}

fn zfetch8(cpu: &mut Z80): i64 {
    let v = rd(cpu, cpu.pc)
    cpu.pc = (cpu.pc + 1) & 0xFFFF
    return v
}

fn zfetch16(cpu: &mut Z80): i64 {
    let lo = zfetch8(cpu)
    let hi = zfetch8(cpu)
    return (hi << 8) | lo
}

// --- 16-bit register pair accessors ---
fn getHL(cpu: &Z80): i64 {
    return (cpu.h << 8) | cpu.l
}

fn setHL(cpu: &mut Z80, v: i64) {
    cpu.h = (v >> 8) & 0xFF
    cpu.l = v & 0xFF
}

fn getBC(cpu: &Z80): i64 {
    return (cpu.b << 8) | cpu.c
}

fn getDE(cpu: &Z80): i64 {
    return (cpu.d << 8) | cpu.e
}

fn setFlag(cpu: &mut Z80, bit: i64, on: bool) {
    if on {
        cpu.f = cpu.f | bit
    } else {
        cpu.f = cpu.f & ~bit
    }
}

fn parityEven(v: i64): bool {
    var x = v & 0xFF
    var count: i64 = 0
    var i: i64 = 0
    while i < 8 {
        if (x & 1) != 0 {
            count = count + 1
        }
        x = x >> 1
        i = i + 1
    }
    return (count & 1) == 0
}

// Set S,Z,Y,X from an 8-bit result (caller sets H,P/V,N,C).
fn setSZYX(cpu: &mut Z80, r: i64) {
    let v = r & 0xFF
    setFlag(cpu, FS, (v & 0x80) != 0)
    setFlag(cpu, FZ, v == 0)
    setFlag(cpu, FY, (v & 0x20) != 0)
    setFlag(cpu, FX, (v & 0x08) != 0)
}

// --- register-index access (Z80 encoding 0..7 = B,C,D,E,H,L,(HL),A) ---
fn getReg(cpu: &mut Z80, idx: i64): i64 {
    if idx == 0 {
        return cpu.b
    }
    if idx == 1 {
        return cpu.c
    }
    if idx == 2 {
        return cpu.d
    }
    if idx == 3 {
        return cpu.e
    }
    if idx == 4 {
        return cpu.h
    }
    if idx == 5 {
        return cpu.l
    }
    if idx == 6 {
        return rd(cpu, getHL(cpu))
    }
    return cpu.a
}

fn setReg(cpu: &mut Z80, idx: i64, val: i64) {
    let v = val & 0xFF
    if idx == 0 {
        cpu.b = v
    } else if idx == 1 {
        cpu.c = v
    } else if idx == 2 {
        cpu.d = v
    } else if idx == 3 {
        cpu.e = v
    } else if idx == 4 {
        cpu.h = v
    } else if idx == 5 {
        cpu.l = v
    } else if idx == 6 {
        wr(cpu, getHL(cpu), v)
    } else {
        cpu.a = v
    }
}

// --- ALU on the accumulator ---
fn aluAdd(cpu: &mut Z80, val: i64, carry: i64) {
    let a = cpu.a
    let r = a + val + carry
    let res = r & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, ((a & 0xF) + (val & 0xF) + carry) > 0xF)
    setFlag(cpu, FPV, (((a ^ ~val) & (a ^ res)) & 0x80) != 0)
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, r > 0xFF)
    cpu.a = res
}

fn aluSub(cpu: &mut Z80, val: i64, carry: i64, store: bool) {
    let a = cpu.a
    let r = a - val - carry
    let res = r & 0xFF
    // CP uses operand bits 3/5 for X/Y; SUB/SBC use the result.
    setFlag(cpu, FS, (res & 0x80) != 0)
    setFlag(cpu, FZ, res == 0)
    setFlag(cpu, FH, ((a & 0xF) - (val & 0xF) - carry) < 0)
    setFlag(cpu, FPV, (((a ^ val) & (a ^ res)) & 0x80) != 0)
    setFlag(cpu, FN, true)
    setFlag(cpu, FC, r < 0)
    if store {
        setFlag(cpu, FY, (res & 0x20) != 0)
        setFlag(cpu, FX, (res & 0x08) != 0)
        cpu.a = res
    } else {
        // CP: undocumented flags come from the operand
        setFlag(cpu, FY, (val & 0x20) != 0)
        setFlag(cpu, FX, (val & 0x08) != 0)
    }
}

fn aluAnd(cpu: &mut Z80, val: i64) {
    let res = cpu.a & val & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, true)
    setFlag(cpu, FPV, parityEven(res))
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, false)
    cpu.a = res
}

fn aluXor(cpu: &mut Z80, val: i64) {
    let res = (cpu.a ^ val) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, false)
    setFlag(cpu, FPV, parityEven(res))
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, false)
    cpu.a = res
}

fn aluOr(cpu: &mut Z80, val: i64) {
    let res = (cpu.a | val) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, false)
    setFlag(cpu, FPV, parityEven(res))
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, false)
    cpu.a = res
}

fn doAlu(cpu: &mut Z80, op: i64, val: i64) {
    let cf = cpu.f & FC
    if op == 0 {
        aluAdd(cpu, val, 0)
    } else if op == 1 {
        aluAdd(cpu, val, cf)
    } else if op == 2 {
        aluSub(cpu, val, 0, true)
    } else if op == 3 {
        aluSub(cpu, val, cf, true)
    } else if op == 4 {
        aluAnd(cpu, val)
    } else if op == 5 {
        aluXor(cpu, val)
    } else if op == 6 {
        aluOr(cpu, val)
    } else {
        aluSub(cpu, val, 0, false) // CP
    }
}

fn incReg(cpu: &mut Z80, idx: i64) {
    let v = getReg(cpu, idx)
    let res = (v + 1) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, (v & 0xF) == 0xF)
    setFlag(cpu, FPV, v == 0x7F)
    setFlag(cpu, FN, false)
    setReg(cpu, idx, res)
}

fn decReg(cpu: &mut Z80, idx: i64) {
    let v = getReg(cpu, idx)
    let res = (v - 1) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, (v & 0xF) == 0)
    setFlag(cpu, FPV, v == 0x80)
    setFlag(cpu, FN, true)
    setReg(cpu, idx, res)
}

fn getAF(cpu: &Z80): i64 {
    return (cpu.a << 8) | cpu.f
}

fn setAF(cpu: &mut Z80, v: i64) {
    cpu.a = (v >> 8) & 0xFF
    cpu.f = v & 0xFF
}

fn setBC(cpu: &mut Z80, v: i64) {
    cpu.b = (v >> 8) & 0xFF
    cpu.c = v & 0xFF
}

fn setDE(cpu: &mut Z80, v: i64) {
    cpu.d = (v >> 8) & 0xFF
    cpu.e = v & 0xFF
}

// rp table (p: 0 BC, 1 DE, 2 HL, 3 SP)
fn getRP(cpu: &Z80, p: i64): i64 {
    if p == 0 {
        return getBC(cpu)
    }
    if p == 1 {
        return getDE(cpu)
    }
    if p == 2 {
        return getHL(cpu)
    }
    return cpu.sp
}

fn setRP(cpu: &mut Z80, p: i64, v: i64) {
    if p == 0 {
        setBC(cpu, v)
    } else if p == 1 {
        setDE(cpu, v)
    } else if p == 2 {
        setHL(cpu, v)
    } else {
        cpu.sp = v & 0xFFFF
    }
}

// rp2 table (p: 0 BC, 1 DE, 2 HL, 3 AF)
fn getRP2(cpu: &Z80, p: i64): i64 {
    if p == 3 {
        return getAF(cpu)
    }
    return getRP(cpu, p)
}

fn setRP2(cpu: &mut Z80, p: i64, v: i64) {
    if p == 3 {
        setAF(cpu, v)
    } else {
        setRP(cpu, p, v)
    }
}

// Deliver the Z80 maskable interrupt (its INT line is tied to the VDP VBlank on
// the Genesis). Fires once per frame if interrupts are enabled. IM 1 (the usual
// mode) vectors to $0038; IM 2 uses the I-register vector table.
fn z80Interrupt(cpu: &mut Z80): bool {
    if !cpu.iff1 {
        return false
    }
    cpu.iff1 = false
    cpu.iff2 = false
    cpu.halted = false
    push16(cpu, cpu.pc)
    if cpu.im == 2 {
        let vec = ((cpu.i << 8) | 0xFF) & 0xFFFF
        cpu.pc = rd(cpu, vec) | (rd(cpu, (vec + 1) & 0xFFFF) << 8)
    } else {
        cpu.pc = 0x0038 // IM 0/1 -> RST 38
    }
    return true
}

fn push16(cpu: &mut Z80, v: i64) {
    cpu.sp = (cpu.sp - 1) & 0xFFFF
    wr(cpu, cpu.sp, (v >> 8) & 0xFF)
    cpu.sp = (cpu.sp - 1) & 0xFFFF
    wr(cpu, cpu.sp, v & 0xFF)
}

fn pop16(cpu: &mut Z80): i64 {
    let lo = rd(cpu, cpu.sp)
    cpu.sp = (cpu.sp + 1) & 0xFFFF
    let hi = rd(cpu, cpu.sp)
    cpu.sp = (cpu.sp + 1) & 0xFFFF
    return (hi << 8) | lo
}

// Condition codes (y 0-7): NZ,Z,NC,C,PO,PE,P,M.
fn testCC(cpu: &Z80, y: i64): bool {
    if y == 0 {
        return (cpu.f & FZ) == 0
    }
    if y == 1 {
        return (cpu.f & FZ) != 0
    }
    if y == 2 {
        return (cpu.f & FC) == 0
    }
    if y == 3 {
        return (cpu.f & FC) != 0
    }
    if y == 4 {
        return (cpu.f & FPV) == 0
    }
    if y == 5 {
        return (cpu.f & FPV) != 0
    }
    if y == 6 {
        return (cpu.f & FS) == 0
    }
    return (cpu.f & FS) != 0
}

// ADD HL, rr: H from bit-11 carry, C from bit-15, N=0; X/Y from result high byte;
// S/Z/P-V unaffected.
fn add16(cpu: &mut Z80, a: i64, b: i64): i64 {
    let r = a + b
    let res = r & 0xFFFF
    setFlag(cpu, FH, ((a & 0xFFF) + (b & 0xFFF)) > 0xFFF)
    setFlag(cpu, FC, r > 0xFFFF)
    setFlag(cpu, FN, false)
    setFlag(cpu, FY, (res & 0x2000) != 0)
    setFlag(cpu, FX, (res & 0x0800) != 0)
    return res
}

// Accumulator rotates (RLCA/RRCA/RLA/RRA): C from the rotated bit, H=N=0,
// X/Y from the result; S/Z/P-V unaffected.
fn rotAcc(cpu: &mut Z80, kind: i64) {
    let a = cpu.a
    var res: i64 = 0
    var carry = false
    if kind == 0 {
        // RLCA
        carry = (a & 0x80) != 0
        res = ((a << 1) | (if carry {
            1
        } else {
            0
        }
        )) & 0xFF
    } else if kind == 1 {
        // RRCA
        carry = (a & 0x01) != 0
        res = ((a >> 1) | (if carry {
            0x80
        } else {
            0
        }
        )) & 0xFF
    } else if kind == 2 {
        // RLA (through carry)
        let cin = (cpu.f & FC) != 0
        carry = (a & 0x80) != 0
        res = ((a << 1) | (if cin {
            1
        } else {
            0
        }
        )) & 0xFF
    } else {
        // RRA
        let cin = (cpu.f & FC) != 0
        carry = (a & 0x01) != 0
        res = ((a >> 1) | (if cin {
            0x80
        } else {
            0
        }
        )) & 0xFF
    }
    cpu.a = res
    setFlag(cpu, FC, carry)
    setFlag(cpu, FH, false)
    setFlag(cpu, FN, false)
    setFlag(cpu, FY, (res & 0x20) != 0)
    setFlag(cpu, FX, (res & 0x08) != 0)
}

fn doDaa(cpu: &mut Z80) {
    var a = cpu.a
    var adjust: i64 = 0
    let n = (cpu.f & FN) != 0
    var carry = (cpu.f & FC) != 0
    if (cpu.f & FH) != 0 || (a & 0xF) > 9 {
        adjust = adjust | 0x06
    }
    if carry || a > 0x99 {
        adjust = adjust | 0x60
        carry = true
    }
    if n {
        a = (a - adjust) & 0xFF
    } else {
        a = (a + adjust) & 0xFF
    }
    setFlag(cpu, FH, (((cpu.a ^ a) & 0x10) != 0))
    cpu.a = a
    setSZYX(cpu, a)
    setFlag(cpu, FPV, parityEven(a))
    setFlag(cpu, FC, carry)
}

// Execute one instruction. Returns false on an opcode not yet implemented.
fn stepZ80(cpu: &mut Z80): bool {
    ymTimerTick(cpu, 1) // ~1 emulated-us per step (see struct note); paces sound drivers
    let op = fetchOp(cpu)
    let x = (op >> 6) & 0x3
    let y = (op >> 3) & 0x7
    let z = op & 0x7
    let p = y >> 1
    let q = y & 1

    if op == 0x76 {
        cpu.halted = true // HALT
        return true
    }
    if op == 0xCB {
        return execCB(cpu)
    }
    if op == 0xED {
        return execED(cpu)
    }
    if op == 0xDD {
        return execIndex(cpu, false)
    }
    if op == 0xFD {
        return execIndex(cpu, true)
    }
    if x == 1 {
        setReg(cpu, y, getReg(cpu, z)) // LD r, r'
        return true
    }
    if x == 2 {
        doAlu(cpu, y, getReg(cpu, z)) // ALU A, r
        return true
    }
    if x == 0 {
        return execX0(cpu, op, y, z, p, q)
    }
    return execX3(cpu, op, y, z, p, q)
}

fn execX0(cpu: &mut Z80, _op: i64, y: i64, z: i64, p: i64, q: i64): bool {
    if z == 0 {
        if y == 0 {
            return true // NOP
        }
        if y == 1 {
            // EX AF, AF'
            let t = getAF(cpu)
            setAF(cpu, cpu.af_)
            cpu.af_ = t
            return true
        }
        let d = signExt8(zfetch8(cpu))
        if y == 2 {
            // DJNZ
            cpu.b = (cpu.b - 1) & 0xFF
            if cpu.b != 0 {
                cpu.pc = (cpu.pc + d) & 0xFFFF
            }
            return true
        }
        if y == 3 {
            cpu.pc = (cpu.pc + d) & 0xFFFF // JR
            return true
        }
        // JR cc, d  (y 4-7 -> cc 0-3)
        if testCC(cpu, y - 4) {
            cpu.pc = (cpu.pc + d) & 0xFFFF
        }
        return true
    }
    if z == 1 {
        if q == 0 {
            setRP(cpu, p, zfetch16(cpu)) // LD rp, nn
        } else {
            setHL(cpu, add16(cpu, getHL(cpu), getRP(cpu, p))) // ADD HL, rp
        }
        return true
    }
    if z == 2 {
        return execIndirect(cpu, p, q)
    }
    if z == 3 {
        if q == 0 {
            setRP(cpu, p, (getRP(cpu, p) + 1) & 0xFFFF) // INC rp
        } else {
            setRP(cpu, p, (getRP(cpu, p) - 1) & 0xFFFF) // DEC rp
        }
        return true
    }
    if z == 4 {
        incReg(cpu, y)
        return true
    }
    if z == 5 {
        decReg(cpu, y)
        return true
    }
    if z == 6 {
        setReg(cpu, y, zfetch8(cpu)) // LD r, n
        return true
    }
    // z == 7: RLCA/RRCA/RLA/RRA/DAA/CPL/SCF/CCF
    if y < 4 {
        rotAcc(cpu, y)
    } else if y == 4 {
        doDaa(cpu)
    } else if y == 5 {
        cpu.a = (~cpu.a) & 0xFF // CPL
        setFlag(cpu, FH, true)
        setFlag(cpu, FN, true)
        setFlag(cpu, FY, (cpu.a & 0x20) != 0)
        setFlag(cpu, FX, (cpu.a & 0x08) != 0)
    } else if y == 6 {
        // SCF
        setFlag(cpu, FC, true)
        setFlag(cpu, FH, false)
        setFlag(cpu, FN, false)
        setFlag(cpu, FY, (cpu.a & 0x20) != 0)
        setFlag(cpu, FX, (cpu.a & 0x08) != 0)
    } else {
        // CCF
        let oldC = (cpu.f & FC) != 0
        setFlag(cpu, FH, oldC)
        setFlag(cpu, FC,!oldC)
        setFlag(cpu, FN, false)
        setFlag(cpu, FY, (cpu.a & 0x20) != 0)
        setFlag(cpu, FX, (cpu.a & 0x08) != 0)
    }
    return true
}

// z==2 in x==0: indirect accumulator / HL loads.
fn execIndirect(cpu: &mut Z80, p: i64, q: i64): bool {
    if q == 0 {
        if p == 0 {
            wr(cpu, getBC(cpu), cpu.a) // LD (BC), A
        } else if p == 1 {
            wr(cpu, getDE(cpu), cpu.a) // LD (DE), A
        } else if p == 2 {
            let nn = zfetch16(cpu) // LD (nn), HL
            wr(cpu, nn, cpu.l)
            wr(cpu, nn + 1, cpu.h)
        } else {
            wr(cpu, zfetch16(cpu), cpu.a) // LD (nn), A
        }
    } else {
        if p == 0 {
            cpu.a = rd(cpu, getBC(cpu)) // LD A, (BC)
        } else if p == 1 {
            cpu.a = rd(cpu, getDE(cpu)) // LD A, (DE)
        } else if p == 2 {
            let nn = zfetch16(cpu) // LD HL, (nn)
            cpu.l = rd(cpu, nn)
            cpu.h = rd(cpu, nn + 1)
        } else {
            cpu.a = rd(cpu, zfetch16(cpu)) // LD A, (nn)
        }
    }
    return true
}

fn execX3(cpu: &mut Z80, _op: i64, y: i64, z: i64, p: i64, q: i64): bool {
    if z == 0 {
        // RET cc
        if testCC(cpu, y) {
            cpu.pc = pop16(cpu)
        }
        return true
    }
    if z == 1 {
        if q == 0 {
            setRP2(cpu, p, pop16(cpu)) // POP rp2
            return true
        }
        if p == 0 {
            cpu.pc = pop16(cpu) // RET
        } else if p == 1 {
            // EXX
            let b = getBC(cpu)
            let d = getDE(cpu)
            let h = getHL(cpu)
            setBC(cpu, cpu.bc_)
            setDE(cpu, cpu.de_)
            setHL(cpu, cpu.hl_)
            cpu.bc_ = b
            cpu.de_ = d
            cpu.hl_ = h
        } else if p == 2 {
            cpu.pc = getHL(cpu) // JP HL
        } else {
            cpu.sp = getHL(cpu) // LD SP, HL
        }
        return true
    }
    if z == 2 {
        let nn = zfetch16(cpu) // JP cc, nn
        if testCC(cpu, y) {
            cpu.pc = nn
        }
        return true
    }
    if z == 3 {
        if y == 0 {
            cpu.pc = zfetch16(cpu) // JP nn
            return true
        }
        if y == 4 {
            // EX (SP), HL
            let lo = rd(cpu, cpu.sp)
            let hi = rd(cpu, cpu.sp + 1)
            wr(cpu, cpu.sp, cpu.l)
            wr(cpu, cpu.sp + 1, cpu.h)
            cpu.l = lo
            cpu.h = hi
            return true
        }
        if y == 5 {
            // EX DE, HL
            let d = getDE(cpu)
            setDE(cpu, getHL(cpu))
            setHL(cpu, d)
            return true
        }
        if y == 6 {
            cpu.iff1 = false // DI
            cpu.iff2 = false
            return true
        }
        if y == 7 {
            cpu.iff1 = true // EI
            cpu.iff2 = true
            return true
        }
        return false // CB prefix / IN / OUT — deferred
    }
    if z == 4 {
        let nn = zfetch16(cpu) // CALL cc, nn
        if testCC(cpu, y) {
            push16(cpu, cpu.pc)
            cpu.pc = nn
        }
        return true
    }
    if z == 5 {
        if q == 0 {
            push16(cpu, getRP2(cpu, p)) // PUSH rp2
            return true
        }
        if p == 0 {
            let nn = zfetch16(cpu) // CALL nn
            push16(cpu, cpu.pc)
            cpu.pc = nn
            return true
        }
        return false // DD / ED / FD prefixes — deferred
    }
    if z == 6 {
        doAlu(cpu, y, zfetch8(cpu)) // ALU A, n
        return true
    }
    // z == 7: RST
    push16(cpu, cpu.pc)
    cpu.pc = y * 8
    return true
}

fn signExt8(v: i64): i64 {
    if (v & 0x80) != 0 {
        return v - 256
    }
    return v
}

// INC/DEC on an arbitrary 8-bit value with flag effects, returning the result.
fn incVal(cpu: &mut Z80, v: i64): i64 {
    let res = (v + 1) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, (v & 0xF) == 0xF)
    setFlag(cpu, FPV, v == 0x7F)
    setFlag(cpu, FN, false)
    return res
}

fn decVal(cpu: &mut Z80, v: i64): i64 {
    let res = (v - 1) & 0xFF
    setSZYX(cpu, res)
    setFlag(cpu, FH, (v & 0xF) == 0)
    setFlag(cpu, FPV, v == 0x80)
    setFlag(cpu, FN, true)
    return res
}

// DD/FD prefix: IX/IY variants. Handles (index+d) memory ops, the 16-bit index
// ops, and DDCB/FDCB. The undocumented IXh/IXl split-register ops are not needed
// by the Genesis sound driver and are left unimplemented.
fn execIndex(cpu: &mut Z80, isIY: bool): bool {
    var base = if isIY {
        cpu.iy
    } else {
        cpu.ix
    }
    let op = fetchOp(cpu)

    if op == 0xCB {
        let d = signExt8(zfetch8(cpu))
        let addr = (base + d) & 0xFFFF
        return execDDCB(cpu, addr)
    }
    // ADD IX, rp  (rp p==2 is IX itself)
    if op == 0x09 || op == 0x19 || op == 0x29 || op == 0x39 {
        let p = (op >> 4) & 0x3
        var rp = getRP(cpu, p)
        if p == 2 {
            rp = base
        }
        base = add16(cpu, base, rp)
        return storeIndex(cpu, isIY, base)
    }
    if op == 0x21 {
        base = zfetch16(cpu) // LD IX, nn
        return storeIndex(cpu, isIY, base)
    }
    if op == 0x22 {
        let nn = zfetch16(cpu) // LD (nn), IX
        wr(cpu, nn, base & 0xFF)
        wr(cpu, nn + 1, (base >> 8) & 0xFF)
        return true
    }
    if op == 0x2A {
        let nn = zfetch16(cpu) // LD IX, (nn)
        base = rd(cpu, nn) | (rd(cpu, nn + 1) << 8)
        return storeIndex(cpu, isIY, base)
    }
    if op == 0x23 {
        base = (base + 1) & 0xFFFF // INC IX
        return storeIndex(cpu, isIY, base)
    }
    if op == 0x2B {
        base = (base - 1) & 0xFFFF // DEC IX
        return storeIndex(cpu, isIY, base)
    }
    if op == 0xE5 {
        push16(cpu, base) // PUSH IX
        return true
    }
    if op == 0xE1 {
        base = pop16(cpu) // POP IX
        return storeIndex(cpu, isIY, base)
    }
    if op == 0xE3 {
        // EX (SP), IX
        let lo = rd(cpu, cpu.sp)
        let hi = rd(cpu, cpu.sp + 1)
        wr(cpu, cpu.sp, base & 0xFF)
        wr(cpu, cpu.sp + 1, (base >> 8) & 0xFF)
        base = (hi << 8) | lo
        return storeIndex(cpu, isIY, base)
    }
    if op == 0xE9 {
        cpu.pc = base // JP (IX)
        return true
    }
    if op == 0xF9 {
        cpu.sp = base // LD SP, IX
        return true
    }
    if op == 0x34 {
        let d = signExt8(zfetch8(cpu)) // INC (IX+d)
        let a = (base + d) & 0xFFFF
        wr(cpu, a, incVal(cpu, rd(cpu, a)))
        return true
    }
    if op == 0x35 {
        let d = signExt8(zfetch8(cpu)) // DEC (IX+d)
        let a = (base + d) & 0xFFFF
        wr(cpu, a, decVal(cpu, rd(cpu, a)))
        return true
    }
    if op == 0x36 {
        let d = signExt8(zfetch8(cpu)) // LD (IX+d), n
        let n = zfetch8(cpu)
        wr(cpu, (base + d) & 0xFFFF, n)
        return true
    }

    let x = (op >> 6) & 0x3
    let y = (op >> 3) & 0x7
    let z = op & 0x7
    // LD r,(IX+d) / LD (IX+d),r  (x==1 with a memory operand)
    if x == 1 && op != 0x76 && (y == 6 || z == 6) {
        let d = signExt8(zfetch8(cpu))
        let a = (base + d) & 0xFFFF
        if z == 6 {
            setReg(cpu, y, rd(cpu, a)) // LD y, (IX+d)  — y is a real register
        } else {
            wr(cpu, a, getReg(cpu, z)) // LD (IX+d), z
        }
        return true
    }
    // ALU A, (IX+d)
    if x == 2 && z == 6 {
        let d = signExt8(zfetch8(cpu))
        doAlu(cpu, y, rd(cpu, (base + d) & 0xFFFF))
        return true
    }
    // Any other opcode: the prefix is inert here (IXh/IXl split not modelled).
    return false
}

fn storeIndex(cpu: &mut Z80, isIY: bool, v: i64): bool {
    if isIY {
        cpu.iy = v & 0xFFFF
    } else {
        cpu.ix = v & 0xFFFF
    }
    return true
}

// DDCB/FDCB: rotate/shift/bit/res/set on (index+d). Non-BIT ops also copy the
// result into register z (undocumented) unless z selects (HL)/memory.
fn execDDCB(cpu: &mut Z80, addr: i64): bool {
    let op = zfetch8(cpu) // final byte does not bump R
    let x = (op >> 6) & 0x3
    let y = (op >> 3) & 0x7
    let z = op & 0x7
    let v = rd(cpu, addr)

    if x == 1 {
        // BIT y, (index+d): X/Y from the address high byte
        let bitset = ((v >> y) & 1) != 0
        setFlag(cpu, FZ,!bitset)
        setFlag(cpu, FPV,!bitset)
        setFlag(cpu, FH, true)
        setFlag(cpu, FN, false)
        setFlag(cpu, FS, y == 7 && bitset)
        setFlag(cpu, FY, ((addr >> 8) & 0x20) != 0)
        setFlag(cpu, FX, ((addr >> 8) & 0x08) != 0)
        return true
    }
    var res: i64 = 0
    if x == 0 {
        res = shiftOp(cpu, y, v)
    } else if x == 2 {
        res = v & ~(1 << y) // RES
    } else {
        res = v | (1 << y) // SET
    }
    wr(cpu, addr, res)
    if z != 6 {
        setReg(cpu, z, res) // undocumented register copy
    }
    return true
}

// CB prefix: rotates/shifts (x=0), BIT (x=1), RES (x=2), SET (x=3) on reg z.
fn execCB(cpu: &mut Z80): bool {
    let op = fetchOp(cpu) // the CB byte already bumped R; the operand op bumps again
    let x = (op >> 6) & 0x3
    let y = (op >> 3) & 0x7
    let z = op & 0x7

    if x == 0 {
        let v = getReg(cpu, z)
        let res = shiftOp(cpu, y, v)
        setReg(cpu, z, res)
        return true
    }
    if x == 1 {
        // BIT y, r
        let v = getReg(cpu, z)
        let bitset = ((v >> y) & 1) != 0
        setFlag(cpu, FZ,!bitset)
        setFlag(cpu, FPV,!bitset)
        setFlag(cpu, FH, true)
        setFlag(cpu, FN, false)
        setFlag(cpu, FS, y == 7 && bitset)
        // undocumented X/Y: from the operand, except (HL) uses WZ high byte
        if z == 6 {
            setFlag(cpu, FY, ((cpu.wz >> 8) & 0x20) != 0)
            setFlag(cpu, FX, ((cpu.wz >> 8) & 0x08) != 0)
        } else {
            setFlag(cpu, FY, (v & 0x20) != 0)
            setFlag(cpu, FX, (v & 0x08) != 0)
        }
        return true
    }
    if x == 2 {
        setReg(cpu, z, getReg(cpu, z) & ~(1 << y)) // RES
        return true
    }
    setReg(cpu, z, getReg(cpu, z) | (1 << y)) // SET
    return true
}

// 16-bit ADC/SBC HL,rp. S/Z from bit15, H from bit12, PV overflow, N, C, Y/X from
// the result high byte.
fn adcHL(cpu: &mut Z80, rp: i64) {
    let hl = getHL(cpu)
    let c = cpu.f & FC
    let r = hl + rp + c
    let res = r & 0xFFFF
    setFlag(cpu, FS, (res & 0x8000) != 0)
    setFlag(cpu, FZ, res == 0)
    setFlag(cpu, FH, ((hl & 0xFFF) + (rp & 0xFFF) + c) > 0xFFF)
    setFlag(cpu, FPV, (((~(hl ^ rp)) & (hl ^ res)) & 0x8000) != 0)
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, r > 0xFFFF)
    setFlag(cpu, FY, (res & 0x2000) != 0)
    setFlag(cpu, FX, (res & 0x0800) != 0)
    setHL(cpu, res)
}

fn sbcHL(cpu: &mut Z80, rp: i64) {
    let hl = getHL(cpu)
    let c = cpu.f & FC
    let r = hl - rp - c
    let res = r & 0xFFFF
    setFlag(cpu, FS, (res & 0x8000) != 0)
    setFlag(cpu, FZ, res == 0)
    setFlag(cpu, FH, ((hl & 0xFFF) - (rp & 0xFFF) - c) < 0)
    setFlag(cpu, FPV, (((hl ^ rp) & (hl ^ res)) & 0x8000) != 0)
    setFlag(cpu, FN, true)
    setFlag(cpu, FC, r < 0)
    setFlag(cpu, FY, (res & 0x2000) != 0)
    setFlag(cpu, FX, (res & 0x0800) != 0)
    setHL(cpu, res)
}

// One LDI/LDD block transfer step (dir +1 or -1).
fn blockLd(cpu: &mut Z80, dir: i64) {
    let v = rd(cpu, getHL(cpu))
    wr(cpu, getDE(cpu), v)
    setDE(cpu, (getDE(cpu) + dir) & 0xFFFF)
    setHL(cpu, (getHL(cpu) + dir) & 0xFFFF)
    setBC(cpu, (getBC(cpu) - 1) & 0xFFFF)
    let n = (v + cpu.a) & 0xFF
    setFlag(cpu, FH, false)
    setFlag(cpu, FN, false)
    setFlag(cpu, FPV, getBC(cpu) != 0)
    setFlag(cpu, FY, (n & 0x02) != 0)
    setFlag(cpu, FX, (n & 0x08) != 0)
}

// One CPI/CPD block compare step.
fn blockCp(cpu: &mut Z80, dir: i64) {
    let v = rd(cpu, getHL(cpu))
    let r = (cpu.a - v) & 0xFF
    let hcarry = ((cpu.a & 0xF) - (v & 0xF)) < 0
    setHL(cpu, (getHL(cpu) + dir) & 0xFFFF)
    setBC(cpu, (getBC(cpu) - 1) & 0xFFFF)
    setFlag(cpu, FS, (r & 0x80) != 0)
    setFlag(cpu, FZ, r == 0)
    setFlag(cpu, FH, hcarry)
    setFlag(cpu, FN, true)
    setFlag(cpu, FPV, getBC(cpu) != 0)
    var hb: i64 = 0
    if hcarry {
        hb = 1
    }
    let n = (r - hb) & 0xFF
    setFlag(cpu, FY, (n & 0x02) != 0)
    setFlag(cpu, FX, (n & 0x08) != 0)
}

// ED prefix. IN/OUT (and block I/O) are deferred — Genesis maps the YM2612 into
// memory, not Z80 ports, so the sound driver does not use them.
fn execED(cpu: &mut Z80): bool {
    let op = fetchOp(cpu)
    let x = (op >> 6) & 0x3
    let y = (op >> 3) & 0x7
    let z = op & 0x7
    let p = y >> 1
    let q = y & 1

    if x == 1 {
        if z == 2 {
            if q == 0 {
                sbcHL(cpu, getRP(cpu, p))
            } else {
                adcHL(cpu, getRP(cpu, p))
            }
            return true
        }
        if z == 3 {
            let nn = zfetch16(cpu)
            if q == 0 {
                let v = getRP(cpu, p) // LD (nn), rp
                wr(cpu, nn, v & 0xFF)
                wr(cpu, nn + 1, (v >> 8) & 0xFF)
            } else {
                let lo = rd(cpu, nn) // LD rp, (nn)
                let hi = rd(cpu, nn + 1)
                setRP(cpu, p, (hi << 8) | lo)
            }
            return true
        }
        if z == 4 {
            // NEG
            let a = cpu.a
            cpu.a = (0 - a) & 0xFF
            setSZYX(cpu, cpu.a)
            setFlag(cpu, FH, (a & 0xF) != 0)
            setFlag(cpu, FPV, a == 0x80)
            setFlag(cpu, FN, true)
            setFlag(cpu, FC, a != 0)
            return true
        }
        if z == 5 {
            // RETN / RETI: pop PC, restore iff1 from iff2
            cpu.pc = pop16(cpu)
            cpu.iff1 = cpu.iff2
            return true
        }
        if z == 6 {
            // IM: y 0/4 -> 0, 2/6 -> 1, 3/7 -> 2 (1/5 -> 0 on this Z80)
            if y == 2 || y == 6 {
                cpu.im = 1
            } else if y == 3 || y == 7 {
                cpu.im = 2
            } else {
                cpu.im = 0
            }
            return true
        }
        if z == 7 {
            if y == 0 {
                cpu.i = cpu.a // LD I, A
            } else if y == 1 {
                cpu.r = cpu.a // LD R, A
            } else if y == 2 || y == 3 {
                // LD A, I / LD A, R
                cpu.a = if y == 2 {
                    cpu.i
                } else {
                    cpu.r
                }
                setFlag(cpu, FS, (cpu.a & 0x80) != 0)
                setFlag(cpu, FZ, cpu.a == 0)
                setFlag(cpu, FY, (cpu.a & 0x20) != 0)
                setFlag(cpu, FX, (cpu.a & 0x08) != 0)
                setFlag(cpu, FH, false)
                setFlag(cpu, FN, false)
                setFlag(cpu, FPV, cpu.iff2)
            } else if y == 4 {
                // RRD
                let m = rd(cpu, getHL(cpu))
                let newM = ((m >> 4) | ((cpu.a & 0xF) << 4)) & 0xFF
                cpu.a = (cpu.a & 0xF0) | (m & 0xF)
                wr(cpu, getHL(cpu), newM)
                setSZYX(cpu, cpu.a)
                setFlag(cpu, FPV, parityEven(cpu.a))
                setFlag(cpu, FH, false)
                setFlag(cpu, FN, false)
            } else if y == 5 {
                // RLD
                let m = rd(cpu, getHL(cpu))
                let newM = ((m << 4) | (cpu.a & 0xF)) & 0xFF
                cpu.a = (cpu.a & 0xF0) | ((m >> 4) & 0xF)
                wr(cpu, getHL(cpu), newM)
                setSZYX(cpu, cpu.a)
                setFlag(cpu, FPV, parityEven(cpu.a))
                setFlag(cpu, FH, false)
                setFlag(cpu, FN, false)
            }
            return true
        }
        // z 0/1: IN/OUT (C) — deferred
        return false
    }
    if x == 2 {
        // block ops: y 4-7 x z 0-3
        if y >= 4 && z < 4 {
            var dir: i64 = -1
            if y == 4 || y == 6 {
                dir = 1
            }
            if z == 0 {
                blockLd(cpu, dir)
                if (y == 6 || y == 7) && getBC(cpu) != 0 {
                    cpu.pc = (cpu.pc - 2) & 0xFFFF // LDIR/LDDR repeat
                }
                return true
            }
            if z == 1 {
                blockCp(cpu, dir)
                if (y == 6 || y == 7) && getBC(cpu) != 0 && (cpu.f & FZ) == 0 {
                    cpu.pc = (cpu.pc - 2) & 0xFFFF // CPIR/CPDR repeat
                }
                return true
            }
            return false // INI/OUTI family — deferred
        }
        return true // undefined ED in this block acts as NOP
    }
    return true // x 0/3: undefined ED = NOP (pc/R already advanced)
}

// One shift/rotate (CB x=0): sets S,Z,Y,X,P,H=0,N=0,C. Returns the result.
fn shiftOp(cpu: &mut Z80, kind: i64, v: i64): i64 {
    let oldC = (cpu.f & FC) != 0
    var res: i64 = 0
    var carry = false
    if kind == 0 {
        carry = (v & 0x80) != 0
        res = ((v << 1) | (if carry {
            1
        } else {
            0
        }
        )) & 0xFF // RLC
    } else if kind == 1 {
        carry = (v & 0x01) != 0
        res = ((v >> 1) | (if carry {
            0x80
        } else {
            0
        }
        )) & 0xFF // RRC
    } else if kind == 2 {
        carry = (v & 0x80) != 0
        res = ((v << 1) | (if oldC {
            1
        } else {
            0
        }
        )) & 0xFF // RL
    } else if kind == 3 {
        carry = (v & 0x01) != 0
        res = ((v >> 1) | (if oldC {
            0x80
        } else {
            0
        }
        )) & 0xFF // RR
    } else if kind == 4 {
        carry = (v & 0x80) != 0
        res = (v << 1) & 0xFF // SLA
    } else if kind == 5 {
        carry = (v & 0x01) != 0
        res = ((v >> 1) | (v & 0x80)) & 0xFF // SRA
    } else if kind == 6 {
        carry = (v & 0x80) != 0
        res = ((v << 1) | 1) & 0xFF // SLL (undocumented)
    } else {
        carry = (v & 0x01) != 0
        res = (v >> 1) & 0xFF // SRL
    }
    setSZYX(cpu, res)
    setFlag(cpu, FPV, parityEven(res))
    setFlag(cpu, FH, false)
    setFlag(cpu, FN, false)
    setFlag(cpu, FC, carry)
    return res
}
