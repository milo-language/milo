// Sega Genesis / Mega Drive cartridge loader.
// Carts are flat ROM (up to 4 MB) mapped at $000000 — no iNES-style header
// wrangling, no mappers for the common case. The 512-byte "header" at $000100
// is metadata (console name, region, RAM info), not a load-affecting container.
// Ref: https://plutiedev.com/rom-header  — big-endian throughout (68000 is BE).

from "std/io" import {
    readFile
}

struct Cart {
    rom: Vec<u8> // full ROM image, byte-addressable at $000000
    name: string // domestic game name ($000120, 48 bytes, space-padded)
    romEnd: i64 // last ROM address from header ($0001A4)
}

fn romByte(rom: &Vec<u8>, addr: i64): u8 {
    if addr < rom.len {
        return rom[addr]
    }
    return 0
}

fn loadCart(path: &string): Result<Cart, string> {
    var raw = ""
    match readFile(path) {
        Result.Ok(s) => {
            raw = s
        }
        Result.Err(e) => {
            return Result.Err("cannot read ROM file")
        }
    }
    if raw.len < 0x200 {
        return Result.Err("file too small to be a Genesis ROM")
    }

    var rom: Vec<u8> = Vec.new()
    for b in raw {
        rom.push(b)
    }

    // Domestic name at $120, 48 bytes. Many Japanese carts store the title in
    // Shift-JIS fullwidth Latin (lead byte $81/$82) rather than ASCII — decode
    // those to plain ASCII so e.g. Golden Axe reads "GOLDEN AXE" not garbage.
    var end: i64 = 0x120 + 48
    while end > 0x120 && (rom[end - 1] as i64) == 0x20 {
        end = end - 1
    }
    while end >= 0x122 && (rom[end - 2] as i64) == 0x81 && (rom[end - 1] as i64) == 0x40 {
        end = end - 2 // trailing fullwidth spaces
    }
    var name = ""
    var j: i64 = 0x120
    while j < end {
        let b = rom[j] as i64
        if b == 0x81 && j + 1 < end && (rom[j + 1] as i64) == 0x40 {
            name = name + " "
            j = j + 2
        } else if b == 0x82 && j + 1 < end {
            let c = rom[j + 1] as i64
            var out: i64 = -1
            if c >= 0x4F && c <= 0x58 {
                out = 0x30 + (c - 0x4F) // fullwidth 0-9
            } else if c >= 0x60 && c <= 0x79 {
                out = 0x41 + (c - 0x60) // fullwidth A-Z
            } else if c >= 0x81 && c <= 0x9A {
                out = 0x61 + (c - 0x81) // fullwidth a-z
            }
            if out >= 0 {
                name = name + charFromByte(out as u8)
            }
            j = j + 2
        } else if b >= 0x20 && b <= 0x7E {
            name = name + charFromByte(rom[j])
            j = j + 1
        } else {
            j = j + 1 // skip other non-ASCII bytes
        }
    }

    // ROM end address is a big-endian long at $1A4.
    let romEnd = ((rom[0x1A4] as i64) << 24) | ((rom[0x1A5] as i64) << 16) | ((rom[0x1A6] as i64) << 8) | (rom[0x1A7] as i64)

    return Result.Ok(Cart {
        rom: rom,
        name: name,
        romEnd: romEnd,
    }
    )
}

fn charFromByte(b: u8): string {
    var s = ""
    s.push(b)
    return s
}
