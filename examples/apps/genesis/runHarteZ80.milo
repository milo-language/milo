// Z80 SingleStepTest runner over the flat int stream from harteConvZ80.ts.
// Applies each case's initial state, executes one instruction, compares final
// registers + RAM. WZ (MEMPTR) is compared too; internal p/q/ei are skipped.
//   bun run examples/apps/genesis/harteConvZ80.ts roms/z80tests/v1/00.json /tmp/z.flat
//   milo run examples/apps/genesis/runHarteZ80.milo /tmp/z.flat

from "std/args" import {
    args
}
from "std/io" import {
    readFile
}
from "./z80" import {
    Z80, newZ80, stepZ80
}

struct Toks {
    s: string
    pos: i64
}

fn nextTok(t: &mut Toks): i64 {
    while t.pos < t.s.len {
        let c = t.s[t.pos]as i64
        if c == 32 || c == 10 || c == 13 || c == 9 {
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    var v: i64 = 0
    while t.pos < t.s.len {
        let c = t.s[t.pos]as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    return v
}

// Load a state record into the CPU (regs then ram). Returns nothing; leaves the
// stream positioned after the ram list.
fn loadState(cpu: &mut Z80, t: &mut Toks) {
    cpu.a = nextTok(t)
    cpu.b = nextTok(t)
    cpu.c = nextTok(t)
    cpu.d = nextTok(t)
    cpu.e = nextTok(t)
    cpu.f = nextTok(t)
    cpu.h = nextTok(t)
    cpu.l = nextTok(t)
    cpu.i = nextTok(t)
    cpu.r = nextTok(t)
    cpu.pc = nextTok(t)
    cpu.sp = nextTok(t)
    cpu.ix = nextTok(t)
    cpu.iy = nextTok(t)
    cpu.af_ = nextTok(t)
    cpu.bc_ = nextTok(t)
    cpu.de_ = nextTok(t)
    cpu.hl_ = nextTok(t)
    cpu.iff1 = nextTok(t) != 0
    cpu.iff2 = nextTok(t) != 0
    cpu.im = nextTok(t)
    cpu.wz = nextTok(t)
    let ramN = nextTok(t)
    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let val = nextTok(t)
        cpu.mem[addr & 0xFFFF] = (val & 0xFF) as u8
        j = j + 1
    }
}

// Compare CPU against the final record; returns "" on match or first mismatch.
fn checkFinal(cpu: &Z80, t: &mut Toks): string {
    let fa = nextTok(t)
    let fb = nextTok(t)
    let fc = nextTok(t)
    let fd = nextTok(t)
    let fe = nextTok(t)
    let ff = nextTok(t)
    let fh = nextTok(t)
    let fl = nextTok(t)
    let fi = nextTok(t)
    let fr = nextTok(t)
    let fpc = nextTok(t)
    let fsp = nextTok(t)
    let fix = nextTok(t)
    let fiy = nextTok(t)
    let faf = nextTok(t)
    let fbc = nextTok(t)
    let fde = nextTok(t)
    let fhl = nextTok(t)
    let fiff1 = nextTok(t)
    let fiff2 = nextTok(t)
    let fim = nextTok(t)
    let fwz = nextTok(t)

    var mm = ""
    if cpu.a != fa {
        mm = "A " + hx(cpu.a) + "!=" + hx(fa)
    } else if cpu.f != ff {
        mm = "F " + hx(cpu.f) + "!=" + hx(ff)
    } else if cpu.b != fb {
        mm = "B " + hx(cpu.b) + "!=" + hx(fb)
    } else if cpu.c != fc {
        mm = "C " + hx(cpu.c) + "!=" + hx(fc)
    } else if cpu.d != fd {
        mm = "D " + hx(cpu.d) + "!=" + hx(fd)
    } else if cpu.e != fe {
        mm = "E " + hx(cpu.e) + "!=" + hx(fe)
    } else if cpu.h != fh {
        mm = "H " + hx(cpu.h) + "!=" + hx(fh)
    } else if cpu.l != fl {
        mm = "L " + hx(cpu.l) + "!=" + hx(fl)
    } else if cpu.r != fr {
        mm = "R " + hx(cpu.r) + "!=" + hx(fr)
    } else if cpu.pc != fpc {
        mm = "PC " + hx(cpu.pc) + "!=" + hx(fpc)
    } else if cpu.sp != fsp {
        mm = "SP " + hx(cpu.sp) + "!=" + hx(fsp)
    } else if cpu.i != fi {
        mm = "I " + hx(cpu.i) + "!=" + hx(fi)
    } else if cpu.ix != fix {
        mm = "IX " + hx(cpu.ix) + "!=" + hx(fix)
    } else if cpu.iy != fiy {
        mm = "IY " + hx(cpu.iy) + "!=" + hx(fiy)
    }

    let ramN = nextTok(t)
    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let want = nextTok(t)
        let got = cpu.mem[addr & 0xFFFF]as i64
        if got != want && mm == "" {
            mm = "RAM[" + hx(addr) + "] " + hx(got) + "!=" + hx(want)
        }
        j = j + 1
    }
    return mm
}

fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: runHarteZ80 <flat>")
        return 1
    }
    var raw = ""
    match readFile(argv[1]) {
        Result.Ok(s) => {
            raw = s
        }
        Result.Err(e) => {
            print("cannot read " + argv[1])
            return 1
        }
    }
    var t = Toks {
        s: raw, pos: 0
    }
    let total = nextTok(t)
    var cpu = newZ80()
    var passed: i64 = 0
    var failed: i64 = 0
    var firstFail = ""
    var i: i64 = 0
    while i < total {
        loadState(cpu, t)
        let ran = stepZ80(cpu)
        let mm = checkFinal(cpu, t)
        if !ran {
            failed = failed + 1
            if firstFail == "" {
                firstFail = "case " + itoa(i) + ": unimplemented"
            }
        } else if mm == "" {
            passed = passed + 1
        } else {
            failed = failed + 1
            if firstFail == "" {
                firstFail = "case " + itoa(i) + ": " + mm
            }
        }
        i = i + 1
    }
    print("passed " + itoa(passed) + " / " + itoa(passed + failed))
    if firstFail != "" {
        print("first fail: " + firstFail)
    }
    if failed == 0 {
        return 0
    }
    return 1
}

fn itoa(n: i64): string {
    if n == 0 {
        return "0"
    }
    var v = n
    var s = ""
    while v > 0 {
        var d = ""
        d.push((48 + (v % 10)) as u8)
        s = d + s
        v = v / 10
    }
    return s
}

fn hx(n: i64): string {
    var s = "0x"
    var started = false
    var i: i64 = 12
    while i >= 0 {
        let nib = (n >> i) & 0xF
        if nib != 0 || started || i == 0 {
            started = true
            if nib < 10 {
                s.push((48 + nib) as u8)
            } else {
                s.push((87 + nib) as u8)
            }
        }
        i = i - 4
    }
    return s
}
