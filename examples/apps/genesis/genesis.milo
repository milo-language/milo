// Milo Genesis / Mega Drive emulator — live SDL2 frontend.
// Loads a cart, runs the 68000 + VDP, streams a per-frame RGBA framebuffer to an
// SDL texture, and maps the keyboard to controller 1. Same SDL pipeline as the
// NES frontend (examples/apps/nes/nes.milo).
//
// Build (SDL2 via homebrew):
//   milo build examples/apps/genesis/genesis.milo -o /tmp/genesis -- -L/opt/homebrew/lib -lSDL2
//   /tmp/genesis roms/games/sonic1.md
// Keys: arrows = D-pad, Z=B, X=A, C=C, Enter=Start, Esc=quit.

from "./cart68k" import {
    Cart
}
from "./cart68kFile" import {
    loadCart
}
from "./m68k" import {
    M68k, Mem, newCpu, newMem, step, deliverInterrupt, z80Running
}
from "./z80" import {
    stepZ80, z80Interrupt
}
from "./sound" import {
    Synth, newSynth, synthSample
}
from "./render" import {
    renderIndexed, frameWidth, frameHeight, pixelR, pixelG, pixelB
}
from "std/args" import {
    args
}

extern fn SDL_Init(flags: u32): i32

extern fn SDL_CreateWindow(title: *u8, x: i32, y: i32, w: i32, h: i32, flags: u32): *u8

extern fn SDL_CreateRenderer(win: *u8, index: i32, flags: u32): *u8

extern fn SDL_CreateTexture(ren: *u8, format: u32, access: i32, w: i32, h: i32): *u8

extern fn SDL_UpdateTexture(tex: *u8, rect: *u8, pixels: *u8, pitch: i32): i32

extern fn SDL_RenderClear(ren: *u8): i32

extern fn SDL_RenderCopy(ren: *u8, tex: *u8, src: *u8, dst: *u8): i32

extern fn SDL_RenderPresent(ren: *u8): void

extern fn SDL_PollEvent(event: *u8): i32

extern fn SDL_GetKeyboardState(numkeys: *i32): *u8

extern fn SDL_NumJoysticks(): i32

extern fn SDL_IsGameController(index: i32): i32

extern fn SDL_GameControllerOpen(index: i32): *u8

extern fn SDL_GameControllerGetButton(gc: *u8, button: i32): u8

extern fn SDL_GameControllerClose(gc: *u8): void

extern fn SDL_Delay(ms: u32): void

extern fn SDL_Quit(): void

extern fn SDL_OpenAudioDevice(device: *u8, iscapture: i32, desired: *u8, obtained: *u8, allowed: i32): u32

extern fn SDL_QueueAudio(dev: u32, data: *u8, len: u32): i32

extern fn SDL_PauseAudioDevice(dev: u32, pause_on: i32): void

extern fn SDL_GetQueuedAudioSize(dev: u32): u32

let SDL_INIT_VIDEO: u32 = 0x20
let SDL_INIT_AUDIO: u32 = 0x10
let SDL_INIT_GAMECONTROLLER: u32 = 0x2000
// SDL_GameControllerButton ids.
let PAD_A: i32 = 0
let PAD_B: i32 = 1
let PAD_X: i32 = 2
let PAD_BACK: i32 = 4
let PAD_START: i32 = 6
let PAD_DPAD_UP: i32 = 11
let PAD_DPAD_DOWN: i32 = 12
let PAD_DPAD_LEFT: i32 = 13
let PAD_DPAD_RIGHT: i32 = 14
// Controller hotplug events.
let SDL_CONTROLLERDEVICEADDED: u32 = 0x653
let SDL_CONTROLLERDEVICEREMOVED: u32 = 0x654
// Window events (SDL_WINDOWEVENT); the sub-event id is byte 12 of the event.
let SDL_WINDOWEVENT: u32 = 0x200
let SDL_WINDOWEVENT_MINIMIZED: u8 = 7
let SDL_WINDOWEVENT_RESTORED: u8 = 9
let SDL_WINDOWEVENT_FOCUS_GAINED: u8 = 12
let SDL_WINDOWEVENT_FOCUS_LOST: u8 = 13
let SDL_WINDOWPOS_CENTERED: i32 = 0x2FFF0000
let SDL_WINDOW_SHOWN: u32 = 0x4
let SDL_PIXELFORMAT_ABGR8888: u32 = 0x16762004
let SDL_TEXTUREACCESS_STREAMING: i32 = 1
let SDL_QUIT: u32 = 0x100

fn loadRom(m: &mut Mem, cart: &Cart) {
    var i: i64 = 0
    while i < cart.rom.len && i < 0x400000 {
        m.ram[i] = cart.rom[i]
        m.z80.rom.push(cart.rom[i]) // Z80 bank-window ROM copy (DAC samples)
        i = i + 1
    }
}

// Run the 68000 for one video frame (262 scanlines), delivering the VBlank
// interrupt at the start of vblank when enabled.
fn runFrame(cpu: &mut M68k, m: &mut Mem) {
    var line: i64 = 0
    var hIntCounter: i64 = m.vdpRegs[10]
    while line < 262 {
        m.vdpLine = line
        // Horizontal interrupt (level 4): the counter counts down once per active
        // scanline and, when it expires, fires an H-int (if reg0 bit4 enables it)
        // and reloads from reg10. It is held reloaded throughout vblank. Games use
        // it for mid-frame raster effects and timing.
        if line < 224 {
            if hIntCounter == 0 {
                hIntCounter = m.vdpRegs[10]
                if (m.vdpRegs[0] & 0x10) != 0 {
                    deliverInterrupt(cpu, m, 4)
                }
            } else {
                hIntCounter = hIntCounter - 1
            }
        } else {
            hIntCounter = m.vdpRegs[10]
        }
        // ~130 instructions per scanline; co-run the Z80 (sound CPU) at ~half rate.
        var k: i64 = 0
        while k < 130 {
            if !cpu.halted {
                step(cpu, m)
            }
            if z80Running(m) && (k & 1) == 0 {
                stepZ80(m.z80)
            }
            k = k + 1
        }
        if line == 224 {
            if (m.vdpRegs[1] & 0x20) != 0 {
                deliverInterrupt(cpu, m, 6)
            }
            if z80Running(m) {
                z80Interrupt(m.z80) // Z80 INT tied to VBlank (drives sound timers)
            }
        }
        line = line + 1
    }
}

// Generate one frame of audio and queue it to SDL (735 samples @ 44.1 kHz).
fn queueAudio(synth: &mut Synth, m: &Mem, dev: u32) {
    var buf: Vec<u8> = Vec.new()
    var sa: i64 = 0
    while sa < 735 {
        let smp = synthSample(synth, m.z80)
        buf.push((smp.l & 0xFF) as u8)
        buf.push(((smp.l >> 8) & 0xFF) as u8)
        buf.push((smp.r & 0xFF) as u8)
        buf.push(((smp.r >> 8) & 0xFF) as u8)
        sa = sa + 1
    }
    unsafe {
        SDL_QueueAudio(dev, (&buf[0]) as *u8, buf.len as u32)
    }
}

// Convert the CRAM-index framebuffer to RGBA. `srcW` is the frame's actual width
// (256 for H32, 320 for H40); pixels are placed row-padded into a fixed `stride`-
// wide buffer so a mid-run H32<->H40 switch never overflows.
fn blit(m: &Mem, fb: &Vec<i64>, srcW: i64, stride: i64, rgba: &mut Vec<u8>) {
    var i: i64 = 0
    while i < fb.len {
        let row = i / srcW
        let col = i % srcW
        let dst = (row * stride + col) * 4
        rgba[dst] = pixelR(m, fb[i]) as u8
        rgba[dst + 1] = pixelG(m, fb[i]) as u8
        rgba[dst + 2] = pixelB(m, fb[i]) as u8
        rgba[dst + 3] = 255
        i = i + 1
    }
}

// Open the n-th attached game controller (0 = player 1, 1 = player 2), or null.
// Re-run on hotplug so pads can be plugged/unplugged at any time; slot order
// follows SDL's joystick enumeration.
fn openPadN(n: i64): *u8 {
    unsafe {
        var found: i64 = 0
        var ji: i32 = 0
        while ji < SDL_NumJoysticks() {
            if SDL_IsGameController(ji) != 0 {
                if found == n {
                    return SDL_GameControllerOpen(ji)
                }
                found = found + 1
            }
            ji = ji + 1
        }
        return 0 as *u8
    }
}

fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: genesis <rom>")
        return 1
    }
    var cart = Cart {
        rom: Vec.new(), name: "", romEnd: 0
    }
    match loadCart(argv[1]) {
        Result.Ok(c) => {
            cart = c
        }
        Result.Err(e) => {
            print("load failed: " + e)
            return 1
        }
    }
    print("ROM: " + cart.name)

    var m = newMem()
    m.genesis = true
    m.z80.gen = true
    loadRom(m, cart)
    let sp = ((m.ram[0] as i64) << 24) | ((m.ram[1] as i64) << 16) | ((m.ram[2] as i64) << 8) | (m.ram[3] as i64)
    let pc = ((m.ram[4] as i64) << 24) | ((m.ram[5] as i64) << 16) | ((m.ram[6] as i64) << 8) | (m.ram[7] as i64)
    var cpu = newCpu()
    cpu.a[7] = sp & 0xFFFFFFFF
    cpu.pc = pc & 0xFFFFFFFF
    cpu.sr = 0x2700

    // Fixed max-size buffer/texture (320x224) so the H32<->H40 width switch during
    // boot cannot overflow. H32 frames render into the left 256 columns.
    let maxW: i64 = 320
    let h = frameHeight(m)
    var rgba: Vec<u8> = Vec.new()
    var t: i64 = 0
    while t < maxW * h * 4 {
        rgba.push(0)
        t = t + 1
    }

    if SDL_Init(SDL_INIT_VIDEO | SDL_INIT_AUDIO | SDL_INIT_GAMECONTROLLER) != 0 {
        print("SDL_Init failed")
        return 1
    }
    var synth = newSynth()
    unsafe {
        var pad: *u8 = openPadN(0) // player 1
        var pad2: *u8 = openPadN(1) // player 2
        // SDL_AudioSpec (32 bytes): freq 44100, AUDIO_S16LSB (0x8010), mono, 2048 samples.
        var want: [u8; 32] = [0; 32]
        want[0] = 0x44
        want[1] = 0xAC // 44100
        want[4] = 0x10
        want[5] = 0x80 // format S16LSB
        want[6] = 2 // channels (stereo)
        want[8] = 0x00
        want[9] = 0x08 // 2048 samples
        var got: [u8; 32] = [0; 32]
        let audioDev = SDL_OpenAudioDevice(0 as *u8, 0, (&want[0]) as *u8, (&got[0]) as *u8, 0)
        if audioDev != 0 {
            SDL_PauseAudioDevice(audioDev, 0)
        }
        let title = "Milo Genesis"
        let win = SDL_CreateWindow(title, SDL_WINDOWPOS_CENTERED, SDL_WINDOWPOS_CENTERED, (maxW * 3) as i32, (h * 3) as i32, SDL_WINDOW_SHOWN)
        let ren = SDL_CreateRenderer(win, -1, 0)
        let tex = SDL_CreateTexture(ren, SDL_PIXELFORMAT_ABGR8888, SDL_TEXTUREACCESS_STREAMING, maxW as i32, h as i32)
        if (win as i64) == 0 || (ren as i64) == 0 || (tex as i64) == 0 {
            print("SDL setup failed")
            return 2
        }

        var ev: [u8; 64] = [0; 64]
        var quit = false
        var focused = true // false while backgrounded -> pause + silence audio
        var comboFrames: i64 = 0 // Start+Back held -> quit to the menu
        while !quit {
            // Input first, every iteration, so the window stays responsive even
            // while we're pacing on audio.
            while SDL_PollEvent((&ev[0]) as *u8) != 0 {
                let evType: u32 = (ev[0] as u32) | ((ev[1] as u32) << 8) | ((ev[2] as u32) << 16) | ((ev[3] as u32) << 24)
                if evType == SDL_QUIT {
                    quit = true
                }
                // Controller plugged in or removed: re-grab both slots so P1/P2
                // stay assigned as pads come and go at any time.
                if evType == SDL_CONTROLLERDEVICEADDED || evType == SDL_CONTROLLERDEVICEREMOVED {
                    if (pad as i64) != 0 {
                        SDL_GameControllerClose(pad)
                    }
                    if (pad2 as i64) != 0 {
                        SDL_GameControllerClose(pad2)
                    }
                    pad = openPadN(0)
                    pad2 = openPadN(1)
                }
                // Pause + silence audio when backgrounded; resume on refocus.
                if evType == SDL_WINDOWEVENT {
                    let we = ev[12]
                    if we == SDL_WINDOWEVENT_FOCUS_LOST || we == SDL_WINDOWEVENT_MINIMIZED {
                        focused = false
                        if audioDev != 0 {
                            SDL_PauseAudioDevice(audioDev, 1)
                        }
                    }
                    if we == SDL_WINDOWEVENT_FOCUS_GAINED || we == SDL_WINDOWEVENT_RESTORED {
                        focused = true
                        if audioDev != 0 {
                            SDL_PauseAudioDevice(audioDev, 0)
                        }
                    }
                }
            }
            let ks = SDL_GetKeyboardState(0 as *i32)
            var p: i64 = 0
            if ks[82] != 0 {
                p = p | 0x01 // Up
            }
            if ks[81] != 0 {
                p = p | 0x02 // Down
            }
            if ks[80] != 0 {
                p = p | 0x04 // Left
            }
            if ks[79] != 0 {
                p = p | 0x08 // Right
            }
            // Z is the primary action key (attack in most games = Genesis B); X is
            // the secondary (A), C is jump/C. Genesis physical order is A B C, but
            // mapping attack onto Z matches the keyboard instinct.
            if ks[29] != 0 {
                p = p | 0x20 // Z -> B (attack)
            }
            if ks[27] != 0 {
                p = p | 0x10 // X -> A (magic/secondary)
            }
            if ks[6] != 0 {
                p = p | 0x40 // C -> C (jump)
            }
            if ks[40] != 0 {
                p = p | 0x80 // Enter -> Start
            }
            // Overlay the game controller onto the same Genesis pad byte. Face
            // mapping (A/B/C) is a sensible default; tweak to taste per pad.
            if (pad as i64) != 0 {
                if SDL_GameControllerGetButton(pad, PAD_DPAD_UP) != 0 {
                    p = p | 0x01
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_DOWN) != 0 {
                    p = p | 0x02
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_LEFT) != 0 {
                    p = p | 0x04
                }
                if SDL_GameControllerGetButton(pad, PAD_DPAD_RIGHT) != 0 {
                    p = p | 0x08
                }
                if SDL_GameControllerGetButton(pad, PAD_A) != 0 {
                    p = p | 0x10
                } // A
                if SDL_GameControllerGetButton(pad, PAD_B) != 0 {
                    p = p | 0x20
                } // B
                if SDL_GameControllerGetButton(pad, PAD_X) != 0 {
                    p = p | 0x40
                } // C
                if SDL_GameControllerGetButton(pad, PAD_START) != 0 {
                    p = p | 0x80
                } // Start
            }
            m.pad1 = p
            // Player 2 is the second controller only (no keyboard fallback).
            var p2: i64 = 0
            if (pad2 as i64) != 0 {
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_UP) != 0 {
                    p2 = p2 | 0x01
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_DOWN) != 0 {
                    p2 = p2 | 0x02
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_LEFT) != 0 {
                    p2 = p2 | 0x04
                }
                if SDL_GameControllerGetButton(pad2, PAD_DPAD_RIGHT) != 0 {
                    p2 = p2 | 0x08
                }
                if SDL_GameControllerGetButton(pad2, PAD_A) != 0 {
                    p2 = p2 | 0x10
                }
                if SDL_GameControllerGetButton(pad2, PAD_B) != 0 {
                    p2 = p2 | 0x20
                }
                if SDL_GameControllerGetButton(pad2, PAD_X) != 0 {
                    p2 = p2 | 0x40
                }
                if SDL_GameControllerGetButton(pad2, PAD_START) != 0 {
                    p2 = p2 | 0x80
                }
            }
            m.pad2 = p2
            if ks[41] != 0 {
                quit = true // Esc
            }
            // Start+Back (controller) held ~1s quits back to the menu (Genesis
            // pads have no Select, so Back stands in for the exit chord).
            var padQuit = false
            if (pad as i64) != 0 {
                padQuit = SDL_GameControllerGetButton(pad, PAD_START) != 0
                && SDL_GameControllerGetButton(pad, PAD_BACK) != 0
            }
            if padQuit {
                comboFrames = comboFrames + 1
                if comboFrames > 60 {
                    quit = true
                }
            } else {
                comboFrames = 0
            }

            // Audio-mastered pacing: the SDL queue is the clock. Run frames until
            // ~5 frames (24 KB stereo) are buffered, then idle. This keeps a
            // cushion so a backgrounded / throttled window doesn't starve the
            // audio and stutter. No audio device => cap at ~60 fps by delay.
            if !focused {
                SDL_Delay(50) // backgrounded: paused + silent, idle the loop
            } else if audioDev != 0 && SDL_GetQueuedAudioSize(audioDev) >= 24000 {
                SDL_Delay(1)
            } else {
                runFrame(cpu, m)
                if audioDev != 0 {
                    queueAudio(synth, m, audioDev)
                }
                let fb = renderIndexed(m)
                let w = frameWidth(m)
                blit(m, fb, w, maxW, rgba)
                SDL_UpdateTexture(tex, 0 as *u8, (&rgba[0]) as *u8, (maxW * 4) as i32)
                SDL_RenderClear(ren)
                // Copy only the live w*h region of the (maxW-wide) texture, scaled to
                // fill the window — else an H32 (256px) frame leaves the right 64
                // texture columns (unused, black) showing as a black bar. Genesis
                // stretches H32 to the same full width as H40 on a TV.
                var srcRect: [u8; 16] = [0; 16]
                srcRect[8] = (w & 0xFF) as u8
                srcRect[9] = ((w >> 8) & 0xFF) as u8
                srcRect[12] = (h & 0xFF) as u8
                srcRect[13] = ((h >> 8) & 0xFF) as u8
                SDL_RenderCopy(ren, tex, (&srcRect[0]) as *u8, 0 as *u8)
                SDL_RenderPresent(ren)
                if audioDev == 0 {
                    SDL_Delay(16)
                }
            }
        }
        SDL_Quit()
    }
    return 0
}
