// The tree-walking evaluator: walks the AST (by index into Prog) and produces
// JSValues, driving the runtime's scopes, object heap, and GC. Statement
// execution returns a Flow so `return` can unwind out of nested blocks.

from "./ast" import {
    Prog
}
from "./value" import {
    JSValue
}
from "./runtime" import {
    Interp
}
from "./builtins" import {
    stringMethod, charAt, mjStringifyVal, mjJsonParse, mjJsonOmitted
}
from "./regex" import {
    regexCompile, regexExec
}
from "std/math" import {
    mathMod
}

enum Flow {
    Normal,
    Ret(JSValue),
}

fn evalBin(op: &string, a: &JSValue, b: &JSValue): JSValue {
    if op == "+" {
        if isStr(a) || isStr(b) {
            return JSValue.Str(toStr(a) + toStr(b))
        }
        return JSValue.Number(toNum(a) + toNum(b))
    }
    if op == "-" {
        return JSValue.Number(toNum(a) - toNum(b))
    }
    if op == "*" {
        return JSValue.Number(toNum(a) * toNum(b))
    }
    if op == "/" {
        return JSValue.Number(toNum(a) / toNum(b))
    }
    if op == "%" {
        return JSValue.Number(mathMod(toNum(a), toNum(b)))
    }
    if op == "==" {
        return JSValue.Bool(jsEquals(a, b))
    }
    if op == "!=" {
        return JSValue.Bool(!jsEquals(a, b))
    }
    // relational: string<string is lexicographic, else numeric (NaN → false)
    if isStr(a) && isStr(b) {
        let sa = toStr(a)
        let sb = toStr(b)
        if op == "<" {
            return JSValue.Bool(strLess(sa, sb))
        }
        if op == ">" {
            return JSValue.Bool(strLess(sb, sa))
        }
        if op == "<=" {
            return JSValue.Bool(!strLess(sb, sa))
        }
        if op == ">=" {
            return JSValue.Bool(!strLess(sa, sb))
        }
    }
    let x = toNum(a)
    let y = toNum(b)
    if op == "<" {
        return JSValue.Bool(x < y)
    }
    if op == ">" {
        return JSValue.Bool(x > y)
    }
    if op == "<=" {
        return JSValue.Bool(x <= y)
    }
    if op == ">=" {
        return JSValue.Bool(x >= y)
    }
    return JSValue.Undefined
}

// Property read that understands arrays: `length` and integer indices hit the
// element vector, everything else the string-keyed props.
fn getMember(st: &Interp, o: i64, key: &string): JSValue {
    if st.objects[o].isArray {
        if key == "length" {
            return JSValue.Number(arrLen(st, o) as f64)
        }
        let ai = asArrayIndex(key)
        if ai >= 0 {
            return arrGet(st, o, ai)
        }
    }
    // own property first, then walk the prototype chain
    var cur = o
    while cur >= 0 {
        if objHas(st, cur, key) {
            return objGet(st, cur, key)
        }
        cur = st.objects[cur].proto
    }
    return JSValue.Undefined
}

fn setMember(st: &mut Interp, o: i64, key: string, value: JSValue) {
    if st.objects[o].isArray {
        let ai = asArrayIndex(key)
        if ai >= 0 {
            arrSet(st, o, ai, value)
            return
        }
    }
    objSet(st, o, key, value)
}

// Read an assignable target (identifier / member / computed index) as a value.
// Backs ++/-- and compound assignment; the base object of a member target is
// evaluated here and again by writeLValue (harmless unless the base has side
// effects, which is rare).
fn readLValue(prog: &Prog, targetIdx: i64, st: &mut Interp, scope: i64): JSValue {
    let t = getExpr(prog, targetIdx)
    match t {
        Expr.Ident(name) => {
            return scopeLookup(st, scope, name)
        }
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, name)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, key)
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        _ => {
            return JSValue.Undefined
        }
    }
}

fn writeLValue(prog: &Prog, targetIdx: i64, st: &mut Interp, scope: i64, value: JSValue) {
    let t = getExpr(prog, targetIdx)
    match t {
        Expr.Ident(name) => {
            scopeAssign(st, scope, name, value)
        }
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    setMember(st, o, name.clone(), value)
                }
                _ => {
                }
            }
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            match ov {
                JSValue.Obj(o) => {
                    setMember(st, o, key, value)
                }
                _ => {
                }
            }
        }
        _ => {
        }
    }
}

// Built-in function/constructor ids. The Error family shares one path; the
// specific kind is carried in the object's `name` property.
let NATIVE_ERROR: i64 = 0
let NATIVE_TYPE_ERROR: i64 = 1
let NATIVE_RANGE_ERROR: i64 = 2
let NATIVE_SYNTAX_ERROR: i64 = 3
let NATIVE_REFERENCE_ERROR: i64 = 4
let NATIVE_JSON_STRINGIFY: i64 = 5
let NATIVE_JSON_PARSE: i64 = 6
let NATIVE_MATH_FLOOR: i64 = 7
let NATIVE_MATH_CEIL: i64 = 8
let NATIVE_MATH_ROUND: i64 = 9
let NATIVE_MATH_TRUNC: i64 = 10
let NATIVE_MATH_ABS: i64 = 11
let NATIVE_MATH_SIGN: i64 = 12
let NATIVE_MATH_SQRT: i64 = 13
let NATIVE_MATH_POW: i64 = 14
let NATIVE_MATH_MIN: i64 = 15
let NATIVE_MATH_MAX: i64 = 16
let NATIVE_MATH_RANDOM: i64 = 17
let NATIVE_REGEXP: i64 = 18

fn nativeErrorName(id: i64): string {
    if id == NATIVE_TYPE_ERROR {
        return "TypeError"
    }
    if id == NATIVE_RANGE_ERROR {
        return "RangeError"
    }
    if id == NATIVE_SYNTAX_ERROR {
        return "SyntaxError"
    }
    if id == NATIVE_REFERENCE_ERROR {
        return "ReferenceError"
    }
    return "Error"
}

fn isErrorCtor(id: i64): bool {
    return id >= NATIVE_ERROR && id <= NATIVE_REFERENCE_ERROR
}

// Invoke a native function/constructor. Error(msg) and new Error(msg) behave the
// same (both mint an error object), matching JS.
fn callNative(id: i64, argVals: &Vec<JSValue>, st: &mut Interp): JSValue {
    if isErrorCtor(id) {
        let o = newObject(st)
        st.objects[o].isError = true
        objSet(st, o, "name", JSValue.Str(nativeErrorName(id)))
        var msg = ""
        if argVals.len() > 0 {
            msg = toStr(argVals[0])
        }
        objSet(st, o, "message", JSValue.Str(msg))
        return JSValue.Obj(o)
    }
    if id == NATIVE_JSON_STRINGIFY {
        if argVals.len() == 0 || mjJsonOmitted(argVals[0]) {
            // JSON.stringify(undefined) / a function is the JS value undefined
            return JSValue.Undefined
        }
        return JSValue.Str(mjStringifyVal(argVals[0], st))
    }
    if id == NATIVE_JSON_PARSE {
        if argVals.len() == 0 {
            return JSValue.Undefined
        }
        let text = toStr(argVals[0])
        return mjJsonParse(text, st)
    }
    if id >= NATIVE_MATH_FLOOR && id <= NATIVE_MATH_RANDOM {
        return mathNative(id, argVals, st)
    }
    if id == NATIVE_REGEXP {
        var pat = ""
        var flags = ""
        if argVals.len() > 0 {
            pat = toStr(argVals[0])
        }
        if argVals.len() > 1 {
            flags = toStr(argVals[1])
        }
        return makeRegex(st, pat, flags)
    }
    return JSValue.Undefined
}

fn mathNative(id: i64, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    if id == NATIVE_MATH_RANDOM {
        let next = mjNextRandom(st.rngState)
        st.rngState = next
        var bits = next
        if bits < 0 {
            bits = 0 - bits
        }
        let m = bits % 9007199254740992
        return JSValue.Number((m as f64) / 9007199254740992.0)
    }
    if id == NATIVE_MATH_MIN {
        if args.len() == 0 {
            return JSValue.Number(jsInf())
        }
        var m = toNum(args[0])
        var i: i64 = 0
        while i < args.len() {
            let v = toNum(args[i])
            if !(v == v) {
                return JSValue.Number(jsNan())
            }
            if v < m {
                m = v
            }
            i = i + 1
        }
        return JSValue.Number(m)
    }
    if id == NATIVE_MATH_MAX {
        if args.len() == 0 {
            return JSValue.Number(0.0 - jsInf())
        }
        var m = toNum(args[0])
        var i: i64 = 0
        while i < args.len() {
            let v = toNum(args[i])
            if !(v == v) {
                return JSValue.Number(jsNan())
            }
            if v > m {
                m = v
            }
            i = i + 1
        }
        return JSValue.Number(m)
    }
    var x = 0.0
    if args.len() > 0 {
        x = toNum(args[0])
    }
    if id == NATIVE_MATH_FLOOR {
        return JSValue.Number(mjFloor(x))
    }
    if id == NATIVE_MATH_CEIL {
        return JSValue.Number(mjCeil(x))
    }
    if id == NATIVE_MATH_ROUND {
        return JSValue.Number(mjRound(x))
    }
    if id == NATIVE_MATH_TRUNC {
        return JSValue.Number(mjTrunc(x))
    }
    if id == NATIVE_MATH_ABS {
        return JSValue.Number(mjAbs(x))
    }
    if id == NATIVE_MATH_SIGN {
        return JSValue.Number(mjSign(x))
    }
    if id == NATIVE_MATH_SQRT {
        return JSValue.Number(sqrt(x))
    }
    if id == NATIVE_MATH_POW {
        var y = 0.0
        if args.len() > 1 {
            y = toNum(args[1])
        }
        return JSValue.Number(pow(x, y))
    }
    return JSValue.Undefined
}

// x instanceof C: for a user constructor, the object must have been made by it
// (its `ctor` slot matches); for a native Error constructor, the object must be
// an error whose kind matches (Error itself matches any error).
// Compile a pattern and wrap it as a RegExp object (regexId links to the
// compiled program; source/flags/lastIndex are ordinary properties).
fn makeRegex(st: &mut Interp, pattern: string, flags: string): JSValue {
    let re = regexCompile(pattern.clone(), flags.clone())
    let isGlobal = re.flagG
    st.regexes.push(re)
    let id = st.regexes.len() - 1
    let o = newObject(st)
    st.objects[o].regexId = id
    objSet(st, o, "source", JSValue.Str(pattern))
    objSet(st, o, "flags", JSValue.Str(flags))
    objSet(st, o, "global", JSValue.Bool(isGlobal))
    objSet(st, o, "lastIndex", JSValue.Number(0.0))
    return JSValue.Obj(o)
}

fn regexIdOf(st: &Interp, v: &JSValue): i64 {
    match v {
        JSValue.Obj(o) => {
            return st.objects[o].regexId
        }
        _ => {
            return -1
        }
    }
}

// [wholeMatch, group1, group2, ...]; a non-participating group is undefined.
fn buildMatchArray(st: &mut Interp, s: &string, saves: &Vec<i64>): JSValue {
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var g: i64 = 0
    let ng = saves.len() / 2
    while g < ng {
        let a = saves[2 * g]
        let b = saves[2 * g + 1]
        if a < 0 || b < 0 {
            arrPush(st, arr, JSValue.Undefined)
        } else {
            arrPush(st, arr, JSValue.Str(strSlice(s, a, b)))
        }
        g = g + 1
    }
    popTemp(st)
    return JSValue.Obj(arr)
}

fn regexMethod(st: &mut Interp, o: i64, name: &string, args: &Vec<JSValue>): JSValue {
    let rid = st.objects[o].regexId
    var subject = ""
    if args.len() > 0 {
        subject = toStr(args[0])
    }
    if name == "test" {
        let saves = regexExec(st.regexes[rid], subject, 0)
        return JSValue.Bool(saves.len() > 0)
    }
    if name == "exec" {
        let saves = regexExec(st.regexes[rid], subject, 0)
        if saves.len() == 0 {
            return JSValue.Null
        }
        return buildMatchArray(st, subject, saves)
    }
    return JSValue.Undefined
}

// Expand $1..$9, $&, $$ in a replacement string against a match's saves.
fn expandRepl(repl: &string, s: &string, saves: &Vec<i64>): string {
    var out = String.withCapacity(repl.len())
    var i: i64 = 0
    while i < repl.len() {
        let c = repl[i]
        if c == '$' && i + 1 < repl.len() {
            let n = repl[i + 1]
            if n == '$' {
                out.push('$')
                i = i + 2
            } else if n == '&' {
                out = out + strSlice(s, saves[0], saves[1])
                i = i + 2
            } else if n >= '1' && n <= '9' {
                let g = n as i64 - 48
                if 2 * g + 1 < saves.len() {
                    let a = saves[2 * g]
                    let b = saves[2 * g + 1]
                    if a >= 0 && b >= 0 {
                        out = out + strSlice(s, a, b)
                    }
                }
                i = i + 2
            } else {
                out.push(c)
                i = i + 1
            }
        } else {
            out.push(c)
            i = i + 1
        }
    }
    return out
}

fn regexReplace(st: &mut Interp, s: &string, rid: i64, repl: &string): JSValue {
    let global = st.regexes[rid].flagG
    var out = String.withCapacity(s.len())
    var last: i64 = 0
    var searchPos: i64 = 0
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, searchPos)
        if saves.len() == 0 {
            going = false
        } else {
            let mstart = saves[0]
            let mend = saves[1]
            out = out + strSlice(s, last, mstart)
            out = out + expandRepl(repl, s, saves)
            last = mend
            if mend == mstart {
                searchPos = mend + 1
            } else {
                searchPos = mend
            }
            if !global || searchPos > s.len() {
                going = false
            }
        }
    }
    out = out + strSlice(s, last, s.len())
    return JSValue.Str(out)
}

// s.match(re): with the g flag, an array of all matched substrings (or null);
// otherwise the first match array (whole + groups) or null.
fn regexStrMatch(st: &mut Interp, s: &string, rid: i64): JSValue {
    let global = st.regexes[rid].flagG
    if !global {
        let saves = regexExec(st.regexes[rid], s, 0)
        if saves.len() == 0 {
            return JSValue.Null
        }
        return buildMatchArray(st, s, saves)
    }
    let arr = newArray(st)
    pushTemp(st, JSValue.Obj(arr))
    var pos: i64 = 0
    var any = false
    var going = true
    while going {
        let saves = regexExec(st.regexes[rid], s, pos)
        if saves.len() == 0 {
            going = false
        } else {
            any = true
            arrPush(st, arr, JSValue.Str(strSlice(s, saves[0], saves[1])))
            if saves[1] == saves[0] {
                pos = saves[1] + 1
            } else {
                pos = saves[1]
            }
            if pos > s.len() {
                going = false
            }
        }
    }
    popTemp(st)
    if !any {
        return JSValue.Null
    }
    return JSValue.Obj(arr)
}

fn instanceOf(st: &Interp, val: &JSValue, ctor: &JSValue): bool {
    match val {
        JSValue.Obj(o) => {
            match ctor {
                JSValue.Func(fIdx, _e) => {
                    return st.objects[o].ctor == fIdx
                }
                JSValue.Native(id) => {
                    if !st.objects[o].isError {
                        return false
                    }
                    if id == NATIVE_ERROR {
                        return true
                    }
                    let nm = objGet(st, o, "name")
                    return toStr(nm) == nativeErrorName(id)
                }
                _ => {
                    return false
                }
            }
        }
        _ => {
            return false
        }
    }
}

fn setupGlobals(st: &mut Interp) {
    scopeDefine(st, 0, "Error", JSValue.Native(NATIVE_ERROR))
    scopeDefine(st, 0, "TypeError", JSValue.Native(NATIVE_TYPE_ERROR))
    scopeDefine(st, 0, "RangeError", JSValue.Native(NATIVE_RANGE_ERROR))
    scopeDefine(st, 0, "SyntaxError", JSValue.Native(NATIVE_SYNTAX_ERROR))
    scopeDefine(st, 0, "ReferenceError", JSValue.Native(NATIVE_REFERENCE_ERROR))
    // JSON is a plain object whose methods are native functions
    let json = newObject(st)
    objSet(st, json, "stringify", JSValue.Native(NATIVE_JSON_STRINGIFY))
    objSet(st, json, "parse", JSValue.Native(NATIVE_JSON_PARSE))
    scopeDefine(st, 0, "JSON", JSValue.Obj(json))
    // Math likewise: native-fn methods + numeric constants
    let math = newObject(st)
    objSet(st, math, "floor", JSValue.Native(NATIVE_MATH_FLOOR))
    objSet(st, math, "ceil", JSValue.Native(NATIVE_MATH_CEIL))
    objSet(st, math, "round", JSValue.Native(NATIVE_MATH_ROUND))
    objSet(st, math, "trunc", JSValue.Native(NATIVE_MATH_TRUNC))
    objSet(st, math, "abs", JSValue.Native(NATIVE_MATH_ABS))
    objSet(st, math, "sign", JSValue.Native(NATIVE_MATH_SIGN))
    objSet(st, math, "sqrt", JSValue.Native(NATIVE_MATH_SQRT))
    objSet(st, math, "pow", JSValue.Native(NATIVE_MATH_POW))
    objSet(st, math, "min", JSValue.Native(NATIVE_MATH_MIN))
    objSet(st, math, "max", JSValue.Native(NATIVE_MATH_MAX))
    objSet(st, math, "random", JSValue.Native(NATIVE_MATH_RANDOM))
    objSet(st, math, "PI", JSValue.Number(3.141592653589793))
    objSet(st, math, "E", JSValue.Number(2.718281828459045))
    scopeDefine(st, 0, "Math", JSValue.Obj(math))
    scopeDefine(st, 0, "RegExp", JSValue.Native(NATIVE_REGEXP))
}

// typeof: never throws, even for an unbound name (scopeLookup returns undefined).
fn typeofStr(v: &JSValue): string {
    match v {
        JSValue.Undefined => {
            return "undefined"
        }
        JSValue.Null => {
            return "object"
        }
        JSValue.Bool(_b) => {
            return "boolean"
        }
        JSValue.Number(_n) => {
            return "number"
        }
        JSValue.Str(_s) => {
            return "string"
        }
        JSValue.Func(_f, _e) => {
            return "function"
        }
        JSValue.Obj(_o) => {
            return "object"
        }
        JSValue.Native(_id) => {
            return "function"
        }
    }
}

fn evalExpr(prog: &Prog, idx: i64, st: &mut Interp, scope: i64): JSValue {
    // an exception is unwinding — stop evaluating, produce a placeholder
    if st.throwing {
        return JSValue.Undefined
    }
    let node = getExpr(prog, idx)
    match node {
        Expr.Num(n) => {
            return JSValue.Number(n)
        }
        Expr.StrLit(s) => {
            return JSValue.Str(s)
        }
        Expr.BoolLit(b) => {
            return JSValue.Bool(b)
        }
        Expr.NullLit => {
            return JSValue.Null
        }
        Expr.UndefLit => {
            return JSValue.Undefined
        }
        Expr.Ident(name) => {
            return scopeLookup(st, scope, name)
        }
        Expr.Bin(op, a, b) => {
            // && and || short-circuit and yield the operand value, JS-style
            if op == "&&" {
                let va = evalExpr(prog, a, st, scope)
                if !truthy(va) {
                    return va
                }
                return evalExpr(prog, b, st, scope)
            }
            if op == "||" {
                let va = evalExpr(prog, a, st, scope)
                if truthy(va) {
                    return va
                }
                return evalExpr(prog, b, st, scope)
            }
            if op == "instanceof" {
                let lv = evalExpr(prog, a, st, scope)
                let rv = evalExpr(prog, b, st, scope)
                return JSValue.Bool(instanceOf(st, lv, rv))
            }
            let va = evalExpr(prog, a, st, scope)
            let vb = evalExpr(prog, b, st, scope)
            return evalBin(op, va, vb)
        }
        Expr.Un(op, a) => {
            let va = evalExpr(prog, a, st, scope)
            if op == "-" {
                return JSValue.Number(0.0 - toNum(va))
            }
            if op == "typeof" {
                return JSValue.Str(typeofStr(va))
            }
            return JSValue.Bool(!truthy(va))
        }
        Expr.Assign(name, e) => {
            let v = evalExpr(prog, e, st, scope)
            scopeAssign(st, scope, name, cloneValue(v))
            return v
        }
        Expr.Call(callee, argsIdx) => {
            return evalCall(prog, callee, argsIdx, st, scope)
        }
        Expr.Member(objIdx, name) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, name)
                }
                JSValue.Str(s) => {
                    if name == "length" {
                        return JSValue.Number(s.len() as f64)
                    }
                    return JSValue.Undefined
                }
                JSValue.Func(fIdx, _e) => {
                    if name == "prototype" {
                        return JSValue.Obj(getFuncProto(st, fIdx))
                    }
                    return JSValue.Undefined
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.Index(objIdx, keyIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            match ov {
                JSValue.Obj(o) => {
                    return getMember(st, o, key)
                }
                JSValue.Str(s) => {
                    // s[i] → a single-character string (or undefined out of range)
                    let i = toNum(kv) as i64
                    if i >= 0 && i < s.len() {
                        return JSValue.Str(charAt(s, i))
                    }
                    return JSValue.Undefined
                }
                _ => {
                    return JSValue.Undefined
                }
            }
        }
        Expr.SetMember(objIdx, keyIdx, valIdx) => {
            let ov = evalExpr(prog, objIdx, st, scope)
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            let v = evalExpr(prog, valIdx, st, scope)
            match ov {
                JSValue.Obj(o) => {
                    setMember(st, o, key, cloneValue(v))
                }
                _ => {
                }
            }
            return v
        }
        Expr.ObjLit(litIdx) => {
            let obj = newObject(st)
            // root the part-built object so a GC while evaluating later property
            // values (a value may be a call) can't reclaim it
            pushTemp(st, JSValue.Obj(obj))
            var i: i64 = 0
            let n = prog.objLits[litIdx].len()
            while i < n {
                let key = prog.objLits[litIdx][i].key.clone()
                let valIdx = prog.objLits[litIdx][i].val
                let v = evalExpr(prog, valIdx, st, scope)
                objSet(st, obj, key, v)
                i = i + 1
            }
            popTemp(st)
            return JSValue.Obj(obj)
        }

        Expr.ArrLit(litIdx) => {
            let arr = newArray(st)
            // root the part-built array so a GC while evaluating later elements
            // (an element may be a call) can't reclaim it
            pushTemp(st, JSValue.Obj(arr))
            var i: i64 = 0
            let n = prog.arrLits[litIdx].len()
            while i < n {
                let elemIdx = prog.arrLits[litIdx][i]
                let v = evalExpr(prog, elemIdx, st, scope)
                arrPush(st, arr, v)
                i = i + 1
            }
            popTemp(st)
            return JSValue.Obj(arr)
        }
        Expr.New(calleeIdx, argsIdx) => {
            let calleeVal = evalExpr(prog, calleeIdx, st, scope)
            match calleeVal {
                JSValue.Func(fIdx, envIdx) => {
                    pushTemp(st, JSValue.Func(fIdx, envIdx))
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let obj = newObject(st)
                    // record the constructor (for instanceof) and link the
                    // instance to the constructor's prototype (for shared methods)
                    st.objects[obj].ctor = fIdx
                    let proto = getFuncProto(st, fIdx)
                    st.objects[obj].proto = proto
                    pushTemp(st, JSValue.Obj(obj))
                    let result = callFunction(prog, fIdx, envIdx, argVals, JSValue.Obj(obj), st)
                    popTemp(st)
                    popTemp(st)
                    // a constructor that returns an object replaces the new instance
                    match result {
                        JSValue.Obj(r) => {
                            return JSValue.Obj(r)
                        }
                        _ => {
                            return JSValue.Obj(obj)
                        }
                    }
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callNative(id, argVals, st)
                }
                _ => {
                    print("milojs: TypeError: value is not a constructor")
                    return JSValue.Undefined
                }
            }
        }
        Expr.Update(targetIdx, isInc, isPrefix) => {
            let old = readLValue(prog, targetIdx, st, scope)
            let oldNum = toNum(old)
            var newNum = oldNum + 1.0
            if !isInc {
                newNum = oldNum - 1.0
            }
            writeLValue(prog, targetIdx, st, scope, JSValue.Number(newNum))
            if isPrefix {
                return JSValue.Number(newNum)
            }
            // postfix yields the numeric value before the update (JS coerces)
            return JSValue.Number(oldNum)
        }
        Expr.CompoundAssign(targetIdx, op, rhsIdx) => {
            let cur = readLValue(prog, targetIdx, st, scope)
            let rhs = evalExpr(prog, rhsIdx, st, scope)
            let result = evalBin(op, cur, rhs)
            writeLValue(prog, targetIdx, st, scope, cloneValue(result))
            return result
        }
        Expr.Cond(c, a, b) => {
            let vc = evalExpr(prog, c, st, scope)
            if truthy(vc) {
                return evalExpr(prog, a, st, scope)
            }
            return evalExpr(prog, b, st, scope)
        }
        Expr.FuncExpr(f) => {
            return JSValue.Func(f, scope)
        }
    }
}

fn evalArgs(prog: &Prog, argsIdx: i64, st: &mut Interp, scope: i64): Vec<JSValue> {
    var out: Vec<JSValue> = Vec.new()
    var j: i64 = 0
    let n = prog.argLists[argsIdx].len()
    while j < n {
        let eIdx = prog.argLists[argsIdx][j]
        out.push(evalExpr(prog, eIdx, st, scope))
        j = j + 1
    }
    return out
}

fn spaces(n: i64): string {
    var s = ""
    var i: i64 = 0
    while i < n {
        s = s + " "
        i = i + 1
    }
    return s
}

// Reproduces bun's console.log object rendering: one property per line, indented
// two spaces per level, a trailing comma after every entry, string *values*
// double-quoted, closing brace at the parent indent. `{}` stays inline. Nesting
// past depth 2 collapses to `[Object]`. A top-level string prints raw (see
// inspectTop) — only nested strings are quoted.
fn inspectInner(st: &Interp, v: &JSValue, depth: i64): string {
    match v {
        JSValue.Str(s) => {
            return "\"" + s + "\""
        }
        JSValue.Obj(o) => {
            return inspectObj(st, o, depth)
        }
        _ => {
            return toStr(v)
        }
    }
}

// bun renders short arrays inline: `[ 1, 2, "x" ]`, empty as `[]`.
fn inspectArr(st: &Interp, o: i64, depth: i64): string {
    if depth > 2 {
        return "[Array]"
    }
    let n = st.objects[o].elems.len()
    if n == 0 {
        return "[]"
    }
    var out = "[ "
    var i: i64 = 0
    while i < n {
        if i > 0 {
            out = out + ", "
        }
        let v = cloneValue(st.objects[o].elems[i])
        out = out + inspectInner(st, v, depth + 1)
        i = i + 1
    }
    out = out + " ]"
    return out
}

fn inspectObj(st: &Interp, o: i64, depth: i64): string {
    if st.objects[o].isArray {
        return inspectArr(st, o, depth)
    }
    if depth > 2 {
        return "[Object]"
    }
    let n = st.objects[o].props.len()
    if n == 0 {
        return "{}"
    }
    let inner = spaces((depth + 1) * 2)
    let outer = spaces(depth * 2)
    var out = "{\n"
    var i: i64 = 0
    while i < n {
        let key = st.objects[o].props[i].key.clone()
        let val = cloneValue(st.objects[o].props[i].value)
        out = out + inner + key + ": " + inspectInner(st, val, depth + 1) + ",\n"
        i = i + 1
    }
    out = out + outer + "}"
    return out
}

fn inspectTop(st: &Interp, v: &JSValue): string {
    match v {
        JSValue.Obj(o) => {
            return inspectObj(st, o, 0)
        }
        _ => {
            return toStr(v)
        }
    }
}

// Invoke a Milo-level JS function: a fresh scope off the closure's captured env,
// with `this` and the parameters bound, then run the body. argVals is consumed.
fn callFunction(prog: &Prog, fIdx: i64, envIdx: i64, argVals: Vec<JSValue>, thisVal: JSValue, st: &mut Interp): JSValue {
    let callScope = newScope(st, envIdx)
    // root the frame across the whole call so a GC inside the body (or a nested
    // call) can't reclaim it
    pushActive(st, callScope)
    scopeDefine(st, callScope, "this", thisVal)
    var j: i64 = 0
    let nParams = prog.funcs[fIdx].params.len()
    while j < nParams {
        let pName = prog.funcs[fIdx].params[j].clone()
        var v = JSValue.Undefined
        if j < argVals.len() {
            v = cloneValue(argVals[j])
        }
        scopeDefine(st, callScope, pName, v)
        j = j + 1
    }
    let body = prog.funcs[fIdx].body
    let flow = execBlock(prog, body, st, callScope)
    popActive(st)
    match flow {
        Flow.Ret(v) => {
            return v
        }
        Flow.Normal => {
            return JSValue.Undefined
        }
    }
}

// Invoke any callable JSValue (user function or native).
fn callValue(prog: &Prog, fnVal: &JSValue, args: Vec<JSValue>, thisVal: JSValue, st: &mut Interp): JSValue {
    match fnVal {
        JSValue.Func(fIdx, envIdx) => {
            return callFunction(prog, fIdx, envIdx, args, thisVal, st)
        }
        JSValue.Native(id) => {
            return callNative(id, args, st)
        }
        _ => {
            return JSValue.Undefined
        }
    }
}

// The (element, index, array) triple JS array-iteration callbacks receive.
fn makeCbArgs(st: &Interp, o: i64, i: i64): Vec<JSValue> {
    var v: Vec<JSValue> = Vec.new()
    v.push(arrGet(st, o, i))
    v.push(JSValue.Number(i as f64))
    v.push(JSValue.Obj(o))
    return v
}

fn isArrayMethod(name: &string): bool {
    return name == "map" || name == "filter" || name == "forEach" || name == "reduce" || name == "join" || name == "indexOf" || name == "includes" || name == "slice" || name == "reverse" || name == "concat" || name == "push" || name == "pop"
}

// Dispatch a built-in Array method. `o` (the array) is temp-rooted by the caller;
// the result array and the callback are additionally rooted while callbacks run
// (a callback can allocate and collect).
fn arrayMethod(prog: &Prog, o: i64, name: &string, args: &Vec<JSValue>, st: &mut Interp): JSValue {
    let n = arrLen(st, o)
    if name == "push" {
        var j: i64 = 0
        while j < args.len() {
            arrPush(st, o, cloneValue(args[j]))
            j = j + 1
        }
        return JSValue.Number(arrLen(st, o) as f64)
    }
    if name == "pop" {
        if n == 0 {
            return JSValue.Undefined
        }
        return st.objects[o].elems.pop()!
    }
    if name == "join" {
        var sep = ","
        if args.len() > 0 {
            sep = toStr(args[0])
        }
        var out = ""
        var i: i64 = 0
        while i < n {
            if i > 0 {
                out = out + sep
            }
            let e = arrGet(st, o, i)
            // JS renders null/undefined as empty in join
            match e {
                JSValue.Null => {
                }
                JSValue.Undefined => {
                }
                _ => {
                    out = out + toStr(e)
                }
            }
            i = i + 1
        }
        return JSValue.Str(out)
    }
    if name == "indexOf" {
        var i: i64 = 0
        while i < n {
            let e = arrGet(st, o, i)
            if args.len() > 0 && jsEquals(e, args[0]) {
                return JSValue.Number(i as f64)
            }
            i = i + 1
        }
        return JSValue.Number(0.0 - 1.0)
    }
    if name == "includes" {
        var i: i64 = 0
        while i < n {
            let e = arrGet(st, o, i)
            if args.len() > 0 && jsEquals(e, args[0]) {
                return JSValue.Bool(true)
            }
            i = i + 1
        }
        return JSValue.Bool(false)
    }
    if name == "slice" {
        var a: i64 = 0
        var b = n
        if args.len() > 0 {
            a = toNum(args[0]) as i64
        }
        if args.len() > 1 {
            b = toNum(args[1]) as i64
        }
        if a < 0 {
            a = n + a
            if a < 0 {
                a = 0
            }
        }
        if b < 0 {
            b = n + b
        }
        if b > n {
            b = n
        }
        let sliced = newArray(st)
        var i = a
        while i < b {
            arrPush(st, sliced, arrGet(st, o, i))
            i = i + 1
        }
        return JSValue.Obj(sliced)
    }
    if name == "reverse" {
        var i: i64 = 0
        var j = n - 1
        while i < j {
            let lo = arrGet(st, o, i)
            let hi = arrGet(st, o, j)
            arrSet(st, o, i, hi)
            arrSet(st, o, j, lo)
            i = i + 1
            j = j - 1
        }
        return JSValue.Obj(o)
    }
    if name == "concat" {
        let joined = newArray(st)
        pushTemp(st, JSValue.Obj(joined))
        var i: i64 = 0
        while i < n {
            arrPush(st, joined, arrGet(st, o, i))
            i = i + 1
        }
        var a: i64 = 0
        while a < args.len() {
            let av = cloneValue(args[a])
            match av {
                JSValue.Obj(other) => {
                    if st.objects[other].isArray {
                        var k: i64 = 0
                        let m = arrLen(st, other)
                        while k < m {
                            arrPush(st, joined, arrGet(st, other, k))
                            k = k + 1
                        }
                    } else {
                        arrPush(st, joined, JSValue.Obj(other))
                    }
                }
                _ => {
                    arrPush(st, joined, cloneValue(args[a]))
                }
            }
            a = a + 1
        }
        popTemp(st)
        return JSValue.Obj(joined)
    }
    // callback methods: root the callback across the loop
    var cb = JSValue.Undefined
    if args.len() > 0 {
        cb = cloneValue(args[0])
    }
    pushTemp(st, cloneValue(cb))
    if name == "map" {
        let mapped = newArray(st)
        pushTemp(st, JSValue.Obj(mapped))
        var i: i64 = 0
        while i < n {
            let cbArgs = makeCbArgs(st, o, i)
            let r = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            arrPush(st, mapped, r)
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(mapped)
    }
    if name == "filter" {
        let kept = newArray(st)
        pushTemp(st, JSValue.Obj(kept))
        var i: i64 = 0
        while i < n {
            let elem = arrGet(st, o, i)
            let cbArgs = makeCbArgs(st, o, i)
            let keep = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            if truthy(keep) {
                arrPush(st, kept, elem)
            }
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return JSValue.Obj(kept)
    }
    if name == "forEach" {
        var i: i64 = 0
        while i < n {
            let cbArgs = makeCbArgs(st, o, i)
            let _ = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            i = i + 1
        }
        popTemp(st)
        return JSValue.Undefined
    }
    if name == "reduce" {
        var acc = JSValue.Undefined
        var start: i64 = 0
        if args.len() > 1 {
            acc = cloneValue(args[1])
        } else {
            if n > 0 {
                acc = arrGet(st, o, 0)
                start = 1
            }
        }
        pushTemp(st, cloneValue(acc))
        var i = start
        while i < n {
            var cbArgs: Vec<JSValue> = Vec.new()
            cbArgs.push(cloneValue(acc))
            cbArgs.push(arrGet(st, o, i))
            cbArgs.push(JSValue.Number(i as f64))
            acc = callValue(prog, cb, cbArgs, JSValue.Undefined, st)
            i = i + 1
        }
        popTemp(st)
        popTemp(st)
        return acc
    }
    popTemp(st)
    return JSValue.Undefined
}

// Call a member as a method: `this` binds to the receiver. String and array
// receivers dispatch to built-in methods; object receivers use function-valued
// properties. The receiver is temp-rooted across argument evaluation (an argument
// may be a call that triggers GC).
fn callMember(prog: &Prog, recv: JSValue, name: &string, argsIdx: i64, st: &mut Interp, scope: i64): JSValue {
    match recv {
        JSValue.Str(s) => {
            let argVals = evalArgs(prog, argsIdx, st, scope)
            // regex-based string ops when the first arg is a RegExp
            if argVals.len() > 0 && regexIdOf(st, argVals[0]) >= 0 {
                let rid = regexIdOf(st, argVals[0])
                if name == "replace" {
                    var repl = ""
                    if argVals.len() > 1 {
                        repl = toStr(argVals[1])
                    }
                    return regexReplace(st, s, rid, repl)
                }
                if name == "match" {
                    return regexStrMatch(st, s, rid)
                }
            }
            return stringMethod(name, s, argVals, st)
        }
        JSValue.Obj(o) => {
            pushTemp(st, JSValue.Obj(o))
            if st.objects[o].regexId >= 0 {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = regexMethod(st, o, name, argVals)
                popTemp(st)
                return r
            }
            if st.objects[o].isArray && isArrayMethod(name) {
                let argVals = evalArgs(prog, argsIdx, st, scope)
                let r = arrayMethod(prog, o, name, argVals, st)
                popTemp(st)
                return r
            }
            let m = getMember(st, o, name)
            match m {
                JSValue.Func(fIdx, envIdx) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callFunction(prog, fIdx, envIdx, argVals, JSValue.Obj(o), st)
                    popTemp(st)
                    return r
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callNative(id, argVals, st)
                    popTemp(st)
                    return r
                }
                _ => {
                    popTemp(st)
                    print("milojs: TypeError: value is not a function")
                    return JSValue.Undefined
                }
            }
        }
        _ => {
            print("milojs: TypeError: value is not a function")
            return JSValue.Undefined
        }
    }
}

fn evalCall(prog: &Prog, calleeIdx: i64, argsIdx: i64, st: &mut Interp, scope: i64): JSValue {
    // builtin: console.log(...)
    let calleeNode = getExpr(prog, calleeIdx)
    match calleeNode {
        Expr.Member(objIdx, name) => {
            let objNode = getExpr(prog, objIdx)
            match objNode {
                Expr.Ident(objName) => {
                    if objName == "console" && (name == "log" || name == "error" || name == "warn" || name == "info") {
                        let argVals = evalArgs(prog, argsIdx, st, scope)
                        var line = ""
                        var j: i64 = 0
                        while j < argVals.len() {
                            if j > 0 {
                                line = line + " "
                            }
                            line = line + inspectTop(st, argVals[j])
                            j = j + 1
                        }
                        print(line)
                        return JSValue.Undefined
                    }
                }
                _ => {
                }
            }
        }
        _ => {
        }
    }

    // A Member/Index callee is a method call: `this` binds to the receiver.
    // Anything else is a plain call with `this` = undefined.
    let methodNode = getExpr(prog, calleeIdx)
    match methodNode {
        Expr.Member(objIdx, name) => {
            let recv = evalExpr(prog, objIdx, st, scope)
            return callMember(prog, recv, name, argsIdx, st, scope)
        }
        Expr.Index(objIdx, keyIdx) => {
            let recv = evalExpr(prog, objIdx, st, scope)
            let kv = evalExpr(prog, keyIdx, st, scope)
            let key = toStr(kv)
            return callMember(prog, recv, key, argsIdx, st, scope)
        }
        _ => {
            let calleeVal = evalExpr(prog, calleeIdx, st, scope)
            match calleeVal {
                JSValue.Func(fIdx, envIdx) => {
                    pushTemp(st, JSValue.Func(fIdx, envIdx))
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    let r = callFunction(prog, fIdx, envIdx, argVals, JSValue.Undefined, st)
                    popTemp(st)
                    return r
                }
                JSValue.Native(id) => {
                    let argVals = evalArgs(prog, argsIdx, st, scope)
                    return callNative(id, argVals, st)
                }
                _ => {
                    print("milojs: TypeError: value is not a function")
                    return JSValue.Undefined
                }
            }
        }
    }
}

// try/catch/finally. The catch binding and both the pending throw value and any
// pending return value are rooted across the finally block (which can allocate
// and collect). finally overrides: its own throw or return wins; otherwise the
// try/catch's pending throw or return is restored.
fn execTry(prog: &Prog, tryB: i64, param: &string, catchB: i64, finallyB: i64, st: &mut Interp, scope: i64): Flow {
    let tryScope = newScope(st, scope)
    pushActive(st, tryScope)
    var flow = execBlock(prog, tryB, st, tryScope)
    popActive(st)

    if st.throwing && catchB >= 0 {
        let caught = cloneValue(st.thrownValue)
        st.throwing = false
        st.thrownValue = JSValue.Undefined
        let catchScope = newScope(st, scope)
        pushActive(st, catchScope)
        if param.len() > 0 {
            scopeDefine(st, catchScope, param.clone(), caught)
        }
        flow = execBlock(prog, catchB, st, catchScope)
        popActive(st)
    }

    if finallyB < 0 {
        return flow
    }

    // capture what try/catch left pending, then run finally with a clean slate
    let hadThrow = st.throwing
    var savedThrow = cloneValue(st.thrownValue)
    var hadRet = false
    var savedRet = JSValue.Undefined
    match flow {
        Flow.Ret(v) => {
            hadRet = true
            savedRet = cloneValue(v)
        }
        Flow.Normal => {
        }
    }
    st.throwing = false
    st.thrownValue = JSValue.Undefined
    // stash the captured values on the temp-root stack so finally's allocations
    // can't collect them, then recover them afterward (Vec.pop returns the value)
    pushTemp(st, savedThrow)
    pushTemp(st, savedRet)
    let finScope = newScope(st, scope)
    pushActive(st, finScope)
    let finFlow = execBlock(prog, finallyB, st, finScope)
    popActive(st)
    savedRet = st.tempRoots.pop()!
    savedThrow = st.tempRoots.pop()!

    match finFlow {
        Flow.Ret(fv) => {
            return Flow.Ret(fv)
        }
        Flow.Normal => {
        }
    }
    if st.throwing {
        return Flow.Normal
    }
    if hadThrow {
        st.throwing = true
        st.thrownValue = savedThrow
        return Flow.Normal
    }
    if hadRet {
        return Flow.Ret(savedRet)
    }
    return Flow.Normal
}

fn execStmt(prog: &Prog, idx: i64, st: &mut Interp, scope: i64): Flow {
    if st.throwing {
        return Flow.Normal
    }
    let node = getStmt(prog, idx)
    match node {
        Stmt.Decl(name, e) => {
            let v = evalExpr(prog, e, st, scope)
            scopeDefine(st, scope, name, v)
            return Flow.Normal
        }
        Stmt.ExprStmt(e) => {
            evalExpr(prog, e, st, scope)
            return Flow.Normal
        }
        Stmt.If(c, t, f) => {
            let vc = evalExpr(prog, c, st, scope)
            if truthy(vc) {
                return execStmt(prog, t, st, scope)
            }
            if f >= 0 {
                return execStmt(prog, f, st, scope)
            }
            return Flow.Normal
        }
        Stmt.While(c, body) => {
            var looping = true
            while looping {
                let vc = evalExpr(prog, c, st, scope)
                if st.throwing || !truthy(vc) {
                    looping = false
                } else {
                    let flow = execStmt(prog, body, st, scope)
                    match flow {
                        Flow.Ret(v) => {
                            return Flow.Ret(v)
                        }
                        Flow.Normal => {
                        }
                    }
                    if st.throwing {
                        looping = false
                    }
                }
            }
            return Flow.Normal
        }
        Stmt.For(init, cond, update, body) => {
            // the loop gets its own scope so `let`/`var` in the init clause don't
            // leak, and closures made per-iteration capture it
            let loopScope = newScope(st, scope)
            pushActive(st, loopScope)
            if init >= 0 {
                execStmt(prog, init, st, loopScope)
            }
            var looping = true
            while looping {
                if st.throwing {
                    looping = false
                } else {
                    var run = true
                    if cond >= 0 {
                        let vc = evalExpr(prog, cond, st, loopScope)
                        run = truthy(vc)
                    }
                    if !run || st.throwing {
                        looping = false
                    } else {
                        let flow = execStmt(prog, body, st, loopScope)
                        match flow {
                            Flow.Ret(v) => {
                                popActive(st)
                                return Flow.Ret(v)
                            }
                            Flow.Normal => {
                            }
                        }
                        if st.throwing {
                            looping = false
                        } else if update >= 0 {
                            evalExpr(prog, update, st, loopScope)
                        }
                    }
                }
            }
            popActive(st)
            return Flow.Normal
        }
        Stmt.Throw(e) => {
            let v = evalExpr(prog, e, st, scope)
            if !st.throwing {
                st.throwing = true
                st.thrownValue = v
            }
            return Flow.Normal
        }
        Stmt.Try(tryB, param, catchB, finallyB) => {
            return execTry(prog, tryB, param, catchB, finallyB, st, scope)
        }
        Stmt.Ret(e) => {
            let v = evalExpr(prog, e, st, scope)
            return Flow.Ret(v)
        }
        Stmt.Block(b) => {
            let child = newScope(st, scope)
            pushActive(st, child)
            let flow = execBlock(prog, b, st, child)
            popActive(st)
            return flow
        }
        Stmt.FuncDecl(f) => {
            let name = prog.funcs[f].name.clone()
            scopeDefine(st, scope, name, JSValue.Func(f, scope))
            return Flow.Normal
        }
        Stmt.Empty => {
            return Flow.Normal
        }
    }
}

fn execBlock(prog: &Prog, blockIdx: i64, st: &mut Interp, scope: i64): Flow {
    var j: i64 = 0
    let n = prog.blocks[blockIdx].len()
    while j < n {
        // statement boundary = the only GC safepoint (no closure in-flight, all
        // live values rooted in scopes)
        maybeGc(st)
        let sIdx = prog.blocks[blockIdx][j]
        let flow = execStmt(prog, sIdx, st, scope)
        match flow {
            Flow.Ret(v) => {
                return Flow.Ret(v)
            }
            Flow.Normal => {
            }
        }
        // an exception raised in this statement unwinds out of the block
        if st.throwing {
            return Flow.Normal
        }
        j = j + 1
    }
    return Flow.Normal
}
