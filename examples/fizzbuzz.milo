extern fn puts(s: *u8) -> i32
extern fn printf(fmt: *u8) -> i32

fn main() -> i32 {
    var i: i32 = 1
    while i <= 20 {
        if i % 15 == 0 {
            puts("FizzBuzz")
        } else {
            if i % 3 == 0 {
                puts("Fizz")
            } else {
                if i % 5 == 0 {
                    puts("Buzz")
                } else {
                    puts(".")
                }
            }
        }
        i = i + 1
    }
    return 0
}
