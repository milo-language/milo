// Pure (non-SDL) logic for the retro-console menu: ROM discovery, row layout,
// and framebuffer rendering. Split out from menu.milo so a headless harness can
// render the same pixels to a PNG for verification without opening a window.
from "std/fs" import {
    readDir, isDir
}
from "std/io" import {
    readFile
}
from "std/string" import {
    strEndsWith
}
from "./font" import {
    MENU_W, MENU_H, rgb, clear, fillRect, drawText, drawTextCentered, textWidth
}

// A menu row: a system header (kind 0), a selectable ROM (kind 1), or a
// non-selectable note like "(no roms)" (kind 2).
pub struct Row {
    kind: i64,
    label: string,
    sys: string,
    path: string,
}

pub fn joinPath(dir: &string, name: &string): string {
    var full: string = ""
    var k: i64 = 0
    while k < dir.len {
        full.push(dir[k])
        k = k + 1
    }
    full.push(47 as u8) // '/'
    k = 0
    while k < name.len {
        full.push(name[k])
        k = k + 1
    }
    return full
}

// Lexicographic string less-than (byte order) — for sorting ROM names.
pub fn strLess(a: &string, b: &string): bool {
    var i: i64 = 0
    while i < a.len && i < b.len {
        if a[i] != b[i] {
            return a[i] < b[i]
        }
        i = i + 1
    }
    return a.len < b.len
}

// Human-readable label: drop the extension, uppercase, underscores -> spaces.
pub fn prettify(name: &string): string {
    var end = name.len
    var i = name.len - 1
    while i >= 0 {
        if name[i] == 46 { // '.'
            end = i
            break
        }
        i = i - 1
    }
    var s: string = ""
    var j: i64 = 0
    while j < end {
        var c = name[j] as i64
        if c == 95 { // '_'
            c = 32 // space
        }
        if c >= 97 && c <= 122 { // a-z -> A-Z
            c = c - 32
        }
        s.push(c as u8)
        j = j + 1
    }
    return s
}

// Extract a 21-byte SNES header title at `off`, trimmed of trailing spaces, plus
// a printable-character score so the caller can pick LoROM vs HiROM (whichever
// header is real). Returns (score, title).
pub fn snesTitleAt(data: &string, off: i64): i64 {
    if off + 21 > data.len {
        return -1
    }
    var score: i64 = 0
    var i: i64 = 0
    while i < 21 {
        let c = data[off + i] as i64
        if c >= 0x20 && c <= 0x7E {
            score = score + 1
        }
        i = i + 1
    }
    return score
}

pub fn snesTitleStr(data: &string, off: i64): string {
    var s: string = ""
    var end: i64 = 21
    // Trim trailing spaces/nulls.
    while end > 0 {
        let c = data[off + end - 1] as i64
        if c != 0x20 && c != 0x00 {
            break
        }
        end = end - 1
    }
    var i: i64 = 0
    while i < end {
        let c = data[off + i] as i64
        if c >= 0x20 && c <= 0x7E {
            s.push(c as u8)
        } else {
            s.push(0x20 as u8) // replace stray control bytes with a space
        }
        i = i + 1
    }
    return s
}

// Count printable ASCII bytes in a `len`-byte window — used to tell a real
// Genesis header title from garbage (e.g. an interleaved/SMD dump).
pub fn printScore(data: &string, off: i64, len: i64): i64 {
    if off + len > data.len {
        return -1
    }
    var score: i64 = 0
    var i: i64 = 0
    while i < len {
        let c = data[off + i] as i64
        if c >= 0x20 && c <= 0x7E {
            score = score + 1
        }
        i = i + 1
    }
    return score
}

// Read a 48-byte Genesis header title, collapsing runs of spaces and trimming.
// Genesis titles are space-padded to a fixed width ("SONIC THE       HEDGEHOG").
pub fn genesisTitleStr(data: &string, off: i64): string {
    var s: string = ""
    var pendingSpace = false
    var started = false
    var i: i64 = 0
    while i < 48 {
        var c = data[off + i] as i64
        if c < 0x20 || c > 0x7E {
            c = 0x20 // treat stray/control bytes as spaces
        }
        if c == 0x20 {
            if started {
                pendingSpace = true
            }
        } else {
            if pendingSpace {
                s.push(0x20 as u8)
                pendingSpace = false
            }
            s.push(c as u8)
            started = true
        }
        i = i + 1
    }
    return s
}

// Human-readable label. For SNES, read the game name from the cartridge header
// (LoROM $7FC0 / HiROM $FFC0, whichever scores as real ASCII) so "smw.smc" shows
// as "SUPER MARIO WORLD". Falls back to the prettified filename on any failure.
pub fn romTitle(path: &string, name: &string, sys: &string): string {
    if sys == "genesis" {
        match readFile(path) {
            Result.Ok(data) => {
                // Overseas title $150, domestic $120; pick the more printable.
                let oScore = printScore(data, 0x150, 48)
                let dScore = printScore(data, 0x120, 48)
                var off: i64 = 0x150
                var best = oScore
                if dScore > best {
                    off = 0x120
                    best = dScore
                }
                // Real Genesis titles are space-padded ASCII (~48/48 printable);
                // an interleaved/SMD dump scores far lower, so reject it and let
                // the filename fall-through win.
                if best >= 44 {
                    let t = genesisTitleStr(data, off)
                    if t.len > 0 {
                        return t
                    }
                }
            }
            Result.Err(e) => {
            }
        }
    }
    if sys == "snes" {
        match readFile(path) {
            Result.Ok(data) => {
                var base: i64 = 0
                if data.len % 1024 == 512 {
                    base = 512 // skip a copier's 512-byte SMC header
                }
                let loOff = base + 0x7FC0
                let hiOff = base + 0xFFC0
                let loScore = snesTitleAt(data, loOff)
                let hiScore = snesTitleAt(data, hiOff)
                var bestOff = loOff
                var bestScore = loScore
                if hiScore > bestScore {
                    bestOff = hiOff
                    bestScore = hiScore
                }
                if bestScore >= 16 { // mostly-printable = a real title
                    let t = snesTitleStr(data, bestOff)
                    if t.len > 0 {
                        return t
                    }
                }
            }
            Result.Err(e) => {
            }
        }
    }
    return prettify(name)
}

pub fn hasRomExt(name: &string, sys: &string): bool {
    if sys == "nes" {
        return strEndsWith(name, ".nes") || strEndsWith(name, ".NES")
    }
    if sys == "genesis" {
        return strEndsWith(name, ".md") || strEndsWith(name, ".MD")
        || strEndsWith(name, ".bin") || strEndsWith(name, ".BIN")
        || strEndsWith(name, ".gen") || strEndsWith(name, ".GEN")
        || strEndsWith(name, ".smd") || strEndsWith(name, ".SMD")
    }
    if sys == "snes" {
        return strEndsWith(name, ".sfc") || strEndsWith(name, ".SFC")
        || strEndsWith(name, ".smc") || strEndsWith(name, ".SMC")
    }
    return false
}

// Append the header + ROM rows for one system, sorted by name.
pub fn addSystem(rows: &mut Vec<Row>, sel: &mut Vec<i64>, title: string, sys: string): void {
    rows.push(Row {
        kind: 0, label: title, sys: sys.clone(), path: ""
    }
    )
    let dir = "roms/" + sys
    var names: Vec<string> = []
    if isDir(dir) {
        for entry in readDir(dir) {
            if !entry.isDir && hasRomExt(entry.name, sys) {
                names.push(entry.name.clone())
            }
        }
    }
    // Insertion sort — ROM lists are small and this keeps the menu tidy.
    var a: i64 = 1
    while a < names.len {
        var b = a
        while b > 0 && strLess(names[b], names[b - 1]) {
            let t = names[b - 1].clone()
            names[b - 1] = names[b].clone()
            names[b] = t
            b = b - 1
        }
        a = a + 1
    }
    if names.len == 0 {
        rows.push(Row {
            kind: 2, label: "(no ROMs in " + dir + "/)", sys: sys.clone(), path: ""
        }
        )
    } else {
        for n in names {
            let full = joinPath(dir, n)
            sel.push(rows.len)
            rows.push(Row {
                kind: 1, label: romTitle(full, n, sys), sys: sys.clone(), path: full
            }
            )
        }
    }
}

pub fn buildRows(rows: &mut Vec<Row>, sel: &mut Vec<i64>): void {
    addSystem(rows, sel, "NES", "nes")
    addSystem(rows, sel, "GENESIS", "genesis")
    addSystem(rows, sel, "SNES", "snes")
}

// Row layout constants (framebuffer pixels).
pub let LIST_TOP: i64 = 58

pub let ROW_H: i64 = 22

pub fn render(fb: &mut [u32; 230400], rows: &Vec<Row>, selRow: i64, scrollTop: i64, visN: i64, font: &string, glyphs: &[string; 49]): void {
    let bg = rgb(16, 18, 30)
    let gold = rgb(248, 206, 92)
    let romCol = rgb(206, 212, 226)
    let noteCol = rgb(110, 118, 140)
    let barCol = rgb(64, 132, 220)
    let barText = rgb(12, 14, 24)
    let footCol = rgb(120, 128, 150)

    clear(fb, bg)
    drawTextCentered(fb, "MILO RETRO CONSOLE", 14, 3, gold, font, glyphs)

    var i = scrollTop
    var drawn: i64 = 0
    while i < rows.len && drawn < visN {
        let kind = rows[i].kind
        let y = LIST_TOP + drawn * ROW_H
        if kind == 0 {
            drawText(fb, rows[i].label, 24, y, 2, gold, font, glyphs)
        } else if kind == 2 {
            drawText(fb, rows[i].label, 48, y, 2, noteCol, font, glyphs)
        } else {
            if i == selRow {
                fillRect(fb, 40, y - 3, MENU_W - 80, ROW_H - 2, barCol)
                drawText(fb, rows[i].label, 48, y, 2, barText, font, glyphs)
            } else {
                drawText(fb, rows[i].label, 48, y, 2, romCol, font, glyphs)
            }
        }
        i = i + 1
        drawn = drawn + 1
    }

    let foot = "UP/DOWN MOVE   A/ENTER PLAY   B/ESC QUIT"
    drawText(fb, foot, (MENU_W - textWidth(foot, 1)) / 2, MENU_H - 16, 1, footCol, font, glyphs)
}
