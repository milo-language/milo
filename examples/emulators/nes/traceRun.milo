// Headless input-driven regression harness for the 1200-in-1 multicart: boot the
// menu, launch BOMBERMAN with Start, then press Start in-game and confirm the
// framebuffer leaves the title screen (STAGE 1). Guards the NMI-recognition-latency
// fix (serviceInterrupts) — before it, the title->play vblank-wait loop at $C288
// spun forever. Mirrors the jsnes oracle input timing so PCs can be diffed.
// Exit 0 = advanced past title, 1 = stuck. Optional 2nd arg dumps the final
// framebuffer as raw RGB24 (256x240).
//   milo build examples/emulators/nes/traceRun.milo -o /tmp/nesdbg/trace --debug
//   /tmp/nesdbg/trace <rom> [out.rgb]
from "std/args" import {
    args
}
from "std/fs" import {
    writeFile
}
from "./cartridge" import {
    Cartridge
}
from "./cartridgeFile" import {
    loadCartridge
}
from "./cpu" import {
    Cpu, Bus, newBus, newCpuReset, step, clockPpu, clockApu, hex4, serviceInterrupts
}
from "./ppu" import {
    renderFrame
}

pub fn fbHash(bus: &Bus): i64 {
    var h: i64 = 0x1234
    var i: i64 = 0
    while i < 61440 {
        h = (h * 31 + (bus.ppu.fb[i] as i64)) & 0x7FFFFFFF
        i = i + 97
    }
    return h
}

// Run one full frame (NMI-driven), holding `buttons` the whole frame.
pub fn runFrame(cpu: &mut Cpu, bus: &mut Bus, buttons: u8): void {
    bus.buttons = buttons
    let startFrame = bus.ppu.frame
    while bus.ppu.frame == startFrame {
        let before = cpu.cyc
        step(cpu, bus)
        let used = cpu.cyc - before
        var k: i64 = 0
        while k < used * 3 {
            clockPpu(bus)
            k = k + 1
        }
        clockApu(bus, used)
        serviceInterrupts(cpu, bus)
    }
}

pub let START: u8 = 0x08 // bit3 = Start

pub fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: trace <rom>")
        return 1
    }
    match loadCartridge(argv[1]) {
        Result.Ok(cart) => {
            var bus = newBus(cart)
            var cpu = newCpuReset(bus)

            // 60 frames: multicart menu settles on the selected game.
            var f: i64 = 0
            while f < 60 {
                runFrame(cpu, bus, 0)
                f = f + 1
            }
            renderFrame(bus.ppu)
            print("menu       pc=" + hex4(cpu.pc as i64) + " hash=" + hex4(fbHash(bus)))

            // Start x6 to launch BOMBERMAN, then 90 idle frames -> title screen.
            f = 0
            while f < 6 {
                runFrame(cpu, bus, START)
                f = f + 1
            }
            f = 0
            while f < 90 {
                runFrame(cpu, bus, 0)
                f = f + 1
            }
            renderFrame(bus.ppu)
            print("launched   pc=" + hex4(cpu.pc as i64) + " hash=" + hex4(fbHash(bus)))
            let titleHash = fbHash(bus)

            // Start x10 in-game, then 120 idle frames -> gameplay begins.
            f = 0
            while f < 10 {
                runFrame(cpu, bus, START)
                f = f + 1
            }
            f = 0
            while f < 120 {
                runFrame(cpu, bus, 0)
                f = f + 1
            }
            renderFrame(bus.ppu)
            print("afterStart pc=" + hex4(cpu.pc as i64) + " hash=" + hex4(fbHash(bus)))
            // The title->play handoff clears $C288's vblank-wait loop only when NMI
            // dispatch is delayed one instruction (serviceInterrupts). Stuck = the
            // framebuffer never changes from the title screen.
            // Optional: dump the final framebuffer as raw RGB24 (visual check).
            if argv.len >= 3 {
                var data: string = ""
                var i: i64 = 0
                while i < 61440 {
                    let px = bus.ppu.fb[i] as i64
                    data.push((px & 0xFF) as u8)
                    data.push(((px >> 8) & 0xFF) as u8)
                    data.push(((px >> 16) & 0xFF) as u8)
                    i = i + 1
                }
                match writeFile(argv[2], data) {
                    Result.Ok(n) => {
                        print("wrote fb: " + hex4(n))
                    }
                    Result.Err(e) => {
                        print("fb write failed")
                    }
                }
            }
            if fbHash(bus) != titleHash {
                print("advanced past title? YES")
                return 0
            }
            print("advanced past title? NO (stuck at title)")
            return 1
        }
        Result.Err(e) => {
            print("load failed: " + e)
            return 1
        }
    }
}
