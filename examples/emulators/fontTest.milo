// Headless font proof: render the full charset + sample ROM names into the menu
// framebuffer and dump it as raw RGB24 for ffmpeg. Not shipped — verification only.
//   milo build examples/emulators/fontTest.milo -o /tmp/fonttest --debug
//   /tmp/fonttest /tmp/fonttest.rgb
//   ffmpeg -f rawvideo -pixel_format rgb24 -video_size 640x360 -i /tmp/fonttest.rgb -y /tmp/fonttest.png
from "std/fs" import {
    writeFile
}
from "std/args" import {
    args
}
from "./shared/font" import {
    MENU_N, rgb, clear, drawText, drawTextCentered, fontChars, fontGlyphs
}

pub fn main(): i32 {
    var fb: [u32; 230400] = [0; 230400]
    let bg = rgb(18, 20, 34)
    let white = rgb(235, 238, 245)
    let gold = rgb(248, 206, 92)
    let dim = rgb(150, 170, 210)

    let font = fontChars()
    let glyphs = fontGlyphs()

    clear(fb, bg)
    drawTextCentered(fb, "MILO RETRO CONSOLE", 20, 4, gold, font, glyphs)
    drawText(fb, "ABCDEFGHIJKLM", 30, 70, 4, white, font, glyphs)
    drawText(fb, "NOPQRSTUVWXYZ", 30, 110, 4, white, font, glyphs)
    drawText(fb, "0123456789", 30, 150, 4, white, font, glyphs)
    drawText(fb, "-_.:!()[]/,'", 30, 190, 4, white, font, glyphs)
    drawText(fb, "SUPER MARIO BROS 3 (USA).NES", 30, 250, 3, dim, font, glyphs)
    drawText(fb, "SONIC 2 [REV A].MD", 30, 285, 3, dim, font, glyphs)
    drawText(fb, "F-ZERO (V1.1).SFC", 30, 320, 3, dim, font, glyphs)

    // Dump RGB24 (drop the alpha byte of each ABGR word).
    var data: string = ""
    var i: i64 = 0
    while i < MENU_N {
        let px = fb[i] as i64
        data.push((px & 0xFF) as u8)
        data.push(((px >> 8) & 0xFF) as u8)
        data.push(((px >> 16) & 0xFF) as u8)
        i = i + 1
    }
    let argv = args()
    var out = "/tmp/fonttest.rgb"
    if argv.len >= 2 {
        out = argv[1]
    }
    match writeFile(out, data) {
        Result.Ok(n) => {
            print("wrote " + out)
            return 0
        }
        Result.Err(e) => {
            print("write failed")
            return 1
        }
    }
    return 0
}
