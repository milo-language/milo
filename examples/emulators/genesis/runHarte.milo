// Harte 68000 SingleStepTest runner over the flat integer stream produced by
// harteConv.ts (std/json clones subtrees and blows memory on these 6 MB files).
// Applies each case's initial CPU+RAM state, executes one instruction, and
// compares final registers / pc / sr / RAM against the golden state.
//
// Prefetch queue + bus-transaction order are intentionally NOT compared (see
// m68k.milo) — only architectural register/pc/RAM state, which is exact.
//   bun run examples/emulators/genesis/harteConv.ts <op.json.gz> /tmp/op.flat
//   milo run examples/emulators/genesis/runHarte.milo /tmp/op.flat [maxCases]

from "std/args" import {
    args
}
from "std/io" import {
    readFile
}
from "./m68k" import {
    M68k, Mem, newCpu, newMem, step, SR_S
}

// Whitespace-separated decimal integer stream cursor.
pub struct Toks {
    s: string
    pos: i64
}

pub fn nextTok(t: &mut Toks): i64 {
    // skip whitespace
    while t.pos < t.s.len {
        let c = t.s[t.pos] as i64
        if c == 32 || c == 10 || c == 13 || c == 9 {
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    var v: i64 = 0
    var neg = false
    if t.pos < t.s.len && (t.s[t.pos] as i64) == 45 {
        neg = true
        t.pos = t.pos + 1
    }
    while t.pos < t.s.len {
        let c = t.s[t.pos] as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
            t.pos = t.pos + 1
        } else {
            break
        }
    }
    if neg {
        return -v
    }
    return v
}

// Load one state record's registers into the CPU. withPrefetch controls whether
// two prefetch words follow pc. Returns the ram-pair count still to read.
pub fn loadRegs(cpu: &mut M68k, m: &mut Mem, t: &mut Toks, withPrefetch: bool): i64 {
    var i: i64 = 0
    while i < 8 {
        cpu.d[i] = nextTok(t)
        i = i + 1
    }
    i = 0
    while i < 7 {
        cpu.a[i] = nextTok(t)
        i = i + 1
    }
    let usp = nextTok(t)
    let ssp = nextTok(t)
    cpu.sr = nextTok(t)
    cpu.pc = nextTok(t)
    if (cpu.sr & SR_S) != 0 {
        cpu.a[7] = ssp
        cpu.otherSp = usp
    } else {
        cpu.a[7] = usp
        cpu.otherSp = ssp
    }
    if withPrefetch {
        let pf0 = nextTok(t)
        let pf1 = nextTok(t)
        writeWord(m, cpu.pc, pf0)
        writeWord(m, cpu.pc + 2, pf1)
    }
    let ramN = nextTok(t)
    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let val = nextTok(t)
        m.ram[addr & 0xFFFFFF] = (val & 0xFF) as u8
        m.touched.push(addr & 0xFFFFFF)
        j = j + 1
    }
    return ramN
}

pub fn writeWord(m: &mut Mem, addr: i64, w: i64) {
    let a = addr & 0xFFFFFF
    m.ram[a] = ((w >> 8) & 0xFF) as u8
    m.ram[(a + 1) & 0xFFFFFF] = (w & 0xFF) as u8
    m.touched.push(a)
    m.touched.push((a + 1) & 0xFFFFFF)
}

// Compares CPU against the "final" record read from the stream. Returns "" on
// match or a description of the first mismatch. Consumes the record either way.
pub fn checkFinal(cpu: &M68k, m: &Mem, t: &mut Toks): string {
    var fd: [i64; 8] = [0, 0, 0, 0, 0, 0, 0, 0]
    var i: i64 = 0
    while i < 8 {
        fd[i] = nextTok(t)
        i = i + 1
    }
    var fa: [i64; 7] = [0, 0, 0, 0, 0, 0, 0]
    i = 0
    while i < 7 {
        fa[i] = nextTok(t)
        i = i + 1
    }
    let fusp = nextTok(t)
    let fssp = nextTok(t)
    let fsr = nextTok(t)
    let fpc = nextTok(t)
    let ramN = nextTok(t)

    var mismatch = ""
    i = 0
    while i < 8 {
        if (cpu.d[i] & 0xFFFFFFFF) != (fd[i] & 0xFFFFFFFF) && mismatch == "" {
            mismatch = "D" + itoa(i) + " got " + hex8(cpu.d[i]) + " want " + hex8(fd[i])
        }
        i = i + 1
    }
    i = 0
    while i < 7 {
        if (cpu.a[i] & 0xFFFFFFFF) != (fa[i] & 0xFFFFFFFF) && mismatch == "" {
            mismatch = "A" + itoa(i) + " got " + hex8(cpu.a[i]) + " want " + hex8(fa[i])
        }
        i = i + 1
    }
    var usp = cpu.otherSp
    var ssp = cpu.a[7]
    if (cpu.sr & SR_S) == 0 {
        usp = cpu.a[7]
        ssp = cpu.otherSp
    }
    if (usp & 0xFFFFFFFF) != (fusp & 0xFFFFFFFF) && mismatch == "" {
        mismatch = "USP got " + hex8(usp) + " want " + hex8(fusp)
    }
    if (ssp & 0xFFFFFFFF) != (fssp & 0xFFFFFFFF) && mismatch == "" {
        mismatch = "SSP got " + hex8(ssp) + " want " + hex8(fssp)
    }
    if (cpu.pc & 0xFFFFFFFF) != (fpc & 0xFFFFFFFF) && mismatch == "" {
        mismatch = "PC got " + hex8(cpu.pc) + " want " + hex8(fpc)
    }
    if (cpu.sr & 0xFFFF) != (fsr & 0xFFFF) && mismatch == "" {
        mismatch = "SR got " + hex8(cpu.sr & 0xFFFF) + " want " + hex8(fsr)
    }
    var j: i64 = 0
    while j < ramN {
        let addr = nextTok(t)
        let want = nextTok(t) & 0xFF
        let got = m.ram[addr & 0xFFFFFF] as i64
        if got != want && mismatch == "" {
            mismatch = "RAM[" + hex8(addr) + "] got " + hex8(got) + " want " + hex8(want)
        }
        j = j + 1
    }
    return mismatch
}

pub fn resetTouched(m: &mut Mem) {
    for t in m.touched {
        m.ram[t] = 0
    }
    m.touched = Vec.new()
}

pub fn main(): i32 {
    let argv = args()
    if argv.len < 2 {
        print("usage: runHarte <op.flat> [maxCases]")
        return 1
    }
    var maxCases: i64 = 100000000
    if argv.len >= 3 {
        maxCases = strToI(argv[2])
    }

    var raw = ""
    match readFile(argv[1]) {
        Result.Ok(s) => {
            raw = s
        }
        Result.Err(e) => {
            print("cannot read " + argv[1])
            return 1
        }
    }

    var t = Toks {
        s: raw, pos: 0
    }
    let total = nextTok(t)
    var cpu = newCpu()
    var m = newMem()
    var passed: i64 = 0
    var failed: i64 = 0
    var firstFail = ""
    var i: i64 = 0
    while i < total {
        if i >= maxCases {
            break
        }
        let ok = loadRegs(cpu, m, t, true) >= 0
        let ran = step(cpu, m)
        let mismatch = checkFinal(cpu, m, t)
        if !ran {
            failed = failed + 1
            if firstFail == "" {
                firstFail = "case " + itoa(i) + ": opcode unimplemented"
            }
        } else if mismatch == "" {
            passed = passed + 1
        } else {
            failed = failed + 1
            if firstFail == "" {
                firstFail = "case " + itoa(i) + ": " + mismatch
            }
        }
        resetTouched(m)
        i = i + 1
    }

    print("passed " + itoa(passed) + " / " + itoa(passed + failed) + "  (file has " + itoa(total) + " cases)")
    if firstFail != "" {
        print("first fail: " + firstFail)
    }
    if failed == 0 {
        return 0
    }
    return 1
}

// --- tiny formatting helpers ---
pub fn itoa(n: i64): string {
    if n == 0 {
        return "0"
    }
    var v = n
    var neg = false
    if v < 0 {
        neg = true
        v = -v
    }
    var s = ""
    while v > 0 {
        let d = v % 10
        s = digitStr(d) + s
        v = v / 10
    }
    if neg {
        s = "-" + s
    }
    return s
}

pub fn digitStr(d: i64): string {
    var s = ""
    s.push((48 + d) as u8)
    return s
}

pub fn hex8(n: i64): string {
    let v = n & 0xFFFFFFFF
    var s = "0x"
    var i: i64 = 28
    while i >= 0 {
        let nib = (v >> i) & 0xF
        s = s + hexNib(nib)
        i = i - 4
    }
    return s
}

pub fn hexNib(n: i64): string {
    var s = ""
    if n < 10 {
        s.push((48 + n) as u8)
    } else {
        s.push((87 + n) as u8)
    }
    return s
}

pub fn strToI(s: &string): i64 {
    var v: i64 = 0
    for ch in s {
        let c = ch as i64
        if c >= 48 && c <= 57 {
            v = v * 10 + (c - 48)
        }
    }
    return v
}
