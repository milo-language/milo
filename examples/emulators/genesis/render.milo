// Genesis VDP software renderer: background planes A/B + sprites -> a per-pixel
// CRAM-index framebuffer, and CRAM (9-bit BGR) -> RGB helpers. Shared by the PPM
// dumper (bootRun) and the live SDL frontend (genesis). Fine scroll, window plane,
// and strict priority ordering are not applied yet.

from "./m68k" import {
    Mem
}

pub fn frameWidth(m: &Mem): i64 {
    if (m.vdpRegs[12] & 0x1) != 0 {
        return 320
    }
    return 256
}

pub fn frameHeight(_m: &Mem): i64 {
    return 224
}

pub fn planeCells(code: i64): i64 {
    if code == 0 {
        return 32
    }
    if code == 1 {
        return 64
    }
    return 128 // code 3 (2 is invalid, treat as 128)
}

// Genesis 9-bit CRAM entry (----bbb-ggg-rrr-) to 8-bit RGB components. Each
// channel is a 3-bit field, so the result is one of 8 evenly-spaced levels in
// [0, 252] — a bound the RGBA packing downstream relies on.
pub fn cramR(e: i64): i64
ensures result >= 0 && result <= 252
{
    return ((e >> 1) & 0x7) * 36
}

pub fn cramG(e: i64): i64
ensures result >= 0 && result <= 252
{
    return ((e >> 5) & 0x7) * 36
}

pub fn cramB(e: i64): i64
ensures result >= 0 && result <= 252
{
    return ((e >> 9) & 0x7) * 36
}

// Apply a shadow/highlight brightness mode (0 normal, 1 shadow, 2 highlight) to a
// single 0-252 colour component. Shadow halves it; highlight lifts it into the
// upper half of the range.
pub fn shComp(c: i64, mode: i64): i64
requires c >= 0 && c <= 252
ensures result >= 0 && result <= 255
{
    if mode == 1 {
        return c / 2
    }
    if mode == 2 {
        let v = c / 2 + 128
        if v > 255 {
            return 255
        }
        return v
    }
    return c
}

// Decode a packed framebuffer pixel (index in bits 0-5, brightness mode in bits
// 6-7) into 8-bit R/G/B via CRAM.
pub fn pixelR(m: &Mem, packed: i64): i64 {
    return shComp(cramR(m.cram[packed & 0x3F]), (packed >> 6) & 0x3)
}

pub fn pixelG(m: &Mem, packed: i64): i64 {
    return shComp(cramG(m.cram[packed & 0x3F]), (packed >> 6) & 0x3)
}

pub fn pixelB(m: &Mem, packed: i64): i64 {
    return shComp(cramB(m.cram[packed & 0x3F]), (packed >> 6) & 0x3)
}

pub fn vram8(m: &Mem, addr: i64): i64 {
    let a = addr & 0xFFFF
    if a < m.vram.len {
        return m.vram[a] as i64
    }
    return 0
}

// Wrap a (possibly negative) plane coordinate into [0, span).
pub fn wrapCoord(v: i64, span: i64): i64
requires span > 0
ensures result >= 0 && result < span
{
    let r = v % span
    if r < 0 {
        return r + span
    }
    return r
}

// Horizontal scroll for plane P (0=A, 1=B) on scanline y, per the HSCROLL table in
// VRAM (reg13). Modes (reg11 bits 1-0): 00 full-screen, 10 per-8px-cell, 11 per-line.
pub fn hscrollFor(m: &Mem, y: i64, planeB: bool): i64 {
    let hbase = (m.vdpRegs[13] & 0x3F) << 10
    let mode = m.vdpRegs[11] & 0x3
    var row: i64 = 0
    if mode == 3 {
        row = y // per line
    } else if mode == 2 {
        row = y & ~0x7 // per cell (8 lines)
    }
    let planeOff: i64 = if planeB {
        2
    } else {
        0
    }
    let off = hbase + row * 4 + planeOff
    return (vram8(m, off) << 8) | vram8(m, off + 1)
}

// Vertical scroll for plane P from VSRAM. Full-screen mode (reg11 bit2 clear):
// entry 0=A, 1=B. Per-column mode: one entry per 16px column (2 cells).
pub fn vscrollFor(m: &Mem, planeB: bool, colPair: i64): i64 {
    var idx: i64 = 0
    if (m.vdpRegs[11] & 0x4) != 0 {
        idx = (colPair * 2) % 40
    }
    if planeB {
        return m.vsram[(idx + 1) % 40]
    }
    return m.vsram[idx]
}

// A sampled pixel is packed: -1 = transparent, else bit8 = priority, bits5-0 =
// the 6-bit CRAM index.
pub let PRI: i64 = 0x100

// Sample one nametable cell at absolute plane pixel (px,py). `cellStride` is the
// nametable width in cells. Returns the packed value (priority + index) or -1.
pub fn sampleNametable(m: &Mem, base: i64, stride: i64, cellX: i64, cellY: i64, fxIn: i64, fyIn: i64): i64 {
    let entryAddr = base + (cellY * stride + cellX) * 2
    let entry = (vram8(m, entryAddr) << 8) | vram8(m, entryAddr + 1)
    let tileIdx = entry & 0x7FF
    let palLine = (entry >> 13) & 0x3
    let hflip = (entry & 0x0800) != 0
    let vflip = (entry & 0x1000) != 0
    var fx = fxIn
    var fy = fyIn
    if hflip {
        fx = 7 - fx
    }
    if vflip {
        fy = 7 - fy
    }
    let byte = vram8(m, tileIdx * 32 + fy * 4 + (fx / 2))
    var color: i64 = 0
    if (fx & 1) == 0 {
        color = (byte >> 4) & 0xF
    } else {
        color = byte & 0xF
    }
    if color == 0 {
        return -1
    }
    var packed = palLine * 16 + color
    if (entry & 0x8000) != 0 {
        packed = packed | PRI
    }
    return packed
}

// Scrolling background plane sample at absolute plane pixel (px,py).
pub fn samplePlane(m: &Mem, base: i64, pw: i64, ph: i64, px: i64, py: i64): i64 {
    return sampleNametable(m, base, pw, (px / 8) % pw, (py / 8) % ph, px % 8, py % 8)
}

// True where the window plane replaces plane A (reg17 horizontal, reg18 vertical
// boundaries; the window covers the union of the two spans).
pub fn inWindow(m: &Mem, x: i64, y: i64): bool {
    let rv = m.vdpRegs[18]
    let vval = (rv & 0x1F) * 8
    var yin = false
    if (rv & 0x80) != 0 {
        yin = y >= vval
    } else {
        yin = y < vval
    }
    let rh = m.vdpRegs[17]
    let hval = (rh & 0x1F) * 16
    var xin = false
    if (rh & 0x80) != 0 {
        xin = x >= hval
    } else {
        xin = x < hval
    }
    return yin || xin
}

// Window plane sample (no scroll). Nametable width is 64 cells for H40, else 32.
pub fn sampleWindow(m: &Mem, x: i64, y: i64, width: i64): i64 {
    let stride: i64 = if width == 320 {
        64
    } else {
        32
    }
    let base: i64 = if width == 320 {
        (m.vdpRegs[3] & 0x3E) << 10
    } else {
        (m.vdpRegs[3] & 0x3F) << 10
    }
    return sampleNametable(m, base, stride, x / 8, y / 8, x % 8, y % 8)
}

// Build the full frame as a Vec<i64> of CRAM indices: planes B then A, sprites on top.
pub fn renderIndexed(m: &Mem): Vec<i64> {
    let width = frameWidth(m)
    let height = frameHeight(m)
    let planeW = planeCells(m.vdpRegs[16] & 0x3)
    let planeH = planeCells((m.vdpRegs[16] >> 4) & 0x3)
    let baseA = (m.vdpRegs[2] & 0x38) << 10
    let baseB = (m.vdpRegs[4] & 0x7) << 13
    let backdrop = m.vdpRegs[7] & 0x3F
    let sh = (m.vdpRegs[12] & 0x08) != 0 // shadow/highlight mode

    // Display disabled (reg1 bit6 clear): the whole screen shows only the backdrop.
    if (m.vdpRegs[1] & 0x40) == 0 {
        var blank: Vec<i64> = Vec.new()
        var bi: i64 = 0
        while bi < width * height {
            blank.push(backdrop & 0x3F)
            bi = bi + 1
        }
        return blank
    }

    let spanAx = planeW * 8
    let spanAy = planeH * 8

    // Sprite layer: packed value per pixel (-1 transparent, PRI bit + index).
    var spr: Vec<i64> = Vec.new()
    var s: i64 = 0
    while s < width * height {
        spr.push(-1)
        s = s + 1
    }
    drawSprites(m, spr, width, height)

    // Composite per the Genesis layer order (front to back): sprite-hi, A-hi,
    // B-hi, sprite-lo, A-lo, B-lo, backdrop. The window plane replaces A.
    var fb: Vec<i64> = Vec.new()
    var y: i64 = 0
    while y < height {
        let hA = hscrollFor(m, y, false)
        let hB = hscrollFor(m, y, true)
        var x: i64 = 0
        while x < width {
            // Per-column vertical scroll (constant within a 16px column).
            let colPair = x / 16
            let pyA = wrapCoord(y + vscrollFor(m, false, colPair), spanAy)
            let pyB = wrapCoord(y + vscrollFor(m, true, colPair), spanAy)
            var aVal: i64 = -1
            if inWindow(m, x, y) {
                aVal = sampleWindow(m, x, y, width)
            } else {
                aVal = samplePlane(m, baseA, planeW, planeH, wrapCoord(x - hA, spanAx), pyA)
            }
            let bVal = samplePlane(m, baseB, planeW, planeH, wrapCoord(x - hB, spanAx), pyB)
            var sVal = spr[y * width + x]

            // Shadow/highlight (reg12 bit3): areas backed only by low-priority
            // layers are shadowed; sprite palette-3 colors 14/15 are transparent
            // operators that highlight/shadow the pixel beneath. Normal sprite
            // pixels always draw at normal brightness.
            var shadowed = false
            var highlighted = false
            if sh {
                let hiPlane = (aVal >= 0 && (aVal & PRI) != 0) || (bVal >= 0 && (bVal & PRI) != 0)
                shadowed = !hiPlane
                if sVal >= 0 {
                    let sc = sVal & 0x3F
                    if sc == 0x3F {
                        shadowed = true // shadow operator
                        sVal = -1
                    } else if sc == 0x3E {
                        if shadowed {
                            shadowed = false // highlight cancels shadow -> normal
                        } else {
                            highlighted = true
                        }
                        sVal = -1
                    }
                }
            }

            var pick = backdrop
            var winSprite = false
            if sVal >= 0 && (sVal & PRI) != 0 {
                pick = sVal & 0x3F
                winSprite = true
            } else if aVal >= 0 && (aVal & PRI) != 0 {
                pick = aVal & 0x3F
            } else if bVal >= 0 && (bVal & PRI) != 0 {
                pick = bVal & 0x3F
            } else if sVal >= 0 {
                pick = sVal & 0x3F
                winSprite = true
            } else if aVal >= 0 {
                pick = aVal & 0x3F
            } else if bVal >= 0 {
                pick = bVal & 0x3F
            }
            // Brightness mode in bits 6-7: 0 normal, 1 shadow, 2 highlight. A drawn
            // normal sprite pixel is always normal brightness.
            var mode: i64 = 0
            if sh && !winSprite {
                if highlighted {
                    mode = 2
                } else if shadowed {
                    mode = 1
                }
            }
            fb.push((pick & 0x3F) | (mode << 6))
            x = x + 1
        }
        y = y + 1
    }
    return fb
}

// Walk the sprite attribute table's link list; draw each sprite's cells (tiles are
// column-major within a sprite). Colour 0 is transparent.
pub fn drawSprites(m: &Mem, fb: &mut Vec<i64>, width: i64, height: i64) {
    let satBase = (m.vdpRegs[5] & 0x7F) << 9
    var sprIdx: i64 = 0
    var guard: i64 = 0
    while guard < 80 {
        let o = satBase + sprIdx * 8
        let yraw = ((vram8(m, o) << 8) | vram8(m, o + 1)) & 0x3FF
        let sizeByte = vram8(m, o + 2)
        let hs = ((sizeByte >> 2) & 0x3) + 1
        let vs = (sizeByte & 0x3) + 1
        let link = vram8(m, o + 3) & 0x7F
        let attr = (vram8(m, o + 4) << 8) | vram8(m, o + 5)
        let xraw = ((vram8(m, o + 6) << 8) | vram8(m, o + 7)) & 0x1FF
        let tileBase = attr & 0x7FF
        let pal = (attr >> 13) & 0x3
        let hflip = (attr & 0x0800) != 0
        let vflip = (attr & 0x1000) != 0
        let pri = (attr & 0x8000) != 0
        let sx = xraw - 128
        let sy = yraw - 128

        var col: i64 = 0
        while col < hs {
            var row: i64 = 0
            while row < vs {
                let tile = tileBase + col * vs + row
                let destCol = if hflip {
                    hs - 1 - col
                } else {
                    col
                }
                let destRow = if vflip {
                    vs - 1 - row
                } else {
                    row
                }
                drawSprTile(m, fb, width, height, tile, sx + destCol * 8, sy + destRow * 8, pal, hflip, vflip, pri)
                row = row + 1
            }
            col = col + 1
        }

        if link == 0 {
            return
        }
        sprIdx = link
        guard = guard + 1
    }
}

pub fn drawSprTile(m: &Mem, fb: &mut Vec<i64>, width: i64, height: i64, tile: i64, ox: i64, oy: i64, pal: i64, hflip: bool, vflip: bool, pri: bool) {
    var py: i64 = 0
    while py < 8 {
        var px: i64 = 0
        while px < 8 {
            let dx = ox + px
            let dy = oy + py
            if dx >= 0 && dx < width && dy >= 0 && dy < height {
                let slot = dy * width + dx
                // Earliest sprite in the link list wins on overlap.
                if fb[slot] < 0 {
                    var fx = px
                    var fy = py
                    if hflip {
                        fx = 7 - px
                    }
                    if vflip {
                        fy = 7 - py
                    }
                    let byte = vram8(m, tile * 32 + fy * 4 + (fx / 2))
                    var color: i64 = 0
                    if (fx & 1) == 0 {
                        color = (byte >> 4) & 0xF
                    } else {
                        color = byte & 0xF
                    }
                    if color != 0 {
                        var packed = pal * 16 + color
                        if pri {
                            packed = packed | PRI
                        }
                        fb[slot] = packed
                    }
                }
            }
            px = px + 1
        }
        py = py + 1
    }
}
