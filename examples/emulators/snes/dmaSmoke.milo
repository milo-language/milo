// M2/M5 DMA smoke: a ROM sets up DMA channel 0 to copy a 32-byte palette from
// ROM into CGRAM via $2122 (CGDATA) — the exact mechanism games use to load
// graphics — then triggers it with $420B. We verify CGRAM holds the palette.
//   milo run examples/emulators/snes/dmaSmoke.milo

from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, step, busReadCgram, vecZeros
}

pub fn hex2(v: i64): string {
    let d = "0123456789ABCDEF"
    var s = ""
    s.push(d[(v >> 4) & 0xF])
    s.push(d[v & 0xF])
    return s
}

pub fn main(): i32 {
    var rom = vecZeros(0x8000)
    // Program at $8000: CGADD=0; configure DMA ch0 (A->B, CGDATA, src $00:8100,
    // size 32); trigger $420B=1; halt.
    let prog = [0xA9, 0x00, 0x8D, 0x21, 0x21, // LDA #0 ; STA $2121 (CGADD)
    0xA9, 0x00, 0x8D, 0x00, 0x43, // LDA #0 ; STA $4300 (DMAP0)
    0xA9, 0x22, 0x8D, 0x01, 0x43, // LDA #$22 ; STA $4301 (BBAD0 = CGDATA)
    0xA9, 0x00, 0x8D, 0x02, 0x43, // LDA #0 ; STA $4302 (A1T0 lo)
    0xA9, 0x81, 0x8D, 0x03, 0x43, // LDA #$81 ; STA $4303 (A1T0 hi -> $8100)
    0xA9, 0x00, 0x8D, 0x04, 0x43, // LDA #0 ; STA $4304 (A1B0 bank)
    0xA9, 0x20, 0x8D, 0x05, 0x43, // LDA #$20 ; STA $4305 (DAS0 lo = 32)
    0xA9, 0x00, 0x8D, 0x06, 0x43, // LDA #0 ; STA $4306 (DAS0 hi)
    0xA9, 0x01, 0x8D, 0x0B, 0x42, // LDA #1 ; STA $420B (trigger ch0)
    0x80, 0xFE // BRA -2 (halt)
    ]
    var i: i64 = 0
    while i < (prog.len as i64) {
        rom[i] = prog[i] as u8
        i = i + 1
    }
    // Palette at ROM offset $100 (maps to $00:8100): bytes 1..32.
    var k: i64 = 0
    while k < 32 {
        rom[0x100 + k] = (k + 1) as u8
        k = k + 1
    }
    rom[0x7FFC] = 0x00 as u8 // reset vector -> $8000
    rom[0x7FFD] = 0x80 as u8

    var m = busNew(rom, 0)
    var cpu = newCpuReset(m)
    var n: i64 = 0
    while n < 3000 {
        step(cpu, m)
        if busReadCgram(m, 31) == 32 {
            break
        } // last palette byte landed
        n = n + 1
    }

    let c0 = busReadCgram(m, 0)
    let c1 = busReadCgram(m, 1)
    let c31 = busReadCgram(m, 31)
    print("CGRAM[0]=$" + hex2(c0) + " [1]=$" + hex2(c1) + " [31]=$" + hex2(c31) + " (want 01 02 20)")
    if c0 == 1 && c1 == 2 && c31 == 32 {
        print("OK: DMA loaded a 32-byte palette into CGRAM")
        return 0
    }
    print("FAIL")
    return 1
}
