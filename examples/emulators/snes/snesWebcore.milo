// Browser-target SNES core: the pure emulator (65816 + SPC700 + PPU, zero FFI)
// plus a thin handle API the JS/canvas driver calls. Compile with emit-js:
//   bun run src/main.ts emit-js examples/emulators/snes/snesWebcore.milo -o web/snes-core.js
// Per frame the driver calls setButtons(h, bits), stepFrame(h), and blits h.rgba
// (256x224 RGBA) to a canvas. No audio yet (matches the native SDL frontend).
from "./cpu" import {
    Cpu, Mem, busNew, newCpuReset, stepFrame
}
from "./ppu" import {
    renderFrame
}
from "./cartcore" import {
    Cart, parseCart
}

let SNES_W: i64 = 256
let SNES_H: i64 = 224

struct SnesHandle {
    cpu: Cpu
    m: Mem
    fb: Vec<i64> // renderFrame target: 0xRRGGBB per pixel, SNES_W * SNES_H
    rgba: Vec<u8> // reused RGBA framebuffer the driver uploads, SNES_W * SNES_H * 4
}

// Parse `rom` and boot the machine. On a bad image, boots a tiny stub cart so the
// JS side always gets a usable handle (a black screen beats a crash).
fn createSnes(rom: Vec<u8>): SnesHandle {
    var data: Vec<u8> = Vec.new()
    var mapMode: i64 = 0
    match parseCart(rom) {
        Result.Ok(c) => {
            data = c.rom
            mapMode = c.map
        }
        Result.Err(e) => {
            print("SNES ROM parse failed: " + e) // data stays empty -> black screen
        }
    }

    var m = busNew(data, mapMode)
    var cpu = newCpuReset(m)

    var fb: Vec<i64> = Vec.new()
    var rgba: Vec<u8> = Vec.new()
    var i: i64 = 0
    while i < SNES_W * SNES_H {
        fb.push(0)
        rgba.push(0)
        rgba.push(0)
        rgba.push(0)
        rgba.push(255)
        i = i + 1
    }

    return SnesHandle {
        cpu: cpu, m: m, fb: fb, rgba: rgba,
    }
}

// Auto-read joypad 1 word. Bits (matches snes.milo): 0x8000 B, 0x4000 Y,
// 0x2000 Select, 0x1000 Start, 0x0800 Up, 0x0400 Down, 0x0200 Left, 0x0100 Right,
// 0x0080 A, 0x0040 X, 0x0020 L, 0x0010 R.
fn setButtons(h: &mut SnesHandle, j: i64): void {
    h.m.joy1 = j
}

// Second controller (auto-read joypad 2, $421A/$421B). Same bit layout.
fn setButtons2(h: &mut SnesHandle, j: i64): void {
    h.m.joy2 = j
}

// Advance one video frame, then rasterize the PPU's 0xRRGGBB framebuffer into the
// RGBA buffer the driver uploads to its canvas. (Named `advanceFrame` because the
// core's per-frame step is also `stepFrame`; Milo has no import aliasing.)
fn advanceFrame(h: &mut SnesHandle): void {
    stepFrame(h.cpu, h.m)
    renderFrame(h.m.ppu, h.fb)
    var i: i64 = 0
    while i < SNES_W * SNES_H {
        let c = h.fb[i]
        let dst = i * 4
        h.rgba[dst] = ((c >> 16) & 0xFF) as u8
        h.rgba[dst + 1] = ((c >> 8) & 0xFF) as u8
        h.rgba[dst + 2] = (c & 0xFF) as u8
        h.rgba[dst + 3] = 255
        i = i + 1
    }
}

fn frameW(h: &SnesHandle): i64 {
    return SNES_W
}

fn frameH(h: &SnesHandle): i64 {
    return SNES_H
}

// emit-js appends `main(); __flush();`; no-op so importing in the browser has no
// side effects — the driver drives everything.
fn main(): i32 {
    return 0
}
