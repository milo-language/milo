extern fn malloc(size: i64): *u8

@cSig("stdlib.h", "void *realloc(void *, size_t)")
extern fn realloc(ptr: *u8, size: i64): *u8

@cSig("stdlib.h", "void free(void *)")
extern fn free(ptr: *u8): void

@cSig("string.h", "void *memcpy(void *, const void *, size_t)")
extern fn memcpy(dst: *u8, src: *u8, n: i64): *u8

@cSig("string.h", "void *memset(void *, int, size_t)")
extern fn memset(dst: *u8, c: i32, n: i64): *u8

@cSig("string.h", "void *memmove(void *, const void *, size_t)")
extern fn memmove(dst: *u8, src: *u8, n: i64): *u8

@cSig("sys/mman.h", "void *mmap(void *, size_t, int, int, int, off_t)")
extern fn mmap(addr: *u8, len: i64, prot: i32, flags: i32, fd: i32, offset: i64): *u8

@cSig("sys/mman.h", "int munmap(void *, size_t)")
extern fn munmap(addr: *u8, len: i64): i32

@cSig("sys/mman.h", "int mprotect(void *, size_t, int)")
extern fn mprotect(addr: *u8, len: i64, prot: i32): i32

// ── Error ──

@cSig("string.h", "char *strerror(int)")
extern fn strerror(errnum: i32): *u8

// ── Strings ──

@cSig("string.h", "size_t strlen(const char *)")
extern fn strlen(s: *u8): u64

extern fn strcmp(a: *u8, b: *u8): i32

extern fn strncmp(a: *u8, b: *u8, n: i64): i32

extern fn snprintf(buf: *u8, size: i64, fmt: *u8,...): i32

// ── Network ──

extern fn socket(domain: i32, sockType: i32, protocol: i32): i32

// The socket syscalls take `struct sockaddr *` and read the family from its first bytes,
// so ONE extern must serve every family — Milo can't declare bind twice (the resolver
// merges every decl of an imported file, so a second one at another type just loses).
// Raw here, typed at the wrappers below: the unsafe seam stays inside std/os and callers
// never hand-write an addrlen, which is where a wrong-length bug would come from.
extern fn bind(sockfd: i32, addr: *SockAddr, addrlen: u32): i32

extern fn listen(sockfd: i32, backlog: i32): i32

// accept lets the KERNEL choose the peer's family, so the out-param must be sized for any
// of them. This took a 16-byte sockaddr_in with addrlen=16, which silently truncates an
// IPv6 peer (28 bytes) — a live bug independent of AF_UNIX.
extern fn accept(sockfd: i32, addr: &mut SockAddrStorage, addrlen: &mut u32): i32

extern fn connect(sockfd: i32, addr: *SockAddr, addrlen: u32): i32

extern fn setsockopt(fd: i32, level: i32, opt: i32, val: &i32, len: u32): i32

extern fn getsockopt(fd: i32, level: i32, opt: i32, val: &mut i32, len: &mut u32): i32

extern fn htons(hostshort: u16): u16

extern fn ntohs(netshort: u16): u16

// Same shape as accept: the kernel writes back whatever family the socket is, so the
// buffer must be storage-sized, not sockaddr_in-sized.
extern fn getsockname(fd: i32, addr: &mut SockAddrStorage, addrlen: &mut u32): i32

extern fn inet_pton(af: i32, src: *u8, dst: *u8): i32

// ── typed sockaddr wrappers ──
// One per family. Each owns its own addrlen, so no caller can pass the wrong one.

// The bound port, whatever family the socket is. getsockname writes into storage-sized
// space because the kernel picks the family; sin_port and sin6_port BOTH sit at offset 2
// (same invariant as sun_path), so one read serves v4 and v6. Returns -1 on failure.
fn getSockPort(fd: i32): i32 {
    unsafe {
        var st = makeZeroedSockaddrStorage()
        var len: u32 = sockAddrStorageLen()
        if getsockname(fd, st, len) < 0 {
            return -1
        }
        let portPtr = (st.addrOf() as i64 + 2) as *u16
        return ntohs(*portPtr) as i32
    }
}

fn bindIn(fd: i32, addr: &SockAddrIn): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrInLen())
    }
}

fn bindIn6(fd: i32, addr: &SockAddrIn6): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrIn6Len())
    }
}

fn bindUn(fd: i32, addr: &SockAddrUn): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrUnLen())
    }
}

fn connectIn(fd: i32, addr: &SockAddrIn): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrInLen())
    }
}

fn connectIn6(fd: i32, addr: &SockAddrIn6): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrIn6Len())
    }
}

fn connectUn(fd: i32, addr: &SockAddrUn): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrUnLen())
    }
}

// ── TLS (OpenSSL) ──

extern fn TLS_client_method(): *u8

extern fn SSL_CTX_new(method: *u8): *u8

extern fn SSL_CTX_free(ctx: *u8): void

extern fn SSL_CTX_set_default_verify_paths(ctx: *u8): i32

// Loading the trust store (above) is NOT verification — an OpenSSL client defaults to
// SSL_VERIFY_NONE, so the handshake completes against any certificate, self-signed
// included. SSL_VERIFY_PEER (mode 1) is what makes SSL_connect fail on an untrusted
// chain. Pass a null callback to keep OpenSSL's own verdict.
extern fn SSL_CTX_set_verify(ctx: *u8, mode: i32, callback: *u8): void

// Binds the peer certificate to an expected hostname. SNI (SSL_ctrl 55) only tells the
// server which cert to send — it checks nothing on the way back — so without this a
// valid certificate for ANY host satisfies the handshake. OpenSSL 1.1.0+.
extern fn SSL_set1_host(ssl: *u8, hostname: *u8): i32

// X509_V_OK == 0. Belt-and-braces after a handshake: with SSL_VERIFY_PEER set this
// cannot report failure (SSL_connect would already have failed), but it is the check
// that makes the guarantee explicit rather than implied by a mode constant.
extern fn SSL_get_verify_result(ssl: *u8): i64

extern fn SSL_new(ctx: *u8): *u8

extern fn SSL_set_fd(ssl: *u8, fd: i32): i32

extern fn SSL_connect(ssl: *u8): i32

extern fn SSL_read(ssl: *u8, buf: *u8, num: i32): i32

extern fn SSL_write(ssl: *u8, buf: *u8, num: i32): i32

extern fn SSL_free(ssl: *u8): void

extern fn SSL_ctrl(ssl: *u8, cmd: i32, larg: i64, parg: *u8): i64

extern fn SSL_get_error(ssl: *u8, ret: i32): i32

