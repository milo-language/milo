// ── green-aware fd IO ──
// Safe wrappers over the raw syscalls above. Called from a green task they
// set the fd nonblocking and park the task on would-block, so the scheduler
// keeps running; on a plain OS thread they behave like the raw calls. All fd
// IO in std should go through these instead of per-call-site EAGAIN loops.

// One read(2). Returns bytes read, 0 at EOF, <0 on error.
pub fn readFd(fd: i32, buf: *u8, len: i64): i64 {
    let inGreen = schedulerCurrent() as i64 != 0
    if inGreen {
        // A green task depends on this succeeding: without O_NONBLOCK the read below
        // blocks the whole scheduler thread instead of returning EAGAIN and parking, and
        // no other task can ever run to satisfy it — the program simply hangs with no
        // output. On POSIX this never fails; on Windows it fails for anything that is not
        // a socket (ioctlsocket only covers sockets), which is the IOCP tier of the port.
        // Say so and stop, rather than deadlocking silently.
        if setNonblocking(fd) != 0 {
            eprint("milo: green IO on this fd is not supported on this platform (could not set non-blocking) — see docs/roadmap.md")
            exit(1)
        }
    }
    while true {
        let n = read(fd, buf, len)
        if n < 0 && inGreen && netErrno() == netEagain() {
            schedulerWaitRead(fd)
            continue
        }
        return n
    }
    return -1 as i64
}

// Write all len bytes (loops over partial writes). Returns len or <0 on error.
pub fn writeFd(fd: i32, buf: *u8, len: i64): i64 {
    let inGreen = schedulerCurrent() as i64 != 0
    if inGreen {
        // Same deadlock risk as readFd above.
        if setNonblocking(fd) != 0 {
            eprint("milo: green IO on this fd is not supported on this platform (could not set non-blocking) — see docs/roadmap.md")
            exit(1)
        }
    }
    unsafe {
        var sent: i64 = 0
        while sent < len {
            let n = write(fd, (buf as i64 + sent) as *u8, len - sent)
            if n < 0 && inGreen && netErrno() == netEagain() {
                schedulerWaitWrite(fd)
                continue
            }
            if n < 0 {
                return n
            }
            sent = sent + n
        }
        return sent
    }
}

// Green-aware SOCKET read/write. Identical shape to readFd/writeFd but through the
// sockRead/sockWrite seam: on POSIX that is read/write (a socket fd is a normal fd), but on
// Windows a SOCKET is NOT a CRT fd — the CRT _read/_write behind read/write fast-fail on one,
// so socket data must go through recv/send. Socket code (std/net, raw-socket programs) must
// use these, not readFd/writeFd, which stay bound to the CRT fd path for stdout/stdin/pipes.
pub fn recvFd(fd: i32, buf: *u8, len: i64): i64 {
    let inGreen = schedulerCurrent() as i64 != 0
    if inGreen {
        if setNonblocking(fd) != 0 {
            eprint("milo: green socket IO is not supported on this platform (could not set non-blocking) — see docs/roadmap.md")
            exit(1)
        }
    }
    while true {
        let n = sockRead(fd, buf, len)
        if n < 0 && inGreen && netErrno() == netEagain() {
            schedulerWaitRead(fd)
            continue
        }
        return n
    }
    return -1 as i64
}

pub fn sendFd(fd: i32, buf: *u8, len: i64): i64 {
    let inGreen = schedulerCurrent() as i64 != 0
    if inGreen {
        if setNonblocking(fd) != 0 {
            eprint("milo: green socket IO is not supported on this platform (could not set non-blocking) — see docs/roadmap.md")
            exit(1)
        }
    }
    unsafe {
        var sent: i64 = 0
        while sent < len {
            let n = sockWrite(fd, (buf as i64 + sent) as *u8, len - sent)
            if n < 0 && inGreen && netErrno() == netEagain() {
                schedulerWaitWrite(fd)
                continue
            }
            if n < 0 {
                return n
            }
            sent = sent + n
        }
        return sent
    }
}

// Accept one connection; returns the client fd (<0 on error). In a green task
// the client fd is left nonblocking so later readFd/writeFd calls skip a
// redundant fcntl round-trip.
pub fn acceptFd(fd: i32): i32 {
    let inGreen = schedulerCurrent() as i64 != 0
    if inGreen {
        setNonblocking(fd)
    }
    while true {
        // Storage-sized, not sockaddr_in-sized: the kernel writes whatever family the
        // peer used, and a v6 peer needs 28 bytes.
        var clientAddr = makeZeroedSockaddrStorage()
        var addrlen: u32 = sockAddrStorageLen()
        let clientFd = accept(fd, clientAddr, addrlen)
        if clientFd < 0 && inGreen && netErrno() == netEagain() {
            schedulerWaitRead(fd)
            continue
        }
        if clientFd >= 0 && inGreen {
            setNonblocking(clientFd)
        }
        return clientFd
    }
    return -1
}

// Single-shot nonblocking accept: the client fd, or -1 when no connection is
// pending. For event loops that multiplex accept with other work and must not
// park on the listener — a blocking accept stops every other event source
// until the next connection arrives (milojs's cold-fetch hang).
pub fn acceptFdNb(fd: i32): i32 {
    setNonblocking(fd)
    var clientAddr = makeZeroedSockaddrStorage()
    var addrlen: u32 = sockAddrStorageLen()
    let clientFd = accept(fd, clientAddr, addrlen)
    if clientFd >= 0 {
        setNonblocking(clientFd)
    }
    return clientFd
}

// connect(2). In a green task: nonblocking connect, park until writable,
// then check SO_ERROR. Returns 0 on success, <0 on failure.
// Green-aware connect. Takes the raw seam so it serves every family; the per-family
// entry points below (connectFdIn/connectFdIn6/connectFdUn) are what callers use.
pub fn connectFd(fd: i32, addr: *SockAddr, addrlen: u32): i32 {
    if schedulerCurrent() as i64 == 0 {
        return connect(fd, addr, addrlen)
    }
    setNonblocking(fd)
    let r = connect(fd, addr, addrlen)
    if r == 0 {
        return 0
    }
    // Socket would-block/in-progress is netErrno(), not errno: Windows reports socket
    // errors through WSAGetLastError with its own numbering (WSAEWOULDBLOCK 10035), so a
    // raw getErrno() here reads the wrong value and the green park path is never taken.
    // On POSIX netErrno/netEinprogress fold straight back to errno/EINPROGRESS.
    if netErrno() != netEinprogress() {
        return -1
    }
    schedulerWaitWrite(fd)
    var err: i32 = 0
    var len: u32 = 4
    if getsockopt(fd, solSocket(), soError(), err, len) < 0 {
        return -1
    }
    if err != 0 {
        return -1
    }
    return 0
}

pub fn connectFdIn(fd: i32, addr: &SockAddrIn): i32 {
    unsafe {
        return connectFd(fd, (addr.addrOf()) as *SockAddr, sockAddrInLen())
    }
}

pub fn connectFdIn6(fd: i32, addr: &SockAddrIn6): i32 {
    unsafe {
        return connectFd(fd, (addr.addrOf()) as *SockAddr, sockAddrIn6Len())
    }
}

pub fn connectFdUn(fd: i32, addr: &SockAddrUn): i32 {
    unsafe {
        return connectFd(fd, (addr.addrOf()) as *SockAddr, sockAddrUnLen())
    }
}

// ── green-aware TLS IO ──
// SSL_* on a nonblocking fd reports WANT_READ/WANT_WRITE; these park the
// green task until the fd is ready and retry. On a plain OS thread (blocking
// fd) the WANT codes never occur and these reduce to one SSL call.
fn sslWantRead(): i32 {
    return 2
}

fn sslWantWrite(): i32 {
    return 3
}

// Drive SSL_connect to completion. Returns 1 on success (SSL_connect result otherwise).
pub fn sslConnectFd(ssl: *u8, fd: i32): i32 {
    while true {
        let r = SSL_connect(ssl)
        if r == 1 {
            return 1
        }
        if schedulerCurrent() as i64 == 0 {
            return r
        }
        let e = SSL_get_error(ssl, r)
        if e == sslWantRead() {
            schedulerWaitRead(fd)
            continue
        }
        if e == sslWantWrite() {
            schedulerWaitWrite(fd)
            continue
        }
        return r
    }
    return -1
}

// One SSL_read. Returns bytes read (>0), or <=0 on close/error.
pub fn sslReadFd(ssl: *u8, fd: i32, buf: *u8, len: i32): i32 {
    while true {
        let n = SSL_read(ssl, buf, len)
        if n > 0 {
            return n
        }
        if schedulerCurrent() as i64 == 0 {
            return n
        }
        let e = SSL_get_error(ssl, n)
        if e == sslWantRead() {
            schedulerWaitRead(fd)
            continue
        }
        if e == sslWantWrite() {
            schedulerWaitWrite(fd)
            continue
        }
        return n
    }
    return -1
}

// One SSL_write (OpenSSL default writes all-or-WANT; no partial handling needed).
pub fn sslWriteFd(ssl: *u8, fd: i32, buf: *u8, len: i32): i32 {
    while true {
        let n = SSL_write(ssl, buf, len)
        if n > 0 {
            return n
        }
        if schedulerCurrent() as i64 == 0 {
            return n
        }
        let e = SSL_get_error(ssl, n)
        if e == sslWantRead() {
            schedulerWaitRead(fd)
            continue
        }
        if e == sslWantWrite() {
            schedulerWaitWrite(fd)
            continue
        }
        return n
    }
    return -1
}
