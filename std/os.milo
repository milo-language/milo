// std/os — typed libc bindings for Milo, plus green-aware fd IO wrappers

// these imports exist for the green-aware wrappers at the bottom of this
// file; the resolver's visited-set makes the std/os ↔ std/runtime cycle safe
from "std/platform" import {
    getErrno, eagain, einprogress, solSocket, soError, SockAddr, SockAddrIn, SockAddrIn6, SockAddrUn,
    SockAddrStorage, makeZeroedSockaddr, makeZeroedSockaddrStorage, sockAddrStorageLen, sockAddrInLen,
    sockAddrIn6Len, sockAddrUnLen
}
from "std/event" import {
    setNonblocking
}
from "std/runtime" import {
    schedulerCurrent, schedulerWaitRead, schedulerWaitWrite
}

// ── I/O ──

@cSig("unistd.h", "ssize_t read(int, void *, size_t)")
extern fn read(fd: i32, buf: *u8, nbyte: i64): i64

@cSig("unistd.h", "ssize_t write(int, const void *, size_t)")
extern fn write(fd: i32, buf: *u8, nbyte: i64): i64

@cSig("fcntl.h", "int open(const char *, int, ...)")
extern fn open(path: *u8, flags: i32,...): i32

@cSig("unistd.h", "int close(int)")
extern fn close(fd: i32): i32

// signal(SIGPIPE, SIG_IGN). Writing to a socket whose peer has gone away raises
// SIGPIPE, whose default action is to kill the process — a server dies silently
// (exit 141) the first time a client disconnects mid-response. Every runtime
// that serves connections ignores it and handles the EPIPE from write instead.
@cSig("signal.h", "void (*signal(int, void (*)(int)))(int)")
extern fn signal(sig: i32, handler: *u8): *u8

@cSig("unistd.h", "off_t lseek(int, off_t, int)")
extern fn lseek(fd: i32, offset: i64, whence: i32): i64

@cSig("sys/stat.h", "int fstat(int, struct stat *)")
extern fn fstat(fd: i32, buf: *u8): i32

@cSig("sys/stat.h", "int stat(const char *, struct stat *)")
extern fn stat(path: *u8, buf: *u8): i32

@cSig("unistd.h", "int access(const char *, int)")
extern fn access(path: *u8, mode: i32): i32

@cSig("stdio.h", "int puts(const char *)")
extern fn puts(s: *u8): i32

@cSig("stdio.h", "int printf(const char *, ...)")
extern fn printf(fmt: *u8,...): i32

