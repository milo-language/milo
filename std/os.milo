// std/os — typed libc bindings for Milo, plus green-aware fd IO wrappers

// these imports exist for the green-aware wrappers at the bottom of this
// file; the resolver's visited-set makes the std/os ↔ std/runtime cycle safe
from "std/platform" import {
    getErrno, eagain, einprogress, netErrno, netEagain, netEinprogress, solSocket, soError, SockAddr, SockAddrIn, SockAddrIn6, SockAddrUn,
    SockAddrStorage, makeZeroedSockaddr, makeZeroedSockaddrStorage, sockAddrStorageLen, sockAddrInLen,
    sockAddrIn6Len, sockAddrUnLen,
    pthread_create, pthread_join, pthread_detach,
    pthread_mutex_init, pthread_mutex_lock, pthread_mutex_unlock, pthread_mutex_destroy,
    pthread_cond_init, pthread_cond_wait, pthread_cond_signal, pthread_cond_broadcast, pthread_cond_destroy,
    pthread_rwlock_init, pthread_rwlock_rdlock, pthread_rwlock_wrlock, pthread_rwlock_unlock, pthread_rwlock_destroy,
    mmap, munmap, mprotect,
    pipe,
    read, write, open, close, lseek, access, getpid,
    sockRead, sockWrite
}
from "std/event" import {
    setNonblocking
}
from "std/runtime" import {
    schedulerCurrent, schedulerWaitRead, schedulerWaitWrite
}

// ── I/O ──

// signal(SIGPIPE, SIG_IGN). Writing to a socket whose peer has gone away raises
// SIGPIPE, whose default action is to kill the process — a server dies silently
// (exit 141) the first time a client disconnects mid-response. Every runtime
// that serves connections ignores it and handles the EPIPE from write instead.
@cSig("signal.h", "void (*signal(int, void (*)(int)))(int)")
pub extern fn signal(sig: i32, handler: *u8): *u8

@cSig("sys/stat.h", "int fstat(int, struct stat *)")
pub extern fn fstat(fd: i32, buf: *u8): i32

@cSig("sys/stat.h", "int stat(const char *, struct stat *)")
pub extern fn stat(path: *u8, buf: *u8): i32

@cSig("stdio.h", "int puts(const char *)")
pub extern fn puts(s: *u8): i32

@cSig("stdio.h", "int printf(const char *, ...)")
pub extern fn printf(fmt: *u8,...): i32

// ── Memory ──

@cSig("stdlib.h", "void *malloc(size_t)")
pub extern fn malloc(size: i64): *u8

@cSig("stdlib.h", "void *realloc(void *, size_t)")
pub extern fn realloc(ptr: *u8, size: i64): *u8

@cSig("stdlib.h", "void free(void *)")
pub extern fn free(ptr: *u8): void

@cSig("string.h", "void *memcpy(void *, const void *, size_t)")
pub extern fn memcpy(dst: *u8, src: *u8, n: i64): *u8

@cSig("string.h", "void *memset(void *, int, size_t)")
pub extern fn memset(dst: *u8, c: i32, n: i64): *u8

@cSig("string.h", "void *memmove(void *, const void *, size_t)")
pub extern fn memmove(dst: *u8, src: *u8, n: i64): *u8

// ── Error ──

@cSig("string.h", "char *strerror(int)")
pub extern fn strerror(errnum: i32): *u8

// ── Strings ──

@cSig("string.h", "size_t strlen(const char *)")
pub extern fn strlen(s: *u8): u64

pub extern fn strcmp(a: *u8, b: *u8): i32

pub extern fn strncmp(a: *u8, b: *u8, n: i64): i32

pub extern fn snprintf(buf: *u8, size: i64, fmt: *u8,...): i32

// ── Network ──

// On Windows this links to the ws2_32 socket(), which returns a SOCKET (UINT_PTR); the i32
// here takes its low 32 bits, valid because MS documents SOCKET values fit in 32 bits. It
// also requires WSAStartup to have run — std/net does that via ensureNetInit(), and a raw
// std/os socket() caller must call ensureNetInit() (a no-op on POSIX) itself first.
pub extern fn socket(domain: i32, sockType: i32, protocol: i32): i32

// The socket syscalls take `struct sockaddr *` and read the family from its first bytes,
// so ONE extern must serve every family — Milo can't declare bind twice (the resolver
// merges every decl of an imported file, so a second one at another type just loses).
// Raw here, typed at the wrappers below: the unsafe seam stays inside std/os and callers
// never hand-write an addrlen, which is where a wrong-length bug would come from.
pub extern fn bind(sockfd: i32, addr: *SockAddr, addrlen: u32): i32

pub extern fn listen(sockfd: i32, backlog: i32): i32

// accept lets the KERNEL choose the peer's family, so the out-param must be sized for any
// of them. This took a 16-byte sockaddr_in with addrlen=16, which silently truncates an
// IPv6 peer (28 bytes) — a live bug independent of AF_UNIX.
pub extern fn accept(sockfd: i32, addr: &mut SockAddrStorage, addrlen: &mut u32): i32

pub extern fn connect(sockfd: i32, addr: *SockAddr, addrlen: u32): i32

pub extern fn setsockopt(fd: i32, level: i32, opt: i32, val: &i32, len: u32): i32

pub extern fn getsockopt(fd: i32, level: i32, opt: i32, val: &mut i32, len: &mut u32): i32

pub extern fn htons(hostshort: u16): u16

pub extern fn ntohs(netshort: u16): u16

// Same shape as accept: the kernel writes back whatever family the socket is, so the
// buffer must be storage-sized, not sockaddr_in-sized.
pub extern fn getsockname(fd: i32, addr: &mut SockAddrStorage, addrlen: &mut u32): i32

pub extern fn inet_pton(af: i32, src: *u8, dst: *u8): i32

// ── typed sockaddr wrappers ──
// One per family. Each owns its own addrlen, so no caller can pass the wrong one.

// The bound port, whatever family the socket is. getsockname writes into storage-sized
// space because the kernel picks the family; sin_port and sin6_port BOTH sit at offset 2
// (same invariant as sun_path), so one read serves v4 and v6. Returns -1 on failure.
pub fn getSockPort(fd: i32): i32 {
    unsafe {
        var st = makeZeroedSockaddrStorage()
        var len: u32 = sockAddrStorageLen()
        if getsockname(fd, st, len) < 0 {
            return -1
        }
        let portPtr = (st.addrOf() as i64 + 2) as *u16
        return ntohs(*portPtr) as i32
    }
}

pub fn bindIn(fd: i32, addr: &SockAddrIn): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrInLen())
    }
}

pub fn bindIn6(fd: i32, addr: &SockAddrIn6): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrIn6Len())
    }
}

pub fn bindUn(fd: i32, addr: &SockAddrUn): i32 {
    unsafe {
        return bind(fd, (addr.addrOf()) as *SockAddr, sockAddrUnLen())
    }
}

pub fn connectIn(fd: i32, addr: &SockAddrIn): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrInLen())
    }
}

pub fn connectIn6(fd: i32, addr: &SockAddrIn6): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrIn6Len())
    }
}

pub fn connectUn(fd: i32, addr: &SockAddrUn): i32 {
    unsafe {
        return connect(fd, (addr.addrOf()) as *SockAddr, sockAddrUnLen())
    }
}

// ── TLS (OpenSSL) ──

pub extern fn TLS_client_method(): *u8

pub extern fn SSL_CTX_new(method: *u8): *u8

pub extern fn SSL_CTX_free(ctx: *u8): void

pub extern fn SSL_CTX_set_default_verify_paths(ctx: *u8): i32

// Loading the trust store (above) is NOT verification — an OpenSSL client defaults to
// SSL_VERIFY_NONE, so the handshake completes against any certificate, self-signed
// included. SSL_VERIFY_PEER (mode 1) is what makes SSL_connect fail on an untrusted
// chain. Pass a null callback to keep OpenSSL's own verdict.
pub extern fn SSL_CTX_set_verify(ctx: *u8, mode: i32, callback: *u8): void

// Binds the peer certificate to an expected hostname. SNI (SSL_ctrl 55) only tells the
// server which cert to send — it checks nothing on the way back — so without this a
// valid certificate for ANY host satisfies the handshake. OpenSSL 1.1.0+.
pub extern fn SSL_set1_host(ssl: *u8, hostname: *u8): i32

// X509_V_OK == 0. Belt-and-braces after a handshake: with SSL_VERIFY_PEER set this
// cannot report failure (SSL_connect would already have failed), but it is the check
// that makes the guarantee explicit rather than implied by a mode constant.
pub extern fn SSL_get_verify_result(ssl: *u8): i64

pub extern fn SSL_new(ctx: *u8): *u8

pub extern fn SSL_set_fd(ssl: *u8, fd: i32): i32

pub extern fn SSL_connect(ssl: *u8): i32

pub extern fn SSL_read(ssl: *u8, buf: *u8, num: i32): i32

pub extern fn SSL_write(ssl: *u8, buf: *u8, num: i32): i32

pub extern fn SSL_free(ssl: *u8): void

pub extern fn SSL_ctrl(ssl: *u8, cmd: i32, larg: i64, parg: *u8): i64

pub extern fn SSL_get_error(ssl: *u8, ret: i32): i32

