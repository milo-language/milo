// std/ws — WebSocket server protocol (RFC 6455)

from "std/os" import {
    close, readFd, writeFd, htons, malloc, free, memcpy, socket, connectFd, TLS_client_method, SSL_CTX_new, SSL_CTX_free, SSL_CTX_set_default_verify_paths, SSL_CTX_set_verify, SSL_new, SSL_set1_host, SSL_set_fd, sslConnectFd, sslReadFd, sslWriteFd, SSL_free, SSL_ctrl
}
from "std/crypto" import {
    sha1Bytes
}
from "std/base64" import {
    base64Encode
}
from "std/platform" import {
    SockAddrIn, makeSockaddr
}
from "std/random" import {
    randBytes
}

// ── Frame opcodes ──

fn WS_CONTINUATION(): u8 {
    return 0
}

fn WS_TEXT(): u8 {
    return 1
}

fn WS_BINARY(): u8 {
    return 2
}

fn WS_CLOSE(): u8 {
    return 8
}

fn WS_PING(): u8 {
    return 9
}

fn WS_PONG(): u8 {
    return 10
}

// ── Types ──

struct WsMessage {
    opcode: u8,
    payload: string,
}

struct WsConn {
    fd: i32,
    // TLS handle (0 = plain TCP). When set, all frame IO routes through SSL_read/SSL_write.
    ssl: i64,
    // SSL_CTX owned by this conn (0 = none/borrowed). Only the owner frees ssl+ctx on drop.
    _ctx: i64,
    _closed: bool,
    // Client conns must mask outgoing frames (RFC 6455); server conns must not.
    _isClient: bool,
}

impl Drop for WsConn {
    fn drop(self: &mut Self): void {
        // _closed also marks borrowed copies (shared fd/ssl across green threads) — skip teardown.
        if !self._closed {
            unsafe {
                if self.ssl != 0 {
                    SSL_free(self.ssl as *u8)
                }
                if self._ctx != 0 {
                    SSL_CTX_free(self._ctx as *u8)
                }
                if self.fd >= 0 {
                    close(self.fd)
                }
            }
        }
    }
}

// ── WebSocket handshake ──

// RFC 6455 magic GUID
fn _wsMagic(): string {
    return "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"
}

fn _computeAcceptKey(clientKey: &string): string {
    let combined = clientKey.clone() + _wsMagic()
    let hash = sha1Bytes(combined)
    return base64Encode(hash)
}

// Check if raw HTTP request bytes contain a WebSocket upgrade request.
fn isWsUpgrade(raw: &string): bool {
    return _headerContains(raw, "Upgrade", "websocket")
}

// Extract Sec-WebSocket-Key from raw HTTP request.
fn extractWsKey(raw: &string): string {
    return _findHeaderValue(raw, "Sec-WebSocket-Key")
}

// Accept a WebSocket upgrade on an already-accepted TCP fd.
// Pass the raw HTTP request bytes so the handshake can be completed.
fn wsAccept(fd: i32, rawRequest: &string): Result<WsConn, string> {
    if !isWsUpgrade(rawRequest) {
        return Result.Err("not a WebSocket upgrade request")
    }

    let clientKey = extractWsKey(rawRequest)
    if clientKey.len == 0 {
        return Result.Err("missing Sec-WebSocket-Key")
    }

    let acceptKey = _computeAcceptKey(clientKey)

    var resp: string = "HTTP/1.1 101 Switching Protocols\r\n"
    resp = resp + "Upgrade: websocket\r\n"
    resp = resp + "Connection: Upgrade\r\n"
    resp = resp + "Sec-WebSocket-Accept: " + acceptKey + "\r\n"
    resp = resp + "\r\n"

    let n = writeFd(fd, resp, resp.len)
    if n < 0 {
        return Result.Err("failed to send handshake response")
    }

    return Result.Ok(WsConn {
        fd: fd, ssl: 0, _ctx: 0, _closed: false, _isClient: false
    }
    )
}

// ── Frame reading ──

// Read up to `len` bytes from a plain fd or TLS handle. Yields to the green
// scheduler on would-block. Returns bytes read (>0), 0 on clean close, <0 on error.
fn _readSome(fd: i32, ssl: i64, buf: *u8, len: i64): i64 {
    unsafe {
        if ssl != 0 {
            let n = sslReadFd(ssl as *u8, fd, buf, len as i32)
            if n > 0 {
                return n as i64
            }
            return -1 as i64
        }
        return readFd(fd, buf, len)
    }
    return -1 as i64
}

fn _readExact(fd: i32, ssl: i64, buf: *u8, needed: i64): bool {
    var got: i64 = 0
    unsafe {
        while got < needed {
            let n = _readSome(fd, ssl, (buf as i64 + got) as *u8, needed - got)
            if n <= 0 {
                return false
            }
            got = got + n
        }
    }
    return true
}

impl WsConn {
    // Read next WebSocket message. Handles fragmentation, responds to ping automatically.
    fn recv(self: &mut Self): Result<WsMessage, string> {
        var resultPayload: string = ""
        var resultOpcode: u8 = 0

        while true {
            var header: [u8; 2] = [0; 2]
            if !_readExact(self.fd, self.ssl, header, 2) {
                return Result.Err("connection closed")
            }

            let fin = (header[0] & 128) != 0
            let opcode = header[0] & 15
            let masked = (header[1] & 128) != 0
            var payloadLen: i64 = (header[1] & 127) as i64

            if payloadLen == 126 {
                var extLen: [u8; 2] = [0; 2]
                if !_readExact(self.fd, self.ssl, extLen, 2) {
                    return Result.Err("connection closed reading length")
                }
                let hi = extLen[0] as i64
                let lo = extLen[1] as i64
                payloadLen = (hi << 8) | lo
            } else if payloadLen == 127 {
                var extLen: [u8; 8] = [0; 8]
                if !_readExact(self.fd, self.ssl, extLen, 8) {
                    return Result.Err("connection closed reading length")
                }
                payloadLen = 0
                for i in 0..8 {
                    payloadLen = (payloadLen << 8) | extLen[i] as i64
                }
            }

            var maskKey: [u8; 4] = [0; 4]
            if masked {
                if !_readExact(self.fd, self.ssl, maskKey, 4) {
                    return Result.Err("connection closed reading mask")
                }
            }

            // read payload
            var payload: string = ""
            if payloadLen > 0 {
                unsafe {
                    let buf = malloc(payloadLen)
                    if !_readExact(self.fd, self.ssl, buf, payloadLen) {
                        free(buf)
                        return Result.Err("connection closed reading payload")
                    }
                    if masked {
                        for i in 0..payloadLen {
                            let p = (buf as i64 + i) as *u8
                            * p = *p ^ maskKey[i % 4]
                        }
                    }
                    for i in 0..payloadLen {
                        payload.push(*((buf as i64 + i) as *u8))
                    }
                    free(buf)
                }
            }

            // handle control frames inline
            if opcode == WS_PING() {
                let _ = self._sendFrame(WS_PONG(), payload, true)
                continue
            }
            if opcode == WS_PONG() {
                continue
            }
            if opcode == WS_CLOSE() {
                self._closed = true
                let _ = self._sendFrame(WS_CLOSE(), "", true)
                return Result.Err("close")
            }

            // data frame
            if opcode != WS_CONTINUATION() {
                resultOpcode = opcode
                resultPayload = payload
            } else {
                resultPayload = resultPayload + payload
            }

            if fin {
                return Result.Ok(WsMessage {
                    opcode: resultOpcode, payload: resultPayload
                }
                )
            }
        }

        return Result.Err("unreachable")
    }

    // Send a text message.
    fn sendText(self: &Self, msg: &string): Result<i32, string> {
        return self._sendFrame(WS_TEXT(), msg, true)
    }

    // Send a binary message.
    fn sendBinary(self: &Self, data: &string): Result<i32, string> {
        return self._sendFrame(WS_BINARY(), data, true)
    }

    // Send a ping.
    fn ping(self: &Self): Result<i32, string> {
        return self._sendFrame(WS_PING(), "", true)
    }

    // Send close frame and mark connection closed.
    fn close(self: &mut Self): void {
        if !self._closed {
            let _ = self._sendFrame(WS_CLOSE(), "", true)
            self._closed = true
            close(self.fd)
        }
    }

    fn _sendFrame(self: &Self, opcode: u8, payload: &string, fin: bool): Result<i32, string> {
        // header: 1 (fin+op) + 1..9 (len) + 4 (mask key, client only)
        var headerLen: i64 = 2
        if payload.len >= 126 && payload.len < 65536 {
            headerLen = 4
        } else if payload.len >= 65536 {
            headerLen = 10
        }
        // RFC 6455: client→server frames MUST be masked; server frames MUST NOT be.
        let maskBytes: i64 = if self._isClient {
            4 as i64
        } else {
            0 as i64
        }

        var mask: [u8; 4] = [0; 4]
        if self._isClient {
            unsafe {
                randBytes(mask as *u8, 4)
            }
        }

        let total = headerLen + maskBytes + payload.len
        unsafe {
            let frame = malloc(total)
            var pos: i64 = 0

            // byte 0: FIN + opcode
            var b0: u8 = opcode
            if fin {
                b0 = b0 | 128
            }
            *((frame as i64 + pos) as *u8) = b0
            pos = pos + 1

            // byte 1+: mask bit + payload length
            let maskBit: u8 = if self._isClient {
                128 as u8
            } else {
                0 as u8
            }
            if payload.len < 126 {
                *((frame as i64 + pos) as *u8) = maskBit | (payload.len as u8)
                pos = pos + 1
            } else if payload.len < 65536 {
                *((frame as i64 + pos) as *u8) = maskBit | 126
                pos = pos + 1
                * ((frame as i64 + pos) as *u8) = (payload.len >> 8) as u8
                pos = pos + 1
                * ((frame as i64 + pos) as *u8) = (payload.len & 255) as u8
                pos = pos + 1
            } else {
                *((frame as i64 + pos) as *u8) = maskBit | 127
                pos = pos + 1
                for i in 0..8 {
                    let shift = ((7 - i) * 8) as i64
                    * ((frame as i64 + pos) as *u8) = (payload.len >> shift) as u8
                    pos = pos + 1
                }
            }

            // mask key (client only)
            if self._isClient {
                for i in 0..4 {
                    *((frame as i64 + pos) as *u8) = mask[i]
                    pos = pos + 1
                }
            }

            // payload (XOR-masked for client frames)
            if payload.len > 0 {
                if self._isClient {
                    for i in 0..payload.len {
                        *((frame as i64 + pos + i) as *u8) = payload[i] ^ mask[i % 4]
                    }
                } else {
                    memcpy((frame as i64 + pos) as *u8, payload as *u8, payload.len)
                }
            }

            var sent: i64 = 0
            while sent < total {
                var n: i64 = 0
                if self.ssl != 0 {
                    let r = sslWriteFd(self.ssl as *u8, self.fd, (frame as i64 + sent) as *u8, (total - sent) as i32)
                    if r <= 0 {
                        free(frame)
                        return Result.Err("SSL_write failed")
                    }
                    n = r as i64
                } else {
                    n = writeFd(self.fd, (frame as i64 + sent) as *u8, total - sent)
                    if n < 0 {
                        free(frame)
                        return Result.Err("write failed")
                    }
                }
                sent = sent + n
            }
            free(frame)
        }
        return Result.Ok(0)
    }
}

// ── WebSocket client connect ──

// Connect to a WebSocket server. Performs TCP connect + HTTP upgrade handshake.
// Returns a WsConn on successful 101 response.
fn wsConnect(ip: u32, port: u16, path: &string): Result<WsConn, string> {
    let AF_INET: i32 = 2
    let SOCK_STREAM: i32 = 1

    let fd = socket(AF_INET, SOCK_STREAM, 0)
    if fd < 0 {
        return Result.Err("socket() failed")
    }

    var addr = makeSockaddr(port, ip)
    if connectFdIn(fd, addr) < 0 {
        close(fd)
        return Result.Err("connect() failed")
    }

    // generate a 16-byte base64 key (use a fixed key — sufficient for non-encrypted sessions)
    let clientKey = "dGVybXBhaXItbWlsbw=="

    var req: string = "GET " + path + " HTTP/1.1\r\n"
    req = req + "Host: localhost\r\n"
    req = req + "Upgrade: websocket\r\n"
    req = req + "Connection: Upgrade\r\n"
    req = req + "Sec-WebSocket-Key: " + clientKey + "\r\n"
    req = req + "Sec-WebSocket-Version: 13\r\n"
    req = req + "\r\n"

    let n = writeFd(fd, req, req.len)
    if n < 0 {
        close(fd)
        return Result.Err("failed to send upgrade request")
    }

    // read response — expect "HTTP/1.1 101"
    var buf: [u8; 4096] = [0; 4096]
    let respLen = readFd(fd, buf, 4096)
    if respLen <= 0 {
        close(fd)
        return Result.Err("no response from server")
    }

    var resp: string = ""
    for i in 0..respLen {
        resp.push(buf[i])
    }

    if !resp.startsWith("HTTP/1.1 101") {
        close(fd)
        return Result.Err("server did not accept upgrade: " + resp.substr(0, 40))
    }

    // validate Sec-WebSocket-Accept
    let expectedAccept = _computeAcceptKey(clientKey)
    let actualAccept = _findHeaderValue(resp, "Sec-WebSocket-Accept")
    if actualAccept != expectedAccept {
        close(fd)
        return Result.Err("invalid Sec-WebSocket-Accept")
    }

    return Result.Ok(WsConn {
        fd: fd, ssl: 0, _ctx: 0, _closed: false, _isClient: true
    }
    )
}

// Connect to a WebSocket server over TLS (wss://). Performs TCP connect, TLS
// handshake (blocking — call before setting fds nonblocking), then the HTTP
// upgrade handshake over the encrypted channel. `hostname` is used for SNI,
// certificate validation, and the Host header.
fn wsConnectTls(ip: u32, port: u16, hostname: &string, path: &string): Result<WsConn, string> {
    let AF_INET: i32 = 2
    let SOCK_STREAM: i32 = 1

    unsafe {
        let fd = socket(AF_INET, SOCK_STREAM, 0)
        if fd < 0 {
            return Result.Err("socket() failed")
        }

        var addr = makeSockaddr(port, ip)
        if connectFdIn(fd, addr) < 0 {
            close(fd)
            return Result.Err("connect() failed")
        }

        let method = TLS_client_method()
        let ctx = SSL_CTX_new(method)
        if ctx as i64 == 0 {
            close(fd)
            return Result.Err("SSL_CTX_new failed")
        }
        SSL_CTX_set_default_verify_paths(ctx)
        // SSL_VERIFY_PEER (1). Without it wss:// accepted any certificate, self-signed
        // included — the trust store above is loaded but never consulted, because an
        // OpenSSL client defaults to SSL_VERIFY_NONE.
        SSL_CTX_set_verify(ctx, 1, 0 as *u8)

        let ssl = SSL_new(ctx)
        if ssl as i64 == 0 {
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("SSL_new failed")
        }

        // SSL_ctrl(SSL_CTRL_SET_TLSEXT_HOSTNAME=55) sets SNI hostname — which selects
        // the server's cert but verifies nothing. SSL_set1_host binds the cert to the
        // hostname we actually asked for.
        SSL_ctrl(ssl, 55, 0, hostname)
        SSL_set1_host(ssl, hostname)
        SSL_set_fd(ssl, fd)

        if sslConnectFd(ssl, fd) != 1 {
            SSL_free(ssl)
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("TLS handshake failed")
        }

        let sslAddr = ssl as i64
        let ctxAddr = ctx as i64

        let clientKey = "dGVybXBhaXItbWlsbw=="

        var req: string = "GET " + path + " HTTP/1.1\r\n"
        req = req + "Host: " + hostname + "\r\n"
        req = req + "Upgrade: websocket\r\n"
        req = req + "Connection: Upgrade\r\n"
        req = req + "Sec-WebSocket-Key: " + clientKey + "\r\n"
        req = req + "Sec-WebSocket-Version: 13\r\n"
        req = req + "\r\n"

        if sslWriteFd(ssl, fd, req, req.len as i32) <= 0 {
            SSL_free(ssl)
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("failed to send upgrade request")
        }

        // read response — expect "HTTP/1.1 101"
        var buf: [u8; 4096] = [0; 4096]
        let respLen = sslReadFd(ssl, fd, buf as *u8, 4096)
        if respLen <= 0 {
            SSL_free(ssl)
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("no response from server")
        }

        var resp: string = ""
        for i in 0..respLen as i64 {
            resp.push(buf[i])
        }

        if !resp.startsWith("HTTP/1.1 101") {
            SSL_free(ssl)
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("server did not accept upgrade: " + resp.substr(0, 40))
        }

        let expectedAccept = _computeAcceptKey(clientKey)
        let actualAccept = _findHeaderValue(resp, "Sec-WebSocket-Accept")
        if actualAccept != expectedAccept {
            SSL_free(ssl)
            SSL_CTX_free(ctx)
            close(fd)
            return Result.Err("invalid Sec-WebSocket-Accept")
        }

        return Result.Ok(WsConn {
            fd: fd, ssl: sslAddr, _ctx: ctxAddr, _closed: false, _isClient: true
        }
        )
    }
}

// ── Header parsing helpers ──

fn _toLower(ch: u8): u8 {
    if ch >= 'A' && ch <= 'Z' {
        return ch + 32
    }
    return ch
}

fn _findHeaderValue(raw: &string, name: &string): string {
    var i: i64 = 0
    while i < raw.len {
        // find start of line
        if i == 0 || (i > 0 && raw[i - 1] == '\n') {
            var found: bool = true
            if i + name.len >= raw.len {
                found = false
            } else {
                for j in 0..name.len {
                    if _toLower(raw[i + j]) != _toLower(name[j]) {
                        found = false
                        break
                    }
                }
            }
            if found && i + name.len < raw.len && raw[i + name.len] == ':' {
                var start: i64 = i + name.len + 1
                while start < raw.len && raw[start] == ' ' {
                    start = start + 1
                }
                var end: i64 = start
                while end < raw.len && raw[end] != '\r' && raw[end] != '\n' {
                    end = end + 1
                }
                return raw.substr(start, end)
            }
        }
        i = i + 1
    }
    return ""
}

fn _headerContains(raw: &string, name: &string, value: &string): bool {
    let hdr = _findHeaderValue(raw, name)
    if hdr.len == 0 {
        return false
    }
    // case-insensitive substring check
    if value.len > hdr.len {
        return false
    }
    for i in 0..(hdr.len - value.len + 1) {
        var found: bool = true
        for j in 0..value.len {
            if _toLower(hdr[i + j]) != _toLower(value[j]) {
                found = false
                break
            }
        }
        if found {
            return true
        }
    }
    return false
}
