// std/sysinfo — high-level system information (macOS)

@cSig("unistd.h", "int gethostname(char *, size_t)")
pub extern fn gethostname(name: *u8, len: i64): i32

@cSig("unistd.h", "char *getcwd(char *, size_t)")
pub extern fn getcwd(buf: *u8, size: i64): *u8

@cSig("unistd.h", "int chdir(const char *)")
pub extern fn chdir(path: *u8): i32

@cSig("unistd.h", "pid_t getpid(void)")
pub extern fn getpid(): i32

@cSig("unistd.h", "pid_t getppid(void)")
pub extern fn getppid(): i32

@cSig("unistd.h", "uid_t getuid(void)")
pub extern fn getuid(): u32

@cSig("unistd.h", "gid_t getgid(void)")
pub extern fn getgid(): u32

@cSig("unistd.h", "uid_t geteuid(void)")
pub extern fn geteuid(): u32

@cSig("unistd.h", "gid_t getegid(void)")
pub extern fn getegid(): u32

@cSig("unistd.h", "long sysconf(int)")
pub extern fn sysconf(name: i32): i64

@cSig("stdlib.h", "int getloadavg(double [], int)")
pub extern fn getloadavg(loadavg: *f64, nelem: i32): i32

pub extern fn sysctlbyname(name: *u8, oldp: *u8, oldlenp: *i64, newp: *u8, newlen: i64): i32

pub extern fn sysctl(name: *i32, namelen: u32, oldp: *u8, oldlenp: *i64, newp: *u8, newlen: i64): i32

pub extern fn gettimeofday(tv: *u8, tz: *u8): i32

// Mach
pub extern fn mach_host_self(): u32

pub extern fn host_statistics64(host: u32, flavor: i32, info: *u8, count: *u32): i32

pub fn hostname(): string {
    var buf: [u8; 256] = [0; 256]
    gethostname(buf, 256)
    unsafe {
        return _cstrToString(buf as *u8)
    }
}

pub fn cwd(): string {
    var buf: [u8; 4096] = [0; 4096]
    unsafe {
        getcwd(buf, 4096)
        return _cstrToString(buf as *u8)
    }
}

pub fn pid(): i32 {
    return getpid()
}

pub fn ppid(): i32 {
    return getppid()
}

pub fn uid(): u32 {
    return getuid()
}

pub fn gid(): u32 {
    return getgid()
}

pub fn euid(): u32 {
    return geteuid()
}

pub fn egid(): u32 {
    return getegid()
}

pub fn cpuCount(): i64 {
    let n = sysconf(58)
    if n < 1 {
        return 1
    }
    return n
}

pub fn cpuModel(): string {
    var buf: [u8; 256] = [0; 256]
    var len: [i64; 1] = [256]
    unsafe {
        sysctlbyname("machdep.cpu.brand_string", buf as *u8, len as *i64, 0 as *u8, 0)
        return _cstrToString(buf as *u8)
    }
}

pub fn totalMem(): i64 {
    var mem: [i64; 1] = [0]
    var len: [i64; 1] = [8]
    unsafe {
        sysctlbyname("hw.memsize", mem as *u8, len as *i64, 0 as *u8, 0)
    }
    return mem[0]
}

pub fn freeMem(): i64 {
    // HOST_VM_INFO64 = 4, count = 38
    // Include inactive + purgeable pages as available (matches Activity Monitor)
    var stats: [u8; 512] = [0; 512]
    var count: [u32; 1] = [38]
    unsafe {
        if host_statistics64(mach_host_self(), 4, stats, count as *u32) == 0 {
            let freePages = (stats as *u32) [0] as i64
            let inactivePages = (stats as *u32) [2] as i64
            let purgeablePages = (stats as *u32) [22] as i64
            let pageSize = sysconf(29)
            return (freePages + inactivePages + purgeablePages) * pageSize
        }
    }
    return 0
}

pub fn uptime(): i64 {
    // sysctl CTL_KERN=1, KERN_BOOTTIME=21
    var mib: [i32; 2] = [1, 21]
    var boottime: [i64; 2] = [0, 0]
    var len: [i64; 1] = [16]
    unsafe {
        if sysctl(mib as *i32, 2, boottime as *u8, len as *i64, 0 as *u8, 0) != 0 {
            return 0
        }
        var tvbuf: [u8; 16] = [0; 16]
        gettimeofday(tvbuf, 0 as *u8)
        // seconds at offset 0 (little-endian i64)
        var nowSec: i64 = 0
        for i in 0..8 {
            nowSec = nowSec | ((tvbuf[i] as i64) << (i as i64 * 8))
        }
        return nowSec - boottime[0]
    }
}

pub fn loadAvg(): [f64; 3] {
    var avg: [f64; 3] = [0.0; 3]
    getloadavg(avg, 3)
    return avg
}

pub fn osRelease(): string {
    var buf: [u8; 256] = [0; 256]
    var len: [i64; 1] = [256]
    unsafe {
        sysctlbyname("kern.osrelease", buf as *u8, len as *i64, 0 as *u8, 0)
        return _cstrToString(buf as *u8)
    }
}

pub fn setCwd(path: string): bool {
    return chdir(path) == 0
}
