// std/log — logging to stderr with level tags

from "std/time" import {
    epochSecs
}

fn logMsg(tag: string, msg: string): void {
    let ts = epochSecs()
    eprint($"{tag} {ts.toString()} {msg}")
}

pub fn logDebug(msg: string): void {
    logMsg("[DEBUG]", msg)
}

pub fn logInfo(msg: string): void {
    logMsg("[INFO] ", msg)
}

pub fn logWarn(msg: string): void {
    logMsg("[WARN] ", msg)
}

pub fn logError(msg: string): void {
    logMsg("[ERROR]", msg)
}
