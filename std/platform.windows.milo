// platform-specific constants and helpers for Windows (MSVC / UCRT / Winsock)
//
// Every number here was read out of Microsoft's own headers by compiling a probe against
// the Windows SDK and running it — not inferred from the POSIX arms. Windows disagrees
// with darwin/linux on nearly all of them: sockaddr_in has no sin_len and a 16-bit
// family, AF_INET6 is 23 (not 30/10), and the open() flags need _O_BINARY or the CRT
// silently rewrites \n to \r\n on the way out.
//
// PARTIAL BY DESIGN. Windows has no mmap, no fcntl, no ucontext and no dirent, so the
// constants feeding those live below as inert values whose corresponding `extern fn`
// does not exist in any Windows library. Anything that actually reaches them fails at
// LINK time, naming the missing symbol — loudly, not by computing something plausible.
// The real APIs (VirtualAlloc, ioctlsocket/FIONBIO, CreateFiber, FindFirstFile) are the
// later tiers in docs/roadmap.md.

from "std/os" import {
    htons
}

pub extern type SockAddr

// No sin_len on Windows — the BSD-derived length byte was never adopted — so the family
// is a full 16 bits at offset 0 where darwin splits it into two u8s. Same 16 bytes total.
@cLayout("struct sockaddr_in", "winsock2.h")
pub extern struct SockAddrIn {
    sin_family: u16,
    sin_port: u16,
    sin_addr: u32,
    sin_zero: [u8; 8],
}

@cLayout("struct sockaddr_in6", "ws2tcpip.h")
pub extern struct SockAddrIn6 {
    sin6_family: u16,
    sin6_port: u16,
    sin6_flowinfo: u32,
    sin6_addr: [u8; 16],
    sin6_scope_id: u32,
}

// 110 bytes with a 108-byte path — matching linux, not darwin's 106/104. sun_path still
// lands at offset 2. Requires afunix.h (Windows 10 1803+).
@cLayout("struct sockaddr_un", "afunix.h")
pub extern struct SockAddrUn {
    sun_family: u16,
    sun_path: [u8; 108],
}

@cLayout("struct sockaddr_storage", "winsock2.h")
pub extern struct SockAddrStorage {
    ss_family: u16,
    __ss_pad1: [u8; 6],
    __ss_align: i64,
    __ss_pad2: [u8; 112],
}

pub fn makeZeroedSockaddrStorage(): SockAddrStorage {
    unsafe {
        return zeroed<SockAddrStorage>()
    }
}

// 23 here, against 30 on darwin and 10 on linux — no two of the three agree.
pub fn afInet6(): i32 {
    return 23
}

pub fn makeSockaddr6(port: u16, addr: [u8; 16], scopeId: u32): SockAddrIn6 {
    var a = SockAddrIn6 {
        sin6_family: 23 as u16,
        sin6_port: htons(port),
        sin6_flowinfo: 0,
        sin6_addr: [0; 16],
        sin6_scope_id: scopeId,
    }
    var i: i64 = 0
    while i < 16 {
        a.sin6_addr[i] = addr[i]
        i = i + 1
    }
    return a
}

pub fn sockAddrInLen(): u32 {
    return 16
}

pub fn sockAddrIn6Len(): u32 {
    return 28
}

pub fn makeSockaddrUn(path: &string): SockAddrUn {
    var a = SockAddrUn {
        sun_family: 1 as u16,
        sun_path: [0; 108],
    }
    var i: i64 = 0
    while i < path.len && i < sockAddrUnMaxPath() {
        a.sun_path[i] = path[i]
        i = i + 1
    }
    return a
}

pub fn sockAddrUnLen(): u32 {
    return 110
}

// Longest path that still leaves room for the NUL.
pub fn sockAddrUnMaxPath(): i64 {
    return 107
}

pub fn sockAddrStorageLen(): u32 {
    return 128
}

pub fn makeSockaddr(port: u16, addr: u32): SockAddrIn {
    return SockAddrIn {
        sin_family: 2 as u16,
        sin_port: htons(port),
        sin_addr: addr,
        sin_zero: [0; 8],
    }
}

pub fn makeZeroedSockaddr(): SockAddrIn {
    return SockAddrIn {
        sin_family: 0, sin_port: 0, sin_addr: 0, sin_zero: [0; 8],
    }
}

pub fn solSocket(): i32 {
    return 65535
}

pub fn soReuseaddr(): i32 {
    return 4
}

// _O_BINARY (0x8000) is in both: without it the UCRT translates every \n written through
// a CRT fd into \r\n, so a file written by Milo would not match its own bytes.
// _O_WRONLY|_O_CREAT|_O_TRUNC|_O_BINARY
pub fn oWriteCreateTrunc(): i32 {
    return 33537
}

// _O_WRONLY|_O_CREAT|_O_APPEND|_O_BINARY
pub fn oWriteCreateAppend(): i32 {
    return 33033
}

pub fn addrinfoAddrOffset(): i64 {
    return 32
}

// struct _stat64 — 56 bytes, against darwin's 144. st_mode is a 16-bit field at 6.
pub fn statModeOffset(): i64 {
    return 6
}

pub fn statSizeOffset(): i64 {
    return 24
}

pub fn statBufSize(): i64 {
    return 56
}

// ── errno ──

// The UCRT's errno is `*_errno()`, the analogue of darwin's __error().
pub extern fn _errno(): *u8

pub fn getErrno(): i32 {
    unsafe {
        return _loadI32(_errno())
    }
}

// C errno values (errno.h), NOT the Winsock ones. Socket calls on Windows do not set
// errno at all — they report through WSAGetLastError(), where the corresponding codes are
// WSAEWOULDBLOCK 10035 and WSAEINPROGRESS 10036. std/net therefore cannot work by reading
// these; wiring that up is part of the net tier, not this one.
pub fn eagain(): i32 {
    return 11
}

pub fn einprogress(): i32 {
    return 112
}

pub fn soError(): i32 {
    return 4103
}

// ── Winsock init + socket errors ──
//
// Every Winsock call needs WSAStartup to have run first in the process, or socket()
// returns INVALID_SOCKET with WSANOTINITIALISED. There is no POSIX equivalent, so the
// POSIX arms make ensureNetInit() a no-op; here it runs WSAStartup exactly once. std/net
// calls it before creating any socket, so callers never see the requirement.
//
// Socket errors do NOT go through errno on Windows — they come from WSAGetLastError, with
// their own numbering (WSAEWOULDBLOCK 10035, not EAGAIN 11). netErrno/netEagain/
// netEinprogress exist on all three arms so std/net can read socket errors portably; on
// POSIX they fold straight back to errno and its EAGAIN/EINPROGRESS.

@cSig("winsock2.h", "int WSAStartup(WORD, LPWSADATA)")
pub extern fn WSAStartup(version: u16, data: *u8): i32

@cSig("winsock2.h", "int WSAGetLastError(void)")
pub extern fn WSAGetLastError(): i32

pub var _wsaInited: bool = false

pub fn ensureNetInit(): void {
    if _wsaInited {
        return
    }
    // 0x0202 = Winsock 2.2. WSADATA is ~400 bytes; 512 is a safe receive buffer we never
    // read back (we only need the version negotiation to succeed).
    var data: [u8; 512] = [0; 512]
    unsafe {
        WSAStartup(514 as u16, data as *u8)
    }
    _wsaInited = true
}

pub fn netErrno(): i32 {
    return WSAGetLastError()
}

// The Winsock analogue of EAGAIN: a non-blocking socket op that cannot complete now.
pub fn netEagain(): i32 {
    return 10035
}

// The Winsock analogue of EINPROGRESS. On POSIX a non-blocking connect() reports EINPROGRESS;
// on Windows it reports WSAEWOULDBLOCK (10035), NOT WSAEINPROGRESS (10036, which means "a
// blocking call is already in progress" — a different condition). So the in-progress-connect
// code here is 10035, the same value as netEagain(); std/os.connectFd checks against this to
// decide whether to park for the connect to finish.
pub fn netEinprogress(): i32 {
    return 10035
}

// A Windows SOCKET is NOT a CRT fd: closing one with _close() (the `close` in the fd
// section) trips the CRT invalid-parameter fastfail. closesocket is the only correct
// teardown. SOCKET is 8 bytes; std carries socket fds as i32 (their values fit in 32
// bits per MS), so widen once here. POSIX makes closeSocket an alias of close.
@cSig("winsock2.h", "int closesocket(SOCKET)")
pub extern fn closesocket(s: i64): i32

pub fn closeSocket(fd: i32): i32 {
    return closesocket(fd as i64)
}

// ── socket data IO seam ──
//
// A SOCKET is not a CRT fd, so the CRT _read/_write fast-fail on one — socket data IO must go
// through recv/send. The POSIX arms alias sockRead/sockWrite to read/write; here they are the
// real Winsock calls. len is `int` (32-bit) on Windows, so clamp a large request to a short
// op rather than truncating it (every caller already handles short IO).
@cSig("winsock2.h", "int recv(SOCKET, char *, int, int)")
pub extern fn recv(s: i64, buf: *u8, len: i32, flags: i32): i32

@cSig("winsock2.h", "int send(SOCKET, const char *, int, int)")
pub extern fn send(s: i64, buf: *u8, len: i32, flags: i32): i32

pub fn sockRead(fd: i32, buf: *u8, nbyte: i64): i64 {
    unsafe {
        return recv(fd as i64, buf, _clampCount(nbyte) as i32, 0) as i64
    }
}

pub fn sockWrite(fd: i32, buf: *u8, nbyte: i64): i64 {
    unsafe {
        return send(fd as i64, buf, _clampCount(nbyte) as i32, 0) as i64
    }
}

// ── no-equivalent APIs ──
//
// Each `extern fn` below is absent from every Windows library on purpose: declaring it
// keeps the platform surface uniform (the split is whole-file, so every arm must export
// the same names), while any program that actually calls one fails at link with that
// symbol named. The companion constants are inert — they are only ever arguments to
// these missing calls.

// Windows uses ioctlsocket(FIONBIO) for sockets and has no fcntl at all.
pub extern fn fcntl(fd: i32, cmd: i32,...): i32

pub fn fGetfl(): i32 {
    return -1
}

pub fn fSetfl(): i32 {
    return -1
}

pub fn oNonblock(): i32 {
    return -1
}

// SIGCHLD does not exist: Windows has no SIGCHLD/wait() model, process exit is observed
// by waiting on the process HANDLE.
pub fn sigchldNum(): i32 {
    return -1
}

// ── ucontext over Win32 fibers ──
//
// std/runtime wants stackful coroutine switching and reads the context layout entirely
// through the four accessors below, so this arm is free to define its own layout and back
// it with fibers — which are Windows' native form of exactly this primitive.
//
//   [0..8)   fiber handle
//   [8..16)  stack pointer   (written by runtime; fibers own their stack, so unused)
//   [16..24) stack size      (passed to CreateFiber)
//   [24..32) uc_link         (written by runtime but never taken: _taskEntry ends with an
//                             explicit swapcontext back to the scheduler rather than by
//                             returning, which matters because a fiber routine that
//                             RETURNS calls ExitThread and would kill the process)

pub extern fn ConvertThreadToFiber(param: *u8): i64

pub extern fn CreateFiber(stackSize: i64, start: *u8, param: *u8): i64

pub extern fn SwitchToFiber(fiber: i64): void

pub extern fn DeleteFiber(fiber: i64): void

pub extern fn IsThreadAFiber(): i32

// GetCurrentFiber() is a TEB-read intrinsic, not an exported symbol, so it cannot be
// declared as an extern. Tracking the handle ourselves is the workaround — sound because
// every switch in the runtime goes through swapcontext below, which is the only thing
// that can change which fiber is running.
pub var _currentFiber: i64 = 0

pub fn getcontext(ucp: *u8): i32 {
    if IsThreadAFiber() == 0 {
        _currentFiber = ConvertThreadToFiber(0 as *u8)
    }
    unsafe {
        let slot = ucp as *i64
        slot[0] = _currentFiber
    }
    return 0
}

pub fn makecontext(ucp: *u8, func: *u8, _argc: i32): void {
    unsafe {
        let slot = ucp as *i64
        let stackBytes = slot[2]
        slot[0] = CreateFiber(stackBytes, func, 0 as *u8)
    }
}

pub fn swapcontext(oucp: *u8, ucp: *u8): i32 {
    unsafe {
        let from = oucp as *i64
        let to = ucp as *i64
        from [0] = _currentFiber
        let target = to[0]
        _currentFiber = target
        SwitchToFiber(target)
        // Reached again only when something switches back to us, at which point the
        // running fiber is ours again — the global still names whoever we switched to.
        _currentFiber = from [0]
    }
    return 0
}

pub fn uctxSize(): i64 {
    return 32
}

pub fn uctxStackPtrOffset(): i64 {
    return 8
}

pub fn uctxStackSizeOffset(): i64 {
    return 16
}

pub fn uctxLinkOffset(): i64 {
    return 24
}

// ── mmap family over VirtualAlloc ──
//
// Only the anonymous-private mapping std/runtime and std/mem actually use is supported:
// a file-backed mapping (fd >= 0) needs CreateFileMapping/MapViewOfFile, which is a
// different API shape, so it returns failure rather than quietly handing back memory
// with none of the file's contents in it.

pub extern fn VirtualAlloc(addr: *u8, size: i64, allocType: u32, protect: u32): *u8

pub extern fn VirtualFree(addr: *u8, size: i64, freeType: u32): i32

pub extern fn VirtualProtect(addr: *u8, size: i64, protect: u32, old: *u8): i32

// MEM_COMMIT|MEM_RESERVE = 0x3000, PAGE_READWRITE = 0x04.
pub fn mmap(_addr: *u8, len: i64, _prot: i32, _flags: i32, fd: i32, _offset: i64): *u8 {
    if fd >= 0 {
        return 0 as *u8
    }
    unsafe {
        return VirtualAlloc(0 as *u8, len, 12288 as u32, 4 as u32)
    }
}

// MEM_RELEASE (0x8000) requires the size to be 0 and the address to be the exact base
// returned by VirtualAlloc — it always frees the whole reservation, unlike munmap.
pub fn munmap(addr: *u8, _len: i64): i32 {
    if VirtualFree(addr, 0, 32768 as u32) == 0 {
        return -1
    }
    return 0
}

// PAGE_NOACCESS = 0x01, used for the runtime's stack guard page. VirtualProtect must be
// given somewhere to write the previous protection or it fails.
pub fn mprotect(addr: *u8, len: i64, _prot: i32): i32 {
    var old: u32 = 0
    unsafe {
        if VirtualProtect(addr, len, 1 as u32, old.addrOf() as *u8) == 0 {
            return -1
        }
    }
    return 0
}

// Windows has no dirent/opendir; directory iteration is FindFirstFileW/FindNextFileW.
pub fn direntTypeOffset(): i64 {
    return -1
}

pub fn direntNameOffset(): i64 {
    return -1
}

// ── pthreads over Win32 ──
//
// std/sync and std/runtime are written against the pthread API, so rather than fork them
// per-platform this arm provides that API over the native primitives. The mapping is
// direct: a pthread mutex is an SRWLOCK taken exclusively (both are non-recursive), and a
// pthread condvar is a CONDITION_VARIABLE. Both are 8 bytes against the 64/48 std/sync
// mallocs for them, so the caller-allocated storage is already more than large enough.
//
// All of these return 0 unconditionally: the Win32 calls are void and cannot fail the way
// their pthread counterparts can (no EINVAL for an uninitialised object — Initialize* is
// infallible), so there is no error to propagate rather than one being swallowed.

pub extern fn InitializeSRWLock(lock: *u8): void

pub extern fn AcquireSRWLockExclusive(lock: *u8): void

pub extern fn ReleaseSRWLockExclusive(lock: *u8): void

pub extern fn AcquireSRWLockShared(lock: *u8): void

pub extern fn ReleaseSRWLockShared(lock: *u8): void

pub extern fn InitializeConditionVariable(cond: *u8): void

pub extern fn SleepConditionVariableSRW(cond: *u8, lock: *u8, ms: u32, flags: u32): i32

pub extern fn WakeConditionVariable(cond: *u8): void

pub extern fn WakeAllConditionVariable(cond: *u8): void

pub extern fn CreateThread(attrs: *u8, stackSize: i64, start: *u8, arg: *u8, flags: u32, threadId: *u8): i64

pub extern fn WaitForSingleObject(handle: i64, ms: u32): u32

pub extern fn CloseHandle(handle: i64): i32

pub fn pthread_mutex_init(mutex: *u8, _attr: *u8): i32 {
    InitializeSRWLock(mutex)
    return 0
}

pub fn pthread_mutex_lock(mutex: *u8): i32 {
    AcquireSRWLockExclusive(mutex)
    return 0
}

pub fn pthread_mutex_unlock(mutex: *u8): i32 {
    ReleaseSRWLockExclusive(mutex)
    return 0
}

// An SRWLOCK owns no resources, so there is nothing to release.
pub fn pthread_mutex_destroy(_mutex: *u8): i32 {
    return 0
}

pub fn pthread_cond_init(cond: *u8, _attr: *u8): i32 {
    InitializeConditionVariable(cond)
    return 0
}

// INFINITE (0xFFFFFFFF) and flags 0 = wait on the lock held exclusively, matching the
// SRWLOCK acquired by pthread_mutex_lock above.
pub fn pthread_cond_wait(cond: *u8, mutex: *u8): i32 {
    SleepConditionVariableSRW(cond, mutex, 4294967295 as u32, 0 as u32)
    return 0
}

pub fn pthread_cond_signal(cond: *u8): i32 {
    WakeConditionVariable(cond)
    return 0
}

pub fn pthread_cond_broadcast(cond: *u8): i32 {
    WakeAllConditionVariable(cond)
    return 0
}

pub fn pthread_cond_destroy(_cond: *u8): i32 {
    return 0
}

// pthread_t is a HANDLE here. The start routine's signature differs — pthread wants
// void*(*)(void*) and Win32 wants DWORD(*)(LPVOID) — but on x64 both take their argument
// in RCX and return in RAX, and the return value is discarded by every caller in std, so
// the mismatch is confined to a wider return register than Win32 reads back.
pub fn pthread_create(thread: *u8, _attr: *u8, start: *u8, arg: *u8): i32 {
    let h = CreateThread(0 as *u8, 0, start, arg, 0 as u32, 0 as *u8)
    if h == 0 {
        return -1
    }
    unsafe {
        let slot = thread as *i64
        slot[0] = h
    }
    return 0
}

pub fn pthread_join(thread: i64, _retval: *u8): i32 {
    WaitForSingleObject(thread, 4294967295 as u32)
    CloseHandle(thread)
    return 0
}

pub fn pthread_detach(thread: i64): i32 {
    CloseHandle(thread)
    return 0
}

pub fn pthread_rwlock_init(rwlock: *u8, _attr: *u8): i32 {
    InitializeSRWLock(rwlock)
    return 0
}

pub fn pthread_rwlock_rdlock(rwlock: *u8): i32 {
    AcquireSRWLockShared(rwlock)
    return 0
}

pub fn pthread_rwlock_wrlock(rwlock: *u8): i32 {
    AcquireSRWLockExclusive(rwlock)
    return 0
}

// SRWLOCK has separate release calls per mode and no way to ask which one is held, so a
// single unlock cannot serve both. std/sync only ever takes these exclusively; a shared
// reader that reached here would corrupt the lock state, which is why this is exclusive.
pub fn pthread_rwlock_unlock(rwlock: *u8): i32 {
    ReleaseSRWLockExclusive(rwlock)
    return 0
}

pub fn pthread_rwlock_destroy(_rwlock: *u8): i32 {
    return 0
}

// The mmap wrappers above translate these into Win32 page-protection flags themselves,
// so the values only need to be distinct — they are not a POSIX ABI here.
pub fn protRead(): i32 {
    return 1
}

pub fn protWrite(): i32 {
    return 2
}

pub fn protNone(): i32 {
    return 0
}

pub fn mapPrivate(): i32 {
    return 2
}

pub fn mapAnon(): i32 {
    return 4096
}

pub fn mapPrivateAnon(): i32 {
    return 4098
}

// ── time ──

// FILETIME counts 100-nanosecond intervals since 1601-01-01 UTC, so converting to a
// POSIX timeval means subtracting the 11644473600-second gap between that epoch and 1970.
pub extern fn GetSystemTimeAsFileTime(ft: *u8): void

pub extern fn Sleep(ms: u32): void

// Fills a POSIX `struct timeval` — two i64s, seconds then microseconds — because that is
// the layout std/time reads back out of the buffer it passes.
pub fn gettimeofday(tv: *u8, _tz: *u8): i32 {
    var ft: i64 = 0
    unsafe {
        GetSystemTimeAsFileTime(ft.addrOf() as *u8)
        let ticks = ft
        let unixTicks = ticks - 116444736000000000
        let slot = tv as *i64
        slot[0] = unixTicks / 10000000
        slot[1] = (unixTicks % 10000000) / 10
    }
    return 0
}

// Sleep() has millisecond resolution, so sub-millisecond requests round up to 1ms rather
// than to 0 — a busy-wait caller asking for 100us should yield, not spin.
pub fn usleep(usec: u32): i32 {
    let ms = (usec as i64) / 1000
    if ms < 1 {
        Sleep(1 as u32)
    } else {
        Sleep(ms as u32)
    }
    return 0
}

// ── pipe ──

// The UCRT's _pipe takes a buffer size and a text/binary mode that POSIX pipe(2) has no
// equivalent for. _O_BINARY (0x8000) is essential: in text mode the CRT would translate
// \n to \r\n through the pipe, corrupting any binary payload and desynchronising any
// caller that counts bytes.
pub extern fn _pipe(fds: *u8, size: u32, mode: i32): i32

pub fn pipe(fds: *u8): i32 {
    return _pipe(fds, 4096 as u32, 32768)
}

// ── fd I/O ──
//
// The UCRT's fd calls are a different SHAPE from POSIX's, not just a different
// spelling: 32-bit count and 32-bit return where POSIX has size_t/ssize_t. The
// oldnames shim does export `read`/`write`, which is why declaring the POSIX widths
// linked cleanly and then miscompiled — Win64 leaves the upper half of RAX undefined
// for an `int` return, so a -1 could arrive as a large positive i64. Bind the real
// `_`-prefixed symbols at their true widths and widen here, once.

@cSig("io.h", "int _read(int, void *, unsigned int)")
pub extern fn _read(fd: i32, buf: *u8, count: u32): i32

@cSig("io.h", "int _write(int, const void *, unsigned int)")
pub extern fn _write(fd: i32, buf: *u8, count: u32): i32

// `open` is the one fd call whose return is `int` on every platform (only the
// byte-count/offset calls diverge), and it is variadic, so a wrapper fn can't forward
// the optional mode. The UCRT oldnames layer exports `open` as an alias for `_open`, so
// declare it directly — no @cSig, since it comes from <io.h> under the `_`-name and the
// header does not declare the POSIX spelling.
pub extern fn open(path: *u8, flags: i32,...): i32

@cSig("io.h", "int _close(int)")
pub extern fn _close(fd: i32): i32

// _lseek is 32-bit (`long`, 4 bytes under LLP64); _lseeki64 is the one that can
// address a file past 2 GB, which is what POSIX lseek's off_t means here.
@cSig("io.h", "__int64 _lseeki64(int, __int64, int)")
pub extern fn _lseeki64(fd: i32, offset: i64, origin: i32): i64

@cSig("io.h", "int _access(const char *, int)")
pub extern fn _access(path: *u8, mode: i32): i32

// A count that doesn't fit in the CRT's 32-bit parameter is clamped, not truncated:
// a short read/write is a contract every caller already handles, whereas truncation
// would silently transfer the low 32 bits of the requested length.
pub fn _clampCount(nbyte: i64): u32 {
    if nbyte > 2147483647 {
        return 2147483647 as u32
    }
    if nbyte < 0 {
        return 0 as u32
    }
    return nbyte as u32
}

pub fn read(fd: i32, buf: *u8, nbyte: i64): i64 {
    return _read(fd, buf, _clampCount(nbyte)) as i64
}

pub fn write(fd: i32, buf: *u8, nbyte: i64): i64 {
    return _write(fd, buf, _clampCount(nbyte)) as i64
}

pub fn close(fd: i32): i32 {
    return _close(fd)
}

pub fn lseek(fd: i32, offset: i64, whence: i32): i64 {
    return _lseeki64(fd, offset, whence)
}

pub fn access(path: *u8, mode: i32): i32 {
    return _access(path, mode)
}

// <process.h>, not <unistd.h>; the oldnames shim exports `getpid` too, but binding the
// real symbol keeps the declaration checkable against the header it actually comes from.
@cSig("process.h", "int _getpid(void)")
pub extern fn _getpid(): i32

pub fn getpid(): i32 {
    return _getpid()
}

// The bit-bucket device. Windows spells it NUL (case-insensitive, no path); the CRT's
// fd layer opens it just like a file.
pub fn devNullPath(): string {
    return "NUL"
}

// ── dynamic loading ──
//
// LoadLibrary/GetProcAddress/FreeLibrary are the same three operations under different
// names, so the typed layer in std/dl works unchanged. `dlerror` is the one that does
// not map: Windows reports failure through GetLastError, which is per-thread state with
// no string form and no read-and-clear semantics. Rather than return null (which std/dl
// would read as "no error" right after a failure), report a fixed message and let the
// caller go to GetLastError for detail.

@cSig("libloaderapi.h", "HMODULE LoadLibraryA(LPCSTR)")
pub extern fn LoadLibraryA(path: *u8): *u8

@cSig("libloaderapi.h", "FARPROC GetProcAddress(HMODULE, LPCSTR)")
pub extern fn GetProcAddress(handle: *u8, name: *u8): *u8

@cSig("libloaderapi.h", "BOOL FreeLibrary(HMODULE)")
pub extern fn FreeLibrary(handle: *u8): i32

// A null path means "the running executable" for dlopen; LoadLibraryA(NULL) fails
// instead, so route that case to GetModuleHandleA(NULL), which is what it means.
@cSig("libloaderapi.h", "HMODULE GetModuleHandleA(LPCSTR)")
pub extern fn GetModuleHandleA(path: *u8): *u8

pub fn dlopen(_path: *u8, _flags: i32): *u8 {
    unsafe {
        if _path as i64 == 0 {
            return GetModuleHandleA(0 as *u8)
        }
        return LoadLibraryA(_path)
    }
}

pub fn dlsym(_handle: *u8, _symbol: *u8): *u8 {
    unsafe {
        return GetProcAddress(_handle, _symbol)
    }
}

// POSIX dlclose returns 0 on success; FreeLibrary returns nonzero on success.
pub fn dlclose(_handle: *u8): i32 {
    unsafe {
        if FreeLibrary(_handle) != 0 {
            return 0
        }
        return -1
    }
}

pub fn dlerror(): *u8 {
    unsafe {
        return "dynamic load failed — call GetLastError for the code" as *u8
    }
}

// ── executable path ──

// GetModuleFileNameA(NULL, ...) writes the running .exe's path. Returns the
// character count, or 0 on failure. Unlike readlink it NUL-terminates, but the
// exePath wrapper zeroes its buffer and terminates at n regardless, so a
// truncating-without-error result (buffer too small on old Windows) still yields
// a valid, if short, string rather than reading past the fill.
@cSig("libloaderapi.h", "DWORD GetModuleFileNameA(HMODULE, LPSTR, DWORD)")
pub extern fn GetModuleFileNameA(module: *u8, buf: *u8, size: u32): u32

pub fn _exePathInto(buf: *u8, bufsize: i64): i64 {
    unsafe {
        let n = GetModuleFileNameA(0 as *u8, buf, bufsize as u32)
        if n == 0 {
            return -1
        }
        return n as i64
    }
}
