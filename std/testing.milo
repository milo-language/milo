// std/testing — test assertion functions

from "std/os" import {
    exit
}

fn testFail(): void {
    exit(1)
}

pub fn assert(cond: bool): void {
    if !cond {
        eprint("  assertion failed")
        testFail()
    }
}

pub fn assertMsg(cond: bool, msg: string): void {
    if !cond {
        eprint($"  assertion failed: {msg}")
        testFail()
    }
}

pub fn assertEqual(got: i32, expected: i32): void {
    if got != expected {
        eprint($"  assertEqual failed: got {got}, expected {expected}")
        testFail()
    }
}

pub fn assertEqual64(got: i64, expected: i64): void {
    if got != expected {
        eprint($"  assertEqual64 failed: got {got}, expected {expected}")
        testFail()
    }
}

pub fn assertStrEqual(got: &string, expected: &string): void {
    if got != expected {
        eprint("  assertStrEqual failed")
        testFail()
    }
}

pub fn assertBool(got: bool, expected: bool): void {
    if got != expected {
        eprint("  assertBool failed")
        testFail()
    }
}
