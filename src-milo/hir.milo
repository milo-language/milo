// Typed HIR — every expression carries its resolved TypeKind.
// Bridges checker output to codegen.
from "src-milo/ast.milo" import {
    Span
}
from "src-milo/checker/types.milo" import {
    TypeKind
}

// -- Expressions --

struct HIRArg {
    expr: Heap<HIRExpr>,
    passByRef: bool,
    refMut: bool,
}

struct HIRStructField {
    name: string,
    value: Heap<HIRExpr>,
}

struct CaptureInfo {
    name: string,
    ty: TypeKind,
    mutable: bool,
}

struct ClosureParam {
    name: string,
    ty: TypeKind,
}

enum HIRExpr {
    IntLit(i64, TypeKind, Option<Span>),
    FloatLit(f64, TypeKind, Option<Span>),
    BoolLit(bool, TypeKind, Option<Span>),
    CharLit(i32, TypeKind, Option<Span>),
    StringLit(string, TypeKind, Option<Span>),
    Ident(string, TypeKind, bool, Option<Span>), // name, type, isMove, span
    BinOp(string, Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    UnaryOp(string, Heap<HIRExpr>, TypeKind, Option<Span>),
    Call(string, Vec<HIRArg>, TypeKind, bool, Option<Span>), // func, args, type, variadic, span
    StructLit(string, Vec<HIRStructField>, TypeKind, Option<Span>),
    FieldAccess(Heap<HIRExpr>, string, TypeKind, Option<Span>),
    ArrayLit(Vec<Heap<HIRExpr>>, TypeKind, Option<Span>),
    ArrayRepeat(Heap<HIRExpr>, i64, TypeKind, Option<Span>),
    IndexAccess(Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, bool, bool, Option<Span>), // obj, idx, type, isMove, isBorrowed
    EnumLit(string, string, Vec<Heap<HIRExpr>>, TypeKind, Option<Span>), // enumName, variant, args, type
    ArrayLen(Heap<HIRExpr>, TypeKind, Option<Span>),
    StringLen(Heap<HIRExpr>, TypeKind, Option<Span>),
    Unwrap(Heap<HIRExpr>, string, TypeKind, Option<Span>), // operand, enumName, type
    Propagate(Heap<HIRExpr>, string, TypeKind, TypeKind, Option<Span>), // operand, enumName, retType, type
    DefaultValue(Heap<HIRExpr>, Heap<HIRExpr>, string, TypeKind, Option<Span>), // operand, default, enumName, type
    Cast(Heap<HIRExpr>, TypeKind, TypeKind, Option<Span>), // operand, targetType, type
    IsCheck(Heap<HIRExpr>, i32, TypeKind, Option<Span>), // operand, tag, type
    HeapCreate(Heap<HIRExpr>, TypeKind, Option<Span>),
    HeapDeref(Heap<HIRExpr>, TypeKind, Option<Span>),
    PtrDeref(Heap<HIRExpr>, TypeKind, Option<Span>),
    VecNew(TypeKind, TypeKind, Option<Span>), // elementType, type
    VecPush(Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    VecPop(Heap<HIRExpr>, TypeKind, Option<Span>),
    VecLen(Heap<HIRExpr>, TypeKind, Option<Span>),
    HashMapNew(TypeKind, TypeKind, TypeKind, Option<Span>), // keyType, valueType, type
    HashMapInsert(Heap<HIRExpr>, Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    HashMapGet(Heap<HIRExpr>, Heap<HIRExpr>, string, TypeKind, Option<Span>), // map, key, optionEnumName, type
    HashMapContains(Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    HashMapRemove(Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    HashMapLen(Heap<HIRExpr>, TypeKind, Option<Span>),
    StringPush(Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    StringSubstr(Heap<HIRExpr>, Heap<HIRExpr>, Heap<HIRExpr>, TypeKind, Option<Span>),
    StringClone(Heap<HIRExpr>, TypeKind, Option<Span>),
    NumberToString(Heap<HIRExpr>, TypeKind, TypeKind, Option<Span>), // value, valueType, type
    Closure(Vec<ClosureParam>, Vec<Heap<HIRStmt>>, Vec<CaptureInfo>, TypeKind, TypeKind, bool, Option<Span>), // params, body, captures, retType, type, isMove
    ClosureCall(Heap<HIRExpr>, Vec<HIRArg>, TypeKind, Option<Span>),
}

// -- Statements --

enum HIRStmt {
    Let(string, TypeKind, Heap<HIRExpr>, bool, Option<Span>), // name, type, value, mutable
    Assign(Heap<HIRExpr>, Heap<HIRExpr>, Option<Span>),
    Return(Option<Heap<HIRExpr>>, TypeKind, Option<Span>), // value, retType
    If(Heap<HIRExpr>, Vec<Heap<HIRStmt>>, Option<Vec<Heap<HIRStmt>>>, Option<Span>),
    While(Heap<HIRExpr>, Vec<Heap<HIRStmt>>, Option<Span>),
    Break(Option<Span>),
    Continue(Option<Span>),
    ExprStmt(Heap<HIRExpr>, Option<Span>),
    Match(Heap<HIRExpr>, Vec<HIRMatchArm>, string, Option<Span>), // subject, arms, enumName
    UnsafeBlock(Vec<Heap<HIRStmt>>, Option<Span>),
    ForRange(string, TypeKind, Heap<HIRExpr>, Heap<HIRExpr>, Vec<Heap<HIRStmt>>, Option<Span>), // varName, varType, start, end, body
    ForEach(string, Option<string>, TypeKind, Option<TypeKind>, Heap<HIRExpr>, string, Vec<Heap<HIRStmt>>, Option<Span>), // varName, varName2, varType, varType2, iterable, iterableKind, body
}

// -- Match arms --

struct HIRMatchArm {
    pattern: HIRPattern,
    body: Vec<Heap<HIRStmt>>,
}

struct PatternBinding {
    name: string,
    ty: TypeKind,
}

enum HIRPattern {
    EnumPattern(string, Vec<PatternBinding>, i32), // variant, bindings, tag
    LiteralPattern(string, string), // value, literalKind ("int"|"float"|"string"|"char"|"bool")
    WildcardPattern,
}

// -- Top-level --

struct HIRParam {
    name: string,
    ty: TypeKind,
    isRef: bool,
    isRefMut: bool,
}

struct HIRFunction {
    name: string,
    params: Vec<HIRParam>,
    retType: TypeKind,
    body: Vec<Heap<HIRStmt>>,
    isExtern: bool,
    isVariadic: bool,
}

struct HIRField {
    name: string,
    ty: TypeKind,
}

struct HIRStruct {
    name: string,
    fields: Vec<HIRField>,
}

struct HIRVariant {
    name: string,
    tag: i32,
    fields: Vec<TypeKind>,
}

struct HIREnum {
    name: string,
    variants: Vec<HIRVariant>,
}

struct HIRModule {
    structs: Vec<HIRStruct>,
    enums: Vec<HIREnum>,
    functions: Vec<HIRFunction>,
    dropImpls: HashMap<string, bool>,
}
