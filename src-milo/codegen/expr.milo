// Expression codegen: literals, binops, unary, calls, field access, enums, casts
from "src-milo/ast.milo" import { Expr, Stmt, Pattern, StructLitField, Span, Param, MiloType }
from "src-milo/codegen/types.milo" import {
    isVecTy, unwrapVec, ensureVecTy, ensureRealloc, genSizeOf,
    isHashMapTy, hashMapKeyTy, hashMapValTy, hmEntryTy, ensureHashMapTy, nextLabel,
    resolveEnumName, resolveFnName, resolveStructName, resolveTyStr, nameHasMonoPrefix, ensureExit, ensureStrtod, ensureStrlen, astTypeStr,
    Cgen, Val, Local, CgFnSig, FieldInfo,
    nextTemp, emit, emitLabel, emitG, llType, isUnsigned, llTypeBytes, intBits,
    unwrapHeap, stripPercent, binOpInt, cmpOpInt, isArithOp, isCmpOp,
    findLocal, hasLocal, genLoad, ensureMalloc, ensureMemcpy,
    lookupFnRet, lookupFieldIndex, lookupFieldType,
    lookupVariantTag, lookupVariantPayload, lookupEnumPayloadSlots
}
from "src-milo/codegen/stmt.milo" import { genClosure, genClosureCall }
from "std/io" import { readFile }
from "src-milo/codegen/strings.milo" import {
    genStringLit, genStringClone, genStringConcat, genStringEq, genStringCmp,
    genIntToString, genFloatToString, genStringIndex, genStringSlice, emitStringLit, genStringPush
}

// -- Struct literal --

// Coarse type category of a literal field expression (no evaluation).
fn exprCategory(e: &Expr): string {
    match e {
        Expr.IntLit(n, s) => { return "int" }
        Expr.CharLit(c, s) => { return "int" }
        Expr.BoolLit(b, s) => { return "int" }
        Expr.FloatLit(f, s) => { return "float" }
        Expr.StringLit(v, s) => { return "str" }
        _ => { return "" }
    }
}

fn llCategory(ll: &string): string {
    if ll == "%String" { return "str" }
    if ll == "double" || ll == "float" { return "float" }
    if ll.len > 0 && ll[0] == 105 { return "int" }
    return ""
}

// A struct literal `Pair { … }` whose base has >1 monomorphization (Pair_i32_i32
// vs Pair_string_i32) picks the candidate whose field categories match the literal
// field values (which the checker already resolved, but the AST keeps the bare name).
fn disambiguateStructLit(cg: &Cgen, base: &string, fields: &Vec<StructLitField>): string {
    var result = base.clone()
    var count = 0
    for k, v in cg.structs {
        if !nameHasMonoPrefix(k, base) { continue }
        var ok = true
        for fi in 0..fields.len {
            let cat = exprCategory(*fields[fi].value)
            if cat.len == 0 { continue }
            let idx = lookupFieldIndex(cg, k, fields[fi].name)
            if idx < 0 { ok = false }
            else {
                let fcat = llCategory(llType(lookupFieldType(cg, k, idx)))
                if fcat.len > 0 && fcat != cat { ok = false }
            }
        }
        if ok { result = k.clone() count = count + 1 }
    }
    if count == 1 { return result }
    return base.clone()
}

fn genStructLit(cg: &mut Cgen, name: &string, fields: &Vec<StructLitField>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: &string): Val {
    // a bare generic name (`Handle` from a monomorphized body) resolves to its
    // sole instantiation (`Handle_Expr`); a concrete struct name passes through.
    var rname = resolveStructName(cg, name)
    // >1 instantiation → resolveStructName returns the bare name; disambiguate by
    // the literal field value categories.
    if rname == name && !cg.structs.contains(name) {
        rname = disambiguateStructLit(cg, name, fields)
    }
    // still ambiguous (Handle<T> — T isn't in the fields) → use the annotation hint
    // (`let h: Handle<i64> = Handle {…}` → Handle_i64).
    if rname == name && !cg.structs.contains(name) && hintTy.len > 0 {
        let h = stripPercent(resolveTyStr(cg, stripPercent(hintTy)))
        if cg.structs.contains(h) && nameHasMonoPrefix(h, name) { rname = h }
    }
    let structTy = "%" + rname.clone()
    let alloc = nextTemp(cg)
    emit(cg, "  " + alloc + " = alloca " + structTy + "\n")
    for fi in 0..fields.len {
        let ef = fields[fi].clone()
        let idx = lookupFieldIndex(cg, rname, ef.name)
        let fty = lookupFieldType(cg, rname, idx)
        let fv = genExpr(cg, *ef.value, locs, sigs, fty)
        let fp = nextTemp(cg)
        emit(cg, "  " + fp + " = getelementptr " + structTy + ", ptr " + alloc + ", i32 0, i32 " + idx.toString() + "\n")
        emit(cg, "  store " + llType(fv.ty) + " " + fv.v + ", ptr " + fp + "\n")
    }
    let loaded = nextTemp(cg)
    emit(cg, "  " + loaded + " = load " + structTy + ", ptr " + alloc + "\n")
    return Val { v: loaded, ty: structTy }
}

// -- Field access --

fn genFieldAccess(cg: &mut Cgen, object: &Expr, field: &string, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let lv = genLvalue(cg, object, locs, sigs)
    let lvTyLl = llType(lv.ty)
    // Built-in: string.len
    if lvTyLl == "%String" && field == "len" {
        let loaded = nextTemp(cg)
        emit(cg, "  " + loaded + " = load %String, ptr " + lv.v + "\n")
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = extractvalue %String " + loaded + ", 1\n")
        return Val { v: lenT, ty: "i64" }
    }
    // Built-in: vec.len (a field, not a method, in the surface syntax)
    if isVecTy(lv.ty) && field == "len" {
        let lenPtr = nextTemp(cg)
        emit(cg, "  " + lenPtr + " = getelementptr %Vec, ptr " + lv.v + ", i32 0, i32 1\n")
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = load i64, ptr " + lenPtr + "\n")
        return Val { v: lenT, ty: "i64" }
    }
    if isHashMapTy(lv.ty) && field == "len" {
        let lenPtr = nextTemp(cg)
        emit(cg, "  " + lenPtr + " = getelementptr %HashMap, ptr " + lv.v + ", i32 0, i32 1\n")
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = load i64, ptr " + lenPtr + "\n")
        return Val { v: lenT, ty: "i64" }
    }
    // resolve a still-generic type (`Handle<Node>` from a monomorphized/closure
    // context) to its mangled struct name before the field lookup.
    let rawName = stripPercent(resolveTyStr(cg, lv.ty))
    let idx = lookupFieldIndex(cg, rawName, field)
    if idx < 0 {
        eprint("codegen: no field '" + field.clone() + "' on " + lv.ty.clone())
        exit(1)
    }
    let fty = lookupFieldType(cg, rawName, idx)
    let ftyLl = llType(fty)
    let structTy = "%" + rawName
    let fp = nextTemp(cg)
    emit(cg, "  " + fp + " = getelementptr " + structTy + ", ptr " + lv.v + ", i32 0, i32 " + idx.toString() + "\n")
    let loaded = nextTemp(cg)
    emit(cg, "  " + loaded + " = load " + ftyLl + ", ptr " + fp + "\n")
    return Val { v: loaded, ty: fty }
}

// -- Enum literal --

fn variantStructTy(payloadTypes: &Vec<string>): string {
    var s = "{ "
    for i in 0..payloadTypes.len {
        if i > 0 { s = s + ", " }
        s = s + llType(payloadTypes[i])
    }
    s = s + " }"
    return s
}

// `Vec.new()` is an empty {data, len, cap}. Its element type is not recoverable
// from the call, so it rides in on the caller's type hint (`var v: Vec<string> =
// Vec.new()`), exactly as the let/var annotation supplies it in the checker.
fn genVecNew(cg: &mut Cgen, hintTy: &string): Val {
    ensureVecTy(cg)
    let a = nextTemp(cg)
    emit(cg, "  " + a + " = insertvalue %Vec undef, ptr null, 0\n")
    let b = nextTemp(cg)
    emit(cg, "  " + b + " = insertvalue %Vec " + a + ", i64 0, 1\n")
    let c = nextTemp(cg)
    emit(cg, "  " + c + " = insertvalue %Vec " + b + ", i64 0, 2\n")
    var ty = hintTy.clone()
    if !isVecTy(ty) { ty = "Vec<i64>" }
    return Val { v: c, ty: ty }
}

// Append to a Vec through its address: growth has to be visible to the caller,
// so this takes the receiver as an lvalue rather than a loaded value.
fn genVecPush(cg: &mut Cgen, addr: &string, vecTy: &string, elemVal: &Val): Val {
    ensureVecTy(cg)
    ensureRealloc(cg)
    // resolve so a still-generic element (Vec<Handle<Node>>) mangles before it
    // reaches genSizeOf, which would otherwise emit an unsized `%Handle<Node>`.
    let elemTy = unwrapVec(resolveTyStr(cg, vecTy))
    let elemLl = llType(elemTy)

    let dPtr = nextTemp(cg)
    emit(cg, "  " + dPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 0\n")
    let lPtr = nextTemp(cg)
    emit(cg, "  " + lPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 1\n")
    let cPtr = nextTemp(cg)
    emit(cg, "  " + cPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 2\n")

    let d = nextTemp(cg)
    emit(cg, "  " + d + " = load ptr, ptr " + dPtr + "\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = load i64, ptr " + lPtr + "\n")
    let cap = nextTemp(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cPtr + "\n")

    let full = nextTemp(cg)
    emit(cg, "  " + full + " = icmp eq i64 " + l + ", " + cap + "\n")
    let growLbl = nextLabel(cg, "vec.grow")
    let storeLbl = nextLabel(cg, "vec.store")
    emit(cg, "  br i1 " + full + ", label %" + growLbl + ", label %" + storeLbl + "\n")

    emit(cg, growLbl + ":\n")
    let isZero = nextTemp(cg)
    emit(cg, "  " + isZero + " = icmp eq i64 " + cap + ", 0\n")
    let dbl = nextTemp(cg)
    emit(cg, "  " + dbl + " = mul i64 " + cap + ", 2\n")
    let newCap = nextTemp(cg)
    emit(cg, "  " + newCap + " = select i1 " + isZero + ", i64 4, i64 " + dbl + "\n")
    let esz = genSizeOf(cg, elemLl)
    let bytes = nextTemp(cg)
    emit(cg, "  " + bytes + " = mul i64 " + newCap + ", " + esz + "\n")
    let nd = nextTemp(cg)
    emit(cg, "  " + nd + " = call ptr @realloc(ptr " + d + ", i64 " + bytes + ")\n")
    emit(cg, "  store ptr " + nd + ", ptr " + dPtr + "\n")
    emit(cg, "  store i64 " + newCap + ", ptr " + cPtr + "\n")
    emit(cg, "  br label %" + storeLbl + "\n")

    emit(cg, storeLbl + ":\n")
    let dd = nextTemp(cg)
    emit(cg, "  " + dd + " = load ptr, ptr " + dPtr + "\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + dd + ", i64 " + l + "\n")
    emit(cg, "  store " + elemLl + " " + elemVal.v.clone() + ", ptr " + slot + "\n")
    let l1 = nextTemp(cg)
    emit(cg, "  " + l1 + " = add i64 " + l + ", 1\n")
    emit(cg, "  store i64 " + l1 + ", ptr " + lPtr + "\n")
    return Val { v: "0", ty: "void" }
}

// insert-at-index: grow if full, shift [idx..len) right one (descending copy so
// overlapping slots don't clobber), store elem at idx, len++.
fn genVecInsert(cg: &mut Cgen, addr: &string, vecTy: &string, idx: &string, elemVal: &Val): Val {
    ensureVecTy(cg)
    ensureRealloc(cg)
    let elemTy = unwrapVec(vecTy)
    let elemLl = llType(elemTy)

    let dPtr = nextTemp(cg)
    emit(cg, "  " + dPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 0\n")
    let lPtr = nextTemp(cg)
    emit(cg, "  " + lPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 1\n")
    let cPtr = nextTemp(cg)
    emit(cg, "  " + cPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 2\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = load i64, ptr " + lPtr + "\n")
    let cap = nextTemp(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cPtr + "\n")

    let full = nextTemp(cg)
    emit(cg, "  " + full + " = icmp eq i64 " + l + ", " + cap + "\n")
    let growLbl = nextLabel(cg, "vins.grow")
    let shiftLbl = nextLabel(cg, "vins.shift")
    emit(cg, "  br i1 " + full + ", label %" + growLbl + ", label %" + shiftLbl + "\n")
    emit(cg, growLbl + ":\n")
    let d0 = nextTemp(cg)
    emit(cg, "  " + d0 + " = load ptr, ptr " + dPtr + "\n")
    let isZero = nextTemp(cg)
    emit(cg, "  " + isZero + " = icmp eq i64 " + cap + ", 0\n")
    let dbl = nextTemp(cg)
    emit(cg, "  " + dbl + " = mul i64 " + cap + ", 2\n")
    let newCap = nextTemp(cg)
    emit(cg, "  " + newCap + " = select i1 " + isZero + ", i64 4, i64 " + dbl + "\n")
    let esz = genSizeOf(cg, elemLl)
    let bytes = nextTemp(cg)
    emit(cg, "  " + bytes + " = mul i64 " + newCap + ", " + esz + "\n")
    let nd = nextTemp(cg)
    emit(cg, "  " + nd + " = call ptr @realloc(ptr " + d0 + ", i64 " + bytes + ")\n")
    emit(cg, "  store ptr " + nd + ", ptr " + dPtr + "\n")
    emit(cg, "  store i64 " + newCap + ", ptr " + cPtr + "\n")
    emit(cg, "  br label %" + shiftLbl + "\n")

    emit(cg, shiftLbl + ":\n")
    let dd = nextTemp(cg)
    emit(cg, "  " + dd + " = load ptr, ptr " + dPtr + "\n")
    let iAddr = nextTemp(cg)
    emit(cg, "  " + iAddr + " = alloca i64\n")
    let lm1 = nextTemp(cg)
    emit(cg, "  " + lm1 + " = sub i64 " + l + ", 1\n")
    emit(cg, "  store i64 " + lm1 + ", ptr " + iAddr + "\n")
    let condLbl = nextLabel(cg, "vins.cond")
    let bodyLbl = nextLabel(cg, "vins.body")
    let doneLbl = nextLabel(cg, "vins.done")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, condLbl + ":\n")
    let i = nextTemp(cg)
    emit(cg, "  " + i + " = load i64, ptr " + iAddr + "\n")
    let ge = nextTemp(cg)
    emit(cg, "  " + ge + " = icmp sge i64 " + i + ", " + idx.clone() + "\n")
    emit(cg, "  br i1 " + ge + ", label %" + bodyLbl + ", label %" + doneLbl + "\n")
    emit(cg, bodyLbl + ":\n")
    let src = nextTemp(cg)
    emit(cg, "  " + src + " = getelementptr " + elemLl + ", ptr " + dd + ", i64 " + i + "\n")
    let ip1 = nextTemp(cg)
    emit(cg, "  " + ip1 + " = add i64 " + i + ", 1\n")
    let dst = nextTemp(cg)
    emit(cg, "  " + dst + " = getelementptr " + elemLl + ", ptr " + dd + ", i64 " + ip1 + "\n")
    let ev = nextTemp(cg)
    emit(cg, "  " + ev + " = load " + elemLl + ", ptr " + src + "\n")
    emit(cg, "  store " + elemLl + " " + ev + ", ptr " + dst + "\n")
    let im1 = nextTemp(cg)
    emit(cg, "  " + im1 + " = sub i64 " + i + ", 1\n")
    emit(cg, "  store i64 " + im1 + ", ptr " + iAddr + "\n")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, doneLbl + ":\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + dd + ", i64 " + idx.clone() + "\n")
    emit(cg, "  store " + elemLl + " " + elemVal.v.clone() + ", ptr " + slot + "\n")
    let l1 = nextTemp(cg)
    emit(cg, "  " + l1 + " = add i64 " + l + ", 1\n")
    emit(cg, "  store i64 " + l1 + ", ptr " + lPtr + "\n")
    return Val { v: "0", ty: "void" }
}

// remove-at-index: load the elem to return, shift [idx+1..len) left one
// (ascending copy, safe since dst<src for a left shift), len--.
fn genVecRemove(cg: &mut Cgen, addr: &string, vecTy: &string, idx: &string): Val {
    ensureVecTy(cg)
    let elemTy = unwrapVec(vecTy)
    let elemLl = llType(elemTy)

    let dPtr = nextTemp(cg)
    emit(cg, "  " + dPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 0\n")
    let lPtr = nextTemp(cg)
    emit(cg, "  " + lPtr + " = getelementptr %Vec, ptr " + addr.clone() + ", i32 0, i32 1\n")
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = load ptr, ptr " + dPtr + "\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = load i64, ptr " + lPtr + "\n")

    let rslot = nextTemp(cg)
    emit(cg, "  " + rslot + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + idx.clone() + "\n")
    let rv = nextTemp(cg)
    emit(cg, "  " + rv + " = load " + elemLl + ", ptr " + rslot + "\n")

    let iAddr = nextTemp(cg)
    emit(cg, "  " + iAddr + " = alloca i64\n")
    emit(cg, "  store i64 " + idx.clone() + ", ptr " + iAddr + "\n")
    let lm1 = nextTemp(cg)
    emit(cg, "  " + lm1 + " = sub i64 " + l + ", 1\n")
    let condLbl = nextLabel(cg, "vrm.cond")
    let bodyLbl = nextLabel(cg, "vrm.body")
    let doneLbl = nextLabel(cg, "vrm.done")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, condLbl + ":\n")
    let i = nextTemp(cg)
    emit(cg, "  " + i + " = load i64, ptr " + iAddr + "\n")
    let lt = nextTemp(cg)
    emit(cg, "  " + lt + " = icmp slt i64 " + i + ", " + lm1 + "\n")
    emit(cg, "  br i1 " + lt + ", label %" + bodyLbl + ", label %" + doneLbl + "\n")
    emit(cg, bodyLbl + ":\n")
    let ip1 = nextTemp(cg)
    emit(cg, "  " + ip1 + " = add i64 " + i + ", 1\n")
    let src = nextTemp(cg)
    emit(cg, "  " + src + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + ip1 + "\n")
    let dst = nextTemp(cg)
    emit(cg, "  " + dst + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + i + "\n")
    let ev = nextTemp(cg)
    emit(cg, "  " + ev + " = load " + elemLl + ", ptr " + src + "\n")
    emit(cg, "  store " + elemLl + " " + ev + ", ptr " + dst + "\n")
    emit(cg, "  store i64 " + ip1 + ", ptr " + iAddr + "\n")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, doneLbl + ":\n")
    emit(cg, "  store i64 " + lm1 + ", ptr " + lPtr + "\n")
    return Val { v: rv, ty: elemTy }
}

// -- HashMap runtime: flat { K, V } entry array, linear scan --

fn genHashMapNew(cg: &mut Cgen, hintTy: &string): Val {
    ensureHashMapTy(cg)
    let a = nextTemp(cg)
    emit(cg, "  " + a + " = insertvalue %HashMap undef, ptr null, 0\n")
    let b = nextTemp(cg)
    emit(cg, "  " + b + " = insertvalue %HashMap " + a + ", i64 0, 1\n")
    let c = nextTemp(cg)
    emit(cg, "  " + c + " = insertvalue %HashMap " + b + ", i64 0, 2\n")
    var ty = hintTy.clone()
    if !isHashMapTy(ty) { ty = "HashMap<i64, i64>" }
    return Val { v: c, ty: ty }
}

// i1 temp that is true when two keys of keyTy compare equal
fn genKeyEq(cg: &mut Cgen, keyTy: &string, a: &string, b: &string): string {
    let keyLl = llType(keyTy)
    if keyLl == "%String" {
        let r = genStringEq(cg, a, b, true)
        return r.v
    }
    let t = nextTemp(cg)
    emit(cg, "  " + t + " = icmp eq " + keyLl + " " + a + ", " + b + "\n")
    return t
}

// Scan loop shared by contains/getOrDefault/remove/insert: walks entries from
// a data ptr + count, jumping to foundLbl with the index in idxAddr on key
// match, or notFoundLbl after the last entry.
fn genHashMapScan(cg: &mut Cgen, entryTy: &string, keyTy: &string, data: &string, count: &string, keyVal: &string, idxAddr: &string, foundLbl: &string, notFoundLbl: &string) {
    let condLbl = nextLabel(cg, "hm.scan.cond")
    let bodyLbl = nextLabel(cg, "hm.scan.body")
    let stepLbl = nextLabel(cg, "hm.scan.step")
    emit(cg, "  store i64 0, ptr " + idxAddr + "\n")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, condLbl + ":\n")
    let i = nextTemp(cg)
    emit(cg, "  " + i + " = load i64, ptr " + idxAddr + "\n")
    let lt = nextTemp(cg)
    emit(cg, "  " + lt + " = icmp slt i64 " + i + ", " + count + "\n")
    emit(cg, "  br i1 " + lt + ", label %" + bodyLbl + ", label %" + notFoundLbl + "\n")
    emit(cg, bodyLbl + ":\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + entryTy + ", ptr " + data + ", i64 " + i + "\n")
    let kp = nextTemp(cg)
    emit(cg, "  " + kp + " = getelementptr " + entryTy + ", ptr " + slot + ", i32 0, i32 0\n")
    let k = nextTemp(cg)
    emit(cg, "  " + k + " = load " + llType(keyTy) + ", ptr " + kp + "\n")
    let eq = genKeyEq(cg, keyTy, k, keyVal)
    emit(cg, "  br i1 " + eq + ", label %" + foundLbl + ", label %" + stepLbl + "\n")
    emit(cg, stepLbl + ":\n")
    let i1t = nextTemp(cg)
    emit(cg, "  " + i1t + " = add i64 " + i + ", 1\n")
    emit(cg, "  store i64 " + i1t + ", ptr " + idxAddr + "\n")
    emit(cg, "  br label %" + condLbl + "\n")
}

// insert through the receiver's address: replace on key match, else append
// (growing the entry array like Vec push).
fn genHashMapInsert(cg: &mut Cgen, addr: &string, mapTy: &string, keyVal: &Val, valVal: &Val): Val {
    ensureHashMapTy(cg)
    ensureRealloc(cg)
    let keyTy = hashMapKeyTy(mapTy)
    let valTy = hashMapValTy(mapTy)
    let entryTy = hmEntryTy(keyTy, valTy)
    let keyLl = llType(keyTy)
    let valLl = llType(valTy)

    let dPtr = nextTemp(cg)
    emit(cg, "  " + dPtr + " = getelementptr %HashMap, ptr " + addr.clone() + ", i32 0, i32 0\n")
    let lPtr = nextTemp(cg)
    emit(cg, "  " + lPtr + " = getelementptr %HashMap, ptr " + addr.clone() + ", i32 0, i32 1\n")
    let cPtr = nextTemp(cg)
    emit(cg, "  " + cPtr + " = getelementptr %HashMap, ptr " + addr.clone() + ", i32 0, i32 2\n")
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = load ptr, ptr " + dPtr + "\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = load i64, ptr " + lPtr + "\n")
    let cap = nextTemp(cg)
    emit(cg, "  " + cap + " = load i64, ptr " + cPtr + "\n")

    let idxAddr = nextTemp(cg)
    emit(cg, "  " + idxAddr + " = alloca i64\n")
    let foundLbl = nextLabel(cg, "hm.ins.found")
    let missLbl = nextLabel(cg, "hm.ins.miss")
    let doneLbl = nextLabel(cg, "hm.ins.done")
    genHashMapScan(cg, entryTy, keyTy, d, l, keyVal.v, idxAddr, foundLbl, missLbl)

    emit(cg, foundLbl + ":\n")
    let fi = nextTemp(cg)
    emit(cg, "  " + fi + " = load i64, ptr " + idxAddr + "\n")
    let fslot = nextTemp(cg)
    emit(cg, "  " + fslot + " = getelementptr " + entryTy + ", ptr " + d + ", i64 " + fi + "\n")
    let fvp = nextTemp(cg)
    emit(cg, "  " + fvp + " = getelementptr " + entryTy + ", ptr " + fslot + ", i32 0, i32 1\n")
    emit(cg, "  store " + valLl + " " + valVal.v + ", ptr " + fvp + "\n")
    emit(cg, "  br label %" + doneLbl + "\n")

    emit(cg, missLbl + ":\n")
    let full = nextTemp(cg)
    emit(cg, "  " + full + " = icmp eq i64 " + l + ", " + cap + "\n")
    let growLbl = nextLabel(cg, "hm.ins.grow")
    let storeLbl = nextLabel(cg, "hm.ins.store")
    emit(cg, "  br i1 " + full + ", label %" + growLbl + ", label %" + storeLbl + "\n")
    emit(cg, growLbl + ":\n")
    let isZero = nextTemp(cg)
    emit(cg, "  " + isZero + " = icmp eq i64 " + cap + ", 0\n")
    let dbl = nextTemp(cg)
    emit(cg, "  " + dbl + " = mul i64 " + cap + ", 2\n")
    let newCap = nextTemp(cg)
    emit(cg, "  " + newCap + " = select i1 " + isZero + ", i64 8, i64 " + dbl + "\n")
    let esz = genSizeOf(cg, entryTy)
    let bytes = nextTemp(cg)
    emit(cg, "  " + bytes + " = mul i64 " + newCap + ", " + esz + "\n")
    let nd = nextTemp(cg)
    emit(cg, "  " + nd + " = call ptr @realloc(ptr " + d + ", i64 " + bytes + ")\n")
    emit(cg, "  store ptr " + nd + ", ptr " + dPtr + "\n")
    emit(cg, "  store i64 " + newCap + ", ptr " + cPtr + "\n")
    emit(cg, "  br label %" + storeLbl + "\n")
    emit(cg, storeLbl + ":\n")
    let dd = nextTemp(cg)
    emit(cg, "  " + dd + " = load ptr, ptr " + dPtr + "\n")
    let nslot = nextTemp(cg)
    emit(cg, "  " + nslot + " = getelementptr " + entryTy + ", ptr " + dd + ", i64 " + l + "\n")
    let nkp = nextTemp(cg)
    emit(cg, "  " + nkp + " = getelementptr " + entryTy + ", ptr " + nslot + ", i32 0, i32 0\n")
    emit(cg, "  store " + keyLl + " " + keyVal.v + ", ptr " + nkp + "\n")
    let nvp = nextTemp(cg)
    emit(cg, "  " + nvp + " = getelementptr " + entryTy + ", ptr " + nslot + ", i32 0, i32 1\n")
    emit(cg, "  store " + valLl + " " + valVal.v + ", ptr " + nvp + "\n")
    let l1 = nextTemp(cg)
    emit(cg, "  " + l1 + " = add i64 " + l + ", 1\n")
    emit(cg, "  store i64 " + l1 + ", ptr " + lPtr + "\n")
    emit(cg, "  br label %" + doneLbl + "\n")
    emit(cg, doneLbl + ":\n")
    return Val { v: "0", ty: "void" }
}

// contains/getOrDefault: read-only scans over a loaded %HashMap value.
fn genHashMapContains(cg: &mut Cgen, obj: &Val, keyVal: &Val): Val {
    ensureHashMapTy(cg)
    let keyTy = hashMapKeyTy(obj.ty)
    let valTy = hashMapValTy(obj.ty)
    let entryTy = hmEntryTy(keyTy, valTy)
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = extractvalue %HashMap " + obj.v + ", 0\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = extractvalue %HashMap " + obj.v + ", 1\n")
    let resAddr = nextTemp(cg)
    emit(cg, "  " + resAddr + " = alloca i1\n")
    emit(cg, "  store i1 0, ptr " + resAddr + "\n")
    let idxAddr = nextTemp(cg)
    emit(cg, "  " + idxAddr + " = alloca i64\n")
    let foundLbl = nextLabel(cg, "hm.has.found")
    let endLbl = nextLabel(cg, "hm.has.end")
    genHashMapScan(cg, entryTy, keyTy, d, l, keyVal.v, idxAddr, foundLbl, endLbl)
    emit(cg, foundLbl + ":\n")
    emit(cg, "  store i1 1, ptr " + resAddr + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load i1, ptr " + resAddr + "\n")
    return Val { v: r, ty: "bool" }
}

// get returns Option_<V> — the checker monomorphizes it, so the enum layout
// is registered by the time this emits.
fn genHashMapGet(cg: &mut Cgen, obj: &Val, keyVal: &Val): Val {
    ensureHashMapTy(cg)
    let keyTy = hashMapKeyTy(obj.ty)
    let valTy = hashMapValTy(obj.ty)
    let entryTy = hmEntryTy(keyTy, valTy)
    let valLl = llType(valTy)
    // Mangle the whole `Option<valTy>` so a nested generic value (Vec<ImplInfo>)
    // resolves to the registered mono enum (Option_Vec_ImplInfo, not the partial
    // Option_Vec<ImplInfo>).
    let optName = stripPercent(resolveTyStr(cg, "Option<" + valTy + ">"))
    let optTy = "%" + optName
    let someTag = lookupVariantTag(cg, optName, "Some")
    let noneTag = lookupVariantTag(cg, optName, "None")
    let resAddr = nextTemp(cg)
    emit(cg, "  " + resAddr + " = alloca " + optTy + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + optTy + ", ptr " + resAddr + ", i32 0, i32 0\n")
    emit(cg, "  store i32 " + noneTag.toString() + ", ptr " + tagPtr + "\n")
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = extractvalue %HashMap " + obj.v + ", 0\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = extractvalue %HashMap " + obj.v + ", 1\n")
    let idxAddr = nextTemp(cg)
    emit(cg, "  " + idxAddr + " = alloca i64\n")
    let foundLbl = nextLabel(cg, "hm.get.found")
    let endLbl = nextLabel(cg, "hm.get.end")
    genHashMapScan(cg, entryTy, keyTy, d, l, keyVal.v, idxAddr, foundLbl, endLbl)
    emit(cg, foundLbl + ":\n")
    let fi = nextTemp(cg)
    emit(cg, "  " + fi + " = load i64, ptr " + idxAddr + "\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + entryTy + ", ptr " + d + ", i64 " + fi + "\n")
    let vp = nextTemp(cg)
    emit(cg, "  " + vp + " = getelementptr " + entryTy + ", ptr " + slot + ", i32 0, i32 1\n")
    let fv = nextTemp(cg)
    emit(cg, "  " + fv + " = load " + valLl + ", ptr " + vp + "\n")
    // DEEP-CLONE the value: a shallow load shares the value's Vec/String/HashMap
    // buffers with the entry still in the map, so dropping the returned Option
    // frees them out from under the map (later gets read freed memory → garbage).
    let fvc = genCloneOfLoaded(cg, fv, valTy)
    emit(cg, "  store i32 " + someTag.toString() + ", ptr " + tagPtr + "\n")
    let payPtr = nextTemp(cg)
    emit(cg, "  " + payPtr + " = getelementptr " + optTy + ", ptr " + resAddr + ", i32 0, i32 1\n")
    let pstructTy = "{ " + valLl + " }"
    let fp = nextTemp(cg)
    emit(cg, "  " + fp + " = getelementptr " + pstructTy + ", ptr " + payPtr + ", i32 0, i32 0\n")
    emit(cg, "  store " + valLl + " " + fvc + ", ptr " + fp + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load " + optTy + ", ptr " + resAddr + "\n")
    return Val { v: r, ty: optName }
}

fn genHashMapGetOrDefault(cg: &mut Cgen, obj: &Val, keyVal: &Val, defVal: &Val): Val {
    ensureHashMapTy(cg)
    let keyTy = hashMapKeyTy(obj.ty)
    let valTy = hashMapValTy(obj.ty)
    let entryTy = hmEntryTy(keyTy, valTy)
    let valLl = llType(valTy)
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = extractvalue %HashMap " + obj.v + ", 0\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = extractvalue %HashMap " + obj.v + ", 1\n")
    let resAddr = nextTemp(cg)
    emit(cg, "  " + resAddr + " = alloca " + valLl + "\n")
    emit(cg, "  store " + valLl + " " + defVal.v + ", ptr " + resAddr + "\n")
    let idxAddr = nextTemp(cg)
    emit(cg, "  " + idxAddr + " = alloca i64\n")
    let foundLbl = nextLabel(cg, "hm.god.found")
    let endLbl = nextLabel(cg, "hm.god.end")
    genHashMapScan(cg, entryTy, keyTy, d, l, keyVal.v, idxAddr, foundLbl, endLbl)
    emit(cg, foundLbl + ":\n")
    let fi = nextTemp(cg)
    emit(cg, "  " + fi + " = load i64, ptr " + idxAddr + "\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + entryTy + ", ptr " + d + ", i64 " + fi + "\n")
    let vp = nextTemp(cg)
    emit(cg, "  " + vp + " = getelementptr " + entryTy + ", ptr " + slot + ", i32 0, i32 1\n")
    let fv = nextTemp(cg)
    emit(cg, "  " + fv + " = load " + valLl + ", ptr " + vp + "\n")
    // deep-clone so the returned value owns its buffers (see genHashMapGet)
    let fvc = genCloneOfLoaded(cg, fv, valTy)
    emit(cg, "  store " + valLl + " " + fvc + ", ptr " + resAddr + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load " + valLl + ", ptr " + resAddr + "\n")
    return Val { v: r, ty: valTy }
}

// remove through the receiver's address: swap the last entry into the hole.
fn genHashMapRemove(cg: &mut Cgen, addr: &string, mapTy: &string, keyVal: &Val): Val {
    ensureHashMapTy(cg)
    let keyTy = hashMapKeyTy(mapTy)
    let valTy = hashMapValTy(mapTy)
    let entryTy = hmEntryTy(keyTy, valTy)
    let dPtr = nextTemp(cg)
    emit(cg, "  " + dPtr + " = getelementptr %HashMap, ptr " + addr.clone() + ", i32 0, i32 0\n")
    let lPtr = nextTemp(cg)
    emit(cg, "  " + lPtr + " = getelementptr %HashMap, ptr " + addr.clone() + ", i32 0, i32 1\n")
    let d = nextTemp(cg)
    emit(cg, "  " + d + " = load ptr, ptr " + dPtr + "\n")
    let l = nextTemp(cg)
    emit(cg, "  " + l + " = load i64, ptr " + lPtr + "\n")
    let resAddr = nextTemp(cg)
    emit(cg, "  " + resAddr + " = alloca i1\n")
    emit(cg, "  store i1 0, ptr " + resAddr + "\n")
    let idxAddr = nextTemp(cg)
    emit(cg, "  " + idxAddr + " = alloca i64\n")
    let foundLbl = nextLabel(cg, "hm.rm.found")
    let endLbl = nextLabel(cg, "hm.rm.end")
    genHashMapScan(cg, entryTy, keyTy, d, l, keyVal.v, idxAddr, foundLbl, endLbl)
    emit(cg, foundLbl + ":\n")
    let fi = nextTemp(cg)
    emit(cg, "  " + fi + " = load i64, ptr " + idxAddr + "\n")
    let last = nextTemp(cg)
    emit(cg, "  " + last + " = sub i64 " + l + ", 1\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + entryTy + ", ptr " + d + ", i64 " + fi + "\n")
    let lastSlot = nextTemp(cg)
    emit(cg, "  " + lastSlot + " = getelementptr " + entryTy + ", ptr " + d + ", i64 " + last + "\n")
    let moved = nextTemp(cg)
    emit(cg, "  " + moved + " = load " + entryTy + ", ptr " + lastSlot + "\n")
    emit(cg, "  store " + entryTy + " " + moved + ", ptr " + slot + "\n")
    emit(cg, "  store i64 " + last + ", ptr " + lPtr + "\n")
    emit(cg, "  store i1 1, ptr " + resAddr + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load i1, ptr " + resAddr + "\n")
    return Val { v: r, ty: "bool" }
}

// Fixed arrays lower onto the Vec runtime (see astTypeStr): a literal is a
// malloc'd buffer with a {ptr, n, n} header.
fn genArrayLit(cg: &mut Cgen, elems: &Vec<Heap<Expr>>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: &string): Val {
    ensureVecTy(cg)
    ensureMalloc(cg)
    var elemTy = "i64"
    var haveTy = false
    if isVecTy(hintTy) {
        elemTy = unwrapVec(hintTy)
        haveTy = true
    }
    var vals: Vec<Val> = Vec.new()
    for i in 0..elems.len {
        var h = ""
        if haveTy { h = elemTy.clone() }
        let v = genExpr(cg, *elems[i], locs, sigs, h)
        if !haveTy {
            elemTy = v.ty.clone()
            haveTy = true
        }
        vals.push(v)
    }
    let elemLl = llType(elemTy)
    let esz = genSizeOf(cg, elemLl)
    let n = elems.len
    let bytes = nextTemp(cg)
    emit(cg, "  " + bytes + " = mul i64 " + n.toString() + ", " + esz + "\n")
    let data = nextTemp(cg)
    emit(cg, "  " + data + " = call ptr @malloc(i64 " + bytes + ")\n")
    for i in 0..vals.len {
        let slot = nextTemp(cg)
        emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + data + ", i64 " + i.toString() + "\n")
        emit(cg, "  store " + elemLl + " " + vals[i].v + ", ptr " + slot + "\n")
    }
    let a = nextTemp(cg)
    emit(cg, "  " + a + " = insertvalue %Vec undef, ptr " + data + ", 0\n")
    let b = nextTemp(cg)
    emit(cg, "  " + b + " = insertvalue %Vec " + a + ", i64 " + n.toString() + ", 1\n")
    let c = nextTemp(cg)
    emit(cg, "  " + c + " = insertvalue %Vec " + b + ", i64 " + n.toString() + ", 2\n")
    return Val { v: c, ty: "Vec<" + elemTy + ">" }
}

// [x; N] — evaluate once, fill N slots with an emitted loop (N can be large).
fn genArrayRepeat(cg: &mut Cgen, value: &Expr, count: i64, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: &string): Val {
    ensureVecTy(cg)
    ensureMalloc(cg)
    var elemTy = "i64"
    var h = ""
    if isVecTy(hintTy) {
        elemTy = unwrapVec(hintTy)
        h = elemTy.clone()
    }
    let v = genExpr(cg, value, locs, sigs, h)
    if !isVecTy(hintTy) { elemTy = v.ty.clone() }
    let elemLl = llType(elemTy)
    let esz = genSizeOf(cg, elemLl)
    let bytes = nextTemp(cg)
    emit(cg, "  " + bytes + " = mul i64 " + count.toString() + ", " + esz + "\n")
    let data = nextTemp(cg)
    emit(cg, "  " + data + " = call ptr @malloc(i64 " + bytes + ")\n")
    let iAddr = nextTemp(cg)
    emit(cg, "  " + iAddr + " = alloca i64\n")
    emit(cg, "  store i64 0, ptr " + iAddr + "\n")
    let condLbl = nextLabel(cg, "arr.fill.cond")
    let bodyLbl = nextLabel(cg, "arr.fill.body")
    let endLbl = nextLabel(cg, "arr.fill.end")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, condLbl + ":\n")
    let cur = nextTemp(cg)
    emit(cg, "  " + cur + " = load i64, ptr " + iAddr + "\n")
    let lt = nextTemp(cg)
    emit(cg, "  " + lt + " = icmp slt i64 " + cur + ", " + count.toString() + "\n")
    emit(cg, "  br i1 " + lt + ", label %" + bodyLbl + ", label %" + endLbl + "\n")
    emit(cg, bodyLbl + ":\n")
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + data + ", i64 " + cur + "\n")
    emit(cg, "  store " + elemLl + " " + v.v + ", ptr " + slot + "\n")
    let inc = nextTemp(cg)
    emit(cg, "  " + inc + " = add i64 " + cur + ", 1\n")
    emit(cg, "  store i64 " + inc + ", ptr " + iAddr + "\n")
    emit(cg, "  br label %" + condLbl + "\n")
    emit(cg, endLbl + ":\n")
    let a = nextTemp(cg)
    emit(cg, "  " + a + " = insertvalue %Vec undef, ptr " + data + ", 0\n")
    let b = nextTemp(cg)
    emit(cg, "  " + b + " = insertvalue %Vec " + a + ", i64 " + count.toString() + ", 1\n")
    let c = nextTemp(cg)
    emit(cg, "  " + c + " = insertvalue %Vec " + b + ", i64 " + count.toString() + ", 2\n")
    return Val { v: c, ty: "Vec<" + elemTy + ">" }
}

// -- ! unwrap and ?? default (M3c) --

// `expr!` on Option_T / Result_T_E: tag 0 (Some/Ok) yields the payload;
// otherwise print the oracle's message shape and exit(1).
fn genUnwrap(cg: &mut Cgen, inner: &Expr, span: &Option<Span>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let v = genExpr(cg, inner, locs, sigs, "")
    let enumName = resolveEnumName(cg, resolveTyStr(cg, stripPercent(v.ty)))
    let enumTy = "%" + enumName
    let someTag = lookupVariantTag(cg, enumName, "Some")
    var okVariant = "Some"
    var failWord = "None"
    if someTag < 0 {
        okVariant = "Ok"
        failWord = "Err"
    }
    let payloadTypes = lookupVariantPayload(cg, enumName, okVariant)
    if payloadTypes.len != 1 {
        eprint("codegen: '!' on non-unwrappable type " + v.ty.clone())
        exit(1)
    }
    let payTy = payloadTypes[0].clone()
    let payLl = llType(payTy)

    var line: i32 = 0
    var col: i32 = 0
    match span {
        Option.Some(s) => {
            line = s.line
            col = s.col
        }
        Option.None => {}
    }

    let addr = nextTemp(cg)
    emit(cg, "  " + addr + " = alloca " + enumTy + "\n")
    emit(cg, "  store " + enumTy + " " + v.v + ", ptr " + addr + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + enumTy + ", ptr " + addr + ", i32 0, i32 0\n")
    let tag = nextTemp(cg)
    emit(cg, "  " + tag + " = load i32, ptr " + tagPtr + "\n")
    let okTag = lookupVariantTag(cg, enumName, okVariant)
    let isOk = nextTemp(cg)
    emit(cg, "  " + isOk + " = icmp eq i32 " + tag + ", " + okTag.toString() + "\n")
    let okLbl = nextLabel(cg, "unwrap.ok")
    let failLbl = nextLabel(cg, "unwrap.fail")
    emit(cg, "  br i1 " + isOk + ", label %" + okLbl + ", label %" + failLbl + "\n")

    emit(cg, failLbl + ":\n")
    if !cg.declaredPrintf {
        emitG(cg, "declare i32 @printf(ptr, ...)\n")
        cg.declaredPrintf = true
    }
    ensureExit(cg)
    // Err(string) prints the error's message, matching the TS panic shape
    var printedErrString = false
    if failWord == "Err" {
        let errPayload = lookupVariantPayload(cg, enumName, "Err")
        if errPayload.len == 1 && llType(errPayload[0]) == "%String" {
            let fmtLbl = emitStringLit(cg, "error at " + line.toString() + ":" + col.toString() + ": %s\n")
            let payPtrE = nextTemp(cg)
            emit(cg, "  " + payPtrE + " = getelementptr " + enumTy + ", ptr " + addr + ", i32 0, i32 1\n")
            let errStr = nextTemp(cg)
            emit(cg, "  " + errStr + " = load %String, ptr " + payPtrE + "\n")
            let errData = nextTemp(cg)
            emit(cg, "  " + errData + " = extractvalue %String " + errStr + ", 0\n")
            let pcall = nextTemp(cg)
            emit(cg, "  " + pcall + " = call i32 (ptr, ...) @printf(ptr " + fmtLbl + ", ptr " + errData + ")\n")
            printedErrString = true
        }
    }
    if !printedErrString {
        let msgLbl = emitStringLit(cg, "error at " + line.toString() + ":" + col.toString() + ": unwrap called on " + failWord + "\n")
        let pcall2 = nextTemp(cg)
        emit(cg, "  " + pcall2 + " = call i32 (ptr, ...) @printf(ptr " + msgLbl + ")\n")
    }
    emit(cg, "  call void @exit(i32 1)\n")
    emit(cg, "  unreachable\n")

    emit(cg, okLbl + ":\n")
    let payPtr = nextTemp(cg)
    emit(cg, "  " + payPtr + " = getelementptr " + enumTy + ", ptr " + addr + ", i32 0, i32 1\n")
    let pstructTy = "{ " + payLl + " }"
    let fp = nextTemp(cg)
    emit(cg, "  " + fp + " = getelementptr " + pstructTy + ", ptr " + payPtr + ", i32 0, i32 0\n")
    let result = nextTemp(cg)
    emit(cg, "  " + result + " = load " + payLl + ", ptr " + fp + "\n")
    return Val { v: result, ty: payTy }
}

// `expr?` (M3d): Ok/Some yields the payload; Err/None returns early with the
// enclosing fn's result type. Same-enum propagation returns the value as-is;
// differing Result enums copy the Err payload when the slot types match
// (auto-From conversions are not ported yet — fail loud instead of silently).
fn genPropagate(cg: &mut Cgen, inner: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let v = genExpr(cg, inner, locs, sigs, "")
    let srcEnum = resolveEnumName(cg, resolveTyStr(cg, stripPercent(v.ty)))
    let srcTy = "%" + srcEnum
    var okVariant = "Some"
    var failVariant = "None"
    if lookupVariantTag(cg, srcEnum, "Some") < 0 {
        okVariant = "Ok"
        failVariant = "Err"
    }
    let payloadTypes = lookupVariantPayload(cg, srcEnum, okVariant)
    if payloadTypes.len != 1 {
        eprint("codegen: '?' on non-propagatable type " + v.ty.clone())
        exit(1)
    }
    let payTy = payloadTypes[0].clone()
    let payLl = llType(payTy)
    let retEnum = resolveEnumName(cg, stripPercent(cg.curRetTy))
    let retTy = "%" + retEnum

    let addr = nextTemp(cg)
    emit(cg, "  " + addr + " = alloca " + srcTy + "\n")
    emit(cg, "  store " + srcTy + " " + v.v + ", ptr " + addr + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + srcTy + ", ptr " + addr + ", i32 0, i32 0\n")
    let tag = nextTemp(cg)
    emit(cg, "  " + tag + " = load i32, ptr " + tagPtr + "\n")
    let okTag = lookupVariantTag(cg, srcEnum, okVariant)
    let isOk = nextTemp(cg)
    emit(cg, "  " + isOk + " = icmp eq i32 " + tag + ", " + okTag.toString() + "\n")
    let okLbl = nextLabel(cg, "prop.ok")
    let errLbl = nextLabel(cg, "prop.err")
    emit(cg, "  br i1 " + isOk + ", label %" + okLbl + ", label %" + errLbl + "\n")

    emit(cg, errLbl + ":\n")
    if srcEnum == retEnum {
        let whole = nextTemp(cg)
        emit(cg, "  " + whole + " = load " + srcTy + ", ptr " + addr + "\n")
        emit(cg, "  ret " + srcTy + " " + whole + "\n")
    } else {
        let retFail = lookupVariantTag(cg, retEnum, failVariant)
        if retFail < 0 {
            eprint("codegen: '?' cannot propagate " + srcEnum.clone() + " into fn returning " + retEnum.clone())
            exit(1)
        }
        let retAddr = nextTemp(cg)
        emit(cg, "  " + retAddr + " = alloca " + retTy + "\n")
        let rTagPtr = nextTemp(cg)
        emit(cg, "  " + rTagPtr + " = getelementptr " + retTy + ", ptr " + retAddr + ", i32 0, i32 0\n")
        emit(cg, "  store i32 " + retFail.toString() + ", ptr " + rTagPtr + "\n")
        if failVariant == "Err" {
            let srcErrTypes = lookupVariantPayload(cg, srcEnum, "Err")
            let retErrTypes = lookupVariantPayload(cg, retEnum, "Err")
            if srcErrTypes.len == 1 && retErrTypes.len == 1 && llType(srcErrTypes[0]) == llType(retErrTypes[0]) {
                let errLl = llType(srcErrTypes[0])
                let sPay = nextTemp(cg)
                emit(cg, "  " + sPay + " = getelementptr " + srcTy + ", ptr " + addr + ", i32 0, i32 1\n")
                let sfp = nextTemp(cg)
                emit(cg, "  " + sfp + " = getelementptr { " + errLl + " }, ptr " + sPay + ", i32 0, i32 0\n")
                let ev = nextTemp(cg)
                emit(cg, "  " + ev + " = load " + errLl + ", ptr " + sfp + "\n")
                let rPay = nextTemp(cg)
                emit(cg, "  " + rPay + " = getelementptr " + retTy + ", ptr " + retAddr + ", i32 0, i32 1\n")
                let rfp = nextTemp(cg)
                emit(cg, "  " + rfp + " = getelementptr { " + errLl + " }, ptr " + rPay + ", i32 0, i32 0\n")
                emit(cg, "  store " + errLl + " " + ev + ", ptr " + rfp + "\n")
            } else {
                eprint("codegen: '?' error conversion (auto-From) not supported: " + srcEnum.clone() + " -> " + retEnum.clone())
                exit(1)
            }
        }
        let rWhole = nextTemp(cg)
        emit(cg, "  " + rWhole + " = load " + retTy + ", ptr " + retAddr + "\n")
        emit(cg, "  ret " + retTy + " " + rWhole + "\n")
    }

    emit(cg, okLbl + ":\n")
    let payPtr = nextTemp(cg)
    emit(cg, "  " + payPtr + " = getelementptr " + srcTy + ", ptr " + addr + ", i32 0, i32 1\n")
    let fp = nextTemp(cg)
    emit(cg, "  " + fp + " = getelementptr { " + payLl + " }, ptr " + payPtr + ", i32 0, i32 0\n")
    let result = nextTemp(cg)
    emit(cg, "  " + result + " = load " + payLl + ", ptr " + fp + "\n")
    return Val { v: result, ty: payTy }
}

// `expr ?? default`: Some/Ok payload, else the default.
fn genDefaultValue(cg: &mut Cgen, inner: &Expr, defaultE: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let v = genExpr(cg, inner, locs, sigs, "")
    let enumName = resolveEnumName(cg, resolveTyStr(cg, stripPercent(v.ty)))
    let enumTy = "%" + enumName
    var okVariant = "Some"
    if lookupVariantTag(cg, enumName, "Some") < 0 { okVariant = "Ok" }
    let payloadTypes = lookupVariantPayload(cg, enumName, okVariant)
    if payloadTypes.len != 1 {
        eprint("codegen: '??' on non-unwrappable type " + v.ty.clone())
        exit(1)
    }
    let payTy = payloadTypes[0].clone()
    let payLl = llType(payTy)
    let addr = nextTemp(cg)
    emit(cg, "  " + addr + " = alloca " + enumTy + "\n")
    emit(cg, "  store " + enumTy + " " + v.v + ", ptr " + addr + "\n")
    let resAddr = nextTemp(cg)
    emit(cg, "  " + resAddr + " = alloca " + payLl + "\n")
    let dv = genExpr(cg, defaultE, locs, sigs, payTy.clone())
    emit(cg, "  store " + payLl + " " + dv.v + ", ptr " + resAddr + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + enumTy + ", ptr " + addr + ", i32 0, i32 0\n")
    let tag = nextTemp(cg)
    emit(cg, "  " + tag + " = load i32, ptr " + tagPtr + "\n")
    let okTag = lookupVariantTag(cg, enumName, okVariant)
    let isOk = nextTemp(cg)
    emit(cg, "  " + isOk + " = icmp eq i32 " + tag + ", " + okTag.toString() + "\n")
    let okLbl = nextLabel(cg, "dflt.some")
    let endLbl = nextLabel(cg, "dflt.end")
    emit(cg, "  br i1 " + isOk + ", label %" + okLbl + ", label %" + endLbl + "\n")
    emit(cg, okLbl + ":\n")
    let payPtr = nextTemp(cg)
    emit(cg, "  " + payPtr + " = getelementptr " + enumTy + ", ptr " + addr + ", i32 0, i32 1\n")
    let pstructTy = "{ " + payLl + " }"
    let fp = nextTemp(cg)
    emit(cg, "  " + fp + " = getelementptr " + pstructTy + ", ptr " + payPtr + ", i32 0, i32 0\n")
    let pv = nextTemp(cg)
    emit(cg, "  " + pv + " = load " + payLl + ", ptr " + fp + "\n")
    emit(cg, "  store " + payLl + " " + pv + ", ptr " + resAddr + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load " + payLl + ", ptr " + resAddr + "\n")
    return Val { v: r, ty: payTy }
}

// `subject is Enum.Variant` → i1 tag equality (no bindings; a boolean test).
fn genIsExpr(cg: &mut Cgen, subject: &Expr, pattern: &Pattern, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let sv = genExpr(cg, subject, locs, sigs, "")
    let svLl = llType(sv.ty)
    let rawName = stripPercent(sv.ty)
    let tag = nextTemp(cg)
    emit(cg, "  " + tag + " = extractvalue " + svLl + " " + sv.v + ", 0\n")
    match pattern {
        Pattern.EnumPattern(enumName, variant, bindings, span) => {
            let vtag = lookupVariantTag(cg, rawName, variant)
            let res = nextTemp(cg)
            emit(cg, "  " + res + " = icmp eq i32 " + tag + ", " + vtag.toString() + "\n")
            return Val { v: res, ty: "bool" }
        }
        _ => {
            return Val { v: "0", ty: "bool" }
        }
    }
}

// Wrap an already-computed value in `Some` for an `Option<T>` param (auto-wrap at
// a call site). rEnum is the mangled option name (e.g. "Option_u16").
// A named fn used as a closure value needs an adapter: the closure ABI calls
// `fn(ptr env, ptr args…)` but the named fn has no env param and takes its args
// directly. Emit (once) a thunk `@__fnthunk_<name>(ptr env, ptr a0, …)` that drops
// env, adapts each arg (ref → pass ptr; value → load), and calls the real fn.
fn ensureFnThunk(cg: &mut Cgen, name: &string, sigs: &Vec<CgFnSig>): string {
    let thunkName = "__fnthunk_" + name.clone()
    for i in 0..cg.emittedThunks.len {
        if cg.emittedThunks[i] == thunkName { return thunkName }
    }
    cg.emittedThunks.push(thunkName.clone())

    var pTys: Vec<string> = Vec.new()
    var pRefs: Vec<bool> = Vec.new()
    var retTy = "void"
    for si in 0..sigs.len {
        if sigs[si].name == name {
            for pi in 0..sigs[si].paramTys.len { pTys.push(sigs[si].paramTys[pi].clone()) }
            for pi in 0..sigs[si].paramRefs.len { pRefs.push(sigs[si].paramRefs[pi]) }
            retTy = sigs[si].retTy.clone()
        }
    }
    let retLl = llType(resolveTyStr(cg, retTy))

    var hdr = "define " + retLl + " @" + thunkName + "(ptr %__env"
    for pi in 0..pTys.len { hdr = hdr + ", ptr %a" + pi.toString() }
    hdr = hdr + ") {\nentry:\n"

    var body = ""
    var callArgs = ""
    var tctr = 0
    for pi in 0..pTys.len {
        if pi > 0 { callArgs = callArgs + ", " }
        var isRef = false
        if pi < pRefs.len { isRef = pRefs[pi] }
        if isRef {
            callArgs = callArgs + "ptr %a" + pi.toString()
        } else {
            let pll = llType(resolveTyStr(cg, pTys[pi]))
            let t = "%tk" + tctr.toString()
            tctr = tctr + 1
            body = body + "  " + t + " = load " + pll + ", ptr %a" + pi.toString() + "\n"
            callArgs = callArgs + pll + " " + t
        }
    }
    if retLl == "void" {
        body = body + "  call void @" + name.clone() + "(" + callArgs + ")\n  ret void\n"
    } else {
        body = body + "  %tkr = call " + retLl + " @" + name.clone() + "(" + callArgs + ")\n  ret " + retLl + " %tkr\n"
    }
    cg.globals = cg.globals + hdr + body + "}\n\n"
    return thunkName
}

fn genWrapSome(cg: &mut Cgen, innerVal: &Val, rEnum: &string): Val {
    let tag = lookupVariantTag(cg, rEnum, "Some")
    let structTy = "%" + rEnum.clone()
    let alloc = nextTemp(cg)
    emit(cg, "  " + alloc + " = alloca " + structTy + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + structTy + ", ptr " + alloc + ", i32 0, i32 0\n")
    emit(cg, "  store i32 " + tag.toString() + ", ptr " + tagPtr + "\n")
    let payloadTypes = lookupVariantPayload(cg, rEnum, "Some")
    if payloadTypes.len > 0 {
        let payPtr = nextTemp(cg)
        emit(cg, "  " + payPtr + " = getelementptr " + structTy + ", ptr " + alloc + ", i32 0, i32 1\n")
        let vstructTy = variantStructTy(payloadTypes)
        let ftyLl = llType(payloadTypes[0])
        let fp = nextTemp(cg)
        emit(cg, "  " + fp + " = getelementptr " + vstructTy + ", ptr " + payPtr + ", i32 0, i32 0\n")
        var storeVal = innerVal.v.clone()
        let fvLl = llType(innerVal.ty)
        if fvLl != ftyLl && intBits(fvLl) > 0 && intBits(ftyLl) > 0 {
            let w = nextTemp(cg)
            if intBits(fvLl) > intBits(ftyLl) {
                emit(cg, "  " + w + " = trunc " + fvLl + " " + innerVal.v + " to " + ftyLl + "\n")
            } else {
                var ext = "sext"
                if isUnsigned(innerVal.ty) { ext = "zext" }
                emit(cg, "  " + w + " = " + ext + " " + fvLl + " " + innerVal.v + " to " + ftyLl + "\n")
            }
            storeVal = w
        }
        emit(cg, "  store " + ftyLl + " " + storeVal + ", ptr " + fp + "\n")
    }
    let loaded = nextTemp(cg)
    emit(cg, "  " + loaded + " = load " + structTy + ", ptr " + alloc + "\n")
    return Val { v: loaded, ty: rEnum.clone() }
}

// x.checkedAdd/Sub/Mul(y) → Option<T> via an LLVM overflow intrinsic: Some(result)
// on no overflow, None otherwise.
fn genCheckedArith(cg: &mut Cgen, obj: &Val, method: &string, av: &Val): Val {
    let lt = llType(obj.ty)
    var op = "add"
    if method == "checkedSub" { op = "sub" }
    if method == "checkedMul" { op = "mul" }
    var pfx = "s"
    if isUnsigned(obj.ty) { pfx = "u" }
    let intr = "llvm." + pfx + op + ".with.overflow." + lt
    var declared = false
    for i in 0..cg.emittedThunks.len { if cg.emittedThunks[i] == intr { declared = true } }
    if !declared {
        cg.emittedThunks.push(intr.clone())
        emitG(cg, "declare {" + lt + ", i1} @" + intr + "(" + lt + ", " + lt + ")\n")
    }
    let cr = nextTemp(cg)
    emit(cg, "  " + cr + " = call {" + lt + ", i1} @" + intr + "(" + lt + " " + obj.v + ", " + lt + " " + av.v + ")\n")
    let val = nextTemp(cg)
    emit(cg, "  " + val + " = extractvalue {" + lt + ", i1} " + cr + ", 0\n")
    let flag = nextTemp(cg)
    emit(cg, "  " + flag + " = extractvalue {" + lt + ", i1} " + cr + ", 1\n")
    let optName = "Option_" + obj.ty.clone()
    let optTy = "%" + optName.clone()
    let slot = nextTemp(cg)
    emit(cg, "  " + slot + " = alloca " + optTy + "\n")
    let okLbl = nextLabel(cg, "chk.ok")
    let ovLbl = nextLabel(cg, "chk.ov")
    let doneLbl = nextLabel(cg, "chk.done")
    emit(cg, "  br i1 " + flag + ", label %" + ovLbl + ", label %" + okLbl + "\n")
    emitLabel(cg, okLbl)
    let someV = genWrapSome(cg, Val { v: val, ty: obj.ty.clone() }, optName)
    emit(cg, "  store " + optTy + " " + someV.v + ", ptr " + slot + "\n")
    emit(cg, "  br label %" + doneLbl + "\n")
    emitLabel(cg, ovLbl)
    let noneTag = lookupVariantTag(cg, optName, "None")
    let tp = nextTemp(cg)
    emit(cg, "  " + tp + " = getelementptr " + optTy + ", ptr " + slot + ", i32 0, i32 0\n")
    emit(cg, "  store i32 " + noneTag.toString() + ", ptr " + tp + "\n")
    emit(cg, "  br label %" + doneLbl + "\n")
    emitLabel(cg, doneLbl)
    let r = nextTemp(cg)
    emit(cg, "  " + r + " = load " + optTy + ", ptr " + slot + "\n")
    return Val { v: r, ty: optName }
}

fn genEnumLit(cg: &mut Cgen, enumName: &string, variant: &string, args: &Vec<Heap<Expr>>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: &string): Val {
    // Generic enums are registered under their mangled name
    var rEnum = resolveEnumName(cg, enumName)
    var tag = lookupVariantTag(cg, rEnum, variant)
    // A generic enum literal (`Result.Ok(x)`) can't pick its instantiation from
    // the base name alone when several exist; the expected type supplies it.
    if tag < 0 && hintTy.len > 0 {
        let he = stripPercent(resolveTyStr(cg, stripPercent(hintTy)))
        if he.startsWith(enumName + "_") && lookupVariantTag(cg, he, variant) >= 0 {
            rEnum = he.clone()
            tag = lookupVariantTag(cg, he, variant)
        }
    }
    // `Type.method(...)` with no matching variant is a static method on a struct
    // (e.g. File.openRead) — the parser lands both on the enum-literal form. It is
    // registered as `Type$method`; route it to the plain call path.
    if tag < 0 {
        var emptyTA: Vec<MiloType> = Vec.new()
        return genCall(cg, rEnum + "$" + variant, args, emptyTA, locs, sigs, "")
    }
    let structTy = "%" + rEnum
    let alloc = nextTemp(cg)
    emit(cg, "  " + alloc + " = alloca " + structTy + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + structTy + ", ptr " + alloc + ", i32 0, i32 0\n")
    emit(cg, "  store i32 " + tag.toString() + ", ptr " + tagPtr + "\n")
    let payloadTypes = lookupVariantPayload(cg, rEnum, variant)
    if args.len > 0 && payloadTypes.len > 0 {
        let payPtr = nextTemp(cg)
        emit(cg, "  " + payPtr + " = getelementptr " + structTy + ", ptr " + alloc + ", i32 0, i32 1\n")
        let vstructTy = variantStructTy(payloadTypes)
        for fi in 0..args.len {
            let ftyLl = llType(payloadTypes[fi])
            let fp = nextTemp(cg)
            emit(cg, "  " + fp + " = getelementptr " + vstructTy + ", ptr " + payPtr + ", i32 0, i32 " + fi.toString() + "\n")
            let fv = genExpr(cg, *args[fi], locs, sigs, payloadTypes[fi].clone())
            // Reconcile integer width: a payload slot of u32 fed an i64 value
            // (e.g. Result.Ok(someI64) where Ok holds u32) must trunc, or clang
            // rejects `store i32 <i64>`.
            var storeVal = fv.v.clone()
            let fvLl = llType(fv.ty)
            if fvLl != ftyLl && intBits(fvLl) > 0 && intBits(ftyLl) > 0 {
                let w = nextTemp(cg)
                if intBits(fvLl) > intBits(ftyLl) {
                    emit(cg, "  " + w + " = trunc " + fvLl + " " + fv.v + " to " + ftyLl + "\n")
                } else {
                    var ext = "sext"
                    if isUnsigned(fv.ty) { ext = "zext" }
                    emit(cg, "  " + w + " = " + ext + " " + fvLl + " " + fv.v + " to " + ftyLl + "\n")
                }
                storeVal = w
            }
            emit(cg, "  store " + ftyLl + " " + storeVal + ", ptr " + fp + "\n")
        }
    }
    let loaded = nextTemp(cg)
    emit(cg, "  " + loaded + " = load " + structTy + ", ptr " + alloc + "\n")
    return Val { v: loaded, ty: structTy }
}

// -- Cast --

fn genAsCast(cg: &mut Cgen, inner: &Expr, targetTy: &string, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    // A bare fn name cast to a raw pointer (`_osThreadTrampoline as *u8`) is the
    // fn's own address, NOT a closure thunk — pass @name directly.
    let toPtr = (targetTy.len > 0 && targetTy[0] == 42) || llType(targetTy) == "ptr"
    if toPtr {
        match inner {
            Expr.Ident(nm, isp) => {
                if !hasLocal(locs, nm) && cg.fnRets.contains(nm) {
                    return Val { v: "@" + nm.clone(), ty: targetTy.clone() }
                }
            }
            _ => {}
        }
    }
    let v = genExpr(cg, inner, locs, sigs, targetTy.clone())
    let fromLl = llType(v.ty)
    let toLl = llType(targetTy)
    // Pointer target (`x as *T`, or a bare `ptr`): the value is an opaque `ptr`,
    // but carry the SURFACE `*T` so index/index-assign can recover element type T.
    let toIsPtr = (targetTy.len > 0 && targetTy[0] == 42) || toLl == "ptr"
    if toIsPtr {
        // Vec/String decay to their data pointer (field 0), not the whole header.
        if fromLl == "%Vec" || fromLl == "%String" {
            let d = nextTemp(cg)
            emit(cg, "  " + d + " = extractvalue " + fromLl + " " + v.v + ", 0\n")
            return Val { v: d, ty: targetTy.clone() }
        }
        // a closure/fn value cast to a raw pointer yields its fnptr (field 0).
        if fromLl == "%Closure" {
            let d = nextTemp(cg)
            emit(cg, "  " + d + " = extractvalue %Closure " + v.v + ", 0\n")
            return Val { v: d, ty: targetTy.clone() }
        }
        if fromLl == "ptr" || intBits(fromLl) == 0 {
            return Val { v: v.v, ty: targetTy.clone() }
        }
        var src = v.v.clone()
        if intBits(fromLl) < 64 {
            let ext = nextTemp(cg)
            let op = if isUnsigned(v.ty) { "zext" } else { "sext" }
            emit(cg, "  " + ext + " = " + op + " " + fromLl + " " + src + " to i64\n")
            src = ext
        }
        let ip = nextTemp(cg)
        emit(cg, "  " + ip + " = inttoptr i64 " + src + " to ptr\n")
        return Val { v: ip, ty: targetTy.clone() }
    }
    if fromLl == toLl { return v }
    let fromBits = intBits(fromLl)
    let toBits = intBits(toLl)
    // ptr <-> int needs ptrtoint/inttoptr, not bitcast. intBits("ptr") is 64, so
    // without this `p as i64` lands in the equal-width bitcast branch below and
    // clang rejects it.
    if fromLl == "ptr" && toBits > 0 {
        let pi = nextTemp(cg)
        emit(cg, "  " + pi + " = ptrtoint ptr " + v.v + " to i64\n")
        if toBits == 64 {
            return Val { v: pi, ty: toLl }
        }
        let tr = nextTemp(cg)
        emit(cg, "  " + tr + " = trunc i64 " + pi + " to " + toLl + "\n")
        return Val { v: tr, ty: toLl }
    }
    if toLl == "ptr" && fromBits > 0 {
        var src = v.v.clone()
        if fromBits < 64 {
            let ext = nextTemp(cg)
            let op = if isUnsigned(v.ty) { "zext" } else { "sext" }
            emit(cg, "  " + ext + " = " + op + " " + fromLl + " " + src + " to i64\n")
            src = ext
        }
        let ip = nextTemp(cg)
        emit(cg, "  " + ip + " = inttoptr i64 " + src + " to ptr\n")
        return Val { v: ip, ty: "ptr" }
    }
    // int <-> float and float <-> float need real conversion ops, not a relabel.
    let fromIsFloat = fromLl == "double" || fromLl == "float"
    let toIsFloat = toLl == "double" || toLl == "float"
    if fromBits > 0 && toIsFloat {
        let cf = nextTemp(cg)
        var op = "sitofp"
        if isUnsigned(v.ty) { op = "uitofp" }
        emit(cg, "  " + cf + " = " + op + " " + fromLl + " " + v.v + " to " + toLl + "\n")
        return Val { v: cf, ty: toLl }
    }
    if fromIsFloat && toBits > 0 {
        let ci = nextTemp(cg)
        var op = "fptosi"
        if isUnsigned(targetTy) { op = "fptoui" }
        emit(cg, "  " + ci + " = " + op + " " + fromLl + " " + v.v + " to " + toLl + "\n")
        return Val { v: ci, ty: toLl }
    }
    if fromIsFloat && toIsFloat {
        let cff = nextTemp(cg)
        var op = "fpext"
        if fromLl == "double" && toLl == "float" { op = "fptrunc" }
        emit(cg, "  " + cff + " = " + op + " " + fromLl + " " + v.v + " to " + toLl + "\n")
        return Val { v: cff, ty: toLl }
    }
    if fromBits == 0 || toBits == 0 {
        return Val { v: v.v, ty: toLl }
    }
    let t = nextTemp(cg)
    if toBits < fromBits {
        emit(cg, "  " + t + " = trunc " + fromLl + " " + v.v + " to " + toLl + "\n")
    } else if toBits > fromBits {
        let op = if isUnsigned(v.ty) { "zext" } else { "sext" }
        emit(cg, "  " + t + " = " + op + " " + fromLl + " " + v.v + " to " + toLl + "\n")
    } else {
        emit(cg, "  " + t + " = bitcast " + fromLl + " " + v.v + " to " + toLl + "\n")
    }
    return Val { v: t, ty: toLl }
}

// -- Heap deref --

fn genHeapDeref(cg: &mut Cgen, inner: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let v = genExpr(cg, inner, locs, sigs, "")
    var innerRaw = unwrapHeap(v.ty)
    if innerRaw.len == 0 { innerRaw = "i64" }
    let innerLl = llType(innerRaw)
    let loaded = nextTemp(cg)
    emit(cg, "  " + loaded + " = load " + innerLl + ", ptr " + v.v + "\n")
    return Val { v: loaded, ty: innerLl }
}

// -- Method calls --

// In-place two-pointer reverse of a Vec, swapping element-sized blocks via
// memcpy — mirrors the TS oracle's genVecReverse.
fn genVecReverse(cg: &mut Cgen, addr: &string, vecTy: &string): Val {
    ensureMemcpy(cg)
    let elemLl = llType(unwrapVec(vecTy))
    let elemSz = genSizeOf(cg, elemLl)
    let dataPtr = nextTemp(cg)
    emit(cg, "  " + dataPtr + " = getelementptr %Vec, ptr " + addr + ", i32 0, i32 0\n")
    let data = nextTemp(cg)
    emit(cg, "  " + data + " = load ptr, ptr " + dataPtr + "\n")
    let lenPtr = nextTemp(cg)
    emit(cg, "  " + lenPtr + " = getelementptr %Vec, ptr " + addr + ", i32 0, i32 1\n")
    let len = nextTemp(cg)
    emit(cg, "  " + len + " = load i64, ptr " + lenPtr + "\n")
    let tmp = nextTemp(cg)
    emit(cg, "  " + tmp + " = alloca " + elemLl + "\n")
    let loA = nextTemp(cg)
    emit(cg, "  " + loA + " = alloca i64\n")
    emit(cg, "  store i64 0, ptr " + loA + "\n")
    let hiA = nextTemp(cg)
    emit(cg, "  " + hiA + " = alloca i64\n")
    let hiInit = nextTemp(cg)
    emit(cg, "  " + hiInit + " = sub i64 " + len + ", 1\n")
    emit(cg, "  store i64 " + hiInit + ", ptr " + hiA + "\n")
    let condL = nextLabel(cg, "rev.cond")
    let bodyL = nextLabel(cg, "rev.body")
    let endL = nextLabel(cg, "rev.end")
    emit(cg, "  br label %" + condL + "\n")
    emit(cg, condL + ":\n")
    let lo = nextTemp(cg)
    emit(cg, "  " + lo + " = load i64, ptr " + loA + "\n")
    let hi = nextTemp(cg)
    emit(cg, "  " + hi + " = load i64, ptr " + hiA + "\n")
    let cmp = nextTemp(cg)
    emit(cg, "  " + cmp + " = icmp slt i64 " + lo + ", " + hi + "\n")
    emit(cg, "  br i1 " + cmp + ", label %" + bodyL + ", label %" + endL + "\n")
    emit(cg, bodyL + ":\n")
    let loP = nextTemp(cg)
    emit(cg, "  " + loP + " = getelementptr " + elemLl + ", ptr " + data + ", i64 " + lo + "\n")
    let hiP = nextTemp(cg)
    emit(cg, "  " + hiP + " = getelementptr " + elemLl + ", ptr " + data + ", i64 " + hi + "\n")
    emit(cg, "  call ptr @memcpy(ptr " + tmp + ", ptr " + loP + ", i64 " + elemSz + ")\n")
    emit(cg, "  call ptr @memcpy(ptr " + loP + ", ptr " + hiP + ", i64 " + elemSz + ")\n")
    emit(cg, "  call ptr @memcpy(ptr " + hiP + ", ptr " + tmp + ", i64 " + elemSz + ")\n")
    let nlo = nextTemp(cg)
    emit(cg, "  " + nlo + " = add i64 " + lo + ", 1\n")
    emit(cg, "  store i64 " + nlo + ", ptr " + loA + "\n")
    let nhi = nextTemp(cg)
    emit(cg, "  " + nhi + " = sub i64 " + hi + ", 1\n")
    emit(cg, "  store i64 " + nhi + ", ptr " + hiA + "\n")
    emit(cg, "  br label %" + condL + "\n")
    emit(cg, endL + ":\n")
    return Val { v: "0", ty: "void" }
}

// Clone a loaded value of surface type `ty` (already in register `v`), returning
// the cloned register. Strings deep-copy; types with an `impl Clone` route to
// their `Ty$..$clone` helper; Heap boxes recurse; Copy types pass through.
fn genCloneOfLoaded(cg: &mut Cgen, v: &string, ty: &string): string {
    let ll = llType(ty)
    if ll == "%String" {
        return genStringClone(cg, v).v
    }
    // find an impl-Clone helper Ty$..$clone for this type
    let rec = stripPercent(resolveTyStr(cg, stripPercent(ty)))
    var cloneFn = ""
    for k, kv in cg.fnRets {
        if k.startsWith(rec + "$") && k.endsWith("$clone") {
            cloneFn = k.clone()
        }
    }
    if cloneFn.len > 0 {
        // impl-Clone methods take `self: &Self` → a ptr, so materialize v to a
        // temp and pass its address (not the value).
        let slot = nextTemp(cg)
        emit(cg, "  " + slot + " = alloca " + ll + "\n")
        emit(cg, "  store " + ll + " " + v + ", ptr " + slot + "\n")
        let t = nextTemp(cg)
        emit(cg, "  " + t + " = call " + ll + " @" + cloneFn + "(ptr " + slot + ")\n")
        return t
    }
    // Copy (ints/bool/ptr) or no clone helper: value copy is a faithful clone
    return v.clone()
}

// `h.clone()` for h: Heap<T> is a deref-and-clone: the checker types it as T
// (not Heap<T>), so return the cloned pointee VALUE, not a re-boxed pointer.
fn genHeapClone(cg: &mut Cgen, boxPtr: &string, heapTy: &string): Val {
    let inner = unwrapHeap(heapTy)
    let innerLl = llType(inner)
    let p = nextTemp(cg)
    emit(cg, "  " + p + " = load " + innerLl + ", ptr " + boxPtr + "\n")
    let cloned = genCloneOfLoaded(cg, p, inner)
    return Val { v: cloned, ty: inner }
}

// Vec.pop: panic if empty, else len-- and return the (former) last element.
fn genVecPop(cg: &mut Cgen, addr: &string, vecTy: &string): Val {
    let elemTy = unwrapVec(vecTy)
    let elemLl = llType(elemTy)
    let lenPtr = nextTemp(cg)
    emit(cg, "  " + lenPtr + " = getelementptr %Vec, ptr " + addr + ", i32 0, i32 1\n")
    let len = nextTemp(cg)
    emit(cg, "  " + len + " = load i64, ptr " + lenPtr + "\n")
    let isEmpty = nextTemp(cg)
    emit(cg, "  " + isEmpty + " = icmp eq i64 " + len + ", 0\n")
    let panicLbl = nextLabel(cg, "pop.panic")
    let okLbl = nextLabel(cg, "pop.ok")
    emit(cg, "  br i1 " + isEmpty + ", label %" + panicLbl + ", label %" + okLbl + "\n")
    emit(cg, panicLbl + ":\n")
    if !cg.declaredPrintf {
        emitG(cg, "declare i32 @printf(ptr, ...)\n")
        cg.declaredPrintf = true
    }
    ensureExit(cg)
    let msgLbl = emitStringLit(cg, "pop on empty Vec\\n")
    let pcall = nextTemp(cg)
    emit(cg, "  " + pcall + " = call i32 (ptr, ...) @printf(ptr " + msgLbl + ")\n")
    emit(cg, "  call void @exit(i32 1)\n")
    emit(cg, "  unreachable\n")
    emit(cg, okLbl + ":\n")
    let newLen = nextTemp(cg)
    emit(cg, "  " + newLen + " = sub i64 " + len + ", 1\n")
    emit(cg, "  store i64 " + newLen + ", ptr " + lenPtr + "\n")
    let dataPtr = nextTemp(cg)
    emit(cg, "  " + dataPtr + " = getelementptr %Vec, ptr " + addr + ", i32 0, i32 0\n")
    let data = nextTemp(cg)
    emit(cg, "  " + data + " = load ptr, ptr " + dataPtr + "\n")
    let elemPtr = nextTemp(cg)
    emit(cg, "  " + elemPtr + " = getelementptr " + elemLl + ", ptr " + data + ", i64 " + newLen + "\n")
    let val = nextTemp(cg)
    emit(cg, "  " + val + " = load " + elemLl + ", ptr " + elemPtr + "\n")
    return Val { v: val, ty: elemTy }
}

fn genMethodCall(cg: &mut Cgen, object: &Expr, method: &string, args: &Vec<Heap<Expr>>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    // `push` grows the receiver in place, so it needs the address, not a loaded
    // copy. Resolve the lvalue before evaluating the object as a value.
    if method == "push" {
        let lv = genLvalue(cg, object, locs, sigs)
        if isVecTy(lv.ty) {
            let elemTy = unwrapVec(lv.ty)
            let ev = genExpr(cg, *args[0], locs, sigs, elemTy)
            return genVecPush(cg, lv.v, lv.ty, ev)
        }
        if llType(lv.ty) == "%String" {
            let ev = genExpr(cg, *args[0], locs, sigs, "u8")
            // The byte slot is i8; a wider value (e.g. a byte built via i64 bit-ops)
            // must be truncated or clang rejects `store i8 <i64>`.
            var bv = ev.v.clone()
            let evLl = llType(ev.ty)
            if evLl != "i8" && intBits(evLl) > 8 {
                let tb = nextTemp(cg)
                emit(cg, "  " + tb + " = trunc " + evLl + " " + ev.v + " to i8\n")
                bv = tb
            }
            return genStringPush(cg, lv.v, bv)
        }
    }
    // Vec.reverse mutates in place → needs the receiver address. (String.reverse
    // is a different method — it falls through to the strReverse mapping below.)
    if method == "reverse" {
        let lv = genLvalue(cg, object, locs, sigs)
        if isVecTy(lv.ty) {
            return genVecReverse(cg, lv.v, lv.ty)
        }
    }
    // Vec.pop shrinks the receiver in place → needs its address.
    if method == "pop" {
        let lv = genLvalue(cg, object, locs, sigs)
        if isVecTy(lv.ty) {
            return genVecPop(cg, lv.v, lv.ty)
        }
    }
    // insert/remove mutate the receiver in place → need its address, not a copy.
    if method == "insert" || method == "remove" {
        let lv = genLvalue(cg, object, locs, sigs)
        if method == "insert" && isVecTy(lv.ty) {
            let iv = genExpr(cg, *args[0], locs, sigs, "i64")
            var iw = iv.v.clone()
            if llType(iv.ty) != "i64" {
                let ti = nextTemp(cg)
                emit(cg, "  " + ti + " = sext " + llType(iv.ty) + " " + iv.v + " to i64\n")
                iw = ti
            }
            let elemTy = unwrapVec(lv.ty)
            let ev = genExpr(cg, *args[1], locs, sigs, elemTy)
            return genVecInsert(cg, lv.v, lv.ty, iw, ev)
        }
        if method == "remove" && isVecTy(lv.ty) {
            let iv = genExpr(cg, *args[0], locs, sigs, "i64")
            var iw = iv.v.clone()
            if llType(iv.ty) != "i64" {
                let ti = nextTemp(cg)
                emit(cg, "  " + ti + " = sext " + llType(iv.ty) + " " + iv.v + " to i64\n")
                iw = ti
            }
            return genVecRemove(cg, lv.v, lv.ty, iw)
        }
        if isHashMapTy(lv.ty) {
            let keyTy = hashMapKeyTy(lv.ty)
            let kv = genExpr(cg, *args[0], locs, sigs, keyTy)
            if method == "insert" {
                let valTy = hashMapValTy(lv.ty)
                let vv = genExpr(cg, *args[1], locs, sigs, valTy)
                return genHashMapInsert(cg, lv.v, lv.ty, kv, vv)
            }
            return genHashMapRemove(cg, lv.v, lv.ty, kv)
        }
    }
    // `.each(fn)` — call the closure once per element, passing the element address
    // (uniform closure ABI: env + by-ptr arg).
    if method == "each" {
        let ov = genExpr(cg, object, locs, sigs, "")
        if isVecTy(ov.ty) {
            let elemLl = llType(unwrapVec(resolveTyStr(cg, ov.ty)))
            let clv = genExpr(cg, *args[0], locs, sigs, "")
            let d = nextTemp(cg)
            emit(cg, "  " + d + " = extractvalue %Vec " + ov.v + ", 0\n")
            let len = nextTemp(cg)
            emit(cg, "  " + len + " = extractvalue %Vec " + ov.v + ", 1\n")
            let fp = nextTemp(cg)
            emit(cg, "  " + fp + " = extractvalue %Closure " + clv.v + ", 0\n")
            let env = nextTemp(cg)
            emit(cg, "  " + env + " = extractvalue %Closure " + clv.v + ", 1\n")
            let iAddr = nextTemp(cg)
            emit(cg, "  " + iAddr + " = alloca i64\n")
            emit(cg, "  store i64 0, ptr " + iAddr + "\n")
            let condLbl = nextLabel(cg, "each.cond")
            let bodyLbl = nextLabel(cg, "each.body")
            let endLbl = nextLabel(cg, "each.end")
            emit(cg, "  br label %" + condLbl + "\n")
            emitLabel(cg, condLbl)
            let i = nextTemp(cg)
            emit(cg, "  " + i + " = load i64, ptr " + iAddr + "\n")
            let lt = nextTemp(cg)
            emit(cg, "  " + lt + " = icmp slt i64 " + i + ", " + len + "\n")
            emit(cg, "  br i1 " + lt + ", label %" + bodyLbl + ", label %" + endLbl + "\n")
            emitLabel(cg, bodyLbl)
            let slot = nextTemp(cg)
            emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + i + "\n")
            emit(cg, "  call void " + fp + "(ptr " + env + ", ptr " + slot + ")\n")
            let i1 = nextTemp(cg)
            emit(cg, "  " + i1 + " = add i64 " + i + ", 1\n")
            emit(cg, "  store i64 " + i1 + ", ptr " + iAddr + "\n")
            emit(cg, "  br label %" + condLbl + "\n")
            emitLabel(cg, endLbl)
            return Val { v: "0", ty: "void" }
        }
    }
    // `.len()` — the length word of the receiver's 3-word header (same slot the
    // `.len` field reads, exposed as a method for `vec.len()` call syntax).
    if method == "len" {
        let ov = genExpr(cg, object, locs, sigs, "")
        let oll = llType(ov.ty)
        if isVecTy(ov.ty) || oll == "%String" || isHashMapTy(ov.ty) {
            var container = "%Vec"
            if oll == "%String" { container = "%String" }
            if isHashMapTy(ov.ty) { container = "%HashMap" }
            let r = nextTemp(cg)
            emit(cg, "  " + r + " = extractvalue " + container + " " + ov.v + ", 1\n")
            return Val { v: r, ty: "i64" }
        }
    }
    // `.swap(i, j)` mutates in place → needs the receiver address.
    if method == "swap" {
        let lv = genLvalue(cg, object, locs, sigs)
        if isVecTy(lv.ty) {
            let elemLl = llType(unwrapVec(lv.ty))
            let ia = genExpr(cg, *args[0], locs, sigs, "i64")
            let ib = genExpr(cg, *args[1], locs, sigs, "i64")
            var iaw = ia.v.clone()
            if llType(ia.ty) != "i64" {
                let ta = nextTemp(cg)
                emit(cg, "  " + ta + " = sext " + llType(ia.ty) + " " + ia.v + " to i64\n")
                iaw = ta
            }
            var ibw = ib.v.clone()
            if llType(ib.ty) != "i64" {
                let tb = nextTemp(cg)
                emit(cg, "  " + tb + " = sext " + llType(ib.ty) + " " + ib.v + " to i64\n")
                ibw = tb
            }
            let dPtr = nextTemp(cg)
            emit(cg, "  " + dPtr + " = getelementptr %Vec, ptr " + lv.v + ", i32 0, i32 0\n")
            let d = nextTemp(cg)
            emit(cg, "  " + d + " = load ptr, ptr " + dPtr + "\n")
            let slotA = nextTemp(cg)
            emit(cg, "  " + slotA + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + iaw + "\n")
            let slotB = nextTemp(cg)
            emit(cg, "  " + slotB + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + ibw + "\n")
            let va = nextTemp(cg)
            emit(cg, "  " + va + " = load " + elemLl + ", ptr " + slotA + "\n")
            let vb = nextTemp(cg)
            emit(cg, "  " + vb + " = load " + elemLl + ", ptr " + slotB + "\n")
            emit(cg, "  store " + elemLl + " " + vb + ", ptr " + slotA + "\n")
            emit(cg, "  store " + elemLl + " " + va + ", ptr " + slotB + "\n")
            return Val { v: "0", ty: "void" }
        }
    }

    let obj = genExpr(cg, object, locs, sigs, "")
    let objTyLl = llType(obj.ty)
    if isHashMapTy(obj.ty) && method == "contains" {
        let kv = genExpr(cg, *args[0], locs, sigs, hashMapKeyTy(obj.ty))
        return genHashMapContains(cg, obj, kv)
    }
    if isHashMapTy(obj.ty) && method == "get" {
        let kv = genExpr(cg, *args[0], locs, sigs, hashMapKeyTy(obj.ty))
        return genHashMapGet(cg, obj, kv)
    }
    if isHashMapTy(obj.ty) && method == "getOrDefault" {
        let kv = genExpr(cg, *args[0], locs, sigs, hashMapKeyTy(obj.ty))
        let dv = genExpr(cg, *args[1], locs, sigs, hashMapValTy(obj.ty))
        return genHashMapGetOrDefault(cg, obj, kv, dv)
    }
    if isHashMapTy(obj.ty) && method == "len" {
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = extractvalue %HashMap " + obj.v + ", 1\n")
        return Val { v: lenT, ty: "i64" }
    }
    if isVecTy(obj.ty) && method == "len" {
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = extractvalue %Vec " + obj.v + ", 1\n")
        return Val { v: lenT, ty: "i64" }
    }
    if objTyLl == "%String" && method == "clone" {
        return genStringClone(cg, obj.v)
    }
    // Heap<T>.clone() — deep-copy the box (recursive enums rely on this)
    if method == "clone" && unwrapHeap(obj.ty).len > 0 {
        return genHeapClone(cg, obj.v, obj.ty)
    }
    if objTyLl == "%String" && (method == "substr" || method == "slice") {
        let a = genExpr(cg, *args[0], locs, sigs, "i64")
        let b = genExpr(cg, *args[1], locs, sigs, "i64")
        return genStringSlice(cg, obj.v, a.v, b.v)
    }
    if objTyLl == "%String" && method == "cstr" {
        let p = nextTemp(cg)
        emit(cg, "  " + p + " = extractvalue %String " + obj.v + ", 0\n")
        return Val { v: p, ty: "ptr" }
    }
    if objTyLl == "%String" && method == "len" {
        let lenT = nextTemp(cg)
        emit(cg, "  " + lenT + " = extractvalue %String " + obj.v + ", 1\n")
        return Val { v: lenT, ty: "i64" }
    }
    if intBits(objTyLl) > 0 && (method == "checkedAdd" || method == "checkedSub" || method == "checkedMul") {
        let av = genExpr(cg, *args[0], locs, sigs, obj.ty.clone())
        return genCheckedArith(cg, obj, method, av)
    }
    if objTyLl == "i64" && method == "toString" {
        return genIntToString(cg, obj.v, isUnsigned(obj.ty))
    }
    if objTyLl == "double" && method == "toString" {
        return genFloatToString(cg, obj.v)
    }
    // i8/i16/i32 (and their unsigned forms) → widen to i64 then format. Unsigned
    // types zero-extend so e.g. a u8 of 200 prints 200, not -56.
    if method == "toString" && (objTyLl == "i8" || objTyLl == "i16" || objTyLl == "i32") {
        let w = nextTemp(cg)
        var op = "sext"
        if isUnsigned(obj.ty) { op = "zext" }
        emit(cg, "  " + w + " = " + op + " " + objTyLl + " " + obj.v + " to i64\n")
        return genIntToString(cg, w, false)
    }
    // User-defined methods via impl tables: Ty$m or Ty$Trait$m; the receiver
    // is passed by value first (milo0's ref-param convention)
    let recvName = stripPercent(resolveTyStr(cg, stripPercent(obj.ty)))
    var userFn = recvName.clone() + "$" + method.clone()
    if !cg.fnRets.contains(userFn) {
        for k, v in cg.fnRets {
            if k.startsWith(recvName + "$") && k.endsWith("$" + method) {
                userFn = k.clone()
            }
        }
    }
    if cg.fnRets.contains(userFn) {
        // The method's param ref-ness decides which args (incl. self) pass by
        // address vs value — self is param 0.
        var mRefs: Vec<bool> = Vec.new()
        for si in 0..sigs.len {
            if sigs[si].name == userFn {
                for pi in 0..sigs[si].paramRefs.len { mRefs.push(sigs[si].paramRefs[pi]) }
            }
        }
        var selfIsRef = false
        if mRefs.len > 0 { selfIsRef = mRefs[0] }
        var argStr = ""
        if selfIsRef {
            let slv = genLvalue(cg, object, locs, sigs)
            argStr = "ptr " + slv.v
        } else {
            argStr = llType(obj.ty) + " " + obj.v
        }
        for ai in 0..args.len {
            var aRef = false
            if (ai + 1) < mRefs.len { aRef = mRefs[ai + 1] }
            if aRef {
                let alv = genLvalue(cg, *args[ai], locs, sigs)
                argStr = argStr + ", ptr " + alv.v
            } else {
                let av = genExpr(cg, *args[ai], locs, sigs, "")
                argStr = argStr + ", " + llType(av.ty) + " " + av.v
            }
        }
        let retTy = resolveTyStr(cg, lookupFnRet(cg, userFn))
        let retLl = llType(retTy)
        if retLl == "void" {
            emit(cg, "  call void @" + userFn + "(" + argStr + ")\n")
            return Val { v: "0", ty: "void" }
        }
        let t = nextTemp(cg)
        emit(cg, "  " + t + " = call " + retLl + " @" + userFn + "(" + argStr + ")\n")
        return Val { v: t, ty: retTy }
    }

    // String methods are sugar for std/string free functions (`s.trim()` ->
    // `strTrim(s)`): the name is `str` + Capitalized(method), receiver passed as
    // the first arg. parseInt/toInt alias strParseInt; parseF64 is a strtod call.
    if objTyLl == "%String" {
        if method == "parseF64" || method == "parseFloat" || method == "toFloat" {
            ensureStrtod(cg)
            let dp = nextTemp(cg)
            emit(cg, "  " + dp + " = extractvalue %String " + obj.v + ", 0\n")
            let r = nextTemp(cg)
            emit(cg, "  " + r + " = call double @strtod(ptr " + dp + ", ptr null)\n")
            return Val { v: r, ty: "double" }
        }
        var sfn = ""
        if method == "toInt" || method == "parseInt" {
            sfn = "strParseInt"
        } else {
            var first = method[0]
            if first >= 97 && first <= 122 { first = first - 32 }
            sfn = "str"
            sfn.push(first)
            sfn = sfn + method[1..method.len].clone()
        }
        if cg.fnRets.contains(sfn) {
            // strXxx take `&string` (and sometimes `&string`) params → ptr. The
            // receiver (self) is always a ref; other args follow the sig.
            var sRefs: Vec<bool> = Vec.new()
            for si in 0..sigs.len {
                if sigs[si].name == sfn {
                    for pi in 0..sigs[si].paramRefs.len { sRefs.push(sigs[si].paramRefs[pi]) }
                }
            }
            let recvLv = genLvalue(cg, object, locs, sigs)
            var argStr = "ptr " + recvLv.v
            for ai in 0..args.len {
                var aRef = false
                if (ai + 1) < sRefs.len { aRef = sRefs[ai + 1] }
                if aRef {
                    let alv = genLvalue(cg, *args[ai], locs, sigs)
                    argStr = argStr + ", ptr " + alv.v
                } else {
                    let av = genExpr(cg, *args[ai], locs, sigs, "")
                    argStr = argStr + ", " + llType(av.ty) + " " + av.v
                }
            }
            let retTy = resolveTyStr(cg, lookupFnRet(cg, sfn))
            let retLl = llType(retTy)
            let t = nextTemp(cg)
            emit(cg, "  " + t + " = call " + retLl + " @" + sfn + "(" + argStr + ")\n")
            return Val { v: t, ty: retTy }
        }
    }

    // A silent placeholder here becomes invalid IR much later (`trunc i64 0 to
    // %String`), which is a miserable way to discover a missing method. Fail loud.
    eprint("codegen: unsupported method '" + method.clone() + "' on " + objTyLl.clone())
    exit(1)
    return Val { v: "0", ty: "i64" }
}

// -- Index + Slice --

fn genIndex(cg: &mut Cgen, obj: &Expr, idx: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let o = genExpr(cg, obj, locs, sigs, "")
    let i = genExpr(cg, idx, locs, sigs, "i64")
    if llType(o.ty) == "%String" {
        return genStringIndex(cg, o.v, i.v)
    }
    if isVecTy(o.ty) {
        let elemTy = unwrapVec(resolveTyStr(cg, o.ty))
        let elemLl = llType(elemTy)
        let d = nextTemp(cg)
        emit(cg, "  " + d + " = extractvalue %Vec " + o.v + ", 0\n")
        let slot = nextTemp(cg)
        emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + i.v + "\n")
        let v = nextTemp(cg)
        emit(cg, "  " + v + " = load " + elemLl + ", ptr " + slot + "\n")
        return Val { v: v, ty: elemTy }
    }
    // Raw pointer `*T` (unsafe): o.v is already the loaded pointer value.
    if o.ty.len > 0 && o.ty[0] == 42 {
        let elemTy = o.ty[1..o.ty.len].clone()
        let elemLl = llType(elemTy)
        let slot = nextTemp(cg)
        emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + o.v + ", i64 " + i.v + "\n")
        let v = nextTemp(cg)
        emit(cg, "  " + v + " = load " + elemLl + ", ptr " + slot + "\n")
        return Val { v: v, ty: elemTy }
    }
    eprint("codegen: cannot index type " + o.ty.clone())
    exit(1)
    return Val { v: "0", ty: "i64" }
}

fn genSlice(cg: &mut Cgen, obj: &Expr, a: &Expr, b: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let o = genExpr(cg, obj, locs, sigs, "")
    let av = genExpr(cg, a, locs, sigs, "i64")
    let bv = genExpr(cg, b, locs, sigs, "i64")
    if llType(o.ty) == "%String" {
        return genStringSlice(cg, o.v, av.v, bv.v)
    }
    return Val { v: "0", ty: "i64" }
}

// -- Function calls --

// f-strings lower to `format(parts...)`. Fold the parts into one %String:
// string parts pass through, integers go via genIntToString.
fn isIntLlType(ll: &string): bool {
    return ll == "i8" || ll == "i16" || ll == "i32" || ll == "i64"
}

// Display a value of any type as an owned %String (mirrors the oracle's
// emitDisplayPart). Recurses for struct/enum payloads; recursive types bottom out
// at Heap (a ptr → the "<ty>" fallback). Without this, an f-string part that
// isn't a String or integer (e.g. `{e}` where e is an IoError enum) fell through
// to genIntToString and emitted `sext %IoError to i64` — invalid IR.
fn genDisplayString(cg: &mut Cgen, val: &string, ty: &string, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let ll = llType(ty)
    if ll == "%String" { return Val { v: val.clone(), ty: "string" } }
    if ll == "i1" {
        let ts = genStringLit(cg, "true")
        let fs = genStringLit(cg, "false")
        let r = nextTemp(cg)
        emit(cg, "  " + r + " = select i1 " + val.clone() + ", %String " + ts.v + ", %String " + fs.v + "\n")
        return Val { v: r, ty: "string" }
    }
    if ll == "double" { return genFloatToString(cg, val.clone()) }
    if isIntLlType(ll) {
        var widened = val.clone()
        if ll != "i64" {
            let w = nextTemp(cg)
            var op = "sext"
            if isUnsigned(ty) { op = "zext" }
            emit(cg, "  " + w + " = " + op + " " + ll + " " + val.clone() + " to i64\n")
            widened = w
        }
        return genIntToString(cg, widened, isUnsigned(ty))
    }
    if ll.len > 0 && ll[0] == 37 {
        let raw = stripPercent(ty)
        if cg.structs.contains(raw) { return genStructDisplay(cg, val, raw, locs, sigs) }
        if cg.enums.contains(raw) { return genEnumDisplay(cg, val, raw, locs, sigs) }
    }
    return genStringLit(cg, "<" + ty.clone() + ">")
}

fn genStructDisplay(cg: &mut Cgen, val: &string, structName: &string, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let structTy = "%" + structName.clone()
    let stage = nextTemp(cg)
    emit(cg, "  " + stage + " = alloca " + structTy + "\n")
    emit(cg, "  store " + structTy + " " + val.clone() + ", ptr " + stage + "\n")
    var acc = genStringLit(cg, structName.clone() + " { ")
    let fields = cg.structs.get(structName.clone())!
    for i in 0..fields.len {
        if i > 0 {
            let sep = genStringLit(cg, ", ")
            acc = genStringConcat(cg, acc.v, sep.v)
        }
        let namePart = genStringLit(cg, fields[i].name.clone() + ": ")
        acc = genStringConcat(cg, acc.v, namePart.v)
        let fll = llType(fields[i].ty)
        let fp = nextTemp(cg)
        emit(cg, "  " + fp + " = getelementptr " + structTy + ", ptr " + stage + ", i32 0, i32 " + i.toString() + "\n")
        let fv = nextTemp(cg)
        emit(cg, "  " + fv + " = load " + fll + ", ptr " + fp + "\n")
        let isStr = fll == "%String"
        if isStr {
            let q = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q.v)
        }
        let disp = genDisplayString(cg, fv, fields[i].ty, locs, sigs)
        acc = genStringConcat(cg, acc.v, disp.v)
        if isStr {
            let q2 = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q2.v)
        }
    }
    let close = genStringLit(cg, " }")
    acc = genStringConcat(cg, acc.v, close.v)
    return acc
}

fn genEnumDisplay(cg: &mut Cgen, val: &string, enumName: &string, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let enumTy = "%" + enumName.clone()
    let stage = nextTemp(cg)
    emit(cg, "  " + stage + " = alloca " + enumTy + "\n")
    emit(cg, "  store " + enumTy + " " + val.clone() + ", ptr " + stage + "\n")
    let tagPtr = nextTemp(cg)
    emit(cg, "  " + tagPtr + " = getelementptr " + enumTy + ", ptr " + stage + ", i32 0, i32 0\n")
    let tag = nextTemp(cg)
    emit(cg, "  " + tag + " = load i32, ptr " + tagPtr + "\n")
    let resPtr = nextTemp(cg)
    emit(cg, "  " + resPtr + " = alloca %String\n")
    let endLbl = nextLabel(cg, "enum.disp.end")
    let defaultLbl = nextLabel(cg, "enum.disp.default")
    let info = cg.enums.get(enumName.clone())!
    var caseLbls: Vec<string> = Vec.new()
    for vi in 0..info.variants.len {
        caseLbls.push(nextLabel(cg, "enum.disp.case"))
    }
    var sw = "  switch i32 " + tag + ", label %" + defaultLbl + " ["
    for vi in 0..info.variants.len {
        sw = sw + " i32 " + info.variants[vi].tag.toString() + ", label %" + caseLbls[vi]
    }
    sw = sw + " ]\n"
    emit(cg, sw)
    for vi in 0..info.variants.len {
        emit(cg, caseLbls[vi] + ":\n")
        var acc = genStringLit(cg, info.variants[vi].name.clone())
        let np = info.variants[vi].payloadTypes.len
        if np > 0 {
            let op = genStringLit(cg, "(")
            acc = genStringConcat(cg, acc.v, op.v)
            let payPtr = nextTemp(cg)
            emit(cg, "  " + payPtr + " = getelementptr " + enumTy + ", ptr " + stage + ", i32 0, i32 1\n")
            var payStructTy = "{ "
            for fi in 0..np {
                if fi > 0 { payStructTy = payStructTy + ", " }
                payStructTy = payStructTy + llType(info.variants[vi].payloadTypes[fi])
            }
            payStructTy = payStructTy + " }"
            for fi in 0..np {
                if fi > 0 {
                    let sep = genStringLit(cg, ", ")
                    acc = genStringConcat(cg, acc.v, sep.v)
                }
                let fll = llType(info.variants[vi].payloadTypes[fi])
                let fp = nextTemp(cg)
                emit(cg, "  " + fp + " = getelementptr " + payStructTy + ", ptr " + payPtr + ", i32 0, i32 " + fi.toString() + "\n")
                let fv = nextTemp(cg)
                emit(cg, "  " + fv + " = load " + fll + ", ptr " + fp + "\n")
                let isStr = fll == "%String"
                if isStr {
                    let q = genStringLit(cg, "\"")
                    acc = genStringConcat(cg, acc.v, q.v)
                }
                let disp = genDisplayString(cg, fv, info.variants[vi].payloadTypes[fi], locs, sigs)
                acc = genStringConcat(cg, acc.v, disp.v)
                if isStr {
                    let q2 = genStringLit(cg, "\"")
                    acc = genStringConcat(cg, acc.v, q2.v)
                }
            }
            let cp = genStringLit(cg, ")")
            acc = genStringConcat(cg, acc.v, cp.v)
        }
        emit(cg, "  store %String " + acc.v + ", ptr " + resPtr + "\n")
        emit(cg, "  br label %" + endLbl + "\n")
    }
    emit(cg, defaultLbl + ":\n")
    let fb = genStringLit(cg, "<" + enumName.clone() + ".?>")
    emit(cg, "  store %String " + fb.v + ", ptr " + resPtr + "\n")
    emit(cg, "  br label %" + endLbl + "\n")
    emit(cg, endLbl + ":\n")
    let out = nextTemp(cg)
    emit(cg, "  " + out + " = load %String, ptr " + resPtr + "\n")
    return Val { v: out, ty: "string" }
}

fn genFormat(cg: &mut Cgen, args: &Vec<Heap<Expr>>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    ensureStringTy(cg)
    var acc = genStringLit(cg, "")
    for i in 0..args.len {
        let part = genExpr(cg, *args[i], locs, sigs, "")
        let disp = genDisplayString(cg, part.v, part.ty, locs, sigs)
        acc = genStringConcat(cg, acc.v, disp.v)
    }
    return acc
}

// jsonStringify(struct) → `{"f1":v1,"f2":v2}` for scalar fields. Reuses
// genDisplayString for the values (bool→true/false, int/float→number, string
// as-is, wrapped in quotes). NOTE: string values are not yet RFC-escaped, so a
// field containing a quote/backslash produces invalid JSON (the checker permits
// only scalar fields; escaping is a follow-up).
// Five IR lines that append one byte (a constant or an SSA i8 value) to the
// escape buffer %out at index %oi, then bump %oi. `n` names its temps uniquely.
fn jsonAppendIR(n: i64, byteVal: string): string {
    let o = "%jo" + n.toString()
    let p = "%jp" + n.toString()
    let q = "%jq" + n.toString()
    return "  " + o + " = load i64, ptr %oi\n" +
           "  " + p + " = getelementptr i8, ptr %out, i64 " + o + "\n" +
           "  store i8 " + byteVal + ", ptr " + p + "\n" +
           "  " + q + " = add i64 " + o + ", 1\n" +
           "  store i64 " + q + ", ptr %oi\n"
}

// Emit the JSON string-escaping runtime helper once:
// `@__jsonEsc(%String) -> %String` — quotes/backslash/\n\t\r\b\f get a backslash
// escape, other control chars become \u00XX (RFC 8259), everything else copies.
fn ensureJsonEsc(cg: &mut Cgen) {
    for i in 0..cg.emittedThunks.len {
        if cg.emittedThunks[i] == "__jsonEsc" { return }
    }
    cg.emittedThunks.push("__jsonEsc")
    ensureMalloc(cg)
    var f = "define %String @__jsonEsc(%String %s) {\nentry:\n"
    f = f + "  %data = extractvalue %String %s, 0\n"
    f = f + "  %len = extractvalue %String %s, 1\n"
    f = f + "  %sz = mul i64 %len, 6\n"
    f = f + "  %sz1 = add i64 %sz, 1\n"
    f = f + "  %out = call ptr @malloc(i64 %sz1)\n"
    f = f + "  %oi = alloca i64\n  store i64 0, ptr %oi\n"
    f = f + "  %ii = alloca i64\n  store i64 0, ptr %ii\n"
    f = f + "  %escslot = alloca i8\n"
    f = f + "  br label %jl\n"
    f = f + "jl:\n  %i = load i64, ptr %ii\n  %done = icmp sge i64 %i, %len\n  br i1 %done, label %jf, label %jb\n"
    f = f + "jb:\n  %cp = getelementptr i8, ptr %data, i64 %i\n  %c = load i8, ptr %cp\n"
    f = f + "  switch i8 %c, label %jchk [ i8 34, label %j_dq i8 92, label %j_bs i8 10, label %j_nl i8 9, label %j_tb i8 13, label %j_cr i8 8, label %j_bb i8 12, label %j_ff ]\n"
    f = f + "j_dq:\n  store i8 34, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_bs:\n  store i8 92, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_nl:\n  store i8 110, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_tb:\n  store i8 116, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_cr:\n  store i8 114, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_bb:\n  store i8 98, ptr %escslot\n  br label %jesc2\n"
    f = f + "j_ff:\n  store i8 102, ptr %escslot\n  br label %jesc2\n"
    f = f + "jesc2:\n" + jsonAppendIR(1, "92")
    f = f + "  %ec = load i8, ptr %escslot\n" + jsonAppendIR(2, "%ec")
    f = f + "  br label %jnext\n"
    f = f + "jchk:\n  %isc = icmp ult i8 %c, 32\n  br i1 %isc, label %juni, label %jraw\n"
    f = f + "jraw:\n" + jsonAppendIR(3, "%c") + "  br label %jnext\n"
    f = f + "juni:\n" + jsonAppendIR(4, "92") + jsonAppendIR(5, "117") + jsonAppendIR(6, "48") + jsonAppendIR(7, "48")
    f = f + "  %hi = lshr i8 %c, 4\n  %lo = and i8 %c, 15\n"
    f = f + "  %hic = icmp ult i8 %hi, 10\n  %hid = add i8 %hi, 48\n  %hia = add i8 %hi, 87\n  %hich = select i1 %hic, i8 %hid, i8 %hia\n"
    f = f + "  %loc = icmp ult i8 %lo, 10\n  %lod = add i8 %lo, 48\n  %loa = add i8 %lo, 87\n  %loch = select i1 %loc, i8 %lod, i8 %loa\n"
    f = f + jsonAppendIR(8, "%hich") + jsonAppendIR(9, "%loch") + "  br label %jnext\n"
    f = f + "jnext:\n  %i1 = add i64 %i, 1\n  store i64 %i1, ptr %ii\n  br label %jl\n"
    f = f + "jf:\n  %olen = load i64, ptr %oi\n"
    f = f + "  %r0 = insertvalue %String undef, ptr %out, 0\n  %r1 = insertvalue %String %r0, i64 %olen, 1\n  %r2 = insertvalue %String %r1, i64 %sz1, 2\n  ret %String %r2\n}\n\n"
    cg.globals = cg.globals + f
}

// Escape a string Val for JSON, returning the escaped %String Val.
fn genJsonEsc(cg: &mut Cgen, strVal: &string): Val {
    ensureJsonEsc(cg)
    let t = nextTemp(cg)
    emit(cg, "  " + t + " = call %String @__jsonEsc(%String " + strVal.clone() + ")\n")
    return Val { v: t, ty: "string" }
}

// Serialize an anonymous JSON object literal `{ k: v, … }` to a JSON string,
// matching genJsonStringify's format (string values quoted; numbers/bools bare).
fn genJsonObject(cg: &mut Cgen, fields: &Vec<StructLitField>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    var acc = genStringLit(cg, "{")
    for i in 0..fields.len {
        if i > 0 {
            let comma = genStringLit(cg, ",")
            acc = genStringConcat(cg, acc.v, comma.v)
        }
        let key = genStringLit(cg, "\"" + fields[i].name.clone() + "\":")
        acc = genStringConcat(cg, acc.v, key.v)
        let fv = genExpr(cg, *fields[i].value, locs, sigs, "")
        let isStr = llType(fv.ty) == "%String"
        if isStr {
            let q = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q.v)
            let esc = genJsonEsc(cg, fv.v)
            acc = genStringConcat(cg, acc.v, esc.v)
            let q2 = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q2.v)
        } else {
            let disp = genDisplayString(cg, fv.v, fv.ty, locs, sigs)
            acc = genStringConcat(cg, acc.v, disp.v)
        }
    }
    let close = genStringLit(cg, "}")
    acc = genStringConcat(cg, acc.v, close.v)
    return acc
}

fn genJsonStringify(cg: &mut Cgen, arg: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    let sv = genExpr(cg, arg, locs, sigs, "")
    let structName = stripPercent(sv.ty)
    let structTy = "%" + structName.clone()
    let stage = nextTemp(cg)
    emit(cg, "  " + stage + " = alloca " + structTy + "\n")
    emit(cg, "  store " + structTy + " " + sv.v + ", ptr " + stage + "\n")
    var acc = genStringLit(cg, "{")
    let fields = cg.structs.get(structName.clone())!
    for i in 0..fields.len {
        if i > 0 {
            let comma = genStringLit(cg, ",")
            acc = genStringConcat(cg, acc.v, comma.v)
        }
        let key = genStringLit(cg, "\"" + fields[i].name.clone() + "\":")
        acc = genStringConcat(cg, acc.v, key.v)
        let fll = llType(fields[i].ty)
        let fp = nextTemp(cg)
        emit(cg, "  " + fp + " = getelementptr " + structTy + ", ptr " + stage + ", i32 0, i32 " + i.toString() + "\n")
        let fv = nextTemp(cg)
        emit(cg, "  " + fv + " = load " + fll + ", ptr " + fp + "\n")
        let isStr = fll == "%String"
        if isStr {
            let q = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q.v)
            let esc = genJsonEsc(cg, fv)
            acc = genStringConcat(cg, acc.v, esc.v)
            let q2 = genStringLit(cg, "\"")
            acc = genStringConcat(cg, acc.v, q2.v)
        } else {
            let disp = genDisplayString(cg, fv, fields[i].ty, locs, sigs)
            acc = genStringConcat(cg, acc.v, disp.v)
        }
    }
    let close = genStringLit(cg, "}")
    acc = genStringConcat(cg, acc.v, close.v)
    return acc
}

// Copy a NUL-terminated C string at `pv` into an owned %String {buf,len,len+1}.
fn genCstrToString(cg: &mut Cgen, pv: &string): Val {
    ensureStringTy(cg)
    ensureMalloc(cg)
    ensureMemcpy(cg)
    // strlen may or may not be declared by a stdlib extern the program imports;
    // ensureStrlen dedups against genFn's extern-decl path via cg.declaredStrlen.
    ensureStrlen(cg)
    let len = nextTemp(cg)
    emit(cg, "  " + len + " = call i64 @strlen(ptr " + pv + ")\n")
    let cap = nextTemp(cg)
    emit(cg, "  " + cap + " = add i64 " + len + ", 1\n")
    let buf = nextTemp(cg)
    emit(cg, "  " + buf + " = call ptr @malloc(i64 " + cap + ")\n")
    emit(cg, "  call ptr @memcpy(ptr " + buf + ", ptr " + pv + ", i64 " + len + ")\n")
    let nul = nextTemp(cg)
    emit(cg, "  " + nul + " = getelementptr i8, ptr " + buf + ", i64 " + len + "\n")
    emit(cg, "  store i8 0, ptr " + nul + "\n")
    let s0 = nextTemp(cg)
    emit(cg, "  " + s0 + " = insertvalue %String zeroinitializer, ptr " + buf + ", 0\n")
    let s1 = nextTemp(cg)
    emit(cg, "  " + s1 + " = insertvalue %String " + s0 + ", i64 " + len + ", 1\n")
    let s2 = nextTemp(cg)
    emit(cg, "  " + s2 + " = insertvalue %String " + s1 + ", i64 " + cap + ", 2\n")
    return Val { v: s2, ty: "string" }
}

// strip a leading "Option_" so a candidate's `Option<R>` return yields R
fn stripOptionPrefix(s: &string): string {
    if s.len > 7 && s[0] == 79 && s[1] == 112 && s[2] == 116 && s[3] == 105 && s[4] == 111 && s[5] == 110 && s[6] == 95 {
        return s[7..s.len].clone()
    }
    return s.clone()
}

// return type suffix of a "Closure:R" surface type, else ""
fn closureRetOf(ty: &string): string {
    if ty.len < 9 { return "" }
    // "Closure:" is 8 chars
    if ty[0] == 67 && ty[7] == 58 { return ty[8..ty.len].clone() }
    return ""
}

// A generic call whose base name has >1 monomorphization can't be resolved by
// prefix alone. Pick the candidate whose param LLVM types match the actual args,
// breaking a closure-return ambiguity (arenaWith_T_{NodeKind,string,…}) by
// matching the closure arg's carried return type against the candidate's ret.
fn disambiguateGenericCall(cg: &Cgen, base: &string, argVals: &Vec<Val>, sigs: &Vec<CgFnSig>): string {
    var result = base.clone()
    var count = 0
    for si in 0..sigs.len {
        if !nameHasMonoPrefix(sigs[si].name, base) { continue }
        if sigs[si].paramTys.len != argVals.len { continue }
        var ok = true
        for pi in 0..argVals.len {
            var pll = llType(resolveTyStr(cg, sigs[si].paramTys[pi]))
            // a ref param is passed as a bare pointer, so the arg's llType is "ptr"
            if pi < sigs[si].paramRefs.len && sigs[si].paramRefs[pi] { pll = "ptr" }
            let all = llType(resolveTyStr(cg, argVals[pi].ty))
            if pll == "%Closure" && all == "%Closure" {
                let cr = closureRetOf(argVals[pi].ty)
                // arenaWith-style: candidate returns Option<R>; match R exactly
                let candR = stripOptionPrefix(resolveTyStr(cg, sigs[si].retTy))
                if cr.len > 0 && candR != cr { ok = false }
            } else if pll != all {
                ok = false
            }
        }
        if ok {
            result = sigs[si].name.clone()
            count = count + 1
        }
    }
    if count == 1 { return result }
    return base.clone()
}

// A no-arg generic call (`arenaNew<T>()`) can't be disambiguated by arg types —
// pick the monomorphization whose return type matches the expected-type hint.
fn disambiguateByReturn(cg: &Cgen, base: &string, hint: &string): string {
    let want = resolveTyStr(cg, stripPercent(hint))
    var result = base.clone()
    var count = 0
    for k, v in cg.fnRets {
        if !nameHasMonoPrefix(k, base) { continue }
        if resolveTyStr(cg, v) == want {
            result = k.clone()
            count = count + 1
        }
    }
    if count == 1 { return result }
    return base.clone()
}

fn genCall(cg: &mut Cgen, name: &string, args: &Vec<Heap<Expr>>, typeArgs: &Vec<MiloType>, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: &string): Val {
    if name == "format" {
        return genFormat(cg, args, locs, sigs)
    }
    if name == "jsonStringify" && args.len == 1 {
        return genJsonStringify(cg, *args[0], locs, sigs)
    }
    // embedFile("path"): read the file at compile time (relative to the source
    // dir) and emit its contents as a string literal.
    if name == "embedFile" && args.len == 1 {
        var path = ""
        match *args[0] {
            Expr.StringLit(s, sp) => { path = s.clone() }
            _ => {}
        }
        var full = path.clone()
        if cg.sourceDir.len > 0 { full = cg.sourceDir.clone() + "/" + path.clone() }
        var contents = ""
        match readFile(full.clone()) {
            Result.Ok(c) => { contents = c }
            Result.Err(e) => {
                eprint("error: embedFile cannot open '" + path + "'")
                exit(1)
            }
        }
        return genStringLit(cg, contents)
    }
    if name == "flush" {
        if !cg.declaredFflush {
            emitG(cg, "declare i32 @fflush(ptr)\n")
            cg.declaredFflush = true
        }
        let fc = nextTemp(cg)
        emit(cg, "  " + fc + " = call i32 @fflush(ptr null)\n")
        return Val { v: "0", ty: "void" }
    }
    // Promise(fn) → Promise_<R>$run(fn), R recovered from the closure's carried type.
    if name == "Promise" && !cg.fnRets.contains("Promise") && args.len == 1 {
        let clv = genExpr(cg, *args[0], locs, sigs, "")
        let rt = closureRetOf(clv.ty)
        if rt.len > 0 {
            let runName = "Promise_" + rt + "$run"
            let retTy = resolveTyStr(cg, lookupFnRet(cg, runName))
            let retLl = llType(retTy)
            let t = nextTemp(cg)
            emit(cg, "  " + t + " = call " + retLl + " @" + runName + "(%Closure " + clv.v + ")\n")
            return Val { v: t, ty: retTy }
        }
    }
    // assert(cond[, msg]): on false, print to stderr and exit(1); no-op when true.
    // built-in assert only when no real `assert` is in scope (std/testing defines
    // its own 1-arg assert with failure counting — don't shadow it).
    if name == "assert" && !cg.fnRets.contains("assert") {
        let cv = genExpr(cg, *args[0], locs, sigs, "bool")
        let okLbl = nextLabel(cg, "assert.ok")
        let failLbl = nextLabel(cg, "assert.fail")
        emit(cg, "  br i1 " + cv.v + ", label %" + okLbl + ", label %" + failLbl + "\n")
        emit(cg, failLbl + ":\n")
        if !cg.declaredDprintf {
            emitG(cg, "declare i32 @dprintf(i32, ptr, ...)\n")
            cg.declaredDprintf = true
        }
        if args.len >= 2 {
            let mv = genExpr(cg, *args[1], locs, sigs, "string")
            let mp = nextTemp(cg)
            emit(cg, "  " + mp + " = extractvalue %String " + mv.v + ", 0\n")
            let fl = emitStringLit(cg, "assertion failed: %s\n")
            emit(cg, "  call i32 (i32, ptr, ...) @dprintf(i32 2, ptr " + fl + ", ptr " + mp + ")\n")
        } else {
            let fl = emitStringLit(cg, "assertion failed\n")
            emit(cg, "  call i32 (i32, ptr, ...) @dprintf(i32 2, ptr " + fl + ")\n")
        }
        ensureExit(cg)
        emit(cg, "  call void @exit(i32 1)\n")
        emit(cg, "  unreachable\n")
        emit(cg, okLbl + ":\n")
        return Val { v: "0", ty: "void" }
    }
    // sizeOf<T>() — byte size of the instantiated type
    if name == "sizeOf" && typeArgs.len == 1 {
        let ll = llType(resolveTyStr(cg, astTypeStr(typeArgs[0])))
        let sz = genSizeOf(cg, ll)
        return Val { v: sz, ty: "i64" }
    }
    // zeroed<T>() — llvm zeroinitializer of the instantiated type
    if name == "zeroed" && typeArgs.len == 1 {
        let zt = resolveTyStr(cg, astTypeStr(typeArgs[0]))
        return Val { v: "zeroinitializer", ty: zt }
    }
    // Built-in Heap(expr)
    if name == "Heap" {
        let inner = genExpr(cg, *args[0], locs, sigs, "")
        let innerLl = llType(inner.ty)
        let szPtr = nextTemp(cg)
        emit(cg, "  " + szPtr + " = getelementptr " + innerLl + ", ptr null, i32 1\n")
        let szInt = nextTemp(cg)
        emit(cg, "  " + szInt + " = ptrtoint ptr " + szPtr + " to i64\n")
        ensureMalloc(cg)
        let boxPtr = nextTemp(cg)
        emit(cg, "  " + boxPtr + " = call ptr @malloc(i64 " + szInt + ")\n")
        emit(cg, "  store " + innerLl + " " + inner.v + ", ptr " + boxPtr + "\n")
        // carry the element type so `*box` derefs to the right type (was "ptr",
        // which made a string box's deref load an i64 and print the data pointer)
        return Val { v: boxPtr, ty: "Heap<" + inner.ty + ">" }
    }

    // _cstrToString(ptr): copy a NUL-terminated C string into an owned %String.
    if name == "_cstrToString" {
        let cstrp = genExpr(cg, *args[0], locs, sigs, "")
        return genCstrToString(cg, cstrp.v)
    }
    // Runtime-support builtins (mirror the TS oracle's intrinsics).
    if name == "_miloArgCount" {
        let macraw = nextTemp(cg)
        emit(cg, "  " + macraw + " = load i32, ptr @_milo_argc_global\n")
        let macext = nextTemp(cg)
        emit(cg, "  " + macext + " = sext i32 " + macraw + " to i64\n")
        return Val { v: macext, ty: "i64" }
    }
    if name == "_miloArgAt" {
        let maidx = genExpr(cg, *args[0], locs, sigs, "i64")
        let maargv = nextTemp(cg)
        emit(cg, "  " + maargv + " = load ptr, ptr @_milo_argv_global\n")
        let maslot = nextTemp(cg)
        emit(cg, "  " + maslot + " = getelementptr ptr, ptr " + maargv + ", i64 " + maidx.v + "\n")
        let macstr = nextTemp(cg)
        emit(cg, "  " + macstr + " = load ptr, ptr " + maslot + "\n")
        return genCstrToString(cg, macstr)
    }
    if name == "_schedulerGet" {
        let schgv = nextTemp(cg)
        emit(cg, "  " + schgv + " = load ptr, ptr @_milo_scheduler\n")
        return Val { v: schgv, ty: "ptr" }
    }
    if name == "_schedulerSet" {
        let schsp = genExpr(cg, *args[0], locs, sigs, "")
        emit(cg, "  store ptr " + schsp.v + ", ptr @_milo_scheduler\n")
        return Val { v: "0", ty: "void" }
    }
    if name == "_callClosureVoid" {
        let fnPtr = genExpr(cg, *args[0], locs, sigs, "")
        let envPtr = genExpr(cg, *args[1], locs, sigs, "")
        emit(cg, "  call void " + fnPtr.v + "(ptr " + envPtr.v + ")\n")
        return Val { v: "0", ty: "void" }
    }
    if name == "_loadU8" {
        let lu8p = genExpr(cg, *args[0], locs, sigs, "")
        let lu8v = nextTemp(cg)
        emit(cg, "  " + lu8v + " = load i8, ptr " + lu8p.v + "\n")
        return Val { v: lu8v, ty: "u8" }
    }
    if name == "_loadI32" {
        let li32p = genExpr(cg, *args[0], locs, sigs, "")
        let li32v = nextTemp(cg)
        emit(cg, "  " + li32v + " = load i32, ptr " + li32p.v + "\n")
        return Val { v: li32v, ty: "i32" }
    }
    if name == "_strDataPtr" {
        let sdp = genExpr(cg, *args[0], locs, sigs, "")
        let sdg = nextTemp(cg)
        emit(cg, "  " + sdg + " = getelementptr %String, ptr " + sdp.v + ", i32 0, i32 0\n")
        let sdd = nextTemp(cg)
        emit(cg, "  " + sdd + " = load ptr, ptr " + sdg + "\n")
        return Val { v: sdd, ty: "ptr" }
    }
    if name == "_atomicLoadI64" {
        let alip = genExpr(cg, *args[0], locs, sigs, "")
        let aliv = nextTemp(cg)
        emit(cg, "  " + aliv + " = load atomic i64, ptr " + alip.v + " seq_cst, align 8\n")
        return Val { v: aliv, ty: "i64" }
    }
    if name == "_atomicStoreI64" {
        let asip = genExpr(cg, *args[0], locs, sigs, "")
        let asiv = genExpr(cg, *args[1], locs, sigs, "i64")
        emit(cg, "  store atomic i64 " + asiv.v + ", ptr " + asip.v + " seq_cst, align 8\n")
        return Val { v: "0", ty: "void" }
    }
    if name == "_atomicAddI64" {
        let aaip = genExpr(cg, *args[0], locs, sigs, "")
        let aaiv = genExpr(cg, *args[1], locs, sigs, "i64")
        let aaio = nextTemp(cg)
        emit(cg, "  " + aaio + " = atomicrmw add ptr " + aaip.v + ", i64 " + aaiv.v + " seq_cst, align 8\n")
        return Val { v: aaio, ty: "i64" }
    }
    if name == "_atomicSubI64" {
        let asubp = genExpr(cg, *args[0], locs, sigs, "")
        let asubv = genExpr(cg, *args[1], locs, sigs, "i64")
        let asubo = nextTemp(cg)
        emit(cg, "  " + asubo + " = atomicrmw sub ptr " + asubp.v + ", i64 " + asubv.v + " seq_cst, align 8\n")
        return Val { v: asubo, ty: "i64" }
    }
    if name == "_atomicCasI64" {
        let acp = genExpr(cg, *args[0], locs, sigs, "")
        let ace = genExpr(cg, *args[1], locs, sigs, "i64")
        let acd = genExpr(cg, *args[2], locs, sigs, "i64")
        let acpair = nextTemp(cg)
        emit(cg, "  " + acpair + " = cmpxchg ptr " + acp.v + ", i64 " + ace.v + ", i64 " + acd.v + " seq_cst seq_cst, align 8\n")
        let aco = nextTemp(cg)
        emit(cg, "  " + aco + " = extractvalue { i64, i1 } " + acpair + ", 0\n")
        return Val { v: aco, ty: "i64" }
    }
    if name == "_atomicLoadBool" {
        let albp = genExpr(cg, *args[0], locs, sigs, "")
        let albraw = nextTemp(cg)
        emit(cg, "  " + albraw + " = load atomic i8, ptr " + albp.v + " seq_cst, align 1\n")
        let albv = nextTemp(cg)
        emit(cg, "  " + albv + " = trunc i8 " + albraw + " to i1\n")
        return Val { v: albv, ty: "bool" }
    }
    if name == "_atomicStoreBool" {
        let asbp = genExpr(cg, *args[0], locs, sigs, "")
        let asbb = genExpr(cg, *args[1], locs, sigs, "bool")
        let asbe = nextTemp(cg)
        emit(cg, "  " + asbe + " = zext i1 " + asbb.v + " to i8\n")
        emit(cg, "  store atomic i8 " + asbe + ", ptr " + asbp.v + " seq_cst, align 1\n")
        return Val { v: "0", ty: "void" }
    }
    if name == "_atomicSwapBool" {
        let aswp = genExpr(cg, *args[0], locs, sigs, "")
        let aswb = genExpr(cg, *args[1], locs, sigs, "bool")
        let aswe = nextTemp(cg)
        emit(cg, "  " + aswe + " = zext i1 " + aswb.v + " to i8\n")
        let aswo = nextTemp(cg)
        emit(cg, "  " + aswo + " = atomicrmw xchg ptr " + aswp.v + ", i8 " + aswe + " seq_cst, align 1\n")
        let aswv = nextTemp(cg)
        emit(cg, "  " + aswv + " = trunc i8 " + aswo + " to i1\n")
        return Val { v: aswv, ty: "bool" }
    }

    // Evaluate arguments. Pass each parameter's declared type as the hint so a
    // generic enum literal in argument position (`error(_, _, Option.None)`)
    // resolves to the right instantiation instead of an unmangled Option$None.
    var paramHints: Vec<string> = Vec.new()
    var paramRefs: Vec<bool> = Vec.new()
    var calleeVariadic = false
    for si in 0..sigs.len {
        if sigs[si].name == name {
            for pi in 0..sigs[si].paramTys.len {
                paramHints.push(resolveTyStr(cg, sigs[si].paramTys[pi]))
            }
            for pi in 0..sigs[si].paramRefs.len {
                paramRefs.push(sigs[si].paramRefs[pi])
            }
            if sigs[si].isVariadic { calleeVariadic = true }
        }
    }
    var argVals: Vec<Val> = Vec.new()
    for i in 0..args.len {
        var hint = ""
        if i < paramHints.len { hint = paramHints[i].clone() }
        // A ref param takes the argument's ADDRESS (auto-borrow of an lvalue), so
        // the callee mutates the caller's storage rather than a copy.
        var isRefParam = false
        if i < paramRefs.len { isRefParam = paramRefs[i] }
        if isRefParam {
            let lv = genLvalue(cg, *args[i], locs, sigs)
            argVals.push(Val { v: lv.v, ty: "ptr" })
        } else {
            var av = genExpr(cg, *args[i], locs, sigs, hint)
            // auto-wrap a bare T argument into an Option<T> param
            if i < paramHints.len {
                let rp = stripPercent(resolveTyStr(cg, stripPercent(paramHints[i])))
                if cg.enums.contains(rp) && llType(av.ty) != ("%" + rp) {
                    let stag = lookupVariantTag(cg, rp, "Some")
                    if stag >= 0 {
                        let pl = lookupVariantPayload(cg, rp, "Some")
                        if pl.len == 1 && llType(pl[0]) == llType(av.ty) {
                            av = genWrapSome(cg, av, rp)
                        }
                    }
                }
            }
            argVals.push(av)
        }
    }

    let isEprint = name == "eprint"
    let isPrintCall = name == "print" || name == "println" || isEprint
    let isVariadicExtern = name == "printf" || name == "fprintf" ||
                           name == "snprintf" || isPrintCall || calleeVariadic

    // Build argument string
    var argStr = ""
    if isPrintCall {
        // print/println are printf with a format string synthesized from the
        // argument types; passing the values bare (printf(i64 42)) is not even
        // valid IR. Trailing newline matches the TS compiler's `print`.
        var fmt = ""
        for ai in 0..argVals.len {
            let elemLl = llType(argVals[ai].ty)
            if elemLl == "%String" {
                fmt = fmt + "%s"
                let p = nextTemp(cg)
                emit(cg, "  " + p + " = extractvalue %String " + argVals[ai].v + ", 0\n")
                argStr = argStr + ", ptr " + p
            } else if elemLl == "double" {
                // %g (not %f) to match the oracle: trims trailing zeros
                // (3.141590 → 3.14159) and shares double.toString()'s format.
                fmt = fmt + "%g"
                argStr = argStr + ", double " + argVals[ai].v
            } else if elemLl == "i64" {
                // u64 prints unsigned (%llu) — else 18446744073709551615 → -1
                if isUnsigned(argVals[ai].ty) { fmt = fmt + "%llu" } else { fmt = fmt + "%lld" }
                argStr = argStr + ", i64 " + argVals[ai].v
            } else if elemLl == "ptr" {
                fmt = fmt + "%p"
                argStr = argStr + ", ptr " + argVals[ai].v
            } else if elemLl == "i32" {
                if isUnsigned(argVals[ai].ty) { fmt = fmt + "%u" } else { fmt = fmt + "%d" }
                argStr = argStr + ", i32 " + argVals[ai].v
            } else if elemLl == "i1" {
                // bool prints as true/false, matching the TS compiler
                fmt = fmt + "%s"
                let ts = emitStringLit(cg, "true")
                let fs = emitStringLit(cg, "false")
                let b = nextTemp(cg)
                emit(cg, "  " + b + " = select i1 " + argVals[ai].v + ", ptr " + ts + ", ptr " + fs + "\n")
                argStr = argStr + ", ptr " + b
            } else if elemLl.len > 0 && elemLl[0] == 37 {
                // struct/enum (%Name) → Display it as %s. Without this the branch
                // below zext'd the aggregate (`zext %IoError to i32`) → invalid IR.
                fmt = fmt + "%s"
                let ds = genDisplayString(cg, argVals[ai].v, argVals[ai].ty, locs, sigs)
                let dp = nextTemp(cg)
                emit(cg, "  " + dp + " = extractvalue %String " + ds.v + ", 0\n")
                argStr = argStr + ", ptr " + dp
            } else {
                // i8/i16 — printf varargs promote to int
                fmt = fmt + "%d"
                let z = nextTemp(cg)
                emit(cg, "  " + z + " = zext " + elemLl + " " + argVals[ai].v + " to i32\n")
                argStr = argStr + ", i32 " + z
            }
        }
        fmt = fmt + "\n"
        let flabel = emitStringLit(cg, fmt)
        argStr = "ptr " + flabel + argStr
        // eprint writes to stderr via dprintf(2, ...) instead of printf.
        if isEprint {
            if !cg.declaredDprintf {
                emitG(cg, "declare i32 @dprintf(i32, ptr, ...)\n")
                cg.declaredDprintf = true
            }
            emit(cg, "  call i32 (i32, ptr, ...) @dprintf(i32 2, " + argStr + ")\n")
            return Val { v: "0", ty: "void" }
        }
    } else {
        for ai in 0..argVals.len {
            if ai > 0 { argStr = argStr + ", " }
            let elemLl = llType(argVals[ai].ty)
            // A string/Vec passed to a pointer param (`open(path: *u8, …)`) or to a
            // variadic extern decays to its data pointer (field 0). Without this the
            // whole %String struct is passed, shifting the ABI so later args (open's
            // flags) get garbage → wrong open mode → EBADF on read.
            var paramLl = ""
            if ai < paramHints.len { paramLl = llType(paramHints[ai]) }
            let wantPtr = isVariadicExtern || paramLl == "ptr"
            if wantPtr && (elemLl == "%String" || elemLl == "%Vec") {
                let p = nextTemp(cg)
                emit(cg, "  " + p + " = extractvalue " + elemLl + " " + argVals[ai].v + ", 0\n")
                argStr = argStr + "ptr " + p
            } else if wantPtr && elemLl == "%Closure" {
                // a closure passed where a raw fn pointer is expected (e.g.
                // pthread_create's start_routine) decays to its fnptr field.
                let p = nextTemp(cg)
                emit(cg, "  " + p + " = extractvalue %Closure " + argVals[ai].v + ", 0\n")
                argStr = argStr + "ptr " + p
            } else {
                argStr = argStr + elemLl + " " + argVals[ai].v
            }
        }
    }

    // Static method on an instantiated generic type: Type<Args>.method —
    // registered as <MangledType>$method (or $Trait$method)
    var staticName = name.clone()
    var dotIdx: i64 = -1
    for di in 0..name.len {
        if name[di] == 46 {
            dotIdx = di
            break
        }
    }
    if dotIdx > 0 && typeArgs.len > 0 {
        let base = name[0..dotIdx].clone()
        let methodName = name[dotIdx + 1..name.len].clone()
        var full = base + "<"
        for ti in 0..typeArgs.len {
            if ti > 0 { full = full + "," }
            full = full + astTypeStr(typeArgs[ti])
        }
        full = full + ">"
        let tyName = stripPercent(resolveTyStr(cg, full))
        var cand = tyName.clone() + "$" + methodName.clone()
        if !cg.fnRets.contains(cand) {
            for k, v in cg.fnRets {
                if k.startsWith(tyName + "$") && k.endsWith("$" + methodName) {
                    cand = k.clone()
                }
            }
        }
        staticName = cand
    }
    // Generic fns are registered under their mangled name
    var callName = resolveFnName(cg, staticName)
    // resolveFnName falls back to the bare name when >1 instantiation exists;
    // disambiguate by the actual argument types (incl. a closure arg's return).
    if callName == staticName && !cg.fnRets.contains(staticName) {
        callName = disambiguateGenericCall(cg, staticName, argVals, sigs)
    }
    // still ambiguous (a no-arg generic like arenaNew) → use the return-type hint.
    if callName == staticName && !cg.fnRets.contains(staticName) && hintTy.len > 0 {
        callName = disambiguateByReturn(cg, staticName, hintTy)
    }
    let retTy = resolveTyStr(cg, lookupFnRet(cg, callName))
    let retLl = llType(retTy)
    var sigStr = retLl.clone()

    // Builtins: print/println → printf
    let isPrint = name == "print"
    let isPrintln = name == "println"
    var emitName = callName.clone()
    // `exit` is an extern with no prelude body; ensure its declare is emitted.
    if emitName == "exit" { ensureExit(cg) }
    if isPrint || isPrintln {
        emitName = "printf"
        sigStr = "i32 (ptr, ...)"
        if !cg.declaredPrintf {
            emitG(cg, "declare i32 @printf(ptr, ...)\n")
            cg.declaredPrintf = true
        }

    }
    if name == "printf" || name == "fprintf" || name == "snprintf" {
        sigStr = "i32 (ptr, ...)"
    }
    // A variadic callee (e.g. `open(path, flags, ...)`) MUST be called through its
    // full `(fixed…, ...)` function type, or LLVM lowers the trailing args as
    // fixed register params instead of into the vararg region (stack on arm64)
    // where the callee's va_arg reads them → garbage (e.g. open's mode).
    if calleeVariadic && !isPrint && !isPrintln {
        var vsig = retLl.clone() + " ("
        for pi in 0..paramHints.len {
            if pi > 0 { vsig = vsig + ", " }
            vsig = vsig + llType(paramHints[pi])
        }
        if paramHints.len > 0 { vsig = vsig + ", " }
        vsig = vsig + "...)"
        sigStr = vsig
    }

    // A void call must NOT be named (`%t = call void ...` is invalid IR).
    if retLl == "void" {
        emit(cg, "  call " + sigStr + " @" + emitName + "(" + argStr + ")\n")
        return Val { v: "0", ty: "void" }
    }
    let t = nextTemp(cg)
    emit(cg, "  " + t + " = call " + sigStr + " @" + emitName + "(" + argStr + ")\n")

    // carry the SURFACE type (Vec<string>, not %Vec) so field/method resolution
    // on the result (`.len`, index, isVecTy) still works; llType(retTy)==retLl
    return Val { v: t, ty: retTy }
}

// -- Lvalue (address-of) --

fn genLvalue(cg: &mut Cgen, e: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>): Val {
    match e {
        Expr.Ident(name, span) => {
            // a module global's address is @name (used for push/field-store/etc.)
            if !hasLocal(locs, name) && cg.globalVars.contains(name) {
                let surf = cg.globalVars.get(name)!
                return Val { v: "@" + name.clone(), ty: surf }
            }
            let local = findLocal(locs, name)
            return Val { v: local.addr.clone(), ty: local.ty.clone() }
        }
        Expr.FieldAccess(object, field, span) => {
            let inner = genLvalue(cg, *object, locs, sigs)
            let rawName = stripPercent(inner.ty)
            let idx = lookupFieldIndex(cg, rawName, field)
            let fty = lookupFieldType(cg, rawName, idx)
            let structTy = "%" + rawName
            let fp = nextTemp(cg)
            emit(cg, "  " + fp + " = getelementptr " + structTy + ", ptr " + inner.v + ", i32 0, i32 " + idx.toString() + "\n")
            return Val { v: fp, ty: fty }
        }
        Expr.UnaryOp(op, operand, span) => {
            // `*p` as an lvalue: the pointee's address IS the pointer value, so
            // evaluate the operand (Heap<T> box ptr or raw `*T`) and return it
            // with the pointee type. Covers `(*inner).field` reads and writes.
            if op == "*" {
                let pv = genExpr(cg, *operand, locs, sigs, "")
                var pointee = unwrapHeap(pv.ty)
                if pointee.len == 0 && pv.ty.len > 0 && pv.ty[0] == 42 {
                    pointee = pv.ty[1..pv.ty.len].clone()
                }
                if pointee.len == 0 { pointee = "i64" }
                return Val { v: pv.v, ty: pointee }
            }
            return Val { v: "0", ty: "i64" }
        }
        Expr.IndexAccess(obj, idx, span) => {
            // `a[i]` as an lvalue — needed for `a[i].field = x` and `&a[i]`.
            let o = genExpr(cg, *obj, locs, sigs, "")
            let iv = genExpr(cg, *idx, locs, sigs, "i64")
            if isVecTy(o.ty) {
                let elemTy = unwrapVec(resolveTyStr(cg, o.ty))
                let elemLl = llType(elemTy)
                let d = nextTemp(cg)
                emit(cg, "  " + d + " = extractvalue %Vec " + o.v + ", 0\n")
                let slot = nextTemp(cg)
                emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + d + ", i64 " + iv.v + "\n")
                return Val { v: slot, ty: elemTy }
            }
            if o.ty.len > 0 && o.ty[0] == 42 {
                let elemTy = o.ty[1..o.ty.len].clone()
                let elemLl = llType(elemTy)
                let slot = nextTemp(cg)
                emit(cg, "  " + slot + " = getelementptr " + elemLl + ", ptr " + o.v + ", i64 " + iv.v + "\n")
                return Val { v: slot, ty: elemTy }
            }
            return Val { v: "0", ty: "i64" }
        }
        _ => {
            // rvalue (call result, etc.) used where an address is needed
            // (`peek(p).kind`, `match f()`): materialize it into a temp alloca.
            let v = genExpr(cg, e, locs, sigs, "")
            let ll = llType(v.ty)
            let addr = nextTemp(cg)
            emit(cg, "  " + addr + " = alloca " + ll + "\n")
            emit(cg, "  store " + ll + " " + v.v + ", ptr " + addr + "\n")
            return Val { v: addr, ty: v.ty }
        }
    }
}

// -- Main expression dispatch --

// The result expression of an expression-bodied closure statement (`=> expr`
// lowers to one Return/ExprStmt). Returns None when it isn't that shape.
fn genExpr(cg: &mut Cgen, e: &Expr, locs: &Vec<Local>, sigs: &Vec<CgFnSig>, hintTy: string): Val {
    match e {
        Expr.IntLit(n, span) => {
            var ty = hintTy.clone()
            if ty.len == 0 { ty = "i64" }
            var ll = llType(ty)
            // An integer literal in pointer position (`p: *u8 = 0`) is a null
            // pointer: LLVM writes `null`, not the integer constant `0`.
            if ll == "ptr" {
                if n == 0 {
                    return Val { v: "null", ty: "ptr" }
                }
                let t = nextTemp(cg)
                emit(cg, "  " + t + " = inttoptr i64 " + n.toString() + " to ptr\n")
                return Val { v: t, ty: "ptr" }
            }
            // An int literal in float position (`x: f64 = 0`, a zeroed float field)
            // must be a floating constant — LLVM rejects `double 0`, needs `0.0`.
            if ll == "double" || ll == "float" {
                return Val { v: n.toString() + ".0", ty: ll }
            }
            // Only integer hints apply to an int literal; a non-int hint (e.g. a
            // generic type param `A` passed as a call-arg hint) must not retype it.
            let isInt = ll.len > 0 && ll[0] == 105
            if !isInt { return Val { v: n.toString(), ty: "i64" } }
            // keep the SURFACE type (u8/i32/…), not the LLVM type, so unsigned-ness
            // survives — otherwise `let b: u8 = 200; b as i32` sign-extends to -56.
            return Val { v: n.toString(), ty: ty }
        }
        Expr.FloatLit(f, span) => {
            // f.toString() drops the decimal for whole values (0.0 -> "0"), which
            // LLVM rejects as a `double` constant. Ensure a '.' or exponent.
            var fs = f.toString()
            var hasPoint = false
            for ci in 0..fs.len {
                if fs[ci] == 46 || fs[ci] == 101 || fs[ci] == 69 { hasPoint = true }
            }
            if !hasPoint { fs = fs + ".0" }
            return Val { v: fs, ty: "double" }
        }
        Expr.BoolLit(b, span) => {
            let v = if b { "1" } else { "0" }
            return Val { v: v, ty: "i1" }
        }
        Expr.StringLit(s, span) => {
            return genStringLit(cg, s)
        }
        Expr.CharLit(c, span) => {
            return Val { v: c.toString(), ty: "i8" }
        }
        Expr.Ident(name, span) => {
            // A module global (unless a local shadows it): load @name.
            var isLocal = false
            for li in 0..locs.len {
                if locs[li].name == name { isLocal = true }
            }
            if !isLocal && cg.globalVars.contains(name) {
                let surf = cg.globalVars.get(name)!
                let gll = llType(resolveTyStr(cg, surf))
                let g = nextTemp(cg)
                emit(cg, "  " + g + " = load " + gll + ", ptr @" + name.clone() + "\n")
                return Val { v: g, ty: surf }
            }
            // A bare function name used as a closure value → { @thunk, null }, where
            // the thunk adapts the named fn to the closure ABI (env + by-ptr args).
            // (A fn-name cast to a raw ptr — `trampoline as *u8` — is handled in
            // genAsCast, which uses the fn's real address, not the thunk.)
            if !isLocal && cg.fnRets.contains(name) {
                let thunk = ensureFnThunk(cg, name, sigs)
                let f0 = nextTemp(cg)
                emit(cg, "  " + f0 + " = insertvalue %Closure undef, ptr @" + thunk + ", 0\n")
                let f1 = nextTemp(cg)
                emit(cg, "  " + f1 + " = insertvalue %Closure " + f0 + ", ptr null, 1\n")
                return Val { v: f1, ty: "Closure" }
            }
            let local = findLocal(locs, name)
            let lt = llType(local.ty)
            let loaded = genLoad(cg, local.addr, lt)
            return Val { v: loaded.v, ty: local.ty.clone() }
        }
        Expr.UnaryOp(op, inner, span) => {
            if op == "*" {
                return genHeapDeref(cg, *inner, locs, sigs)
            }
            // `&place` yields the place's address (used for `(&x) as *T` extern args).
            if op == "&" {
                let lv = genLvalue(cg, *inner, locs, sigs)
                return Val { v: lv.v, ty: "ptr" }
            }
            let v = genExpr(cg, *inner, locs, sigs, hintTy)
            let t = nextTemp(cg)
            if op == "-" {
                let vll = llType(v.ty)
                // Float negation uses fneg — `sub double 0, x` has an invalid
                // integer `0` operand for a double.
                if vll == "double" || vll == "float" {
                    emit(cg, "  " + t + " = fneg " + vll + " " + v.v + "\n")
                    return Val { v: t, ty: v.ty }
                }
                emit(cg, "  " + t + " = sub " + vll + " 0, " + v.v + "\n")
                return Val { v: t, ty: v.ty }
            }
            if op == "!" {
                emit(cg, "  " + t + " = xor i1 " + v.v + ", 1\n")
                return Val { v: t, ty: "i1" }
            }
            if op == "~" {
                emit(cg, "  " + t + " = xor " + llType(v.ty) + " " + v.v + ", -1\n")
                return Val { v: t, ty: v.ty }
            }
            return v
        }
        Expr.BinOp(op, l, r, span) => {
            // Short-circuit && / || — the RHS must NOT be evaluated eagerly (it may
            // have side effects). Store into a slot to avoid phi/current-block bookkeeping.
            if op == "&&" || op == "||" {
                let res = nextTemp(cg)
                emit(cg, "  " + res + " = alloca i1\n")
                let lhs = genExpr(cg, *l, locs, sigs, "bool")
                emit(cg, "  store i1 " + lhs.v + ", ptr " + res + "\n")
                let rhsLbl = nextLabel(cg, "sc.rhs")
                let endLbl = nextLabel(cg, "sc.end")
                if op == "&&" {
                    emit(cg, "  br i1 " + lhs.v + ", label %" + rhsLbl + ", label %" + endLbl + "\n")
                } else {
                    emit(cg, "  br i1 " + lhs.v + ", label %" + endLbl + ", label %" + rhsLbl + "\n")
                }
                emit(cg, rhsLbl + ":\n")
                let rhs = genExpr(cg, *r, locs, sigs, "bool")
                emit(cg, "  store i1 " + rhs.v + ", ptr " + res + "\n")
                emit(cg, "  br label %" + endLbl + "\n")
                emit(cg, endLbl + ":\n")
                let out = nextTemp(cg)
                emit(cg, "  " + out + " = load i1, ptr " + res + "\n")
                return Val { v: out, ty: "bool" }
            }
            // A comparison's RESULT is bool but its OPERANDS are the compared type —
            // don't leak a "bool" hint onto them (`if 3 > 2` would make the int
            // literals i1 and compare 1 > 0 signed = false).
            var lHint = hintTy.clone()
            if isCmpOp(op) { lHint = "" }
            let lv = genExpr(cg, *l, locs, sigs, lHint)
            let rv = genExpr(cg, *r, locs, sigs, lv.ty.clone())
            let lvLl = llType(lv.ty)
            // String operations
            if lvLl == "%String" {
                if op == "+" { return genStringConcat(cg, lv.v, rv.v) }
                if op == "==" || op == "!=" {
                    return genStringEq(cg, lv.v, rv.v, op == "==")
                }
                if op == "<" || op == "<=" || op == ">" || op == ">=" {
                    return genStringCmp(cg, lv.v, rv.v, op)
                }
            }
            // Enum tag compare
            if (op == "==" || op == "!=") && lvLl.len > 1 && lvLl[0] == 37 {
                let lt = nextTemp(cg)
                emit(cg, "  " + lt + " = extractvalue " + lvLl + " " + lv.v + ", 0\n")
                let rt = nextTemp(cg)
                emit(cg, "  " + rt + " = extractvalue " + lvLl + " " + rv.v + ", 0\n")
                let opn = if op == "==" { "eq" } else { "ne" }
                let res = nextTemp(cg)
                emit(cg, "  " + res + " = icmp " + opn + " i32 " + lt + ", " + rt + "\n")
                return Val { v: res, ty: "bool" }
            }
            // Mixed integer widths (e.g. `i64Var < i32Param`): widen the narrower
            // operand so the op has one type. i1 is excluded (bool, not arithmetic).
            var lvv = lv.v.clone()
            var rvv = rv.v.clone()
            var opLl = lvLl.clone()
            let rvLl = llType(rv.ty)
            let lInt = lvLl.len > 1 && lvLl[0] == 105
            let rInt = rvLl.len > 1 && rvLl[0] == 105
            if lInt && rInt && lvLl != rvLl {
                let lb = intBits(lvLl)
                let rb = intBits(rvLl)
                if lb < rb {
                    let w = nextTemp(cg)
                    let ext = if isUnsigned(lv.ty) { "zext" } else { "sext" }
                    emit(cg, "  " + w + " = " + ext + " " + lvLl + " " + lvv + " to " + rvLl + "\n")
                    lvv = w
                    opLl = rvLl.clone()
                } else {
                    let w = nextTemp(cg)
                    let ext = if isUnsigned(rv.ty) { "zext" } else { "sext" }
                    emit(cg, "  " + w + " = " + ext + " " + rvLl + " " + rvv + " to " + lvLl + "\n")
                    rvv = w
                }
            }
            let t = nextTemp(cg)
            let unsigned = isUnsigned(lv.ty)
            // If a narrower operand was widened, the RESULT value is the wider
            // width — report that, not lv.ty. Otherwise `(u8 | i64shifted) as u8`
            // sees u8->u8 (no-op) and never truncates the actually-i64 value.
            var resTy = lv.ty.clone()
            if opLl != lvLl { resTy = opLl.clone() }
            // Floating-point operands use f-instructions, not the integer ops.
            if lvLl == "double" || lvLl == "float" {
                if isArithOp(op) {
                    var fop = "fadd"
                    if op == "-" { fop = "fsub" }
                    else if op == "*" { fop = "fmul" }
                    else if op == "/" { fop = "fdiv" }
                    else if op == "%" { fop = "frem" }
                    emit(cg, "  " + t + " = " + fop + " " + lvLl + " " + lvv + ", " + rvv + "\n")
                    return Val { v: t, ty: lv.ty }
                }
                if isCmpOp(op) {
                    var fp = "oeq"
                    if op == "!=" { fp = "one" }
                    else if op == "<" { fp = "olt" }
                    else if op == "<=" { fp = "ole" }
                    else if op == ">" { fp = "ogt" }
                    else if op == ">=" { fp = "oge" }
                    emit(cg, "  " + t + " = fcmp " + fp + " " + lvLl + " " + lvv + ", " + rvv + "\n")
                    return Val { v: t, ty: "bool" }
                }
            }
            if isArithOp(op) {
                let opname = binOpInt(op, unsigned)
                emit(cg, "  " + t + " = " + opname + " " + opLl + " " + lvv + ", " + rvv + "\n")
                return Val { v: t, ty: resTy }
            }
            if isCmpOp(op) {
                let opname = cmpOpInt(op, unsigned)
                emit(cg, "  " + t + " = icmp " + opname + " " + opLl + " " + lvv + ", " + rvv + "\n")
                return Val { v: t, ty: "bool" }
            }
            if op == "&&" {
                emit(cg, "  " + t + " = and i1 " + lv.v + ", " + rv.v + "\n")
                return Val { v: t, ty: "i1" }
            }
            if op == "||" {
                emit(cg, "  " + t + " = or i1 " + lv.v + ", " + rv.v + "\n")
                return Val { v: t, ty: "i1" }
            }
            return Val { v: "0", ty: "i64" }
        }
        Expr.Call(name, args, typeArgs, span) => {
            // a call whose callee is a %Closure-typed local is an indirect call
            if hasLocal(locs, name) {
                let lc = findLocal(locs, name)
                if llType(lc.ty) == "%Closure" {
                    return genClosureCall(cg, lc, args, locs, sigs, hintTy)
                }
            }
            return genCall(cg, name, args, typeArgs, locs, sigs, hintTy)
        }
        Expr.StructLit(name, fields, span) => {
            return genStructLit(cg, name, fields, locs, sigs, hintTy)
        }
        Expr.JsonObject(fields, span) => {
            return genJsonObject(cg, fields, locs, sigs)
        }
        Expr.FieldAccess(object, field, span) => {
            return genFieldAccess(cg, *object, field, locs, sigs)
        }
        Expr.Closure(params, retType, body, isMove, span) => {
            return genClosure(cg, params, retType, body, isMove, locs, sigs)
        }
        Expr.EnumLit(enumName, variant, args, span) => {
            if enumName == "Vec" && variant == "new" {
                return genVecNew(cg, hintTy)
            }
            if enumName == "HashMap" && variant == "new" {
                return genHashMapNew(cg, hintTy)
            }
            if enumName == "String" && variant == "withCapacity" {
                // capacity is a growth hint; an empty string (cap 0 = literal
                // convention, push mallocs) is semantically equivalent
                return genStringLit(cg, "")
            }
            return genEnumLit(cg, enumName, variant, args, locs, sigs, hintTy)
        }
        Expr.CastExpr(inner, targetType, span) => {
            // full astTypeStr, not just .name: `x as *i64` must keep pointer-ness
            // (otherwise the target reads as plain i64 and the cast result loses it)
            return genAsCast(cg, *inner, astTypeStr(targetType), locs, sigs)
        }
        Expr.MethodCall(object, method, args, span) => {
            return genMethodCall(cg, *object, method, args, locs, sigs)
        }
        Expr.IndexAccess(obj, idx, span) => {
            return genIndex(cg, *obj, *idx, locs, sigs)
        }
        Expr.IfExpr(cond, thenE, elseE, span) => {
            let cv = genExpr(cg, *cond, locs, sigs, "bool")
            let thenLbl = nextLabel(cg, "ifx.then")
            let elseLbl = nextLabel(cg, "ifx.else")
            let endLbl = nextLabel(cg, "ifx.end")
            emit(cg, "  br i1 " + cv.v + ", label %" + thenLbl + ", label %" + elseLbl + "\n")
            emitLabel(cg, thenLbl)
            let av = genExpr(cg, *thenE, locs, sigs, hintTy)
            // the phi predecessor is wherever control actually is now — a nested
            // if-expr (`else if …`) ends in its OWN block, not thenLbl/elseLbl.
            let thenPred = cg.curBlock.clone()
            emit(cg, "  br label %" + endLbl + "\n")
            emitLabel(cg, elseLbl)
            let bv = genExpr(cg, *elseE, locs, sigs, av.ty.clone())
            let elsePred = cg.curBlock.clone()
            emit(cg, "  br label %" + endLbl + "\n")
            emitLabel(cg, endLbl)
            let r = nextTemp(cg)
            let ll = llType(av.ty)
            emit(cg, "  " + r + " = phi " + ll + " [" + av.v + ", %" + thenPred + "], [" + bv.v + ", %" + elsePred + "]\n")
            return Val { v: r, ty: av.ty.clone() }
        }
        Expr.ArrayLit(elems, span) => {
            return genArrayLit(cg, elems, locs, sigs, hintTy)
        }
        Expr.ArrayRepeat(value, count, span) => {
            return genArrayRepeat(cg, *value, count, locs, sigs, hintTy)
        }
        Expr.Unwrap(inner, span) => {
            return genUnwrap(cg, *inner, span, locs, sigs)
        }
        Expr.DefaultValue(inner, defaultE, span) => {
            return genDefaultValue(cg, *inner, *defaultE, locs, sigs)
        }
        Expr.Propagate(inner, span) => {
            return genPropagate(cg, *inner, locs, sigs)
        }
        Expr.IsExpr(subject, pattern, span) => {
            return genIsExpr(cg, *subject, *pattern, locs, sigs)
        }
        _ => {
            return Val { v: "0", ty: "i64" }
        }
    }
}
