// @expect: bind ok

// Blocking-socket smoke test across platforms. On Windows this needs Winsock to be
// initialised first (ensureNetInit -> WSAStartup); on POSIX that call is a no-op. The
// async/non-blocking socket fixtures still need the IOCP tier and stay skipped.

from "std/platform" import {
    SockAddrIn, makeSockaddr, ensureNetInit, closeSocket
}

extern fn socket(domain: i32, sockType: i32, protocol: i32): i32

// bind takes &SockAddrIn — auto-borrow passes the pointer, matching C ABI
extern fn bind(sockfd: i32, addr: &SockAddrIn, addrlen: u32): i32

fn main(): i32 {
    ensureNetInit()
    let fd = socket(2, 1, 0)
    if fd < 0 {
        print("socket failed")
        return 1
    }
    var addr = makeSockaddr(0, 0)
    let result = bindIn(fd, addr)
    if result == 0 {
        print("bind ok")
    } else {
        print("bind failed: ", result)
    }
    closeSocket(fd)
    return 0
}
