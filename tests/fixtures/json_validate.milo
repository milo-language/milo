// @expect: invalid
// @expect: invalid

fn is_ws(ch: u8) -> bool {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn is_digit(ch: u8) -> bool {
    return ch >= '0' && ch <= '9'
}

fn is_hex(ch: u8) -> bool {
    return is_digit(ch) || (ch >= 'A' && ch <= 'F') || (ch >= 'a' && ch <= 'f')
}

fn skip_ws(s: &String, pos: &mut i64) {
    while pos < s.len && is_ws(s[pos]) {
        pos = pos + 1
    }
}

fn parse_value(s: &String, pos: &mut i64) -> bool {
    skip_ws(s, pos)
    if pos >= s.len { return false }
    let ch = s[pos]
    if ch == '"' { return parse_string(s, pos) }
    if ch == '{' { return parse_object(s, pos) }
    if ch == '[' { return parse_array(s, pos) }
    if ch == 't' { return expect_chars(s, pos, "true") }
    if ch == 'f' { return expect_chars(s, pos, "false") }
    if ch == 'n' { return expect_chars(s, pos, "null") }
    if ch == '-' || is_digit(ch) { return parse_number(s, pos) }
    return false
}

fn parse_string(s: &String, pos: &mut i64) -> bool {
    if pos >= s.len || s[pos] != '"' { return false }
    pos = pos + 1
    while pos < s.len {
        let ch = s[pos]
        if ch == '"' {
            pos = pos + 1
            return true
        } else if ch == '\\' {
            pos = pos + 1
            if pos >= s.len { return false }
            let esc = s[pos]
            if esc == 'u' {
                pos = pos + 1
                var i: i64 = 0
                while i < 4 {
                    if pos >= s.len || !is_hex(s[pos]) { return false }
                    pos = pos + 1
                    i = i + 1
                }
            } else if esc == '"' || esc == '\\' || esc == '/' || esc == 'b' || esc == 'f' || esc == 'n' || esc == 'r' || esc == 't' {
                pos = pos + 1
            } else {
                return false
            }
        } else {
            pos = pos + 1
        }
    }
    return false
}

fn parse_number(s: &String, pos: &mut i64) -> bool {
    if pos >= s.len { return false }
    if s[pos] == '-' {
        pos = pos + 1
        if pos >= s.len { return false }
    }
    if s[pos] == '0' {
        pos = pos + 1
    } else if is_digit(s[pos]) {
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    } else {
        return false
    }
    if pos < s.len && s[pos] == '.' {
        pos = pos + 1
        if pos >= s.len || !is_digit(s[pos]) { return false }
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    }
    if pos < s.len && (s[pos] == 'e' || s[pos] == 'E') {
        pos = pos + 1
        if pos >= s.len { return false }
        if s[pos] == '+' || s[pos] == '-' { pos = pos + 1 }
        if pos >= s.len || !is_digit(s[pos]) { return false }
        while pos < s.len && is_digit(s[pos]) {
            pos = pos + 1
        }
    }
    return true
}

fn parse_array(s: &String, pos: &mut i64) -> bool {
    if pos >= s.len || s[pos] != '[' { return false }
    pos = pos + 1
    skip_ws(s, pos)
    if pos < s.len && s[pos] == ']' {
        pos = pos + 1
        return true
    }
    if !parse_value(s, pos) { return false }
    skip_ws(s, pos)
    while pos < s.len {
        if s[pos] == ']' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parse_value(s, pos) { return false }
            skip_ws(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parse_object(s: &String, pos: &mut i64) -> bool {
    if pos >= s.len || s[pos] != '{' { return false }
    pos = pos + 1
    skip_ws(s, pos)
    if pos < s.len && s[pos] == '}' {
        pos = pos + 1
        return true
    }
    if !parse_kv(s, pos) { return false }
    skip_ws(s, pos)
    while pos < s.len {
        if s[pos] == '}' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parse_kv(s, pos) { return false }
            skip_ws(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parse_kv(s: &String, pos: &mut i64) -> bool {
    skip_ws(s, pos)
    if !parse_string(s, pos) { return false }
    skip_ws(s, pos)
    if pos >= s.len || s[pos] != ':' { return false }
    pos = pos + 1
    return parse_value(s, pos)
}

fn expect_chars(s: &String, pos: &mut i64, expected: &String) -> bool {
    var i: i64 = 0
    while i < expected.len {
        if pos >= s.len || s[pos] != expected[i] { return false }
        pos = pos + 1
        i = i + 1
    }
    return true
}

fn validate(json: String) -> bool {
    var pos: i64 = 0
    if !parse_value(json, pos) { return false }
    skip_ws(json, pos)
    return pos == json.len
}

fn check(json: String, expected: bool) {
    let result = validate(json)
    if result == expected {
        if expected { println("valid") }
        else { println("invalid") }
    } else {
        println("ERROR")
    }
}

fn main() -> i32 {
    check("null", true)
    check("42", true)
    check("\"hello\"", true)
    check("[1, 2, 3]", true)
    check("{\"a\": 1}", true)
    check("{\"a\": [true, null]}", true)
    check("3.14e-2", true)
    check("  { \"x\" : { \"y\" : [] } }  ", true)
    check("", false)
    check("[1,]", false)
    check("\"abc", false)
    check("{\"a\" 1}", false)
    return 0
}
