// @expect: 10
// @expect: 11
// @expect: 21
// @expect: false
// @expect: 21
import "std/arena"

fn main(): i32 {
    var arena: Arena<i32> = arena_new()
    let h = arena_alloc(arena, 10)

    match arena_get(arena, h) {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    // in-place increment via closure
    arena_modify(arena, h, (v: i32) => v + 1)
    match arena_get(arena, h) {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    // chain modifications
    arena_modify(arena, h, (v: i32) => v * 2)
    arena_modify(arena, h, (v: i32) => v - 1)
    match arena_get(arena, h) {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    // stale handle — modify returns false, value unchanged
    arena_free(arena, h)
    let ok = arena_modify(arena, h, (v: i32) => v + 100)
    if ok { print("true") } else { print("false") }

    // re-alloc reuses slot but with bumped gen; old handle still stale
    let h2 = arena_alloc(arena, 21)
    match arena_get(arena, h2) {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    return 0
}
