// @expect: 42
// @expect: none

fn maybeDouble(x: i32?): i32? {
    let val = x?
    return Option.Some(val * 2)
}

fn main(): i32 {
    let a = Option.Some(21)
    let result = maybeDouble(a)
    match result {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    let b: i32? = Option.None
    let result2 = maybeDouble(b)
    match result2 {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    return 0
}

