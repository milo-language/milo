// vec slice: non-owning view via v[a..b]; iterate + index the slice, source still owns
pub fn main(): i32 {
    var v: Vec<i32> = Vec.new()
    v.push(10)
    v.push(20)
    v.push(30)
    v.push(40)
    let mid = v[1..3]
    print(mid.len())
    for x in mid {
        print(x)
    }
    // source unaffected by the borrow
    print(v.len())
    return 0
}
// @expect: 2
// @expect: 20
// @expect: 30
// @expect: 4
