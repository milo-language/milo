// @expect: got 42
// @expect: done

enum Option {
    Some(i32),
    None,
}

fn main(): i32 {
    let x = Option.Some(42)
    if let Option.Some(val) = x {
        print("got %d\n", val)
    }

    let y = Option.None
    if let Option.Some(val) = y {
        print("should not print\n")
    }

    print("done\n")
    return 0
}
