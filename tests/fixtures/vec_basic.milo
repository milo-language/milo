// @expect: 0
// @expect: 3
// @expect: 10
// @expect: 20
// @expect: 30

fn main(): i32 {
    var v: Vec<i32> = Vec.new()
    print("%lld\n", v.len)

    v.push(10)
    v.push(20)
    v.push(30)
    print("%lld\n", v.len)

    print("%d\n", v[0])
    print("%d\n", v[1])
    print("%d\n", v[2])

    return 0
}
