// @expect: 0
// @expect: 3
// @expect: 10
// @expect: 20
// @expect: 30
extern fn printf(fmt: *u8, ...) -> i32

fn main() -> i32 {
    var v: Vec<i32> = Vec::new()
    printf("%lld\n", v.len)

    v.push(10)
    v.push(20)
    v.push(30)
    printf("%lld\n", v.len)

    printf("%d\n", v[0])
    printf("%d\n", v[1])
    printf("%d\n", v[2])

    return 0
}
