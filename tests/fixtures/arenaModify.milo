// @expect: 10
// @expect: 11
// @expect: 21
// @expect: false
// @expect: 21
from "std/arena" import { Arena, arenaAlloc, arenaFree, arenaGet, arenaModify, arenaNew }

fn main(): i32 {
    var arena: Arena<i32> = arenaNew()
    let h = arenaAlloc(arena, 10)

    match arenaGet(arena, h) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // in-place increment via closure
    arenaModify(arena, h, (v: i32) => v + 1)
    match arenaGet(arena, h) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // chain modifications
    arenaModify(arena, h, (v: i32) => v * 2)
    arenaModify(arena, h, (v: i32) => v - 1)
    match arenaGet(arena, h) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // stale handle — modify returns false, value unchanged
    arenaFree(arena, h)
    let ok = arenaModify(arena, h, (v: i32) => v + 100)
    if ok {
        print("true")
    } else {
        print("false")
    }

    // re-alloc reuses slot but with bumped gen; old handle still stale
    let h2 = arenaAlloc(arena, 21)
    match arenaGet(arena, h2) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    return 0
}

