// @expect: count=2
// @expect: alice 30
// @expect: bob 25
// @expect: missing=-1
// Zero-copy JSON cursor navigation: curField/curChild return node indices into
// the parsed doc (no per-access deep clone of source + nodes like get/at), and
// only curStr materializes a single leaf string.
from "std/json" import {
    jsonParse
}

pub fn main(): i32 {
    let doc = match jsonParse("{\"users\":[{\"name\":\"alice\",\"age\":30},{\"name\":\"bob\",\"age\":25}]}") {
        Result.Ok(j) => j
        Result.Err(e) => {
            print("parse fail")
            return 1
        }
    }
    let root = doc.curRoot()
    let users = doc.curField(root, "users")
    print($"count={doc.curLen(users)}")
    var i: i64 = 0
    while i < doc.curLen(users) {
        let u = doc.curChild(users, i)
        let name = match doc.curStr(doc.curField(u, "name")) {
            Option.Some(s) => s, Option.None => "?"
        }
        let age = match doc.curInt(doc.curField(u, "age")) {
            Option.Some(n) => n, Option.None => -1
        }
        print($"{name} {age}")
        i = i + 1
    }
    let missing = doc.curField(root, "nope")
    print($"missing={missing}")
    return 0
}
