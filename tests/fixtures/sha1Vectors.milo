from "std/sha1" import {
    sha1
}

// Checked against `shasum -a 1`; git blob object ids use this construction.
fn main(): i32 {
    print(sha1(""))
    print(sha1("abc"))
    print(sha1("The quick brown fox jumps over the lazy dog"))
    print(sha1("The quick brown fox jumps over the lazy cog"))
    return 0
}
