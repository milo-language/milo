// @expect: name: double
// @expect: result: 10

pub fn double(x: i32): i32 {
    return x * 2
}

pub struct Op {
    name: string,
    apply: (i32) => i32,
}

pub fn main(): i32 {
    var ops: Vec<Op> = Vec.new()
    ops.push(Op {
        name: "double", apply: double
    }
    )

    let op = ops[0]
    print("name: ", op.name)
    print("result: ", op.apply(5))
    return 0
}
