// by-value extern struct args/returns are safe (POD copy) — no unsafe block needed,
// and the struct stays usable after being passed (Copy semantics)
pub extern struct P {
    x: i32,
    y: i32,
}

pub extern fn sum_p(p: P): i32

pub fn main(): i32 {
    let p = P {
        x: 5, y: 7
    }
    print(sum_p(p))
    print(sum_p(p))
    return 0
}
// @expect: 12
// @expect: 12
