// @expect: 0 0 0 0
// @expect: 42 42 42
extern fn printf(fmt: *u8, ...): i32

fn main(): i32 {
    let zeros: [i32; 4] = [0; 4]
    printf("%d %d %d %d\n", zeros[0], zeros[1], zeros[2], zeros[3])

    let filled: [i32; 3] = [42; 3]
    printf("%d %d %d\n", filled[0], filled[1], filled[2])
    return 0
}
