// @expect: 78.5397
// @expect: 16
// @expect: 28.2745

pub interface Shape {
    fn area(self: &Self): f64
}

pub struct Circle {
    radius: f64
}

impl Circle {
    fn area(self: &Self): f64 {
        return 3.14159 * self.radius * self.radius
    }
}

pub struct Square {
    side: f64
}

impl Square {
    fn area(self: &Self): f64 {
        return self.side * self.side
    }
}

pub struct Triangle {
    base: f64, height: f64
}

impl Triangle {
    fn area(self: &Self): f64 {
        return 0.5 * self.base * self.height
    }
}

pub fn main(): i32 {
    var shapes: Vec<Heap<Shape>> = Vec.new()
    shapes.push(Heap(Circle {
        radius: 5.0
    }
    ))
    shapes.push(Heap(Square {
        side: 4.0
    }
    ))
    shapes.push(Heap(Triangle {
        base: 10.0, height: 5.6549
    }
    ))
    for s in shapes {
        print(s.area())
    }
    return 0
}
