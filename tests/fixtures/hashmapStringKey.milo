// @expect: len: 2
// @expect: has hello: true
// @expect: has nope: false
// @expect: got hello: 42

fn main(): i32 {
    var m: HashMap<string, i32> = HashMap.new()
    m.insert("hello", 42)
    m.insert("world", 99)

    print("len: ", m.len)
    if m.contains("hello") {
        print("has hello: true")
    } else {
        print("has hello: false")
    }
    if m.contains("nope") {
        print("has nope: true")
    } else {
        print("has nope: false")
    }

    let r = m.get("hello")
    if let Option.Some(v) = r {
        print("got hello: ", v)
    } else {
        print("hello not found")
    }
    return 0
}
