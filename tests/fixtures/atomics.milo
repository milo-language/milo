// @expect: 0
// @expect: 42
// @expect: 42
// @expect: 10
// @expect: 7
// @expect: false
// @expect: true
// @expect: false

from "std/sync" import {
    AtomicI64, AtomicBool
}

fn main(): i32 {
    let counter = AtomicI64.new(0)
    print(counter.load())
    counter.store(42)
    print(counter.load())

    // CAS: returns old value
    let old = counter.cas(42, 99)
    print(old)

    // Add/Sub
    counter.store(5)
    counter.add(5)
    print(counter.load())
    counter.sub(3)
    print(counter.load())
    counter.destroy()

    let flag = AtomicBool.new(false)
    print(flag.load())
    flag.store(true)
    print(flag.load())
    let _prev = flag.swap(false)
    print(flag.load())
    flag.destroy()

    return 0
}
