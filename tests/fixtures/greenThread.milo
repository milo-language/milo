// @expect: start
// @expect: spawned
// @expect: green 0
// @expect: green 1
// @expect: green 2
// @expect: green 3
// @expect: green 4
// @expect: green 5
// @expect: green 6
// @expect: green 7
// @expect: green 8
// @expect: green 9

from "std/runtime" import {
    Task
}
from "std/sync" import {
    WaitGroup
}

pub fn main(): i32 {
    print("start")
    let wg = WaitGroup.new()
    var i = 0
    while i < 10 {
        wg.add(1)
        let n = i
        Task.spawn(move(): void => {
            print("green " + n.toString())
            wg.done()
        }
        )
        i = i + 1
    }
    print("spawned")
    wg.wait()
    wg.destroy()
    return 0
}
