// @expect: name: double
// @expect: result: 10

fn double(x: i32): i32 {
    return x * 2
}

struct Op {
    name: string,
    apply: (i32) => i32,
}

fn useOps(ops: &Vec<Op>): void {
    let op = ops[0]
    print("name: ", op.name)
    print("result: ", op.apply(5))
}

fn main(): i32 {
    var ops: Vec<Op> = Vec.new()
    ops.push(Op {
        name: "double", apply: double
    }
    )
    useOps(ops)
    return 0
}
