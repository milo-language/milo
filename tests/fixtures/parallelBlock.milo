// @expect: 20
// @expect: 30
// @expect: 50

fn double(x: i64): i64 {
    return x * 2
}

fn triple(x: i64): i64 {
    return x * 3
}

fn main(): i32 {
    let base: i64 = 10
    parallel {
        let a = double(base)
        let b = triple(base)
    }
    print(a)
    print(b)
    print(a + b)
    return 0
}
