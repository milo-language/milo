// @expect: 7
extern fn printf(fmt: *u8, ...): i32

enum Shape {
    Circle(i32),
    Rectangle(i32, i32),
    Point,
}

fn main(): i32 {
    let s = Shape.Rectangle(3, 4)
    match s {
        Shape.Circle(r) => {
            printf("%d\n", r)
        }
        Shape.Rectangle(w, h) => {
            printf("%d\n", w + h)
        }
        Shape.Point => {
            printf("0\n")
        }
    }
    return 0
}
