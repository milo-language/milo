// @expect: 42
// @expect: none
// @expect: 99
// @expect: 2
// @expect: 100
from "std/arena" import {
    Arena, arenaAlloc, arenaFree, arenaGet, arenaLen, arenaNew
}

pub fn main(): i32 {
    var arena: Arena<i32> = arenaNew()
    let h1 = arenaAlloc(arena, 42)
    let h2 = arenaAlloc(arena, 99)

    match arenaGet(arena, h1) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    arenaFree(arena, h1)

    match arenaGet(arena, h1) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    match arenaGet(arena, h2) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // alloc reuses freed slot
    let h3 = arenaAlloc(arena, 100)
    print(arenaLen(arena))

    match arenaGet(arena, h3) {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    return 0
}
