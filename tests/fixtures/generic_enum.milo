// @expect: 42
extern fn printf(fmt: *u8, ...) -> i32

enum Option<T> {
    Some(T),
    None,
}

fn main() -> i32 {
    let x = Option::Some(42)
    match x {
        Option::Some(val) => {
            printf("%d\n", val)
        }
        Option::None => {
            printf("none\n")
        }
    }
    return 0
}
