// Trailing/separating ';' is a cosmetic no-op in Milo (statements are
// newline/grammar-delimited). The load-bearing ';' in `[T; N]` still works.
// @expect: 3
// @expect: 42

let g: i32 = 7

fn main(): i32 {
    let a: [i32; 3] = [1, 2, 3]
    print(a.len)
    let x: i32 = 6 * g
    let y: i32 = 0
    print(x)
    return y
}
