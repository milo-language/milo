// @expect: launch failed

// Launching a program that does not exist fails — but WHERE it fails differs by OS,
// and the fixture normalises both to the same observable outcome. On POSIX the exec
// can only fail post-fork inside the child, so spawn() succeeds and the failure shows
// up as a nonzero exit through wait(). On Windows CreateProcess resolves the program
// up front, so spawn() itself returns Err. Either way: the child never ran.

from "std/process" import {
    Child
}

fn main(): i32 {
    var args: Vec<string> = Vec.new()
    match Child.spawn("milo_no_such_binary_xyz", args, true) {
        Result.Ok(child) => {
            match child.wait() {
                Result.Ok(code) => {
                    if code != 0 {
                        print("launch failed")
                    } else {
                        print("unexpected success")
                    }
                }
                Result.Err(_msg) => {
                    print("launch failed")
                }
            }
            child.close()
        }
        Result.Err(_msg) => {
            print("launch failed")
        }
    }
    return 0
}
