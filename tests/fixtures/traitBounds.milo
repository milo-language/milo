// @expect: 99

pub trait HasValue {
    fn value(self: &Self): i32
}

pub struct Box99 {
    x: i32
}

impl HasValue for Box99 {
    fn value(self: &Self): i32 {
        return 99
    }
}

pub fn printValue < T: HasValue > (thing: &T) {
    print(thing.value())
}

pub fn main(): i32 {
    let b = Box99 {
        x: 0
    }
    printValue(b)
    return 0
}
