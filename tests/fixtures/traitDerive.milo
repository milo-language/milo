// @expect: 1
// @expect: 0

@derive(Eq)

struct Point {
    x: i32, y: i32
}

fn main(): i32 {
    let a = Point {
        x: 1, y: 2
    }
    let b = Point {
        x: 1, y: 2
    }
    let c = Point {
        x: 3, y: 4
    }
    if a.eq(b) {
        print("1")
    } else {
        print("0")
    }
    if a.eq(c) {
        print("1")
    } else {
        print("0")
    }
    return 0
}
