// @expect: 7
// @expect: 1
// @expect: 99
// @expect: 2
// @expect: 3
// @expect: 99
// @expect: 7
// @expect: 1
// @expect: 2
// @expect: 3
// Vec.insert(i, v) shifts right (grows as needed); Vec.remove(i) shifts left
// and returns the removed element.
fn main(): i32 {
    var v: Vec<i64> = [1, 2, 3]
    v.insert(1, 99)
    v.insert(0, 7)
    for i in 0..v.len() {
        print(v[i])
    }
    let r = v.remove(2)
    print(r)
    for i in 0..v.len() {
        print(v[i])
    }
    return 0
}
