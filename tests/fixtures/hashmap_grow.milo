// @expect: len: 20
// @expect: has 0: true
// @expect: has 19: true
// @expect: has 20: false

fn main(): i32 {
    var m: HashMap<i32, i32> = HashMap.new()
    var i: i32 = 0
    while i < 20 {
        m.insert(i, i * 10)
        i = i + 1
    }

    print("len: %ld", m.len)
    if m.contains(0) {
        print("has 0: true")
    } else {
        print("has 0: false")
    }
    if m.contains(19) {
        print("has 19: true")
    } else {
        print("has 19: false")
    }
    if m.contains(20) {
        print("has 20: true")
    } else {
        print("has 20: false")
    }
    return 0
}
