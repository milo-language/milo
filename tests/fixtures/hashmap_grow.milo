// @expect: len: 20
// @expect: has 0: true
// @expect: has 19: true
// @expect: has 20: false
extern fn printf(fmt: *u8, ...): i32

fn main(): i32 {
    var m: HashMap<i32, i32> = HashMap.new()
    var i: i32 = 0
    while i < 20 {
        m.insert(i, i * 10)
        i = i + 1
    }

    printf("len: %ld\n", m.len)
    if m.contains(0) {
        printf("has 0: true\n")
    } else {
        printf("has 0: false\n")
    }
    if m.contains(19) {
        printf("has 19: true\n")
    } else {
        printf("has 19: false\n")
    }
    if m.contains(20) {
        printf("has 20: true\n")
    } else {
        printf("has 20: false\n")
    }
    return 0
}
