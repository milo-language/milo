// @expect: value: 42
// @expect: leaf: 7

enum Tree {
    Node(Box<Tree>, Box<Tree>),
    Leaf(i32)
}

fn printBoxed(b: &Box<i32>) {
    print("value: ", * b)
}

fn printLeaf(t: &Box<Tree>) {
    match * t {
        Tree.Leaf(n) => {
            print("leaf: ", n)
        }
        Tree.Node(l, r) => {
        }
    }
}

fn main(): i32 {
    let b = Box(42)
    printBoxed(b)

    let t = Box(Tree.Leaf(7))
    printLeaf(t)
    return 0
}

