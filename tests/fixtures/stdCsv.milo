// @expect: 3
// @expect: name|age|city
// @expect: Alice|30|NYC
// @expect: Bob|25|SF
// @expect: a
// @expect: b,c
// @expect: d"e

from "std/csv" import {
    csvParse
}

fn main(): i32 {
    let data = "name,age,city\nAlice,30,NYC\nBob,25,SF\n"
    let rows = csvParse(data)
    print(rows.len.toString())

    var ri: i64 = 0
    while ri < rows.len {
        var ci: i64 = 0
        var rowStr = ""
        while ci < rows[ri].len {
            if ci > 0 {
                rowStr = rowStr + "|"
            }
            rowStr = rowStr + rows[ri][ci]
            ci = ci + 1
        }
        print(rowStr)
        ri = ri + 1
    }

    let quoted = "a,\"b,c\",\"d\"\"e\"\n"
    let qrows = csvParse(quoted)
    var qi: i64 = 0
    while qi < qrows[0].len {
        print(qrows[0][qi])
        qi = qi + 1
    }
    return 0
}
