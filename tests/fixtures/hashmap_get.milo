// @expect: got 42: 420
// @expect: key 99 not found
extern fn printf(fmt: *u8, ...) -> i32

enum Option<T> {
    Some(T),
    None,
}

fn main() -> i32 {
    var m: HashMap<i32, i32> = HashMap::new()
    m.insert(42, 420)
    m.insert(7, 70)

    let r1 = m.get(42)
    if let Option::Some(v) = r1 {
        printf("got 42: %d\n", v)
    } else {
        printf("42 not found\n")
    }

    let r2 = m.get(99)
    if let Option::Some(v) = r2 {
        printf("got 99: %d\n", v)
    } else {
        printf("key 99 not found\n")
    }
    return 0
}
