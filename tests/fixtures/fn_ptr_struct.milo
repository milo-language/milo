// @expect: double: 42
// @expect: triple: 30
fn double(x: i32): i32 {
    return x * 2
}

fn triple(x: i32): i32 {
    return x * 3
}

struct Handler {
    name: string,
    apply: fn(i32): i32,
}

fn main(): i32 {
    let h = Handler { name: "double", apply: double }
    let result = h.apply(21)
    print("%s: %d\n", h.name, result)
    let h2 = Handler { name: "triple", apply: triple }
    print("%s: %d\n", h2.name, h2.apply(10))
    return 0
}
