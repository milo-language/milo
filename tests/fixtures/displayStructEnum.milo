// @expect: User { name: "alice", age: 30, happy: true }
// @expect: Red
// @expect: Rgb(255, 128, 0)
// @expect: Some(42)
// @expect: None

pub struct User {
    name: string,
    age: i64,
    happy: bool,
}

pub enum Color {
    Red,
    Green,
    Blue,
    Rgb(u8, u8, u8),
}

pub fn main(): i32 {
    let u = User {
        name: "alice", age: 30, happy: true
    }
    print(u)

    let c1 = Color.Red
    let c2 = Color.Rgb(255 as u8, 128 as u8, 0 as u8)
    print(c1)
    print(c2)

    let someVal: Option<i64> = Option.Some(42 as i64)
    let noVal: Option<i64> = Option.None
    print(someVal)
    print(noVal)

    return 0
}
