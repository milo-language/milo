// @expect: sum 120

from "std/runtime" import {
    Task, Promise
}

fn main(): i32 {
    var promises: Vec<Promise<i64>> = Vec.new()

    var i: i64 = 1
    while i <= 3 {
        let val = i * 20
        promises.push(Promise<i64>.run(move(): i64 => {
            return val
        }
        ))
        i = i + 1
    }

    let results = Promise.all(promises).await()!
    var sum: i64 = 0
    for r in results {
        sum = sum + r
    }
    print("sum ", sum)
    return 0
}
