// @expect: size: 8
// @expect: io error: not found: missing.txt
// @expect: parse error: bad format

pub enum IoError {
    NotFound(string),
    PermissionDenied(string),
}

pub enum ParseError {
    BadFormat(string),
}

pub enum AppError {
    Io(IoError),
    Parse(ParseError),
}

pub fn readFile(path: string): Result<string, IoError> {
    if path == "missing.txt" {
        return Result.Err(IoError.NotFound(path))
    }
    return Result.Ok(path.clone())
}

pub fn parseData(s: string): Result<i32, ParseError> {
    if s == "bad.txt" {
        return Result.Err(ParseError.BadFormat("bad format"))
    }
    return Result.Ok(s.len as i32)
}

pub fn process(path: string): Result<i32, AppError> {
    let contents = readFile(path)?
    let size = parseData(contents)?
    return Result.Ok(size)
}

pub fn showError(e: AppError): void {
    match e {
        AppError.Io(io) => {
            match io {
                IoError.NotFound(p) => {
                    print("io error: not found: ", p)
                }
                IoError.PermissionDenied(p) => {
                    print("io error: denied: ", p)
                }
            }
        }
        AppError.Parse(pe) => {
            match pe {
                ParseError.BadFormat(m) => {
                    print("parse error: ", m)
                }
            }
        }
    }
}

pub fn main(): i32 {
    match process("data.txt") {
        Result.Ok(n) => {
            print("size: ", n)
        }
        Result.Err(e) => {
            showError(e)
        }
    }
    match process("missing.txt") {
        Result.Ok(n) => {
            print("size: ", n)
        }
        Result.Err(e) => {
            showError(e)
        }
    }
    match process("bad.txt") {
        Result.Ok(n) => {
            print("size: ", n)
        }
        Result.Err(e) => {
            showError(e)
        }
    }
    return 0
}
