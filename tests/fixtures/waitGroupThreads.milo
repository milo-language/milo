// @expect: both done

from "std/runtime" import {
    Promise
}
from "std/sync" import {
    WaitGroup
}

fn main(): i32 {
    let wg = WaitGroup.new()
    wg.add(2)
    let t1 = Promise<i64>.blocking(move(): i64 => {
        wg.done()
        return 0
    }
    )
    let t2 = Promise<i64>.blocking(move(): i64 => {
        wg.done()
        return 0
    }
    )
    wg.wait()
    print("both done")
    t1.await()!
    t2.await()!
    wg.destroy()
    return 0
}
