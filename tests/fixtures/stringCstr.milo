extern fn puts(s: *u8): i32

extern fn strlen(s: *u8): i64

fn main(): i32 {
    let msg = "hello cstr"

    // .cstr() returns *u8 without unsafe
    let ptr = msg.cstr()

    // passing *u8 to extern *u8 param is safe (ptr already exists)
    let len = strlen(ptr)
    if len == 10 {
        puts("length ok")
    }

    // string auto-coercion still works
    puts(msg)

    return 0
}

// @expect: length ok
// @expect: hello cstr
