// @expect: got 10
// @expect: got 20
// @expect: got 30
// @expect: main done

// Regression: main thread calls ch.recv() directly (not inside a spawned
// task) with only a green sender. Before the three-branch fix, recv fell
// through to pthread_cond_wait and deadlocked — nobody was driving the
// scheduler, so the green sender never ran. Now recv drives the scheduler
// itself when a scheduler exists on the main thread.
from "std/runtime" import {
    Task
}
from "std/sync" import {
    Channel
}

pub fn main(): i32 {
    let ch = Channel<i64>.new(1)!

    Task.spawn(move(): void => {
        var i: i64 = 1
        while i <= 3 {
            ch.send(i * 10)!
            i = i + 1
        }
    }
    )

    var n: i64 = 0
    while n < 3 {
        let v = ch.recv()!
        print("got ", v)
        n = n + 1
    }
    print("main done")
    return 0
}
