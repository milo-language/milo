// @expect: 42
// @expect: 42
// @expect: 99

from "std/sync" import { rwLockNew, rwLockRead, rwLockWrite, rwLockUnlock, withReadLock, withWriteLock, rwLockDestroy, atomicI64New, atomicI64Load, atomicI64Store, atomicI64Destroy }

fn main(): i32 {
    let rw = rwLockNew()!
    let val = atomicI64New(42)

    // Multiple readers can lock simultaneously
    rwLockRead(rw)!
    let v1 = atomicI64Load(val)
    rwLockUnlock(rw)!
    print(v1)

    // withReadLock closure
    withReadLock(rw, (): void => {
        print(atomicI64Load(val))
    })!

    // Exclusive write lock
    withWriteLock(rw, (): void => {
        atomicI64Store(val, 99)
    })!

    // Verify write
    rwLockRead(rw)!
    print(atomicI64Load(val))
    rwLockUnlock(rw)!

    atomicI64Destroy(val)
    rwLockDestroy(rw)
    return 0
}
