// @expect: 42
// @expect: 42
// @expect: 99

from "std/sync" import {
    RwLock, AtomicI64
}

fn main(): i32 {
    let rw = RwLock.new()!
    let val = AtomicI64.new(42)

    // Multiple readers can lock simultaneously
    rw.read()!
    let v1 = val.load()
    rw.unlock()!
    print(v1)

    // withReadLock closure
    rw.withReadLock((): void => {
        print(val.load())
    }
    )!

    // Exclusive write lock
    rw.withWriteLock((): void => {
        val.store(99)
    }
    )!

    // Verify write
    rw.read()!
    print(val.load())
    rw.unlock()!

    val.destroy()
    rw.destroy()
    return 0
}
