// @expect: alpha
// @expect: alpha

// match on *h through a borrowed Heap reads the pointee in place; it must not
// consume it. The owned-match path used to zero the pointee through the
// borrow, so a second read saw an empty payload (silently).
pub enum Ex {
    Name(string),
    Nil,
}

pub fn readName(h: &Heap<Ex>): string {
    match *h {
        Ex.Name(n) => {
            return n.clone()
        }
        Ex.Nil => {
            return "nil"
        }
    }
    return ""
}

pub fn main(): i32 {
    let h = Heap(Ex.Name("alpha"))
    print(readName(h))
    print(readName(h))
    return 0
}
