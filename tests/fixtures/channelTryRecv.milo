// @expect: none
// @expect: true
// @expect: 42
// @expect: 0

from "std/sync" import { channelNew, channelTrySend, channelTryRecv, channelLen, channelDestroy }

fn main(): i32 {
    let ch = channelNew(2)!

    // tryRecv on empty channel returns None
    let r1 = channelTryRecv(ch)
    match r1 {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    // trySend succeeds when not full
    let ok = channelTrySend(ch, 42)
    print(ok)

    // tryRecv gets the value
    let r2 = channelTryRecv(ch)
    match r2 {
        Option.Some(v) => { print(v) }
        Option.None => { print("none") }
    }

    // channelLen after drain
    print(channelLen(ch))

    channelDestroy(ch)
    return 0
}
