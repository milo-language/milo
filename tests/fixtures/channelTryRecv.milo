// @expect: none
// @expect: true
// @expect: 42
// @expect: 0

from "std/sync" import {
    Channel
}

fn main(): i32 {
    let ch = Channel<i64>.new(2)!

    // tryRecv on empty channel returns None
    let r1 = ch.tryRecv()
    match r1 {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // trySend succeeds when not full
    let ok = ch.trySend(42)
    print(ok)

    // tryRecv gets the value
    let r2 = ch.tryRecv()
    match r2 {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }

    // len after drain
    print(ch.len())

    ch.destroy()
    return 0
}
