// @expect: 16
// @expect: 2
// @expect: 8080
// @expect: 3232235777
// @expect: 0 0 0 0 0 0 0 0

struct SockAddrIn {
    sinLen: u8,
    sinFamily: u8,
    sinPort: u16,
    sinAddr: u32,
    sinZero: [u8; 8],
}

fn printAddr(a: &SockAddrIn): void {
    print(a.sinLen)
    print(a.sinFamily)
    print(a.sinPort)
    print(a.sinAddr)
    print(a.sinZero[0], " ", a.sinZero[1], " ", a.sinZero[2], " ", a.sinZero[3], " ", a.sinZero[4], " ", a.sinZero[5], " ", a.sinZero[6], " ", a.sinZero[7])
}

fn main(): i32 {
    let addr = SockAddrIn {
        sinLen: 16,
        sinFamily: 2,
        sinPort: 8080,
        sinAddr: 3232235777,
        sinZero: [0, 0, 0, 0, 0, 0, 0, 0],
    }
    printAddr(addr)
    return 0
}
