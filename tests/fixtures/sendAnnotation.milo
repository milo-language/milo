// @expect: 42

from "std/thread" import { spawn, threadJoin }

@send
struct SafeHandle {
    _ptr: *u8,
}

fn main(): i32 {
    unsafe {
        let h = SafeHandle { _ptr: 0 as *u8 }
        let t = spawn(move (): void => {
            let _x = h._ptr
        })!
        threadJoin(t)!
    }
    print(42)
    return 0
}
