// @expect: 42

from "std/runtime" import {
    Promise
}

struct SafeHandle {
    _ptr: *u8,
}

// Safety: this fixture uses only a null sentinel and never dereferences it.
unsafe

impl Send for SafeHandle {
}

fn main(): i32 {
    let h = SafeHandle {
        _ptr: 0 as *u8
    }
    let t = Promise<i64>.blocking(move(): i64 => {
        let _x = h._ptr
        return 0
    }
    )
    t.await()!
    print(42)
    return 0
}
