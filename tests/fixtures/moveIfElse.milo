// @expect: 1

pub struct Point {
    x: i32, y: i32
}

pub fn consume(p: Point): i32 {
    return p.x
}

pub fn main(): i32 {
    let p = Point {
        x: 1, y: 2
    }
    var result: i32 = 0
    if true {
        result = consume(p)
    } else {
        result = consume(p)
    }
    print(result)
    return 0
}
