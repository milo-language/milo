// @expect: got 42
// @expect: done

pub enum Option {
    Some(i32),
    None,
}

pub fn main(): i32 {
    let x = Option.Some(42)
    if let Option.Some(val) = x {
        print("got ", val)
    }

    let y = Option.None
    if let Option.Some(val) = y {
        print("should not print")
    }

    print("done")
    return 0
}
