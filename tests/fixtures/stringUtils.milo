// @expect: contains: true false true
// @expect: indexOf: 6 -1 0
// @expect: indexOfFrom: 14 -1
// @expect: startsWith: true false
// @expect: endsWith: true false
// @expect: toLower: hello world
// @expect: toUpper: HELLO WORLD
// @expect: trim: [hello]
// @expect: trimStart: [hello   ]
// @expect: trimEnd: [   hello]
// @expect: split: [hello] [world] [foo] 3
// @expect: splitChar: [a] [b] [c] 3
// @expect: repeat: ababab
// @expect: replace: hello universe
// @expect: isFuncs: true true false true
import "std/string"

fn boolStr(b: bool): string {
    if b {
        return "true"
    }
    return "false"
}

fn main(): i32 {
    let s = "hello world"

    // contains
    print("contains: ", boolStr(strContains(s, "world")), " ", boolStr(strContains(s, "xyz")), " ", boolStr(strContains(s, "")))

    // indexOf
    print("indexOf: ", strIndexOf(s, "world"), " ", strIndexOf(s, "xyz"), " ", strIndexOf(s, "hello"))

    // indexOfFrom
    let s2 = "hello world hello"
    print("indexOfFrom: ", strIndexOfFrom(s2, "llo", 5 as i64), " ", strIndexOfFrom(s2, "xyz", 0 as i64))

    // startsWith
    print("startsWith: ", boolStr(strStartsWith(s, "hello")), " ", boolStr(strStartsWith(s, "world")))

    // endsWith
    print("endsWith: ", boolStr(strEndsWith(s, "world")), " ", boolStr(strEndsWith(s, "hello")))

    // toLower / toUpper
    let lower = strToLower("HELLO WORLD")
    print("toLower: ", lower)
    let up = strToUpper("hello world")
    print("toUpper: ", up)

    // trim
    let padded = "   hello   "
    print("trim: [", strTrim(padded), "]")
    print("trimStart: [", strTrimStart(padded), "]")
    print("trimEnd: [", strTrimEnd(padded), "]")

    // split
    let csv = "hello,world,foo"
    let parts = strSplit(csv, ",")
    print("split: [", parts[0], "] [", parts[1], "] [", parts[2], "] ", parts.len)

    // split by char
    let abc = "a:b:c"
    let abcParts = strSplit(abc, ":")
    print("splitChar: [", abcParts[0], "] [", abcParts[1], "] [", abcParts[2], "] ", abcParts.len)

    // repeat
    print("repeat: ", strRepeat("ab", 3))

    // replace
    print("replace: ", strReplace(s, "world", "universe"))

    // is_* functions
    print("isFuncs: ", boolStr(charIsDigit(48)), " ", boolStr(charIsAlpha(65)), " ", boolStr(charIsWhitespace(65)), " ", boolStr(charIsAlphanumeric(57)))

    return 0
}

