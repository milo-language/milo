// @expect: len: 3
// @expect: has 2: true
// @expect: removed
// @expect: len: 2
// @expect: has 2: false
// @expect: has 1: true
// @expect: has 3: true

fn main(): i32 {
    var m: HashMap<i32, i32> = HashMap.new()
    m.insert(1, 10)
    m.insert(2, 20)
    m.insert(3, 30)

    print("len: %ld\n", m.len)
    if m.contains(2) {
        print("has 2: true\n")
    } else {
        print("has 2: false\n")
    }

    m.remove(2)
    print("removed\n")
    print("len: %ld\n", m.len)

    if m.contains(2) {
        print("has 2: true\n")
    } else {
        print("has 2: false\n")
    }
    if m.contains(1) {
        print("has 1: true\n")
    } else {
        print("has 1: false\n")
    }
    if m.contains(3) {
        print("has 3: true\n")
    } else {
        print("has 3: false\n")
    }
    return 0
}
