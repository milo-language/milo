// @expect: double: 42
// @expect: triple: 30

pub fn double(x: i32): i32 {
    return x * 2
}

pub fn triple(x: i32): i32 {
    return x * 3
}

pub struct Handler {
    name: string,
    apply: (i32) => i32,
}

pub fn main(): i32 {
    let h = Handler {
        name: "double", apply: double
    }
    let result = h.apply(21)
    print(h.name, ": ", result)
    let h2 = Handler {
        name: "triple", apply: triple
    }
    print(h2.name, ": ", h2.apply(10))
    return 0
}
