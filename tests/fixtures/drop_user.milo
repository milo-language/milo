// @expect: using 1 2
// @expect: drop 1
// @expect: drop 2

struct Resource {
    id: i32,
}

impl Drop for Resource {
    fn drop(self: &mut Self): void {
        print("drop %d", self.id)
    }
}

fn main(): i32 {
    let r1 = Resource { id: 1 }
    let r2 = Resource { id: 2 }
    print("using %d %d", r1.id, r2.id)
    return 0
}
