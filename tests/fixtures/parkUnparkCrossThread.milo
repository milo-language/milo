// @skip-os: win32
// the green scheduler's event loop is kqueue/epoll readiness-based; Windows
// needs the IOCP completion port rewrite (docs/roadmap.md).

// @expect: parking
// @expect: resumed

from "std/runtime" import {
    Task, Promise, schedulerCurrent, schedulerPark, schedulerUnpark, schedulerRunToCompletion
}
from "std/time" import {
    sleepMs
}
from "std/sync" import {
    AtomicI64
}

fn main(): i32 {
    let slot = AtomicI64.new(0)

    Task.spawn(move(): void => {
        slot.store(schedulerCurrent() as i64)
        print("parking")
        schedulerPark()
        print("resumed")
    }
    )

    // foreign OS thread unparks the task via the transfer list + wakeup event
    // (fire-and-forget — it finishes before the task resumes, handle unused)
    let _t = Promise<i64>.blocking(move(): i64 => {
        while slot.load() == 0 {
        }
        // give the task time to actually reach schedulerPark after storing slot
        sleepMs(50)
        unsafe {
            schedulerUnpark(slot.load() as *u8)
        }
        return 0
    }
    )

    schedulerRunToCompletion()
    return 0
}
