// @expect: task got 7
// @expect: sender resumed

// cross-world wakes both directions: a foreign OS-thread send unparks a green
// task blocked in recv (via the scheduler wakeup event), and a foreign-thread
// recv unparks a green task blocked in send on a full channel. The OS threads
// come from Promise.blocking (fire-and-forget — they finish before the tasks
// they wake, so their handles are unused).
from "std/runtime" import {
    Task, Promise, schedulerRunToCompletion
}
from "std/time" import {
    sleepMs
}
from "std/sync" import {
    Channel
}

fn main(): i32 {
    let ch = Channel<i64>.new(1)!
    Task.spawn(move(): void => {
        let v = ch.recv()!
        print("task got ", v)
    }
    )
    let _t1 = Promise<i64>.blocking(move(): i64 => {
        // give the task time to park in recv first
        sleepMs(50)
        ch.send(7)!
        return 0
    }
    )

    let ch2 = Channel<i64>.new(1)!
    ch2.send(1)!
    Task.spawn(move(): void => {
        ch2.send(2)!
        print("sender resumed")
    }
    )
    let _t2 = Promise<i64>.blocking(move(): i64 => {
        sleepMs(100)
        let _a = ch2.recv()!
        let _b = ch2.recv()!
        return 0
    }
    )

    schedulerRunToCompletion()
    return 0
}
