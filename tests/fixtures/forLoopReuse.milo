fn main(): i32 {
    var v1: Vec<i32> = Vec.new()
    v1.push(1)
    v1.push(2)
    for x in v1 {
        print(x)
    }

    var v2: Vec<i32> = Vec.new()
    v2.push(3)
    v2.push(4)
    for x in v2 {
        print(x)
    }

    for i in 0..3 {
        print(i)
    }
    for i in 5..8 {
        print(i)
    }

    return 0
}
