// @expect: hello pipe

// std/process is fork/exec on POSIX and CreateProcess on Windows; the Child pipe API
// is identical either way. `cat` is a stdin->stdout passthrough on POSIX; `sort` is
// the closest Windows-native equivalent and echoes a single line unchanged.

from "std/process" import {
    Child
}

fn main(): i32 {
    var args: Vec<string> = Vec.new()
    let prog = if @targetOs() == "windows" {
        "sort"
    } else {
        "cat"
    }
    match Child.spawn(prog, args, true) {
        Result.Ok(child) => {
            let _w = child.writeStdinStr("hello pipe\n")
            child.closeStdin()

            var out: string = String.withCapacity(64)
            var buf: [u8; 256] = [0; 256]
            while true {
                var n: i64 = 0
                unsafe {
                    n = child.readStdout(buf as *u8, 256)
                }
                if n <= 0 {
                    break
                }
                for i in 0..n {
                    if buf[i] != 10 {
                        out.push(buf[i])
                    }
                }
            }
            print(out)
            let _s = child.wait()
            child.close()
        }
        Result.Err(msg) => {
            print($"spawn error: {msg}")
        }
    }
    return 0
}
