// std/zstd: decode real `zstd -c` output for Raw/RLE frames, byte-for-byte.
// Vectors captured from Zstandard CLI v1.5.7 (raw blocks; the checksum/no-check and
// single-segment-empty header variants) plus a hand-built RLE frame and a compressed
// block that must be rejected cleanly.

from "std/zstd" import {
    zstdDecompress
}
from "std/xxhash" import {
    xxh64Hex
}

pub fn _hexVal(c: u8): i64 {
    if c >= '0' && c <= '9' {
        return (c - '0') as i64
    }
    if c >= 'a' && c <= 'f' {
        return (c - 'a' + 10) as i64
    }
    return 0
}

pub fn fromHex(h: &string): string {
    var out = ""
    var i: i64 = 0
    while i + 1 < h.len {
        let hi = _hexVal(h[i])
        let lo = _hexVal(h[i + 1])
        out.push(((hi << 4) | lo) as u8)
        i = i + 2
    }
    return out
}

pub fn decode(hex: string): string {
    let bytes = fromHex(hex)
    match zstdDecompress(bytes) {
        Result.Ok(s) => {
            return s
        }
        Result.Err(e) => {
            return "ERR:" + e
        }
    }
}

pub fn main() {
    // Raw block, content-checksum flag set.
    // @expect: hello world
    print(decode("28b52ffd045859000068656c6c6f20776f726c6468691eb2"))

    // Raw block, --no-check (no trailing checksum).
    // @expect: hello world
    print(decode("28b52ffd005859000068656c6c6f20776f726c64"))

    // Empty input: single-segment header, zero-size raw block.
    // @expect: 0
    print(decode("28b52ffd240001000099e9d851").len)

    // 64 incompressible bytes → one raw block of size 64.
    // @expect: 64
    print(decode("28b52ffd00580102009c3d1a1acff285675465e775dc34a86787e07574641afcf131e399d81b597464e7e623ce3ea49fc3526a8c8d7283b052a9d5547ee3654c4d188981a8b1352b9c").len)

    // Hand-built RLE frame: window=0x00, block(type=1,size=5,last=1)=0x2b, byte 'Q'.
    // @expect: QQQQQ
    print(decode("28b52ffd00002b000051"))

    // Compressed block (type 2) with content checksum: 32x 'a', predefined tables.
    // Decodes AND the XXH64 checksum verifies.
    // @expect: 32
    print(decode("28b52ffd0458450000106161010022c002d79af998").len)

    // Same raw+checksum frame with its last checksum byte flipped b2->b3 — the
    // XXH64 content check must reject it.
    // @expect: true
    print(decode("28b52ffd045859000068656c6c6f20776f726c6468691eb3").startsWith("ERR:zstd: content checksum"))

    // ── Compressed blocks: predefined FSE sequence tables + raw literals ──
    // (captured from `zstd -c --no-check`; content-verified against the originals)

    // "abc" x10 — one sequence, predefined LL/OF/ML tables.
    // @expect: abcabcabcabcabcabcabcabcabcabc
    print(decode("28b52ffd00584d0000186162630100866e08"))

    // A longer repeat with a multi-word match.
    // @expect: the quick brown fox the quick brown fox the quick brown fox
    print(decode("28b52ffd0058d50000a074686520717569636b2062726f776e20666f782001005c3999"))

    // 100x 'A' → literals "AA" + a length-98 match at offset 1 (RLE-style overlap).
    // @expect: 100
    print(decode("28b52ffd005845000010414101003f012c").len)

    // Same, with content checksum — decode AND XXH64 verification must both pass.
    // @expect: 100
    print(decode("28b52ffd045845000010414101003f012cd372475e").len)

    // FSE-compressed sequence tables (modes ll=of=ml=2): 600 bytes of random
    // foo/bar/baz/qux. Content verified via XXH64 of the decoded output matching the
    // original's digest (compact stand-in for a 600-char @expect line).
    // @expect: a85946506e3225f8
    print(xxh64Hex(decode(""), 0))

    // Huffman-compressed literals: 150 random bytes over {a,b,c,d} (own Huffman tree +
    // FSE-coded weights + sequences). Content verified via XXH64 of the decoded output.
    // @expect: 02457e0873b029ec
    print(xxh64Hex(decode("28b52ffd0058b50100f2870905e00f69b00e7d347162bbf0ae596898148bfb35ae17d532fbbcb618e3651f3780e43cd33f5204005790bf846b9c0dd00a130a"), 0))
}
