// @expect: --- fail path ---
// @expect: failing early
// @expect: drop 1
// @expect: drop 2
// @expect: --- success path ---
// @expect: success
// @expect: drop 1
// @expect: drop 2

struct Guard {
    id: i32,
}

impl Drop for Guard {
    fn drop(self: &mut Self): void {
        print("drop ", self.id)
    }
}

fn mightFail(fail: bool): i32 {
    let g1 = Guard { id: 1 }
    let g2 = Guard { id: 2 }
    if fail {
        print("failing early")
        return -1
    }
    print("success")
    return 0
}

fn main(): i32 {
    print("--- fail path ---")
    mightFail(true)
    print("--- success path ---")
    mightFail(false)
    return 0
}
