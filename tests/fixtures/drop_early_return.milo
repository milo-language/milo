// @expect: --- fail path ---
// @expect: failing early
// @expect: drop 1
// @expect: drop 2
// @expect: --- success path ---
// @expect: success
// @expect: drop 1
// @expect: drop 2
extern fn printf(fmt: *u8, ...): i32

struct Guard {
    id: i32,
}

impl Drop for Guard {
    fn drop(self: &mut Self): void {
        printf("drop %d\n", self.id)
    }
}

fn might_fail(fail: bool): i32 {
    let g1 = Guard { id: 1 }
    let g2 = Guard { id: 2 }
    if fail {
        printf("failing early\n")
        return -1
    }
    printf("success\n")
    return 0
}

fn main(): i32 {
    printf("--- fail path ---\n")
    might_fail(true)
    printf("--- success path ---\n")
    might_fail(false)
    return 0
}
