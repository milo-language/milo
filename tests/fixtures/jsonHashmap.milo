// @expect: name=milo
// @expect: version=1
// @expect: missing=no

pub enum JsonValue {
    Null,
    Bool(bool),
    Number(i64),
    Str(string),
    Object(HashMap<string, Heap<JsonValue>>),
}

pub fn isWs(ch: u8): bool {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

pub fn isDigit(ch: u8): bool {
    return ch >= '0' && ch <= '9'
}

pub fn skipWs(s: &string, pos: &mut i64) {
    while pos < s.len && isWs(s[pos]) {
        pos = pos + 1
    }
}

pub fn parseValue(s: &string, pos: &mut i64): Heap<JsonValue> {
    skipWs(s, pos)
    if pos >= s.len {
        return Heap(JsonValue.Null)
    }
    let ch = s[pos]
    if ch == '"' {
        return parseString(s, pos)
    }
    if ch == '{' {
        return parseObject(s, pos)
    }
    if ch == 't' {
        pos = pos + 4
        return Heap(JsonValue.Bool(true))
    }
    if ch == 'f' {
        pos = pos + 5
        return Heap(JsonValue.Bool(false))
    }
    if ch == 'n' {
        pos = pos + 4
        return Heap(JsonValue.Null)
    }
    if isDigit(ch) || ch == '-' {
        return parseNumber(s, pos)
    }
    return Heap(JsonValue.Null)
}

pub fn parseNumber(s: &string, pos: &mut i64): Heap<JsonValue> {
    var neg: bool = false
    if s[pos] == '-' {
        neg = true
        pos = pos + 1
    }
    var n: i64 = 0
    while pos < s.len && isDigit(s[pos]) {
        n = n * 10 + (s[pos] as i64 - '0' as i64)
        pos = pos + 1
    }
    if neg {
        n = 0 - n
    }
    return Heap(JsonValue.Number(n))
}

pub fn parseString(s: &string, pos: &mut i64): Heap<JsonValue> {
    let value = parseStringRaw(s, pos)
    return Heap(JsonValue.Str(value))
}

pub fn parseStringRaw(s: &string, pos: &mut i64): string {
    pos = pos + 1
    var result: string = ""
    while pos < s.len && s[pos] != '"' {
        if s[pos] == '\\' {
            pos = pos + 1
        }
        result.push(s[pos])
        pos = pos + 1
    }
    pos = pos + 1
    return result
}

pub fn parseObject(s: &string, pos: &mut i64): Heap<JsonValue> {
    pos = pos + 1
    var entries: HashMap<string, Heap<JsonValue>> = HashMap.new()
    skipWs(s, pos)
    if pos < s.len && s[pos] != '}' {
        skipWs(s, pos)
        let k1 = parseStringRaw(s, pos)
        skipWs(s, pos)
        pos = pos + 1
        let v1 = parseValue(s, pos)
        entries.insert(k1, v1)
        skipWs(s, pos)
        while pos < s.len && s[pos] == ',' {
            pos = pos + 1
            skipWs(s, pos)
            let k = parseStringRaw(s, pos)
            skipWs(s, pos)
            pos = pos + 1
            let v = parseValue(s, pos)
            entries.insert(k, v)
            skipWs(s, pos)
        }
    }
    pos = pos + 1
    return Heap(JsonValue.Object(entries))
}

pub fn main(): i32 {
    let input: string = "{\"name\": \"milo\", \"version\": 1, \"active\": true}"
    var pos: i64 = 0
    let result = parseValue(input, pos)
    match *result {
        JsonValue.Object(obj) => {
            let r1 = obj.get("name")
            if let Option.Some(val) = r1 {
                match *val {
                    JsonValue.Str(s) => {
                        print("name=", s)
                    }
                    _ => {
                        print("name=?")
                    }
                }
            }
            let r2 = obj.get("version")
            if let Option.Some(val) = r2 {
                match *val {
                    JsonValue.Number(n) => {
                        print("version=", n)
                    }
                    _ => {
                        print("version=?")
                    }
                }
            }
            let r3 = obj.get("missingKey")
            if let Option.Some(val) = r3 {
                print("missing=yes")
            } else {
                print("missing=no")
            }
        }
        _ => {
            print("not an object")
        }
    }
    return 0
}
