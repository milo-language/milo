// @expect: {"name":"Chad","age":30,"score":3.14,"active":true}

struct User {
    name: string,
    age: i32,
    score: f64,
    active: bool,
}

fn main(): i32 {
    let user = User { name: "Chad", age: 30, score: 3.14, active: true }
    let json = json_stringify(user)
    print("%s", json)
    return 0
}
