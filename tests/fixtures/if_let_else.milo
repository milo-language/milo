// @expect: got 10
// @expect: was none

enum Option {
    Some(i32),
    None,
}

fn main(): i32 {
    let a = Option.Some(10)
    if let Option.Some(v) = a {
        print("got %d\n", v)
    } else {
        print("was none\n")
    }

    let b = Option.None
    if let Option.Some(v) = b {
        print("got value\n")
    } else {
        print("was none\n")
    }

    return 0
}
