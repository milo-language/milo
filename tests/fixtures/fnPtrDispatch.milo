// @expect: double(7) = 14
// @expect: triple(7) = 21

fn double(x: i32): i32 {
    return x * 2
}

fn triple(x: i32): i32 {
    return x * 3
}

struct Op {
    name: string,
    apply: (i32) => i32,
}

fn dispatch(ops: &Vec<Op>, x: i32): void {
    var i: i64 = 0
    while i < ops.len {
        let op = ops[i]
        print(op.name, "(", x, ") = ", op.apply(x))
        i = i + 1
    }
}

fn run(f: (i32) => void, x: i32): void {
    f(x)
}

fn main(): i32 {
    var ops: Vec<Op> = Vec.new()
    ops.push(Op {
        name: "double", apply: double
    }
    )
    ops.push(Op {
        name: "triple", apply: triple
    }
    )

    run((x: i32) => {
        dispatch(ops, x)
    }
    , 7)
    return 0
}

