// @expect: 30
// @expect: 2
// @expect: 20
// @expect: 1

fn main(): i32 {
    var v: Vec<i32> = Vec.new()
    v.push(10)
    v.push(20)
    v.push(30)

    let a = v.pop()
    print("%d\n", a)
    print("%lld\n", v.len)

    let b = v.pop()
    print("%d\n", b)
    print("%lld\n", v.len)

    return 0
}
