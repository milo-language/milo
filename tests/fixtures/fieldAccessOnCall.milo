// @expect: 42
// @expect: hello
// @expect: 99

pub struct Pair {
    x: i32,
    y: i32,
}

pub struct Named {
    name: string,
    value: i64,
}

pub fn makePair(): Pair {
    return Pair {
        x: 42, y: 99
    }
}

pub fn makeNamed(): Named {
    return Named {
        name: "hello", value: 99
    }
}

pub fn main(): i32 {
    let x = makePair().x
    print(x)
    let name = makeNamed().name
    print(name)
    let val = makeNamed().value
    print(val)
    return 0
}
