// @expect: len:3
// @expect: popped:30
// @expect: popped:20
// @expect: len:1

pub struct Stack<T> {
    items: Vec<T>,
}

pub fn stackPush<T>(s: &mut Stack<T>, val: T): void {
    s.items.push(val)
}

pub fn stackPop<T>(s: &mut Stack<T>): Option<T> {
    return s.items.pop()
}

pub fn stackLen<T>(s: &Stack<T>): i64 {
    return s.items.len()
}

pub fn main(): i32 {
    var s: Stack<i64> = Stack {
        items: Vec.new()
    }
    stackPush(s, 10)
    stackPush(s, 20)
    stackPush(s, 30)
    print("len:", stackLen(s))

    match stackPop(s) {
        Option.Some(val) => {
            print("popped:", val)
        }
        Option.None => {
            print("empty")
        }
    }

    match stackPop(s) {
        Option.Some(val) => {
            print("popped:", val)
        }
        Option.None => {
            print("empty")
        }
    }

    print("len:", stackLen(s))
    return 0
}
