// @expect: 99

pub extern fn qsort(base: *u8, num: i64, size: i64, cmp: *u8): void

pub fn cmpI32(a: *u8, b: *u8): i32 {
    unsafe {
        let va = *(a as *i32)
        let vb = *(b as *i32)
        return va - vb
    }
}

pub fn main(): i32 {
    var arr: [i32; 5] = [0; 5]
    arr[0] = 50
    arr[1] = 10
    arr[2] = 99
    arr[3] = 30
    arr[4] = 70
    unsafe {
        qsort((arr[0].addrOf()) as *u8, 5, 4, cmpI32 as *u8)
    }
    // sorted: 10 30 50 70 99 — last element is max
    print(arr[4])
    return 0
}
