// @expect: hello from thread
// @expect: value is 42
// @expect: done

from "std/runtime" import {
    Promise
}

pub fn main(): i32 {
    let msg = "hello from thread"
    let val: i64 = 42

    let t = Promise<i64>.blocking(move(): i64 => {
        print(msg)
        print("value is ", val)
        return 0
    }
    )

    t.await()!
    print("done")
    return 0
}
