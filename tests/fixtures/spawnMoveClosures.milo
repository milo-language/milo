// @expect: hello from thread
// @expect: value is 42
// @expect: done

import "std/thread"

fn main(): i32 {
    let msg = "hello from thread"
    let val: i64 = 42

    let t = spawn(move (): void => {
        print(msg)
        print("value is ", val)
    })!

    threadJoin(t)!
    print("done")
    return 0
}
