// closure capturing an immutable local
extern fn printf(fmt: *u8, ...) -> i32

fn apply(f: fn(i32) -> i32, x: i32) -> i32 {
    return f(x)
}

fn main() -> i32 {
    let multiplier: i32 = 3
    let result = apply((x: i32) => x * multiplier, 14)
    printf("%d\n", result)
    return 0
}
// @expect: 42
