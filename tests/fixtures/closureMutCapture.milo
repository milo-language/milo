// closure mutating a captured var — visible outside

pub fn callIt(f: () => void) {
    f()
}

pub fn main(): i32 {
    var count: i32 = 0
    callIt(() => {
        count = count + 1
    }
    )
    callIt(() => {
        count = count + 1
    }
    )
    callIt(() => {
        count = count + 1
    }
    )
    print(count)
    return 0
}
// @expect: 3
