// @expect: equal
// @expect: not equal

pub fn main(): i32 {
    let a = "hello"
    let b = "hello"
    let c = "world"
    if a == b {
        print("equal")
    } else {
        print("nope")
    }
    if a != c {
        print("not equal")
    } else {
        print("nope")
    }
    return 0
}
