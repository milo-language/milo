// @expect: none
extern fn printf(fmt: *u8, ...): i32

fn try_double(opt: i32?): i32? {
    let val = opt?
    return Option.Some(val * 2)
}

fn main(): i32 {
    let result = try_double(Option.None)
    match result {
        Option.Some(v) => {
            printf("%d\n", v)
        }
        Option.None => {
            printf("none\n")
        }
    }
    return 0
}
