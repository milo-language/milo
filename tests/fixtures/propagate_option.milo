// @expect: none

fn try_double(opt: i32?): i32? {
    let val = opt?
    return Option.Some(val * 2)
}

fn main(): i32 {
    let result = try_double(Option.None)
    match result {
        Option.Some(v) => {
            print("%d", v)
        }
        Option.None => {
            print("none")
        }
    }
    return 0
}
