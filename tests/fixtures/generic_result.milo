// @expect: error: 404

enum Result<T, E> {
    Ok(T),
    Err(E),
}

fn main(): i32 {
    let r: Result<i32, i32> = Result.Err(404)
    match r {
        Result.Ok(val) => {
            print("ok: ", val)
        }
        Result.Err(code) => {
            print("error: ", code)
        }
    }
    return 0
}
