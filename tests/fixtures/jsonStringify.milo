// @expect: {"name":"Chad","age":30,"score":3.14,"active":true}

pub struct User {
    name: string,
    age: i32,
    score: f64,
    active: bool,
}

pub fn main(): i32 {
    let user = User {
        name: "Chad", age: 30, score: 3.14, active: true
    }
    let json = jsonStringify(user)
    print(json)
    return 0
}
