// Pointer depth > 1 is representable: **u8 is distinct from *u8 (regression — they
// used to collapse to the same type because isPtr was a boolean, not a count).
// Vec<*u8>.ptr() yields **u8; deref once to *u8, once more to the byte.
pub fn main(): void {
    var v: Vec<*u8> = Vec.new()
    let s = "hi"
    unsafe {
        v.push(s.cstr())
        let pp: **u8 = v.ptr()
        let first: *u8 = pp[0]
        // @expect: 104
        print(first[0] as i64)
    }
}
