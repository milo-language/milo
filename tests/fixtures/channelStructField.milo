// @expect: hello from worker
// @expect: done

from "std/runtime" import {
    Promise
}
from "std/sync" import {
    Channel
}

struct Worker {
    ch: Channel<string>
}

fn main(): i32 {
    let ch = Channel<string>.new(8)!
    let w = Worker {
        ch: ch
    }

    let t = Promise<i64>.blocking(move(): i64 => {
        w.ch.send("hello from worker")!
        return 0
    }
    )

    let msg = w.ch.recv()!
    print(msg)
    t.await()!
    w.ch.destroy()
    print("done")
    return 0
}
