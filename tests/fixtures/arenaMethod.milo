// @expect: Alice
// @expect: Bob
// @expect: gone
// @expect: updated
// @expect: true
// @expect: false
from "std/arena" import {
    Arena, Handle, arenaNew
}

fn main(): i32 {
    var names: Arena<string> = arenaNew()

    let a = names.alloc("Alice")
    let b = names.alloc("Bob")

    print(names.get(a)!)
    print(names.get(b)!)

    // free + stale handle
    names.free(a)
    match names.get(a) {
        Option.Some(n) => {
            print(n)
        }
        Option.None => {
            print("gone")
        }
    }

    // set
    names.set(b, "updated")
    print(names.get(b)!)

    // handle equality via @derive(Eq)
    var nums: Arena<i64> = arenaNew()
    let h1 = nums.alloc(42)
    let h2: Handle<i64> = Handle {
        arenaId: h1.arenaId, index: h1.index, generation: h1.generation
    }
    print(h1 == h2)

    let h3 = nums.alloc(99)
    print(h2 == h3)

    return 0
}
