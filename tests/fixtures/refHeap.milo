// @expect: value: 42
// @expect: leaf: 7

enum Tree {
    Node(Heap<Tree>, Heap<Tree>),
    Leaf(i32)
}

fn printHeaped(b: &Heap<i64>) {
    print("value: ", *b)
}

fn printLeaf(t: &Heap<Tree>) {
    match *t {
        Tree.Leaf(n) => {
            print("leaf: ", n)
        }
        Tree.Node(l, r) => {
        }
    }
}

fn main(): i32 {
    let b = Heap(42)
    printHeaped(b)

    let t = Heap(Tree.Leaf(7))
    printLeaf(t)
    return 0
}
