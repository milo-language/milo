// @expect: bob
// Returning a concrete boxed value where the fn's return type is a boxed
// interface coerces to the trait object (parity with let-bindings / call args).
pub interface Greeter {
    fn name(self: &Self): string
}

pub struct P {
    n: string
}

impl P {
    fn name(self: &Self): string {
        return self.n.clone()
    }
}

pub fn mk(): Heap<Greeter> {
    return Heap(P {
        n: "bob"
    }
    )
}

pub fn main(): i32 {
    let g = mk()
    print(g.name())
    return 0
}
