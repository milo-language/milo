// @expect: 3
// @expect: 2
// @expect: 1
// @expect: true
// @expect: true

from "std/pool" import {
    Pool, poolNew, poolAlloc, poolFree, poolLive, poolAvailable, poolFull, poolEmpty, poolReset
}

fn main(): i32 {
    var pool = poolNew(16, 3)!

    print(pool.live())
    let a = pool.alloc()!
    print(pool.live())
    let b = pool.alloc()!
    print(pool.live())
    let c = pool.alloc()!
    print(pool.live())

    pool.free(b)
    print(pool.live())
    pool.free(a)
    print(pool.live())

    print(pool.full() == false)

    pool.reset()
    print(pool.empty())

    return 0
}
