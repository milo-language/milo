// @expect: 4660
// @expect: 6
// @expect: 2147483648

// Context-free int literals default to i64, so they mix with i64 values without an `as` cast.
// Before the i64 default these arms/counters were i32 and `reg & mask` / `i < len` needed casts.
pub fn main(): i32 {
    let reg: i64 = 0x1234
    let wide = true
    let mask = if wide {
        0xFFFF
    } else {
        0xFF
    } // if-arms are context-free -> i64
    let masked = reg & mask // i64 & i64, no cast
    print(masked)

    var sum: i64 = 0
    for i in 0..4 { // loop counter context-free -> i64, adds into i64 sum
        sum = sum + i
    }
    print(sum)

    let x = 2147483647 + 1 // fits i64; would have overflowed the old i32 default
    print(x)
    return 0
}
