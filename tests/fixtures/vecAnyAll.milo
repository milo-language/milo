// @expect: any: true
// @expect: all: false
// @expect: any: false
// @expect: all: true
fn main(): i32 {
    var nums: Vec<i32> = Vec.new()
    nums.push(1)
    nums.push(2)
    nums.push(3)
    print("any: ", nums.any((n: &i32) => n > 2))
    print("all: ", nums.all((n: &i32) => n > 1))
    print("any: ", nums.any((n: &i32) => n > 100))
    print("all: ", nums.all((n: &i32) => n > 0))
    return 0
}
