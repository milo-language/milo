pub extern fn puts(s: *u8): i32

pub extern fn malloc(size: i64): *u8

pub extern struct Point {
    x: i32,
    y: i32,
}

pub fn main(): i32 {
    unsafe {
        let p = malloc(8) as *Point

        // write through pointer
        p.x = 10
        p.y = 20

        // read through pointer
        if p.x == 10 && p.y == 20 {
            puts("ptr field access ok")
        }
    }
    return 0
}

// @expect: ptr field access ok
