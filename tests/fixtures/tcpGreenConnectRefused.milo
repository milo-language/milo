// @skip-os: win32
// Links for Windows now (std/net carries no OpenSSL after the std/fetch split), and
// the successful green socket path runs clean under Wine (greenThreadEcho) — but Wine
// crashes emulating FD_CONNECT for a *refused* non-blocking connect (exit 9, no output),
// which is the exact case this fixture tests. Real Windows reports a refused connect via
// FD_CONNECT/SO_ERROR; test-windows is the authority, so unskip once it confirms there.

// @expect: connect failed
// @expect: after

// green-aware connect: a refused connection from inside a task reports an
// error via SO_ERROR after parking on writability — it must not hang
from "std/runtime" import {
    Task
}
from "std/net" import {
    TcpStream, ip4
}

pub fn main(): i32 {
    let t = Task.spawn(move(): void => {
        match TcpStream.connect(ip4(127, 0, 0, 1), 1) {
            Result.Ok(_) => {
                print("connected")
            }
            Result.Err(_) => {
                print("connect failed")
            }
        }
        print("after")
    }
    )
    t.join()
    return 0
}
