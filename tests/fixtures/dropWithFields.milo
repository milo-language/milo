// @expect: connected: fd=42
// @expect: closing connection 42

struct Connection {
    name: string,
    fd: i32,
}

impl Drop for Connection {
    fn drop(self: &mut Self): void {
        print("closing connection ", self.fd)
    }
}

fn main(): i32 {
    let c = Connection {
        name: "db", fd: 42
    }
    print("connected: fd=", c.fd)
    return 0
}

