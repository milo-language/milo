// @expect: found: 42
// @expect: missing

fn main(): i32 {
    var m: HashMap<string, i64> = HashMap.new()
    m.insert("hello", 42)
    m.insert("world", 99)
    let r1 = m.get("hello")
    if let Option.Some(v) = r1 {
        print("found: %lld", v)
    }
    let r2 = m.get("missing")
    if let Option.Some(v) = r2 {
        print("found: %lld", v)
    } else {
        print("missing")
    }
    return 0
}
