// structs mixing float and integer fields — per-eightbyte SSE/INTEGER classification
pub extern struct M1 {
    d: f64,
    i: i64,
}

pub extern struct M2 {
    i: i32,
    f: f32,
}

pub extern fn m1_use(m: M1): f64

pub extern fn m1_make(d: f64, i: i64): M1

pub extern fn m2_use(m: M2): f32

pub fn main(): i32 {
    print(m1_use(M1 {
        d: 10.0, i: 5
    }
    ))
    let m = m1_make(3.0, 4)
    print(m1_use(m))
    print(m2_use(M2 {
        i: 6, f: 7.0
    }
    ))
    return 0
}
// @expect: 15
// @expect: 7
// @expect: 13
