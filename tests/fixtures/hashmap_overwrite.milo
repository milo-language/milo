// @expect: len: 1
// @expect: has key: true

fn main(): i32 {
    var m: HashMap<i32, i32> = HashMap.new()
    m.insert(1, 100)
    m.insert(1, 200)

    print("len: %ld\n", m.len)
    if m.contains(1) {
        print("has key: true\n")
    } else {
        print("has key: false\n")
    }
    return 0
}
