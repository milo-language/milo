// @expect: 1

enum Color {
    Red,
    Green,
    Blue,
}

fn main(): i32 {
    let c = Color.Green
    match c {
        Color.Red => {
            print(0)
        }
        Color.Green => {
            print(1)
        }
        Color.Blue => {
            print(2)
        }
    }
    return 0
}
