// A heap local bound inside a loop body must not be double-freed by `break`'s
// scope cleanup plus the function epilogue (guarded drops must be idempotent).
// @expect: 3
// @expect: 2
// @expect: 1
// @expect: done
pub struct Msg {
    payload: string
}

pub fn getMsg(n: i64): Result<Msg, string> {
    if n <= 0 {
        return Result.Err("done")
    }
    return Result.Ok(Msg {
        payload: "frame-" + n.toString() + "-aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    }
    )
}

pub fn main(): i32 {
    var i: i64 = 3
    while true {
        match getMsg(i) {
            Result.Ok(msg) => {
                let raw = msg.payload
                print(i.toString())
                i = i - 1
            }
            Result.Err(e) => {
                break
            }
        }
    }
    print("done")
    return 0
}
