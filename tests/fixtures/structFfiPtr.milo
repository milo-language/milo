// @expect: 16 2 8080

struct SockAddrIn {
    sinLen: u8,
    sinFamily: u8,
    sinPort: u16,
    sinAddr: u32,
    sinZero: [u8; 8],
}

// simulates passing struct pointer to C — printf reads from the pointer

fn dump(addr: &SockAddrIn): void {
    print(addr.sinLen, " ", addr.sinFamily, " ", addr.sinPort)
}

fn main(): i32 {
    var addr = SockAddrIn {
        sinLen: 16,
        sinFamily: 2,
        sinPort: 8080,
        sinAddr: 0,
        sinZero: [0, 0, 0, 0, 0, 0, 0, 0],
    }
    dump(addr)
    return 0
}
