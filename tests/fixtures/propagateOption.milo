// @expect: none

fn tryDouble(opt: i32?): i32? {
    let val = opt?
    return Option.Some(val * 2)
}

fn main(): i32 {
    let result = tryDouble(Option.None)
    match result {
        Option.Some(v) => {
            print(v)
        }
        Option.None => {
            print("none")
        }
    }
    return 0
}
