// `from` and `in` are contextual keywords: usable as ordinary identifiers
// (param names, locals) outside import / for-in position.
pub fn pick(from: i64, in: i64): i64 {
    var out = 0
    for i in from..in {
        out = out + i
    }
    return out
}

pub fn main(): void {
    let from = 2
    let in = 5
    // @expect: 9
    print(pick(from, in))
}
