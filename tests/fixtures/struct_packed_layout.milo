// @expect: 16
// @expect: 2
// @expect: 8080
// @expect: 3232235777
// @expect: 0 0 0 0 0 0 0 0

struct SockAddrIn {
    sin_len: u8,
    sin_family: u8,
    sin_port: u16,
    sin_addr: u32,
    sin_zero: [u8; 8],
}

fn print_addr(a: &SockAddrIn): void {
    print(a.sin_len)
    print(a.sin_family)
    print(a.sin_port)
    print(a.sin_addr)
    print(a.sin_zero[0], " ", a.sin_zero[1], " ", a.sin_zero[2], " ", a.sin_zero[3], " ", a.sin_zero[4], " ", a.sin_zero[5], " ", a.sin_zero[6], " ", a.sin_zero[7])
}

fn main(): i32 {
    let addr = SockAddrIn {
        sin_len: 16,
        sin_family: 2,
        sin_port: 8080,
        sin_addr: 3232235777,
        sin_zero: [0, 0, 0, 0, 0, 0, 0, 0],
    }
    print_addr(addr)
    return 0
}
