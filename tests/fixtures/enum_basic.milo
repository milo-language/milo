// @expect: 1
extern fn printf(fmt: *u8, ...): i32

enum Color {
    Red,
    Green,
    Blue,
}

fn main(): i32 {
    let c = Color::Green
    match c {
        Color::Red => {
            printf("%d\n", 0)
        }
        Color::Green => {
            printf("%d\n", 1)
        }
        Color::Blue => {
            printf("%d\n", 2)
        }
    }
    return 0
}
