// @expect: 1

enum Color {
    Red,
    Green,
    Blue,
}

fn main(): i32 {
    let c = Color.Green
    match c {
        Color.Red => {
            print("%d", 0)
        }
        Color.Green => {
            print("%d", 1)
        }
        Color.Blue => {
            print("%d", 2)
        }
    }
    return 0
}
