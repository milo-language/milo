// @expect: exported
// @export gives a fn external linkage. Without it, a fn from an imported module is
// `internal` and invisible to a dlopen'd library resolving against this executable.
// Asserted properly in tests/napi.test.ts (which can inspect the symbol table);
// here we only pin that the attribute parses and does not change behavior.
@export
fn exportedEntry(a: i32): i32 {
    return a + 1
}

fn main(): i32 {
    if exportedEntry(1) == 2 {
        print("exported")
    }
    return 0
}
