// @expect: hello from thread
// @expect: done

from "std/thread" import { threadJoin, threadSpawn }

fn worker(arg: *u8): *u8 {
    print("hello from thread")
    unsafe { return 0 as *u8 }
}

fn main(): i32 {
    unsafe {
        let t = threadSpawn(worker as *u8, 0 as *u8)!
        threadJoin(t)!
    }
    print("done")
    return 0
}
