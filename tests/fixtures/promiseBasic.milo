// @expect: 42
// @expect: hello
// @expect: done

from "std/runtime" import { Task, Promise }

fn main(): i32 {
    let a = Promise<i64>.run(move (): i64 => {
        return 42
    })
    let b = Promise<string>.run(move (): string => {
        return "hello"
    })

    let valA = a.await()!
    let valB = b.await()!
    print(valA)
    print(valB)
    print("done")
    return 0
}
