// @expect: 1225
// @expect: done

from "std/runtime" import {
    Promise
}

pub fn sumTo(n: i64): i64 {
    var acc: i64 = 0
    var i: i64 = 0
    while i < n {
        acc = acc + i
        i = i + 1
    }
    return acc
}

pub fn main(): i32 {
    // CPU-bound work on a real OS thread; main awaits without a scheduler.
    let p = Promise<i64>.blocking(move(): i64 => {
        return sumTo(50)
    }
    )
    let r = p.await()!
    print(r)
    print("done")
    return 0
}
