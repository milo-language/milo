// @expect: hello world
// @expect: foobar
// @expect: done
// tests: string drop on scope exit, reassignment drops old value, move zeroes source

fn consume(s: string) {
    print(s)
}

fn main(): i32 {
    let a = "hello" + " world"
    consume(a)

    var b = "foo" + "bar"
    print(b)
    b = "replaced"

    print("done")
    return 0
}

