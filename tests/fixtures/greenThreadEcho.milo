// @expect: server ready
// @expect: done
// @expect: client 1 connected
// @expect: echo: hello from 1
// @expect: client 2 connected
// @expect: echo: hello from 2

from "std/os" import {
    connectIn, bindIn, getSockPort,
    socket, bind, listen, accept, connect, read, write, close, setsockopt, getsockname, ntohs, pipe
}
from "std/platform" import {
    SockAddrIn, makeSockaddr, makeZeroedSockaddr, makeZeroedSockaddrStorage, sockAddrStorageLen, solSocket, soReuseaddr, getErrno, eagain
}
from "std/event" import {
    setNonblocking
}
from "std/runtime" import {
    Task, schedulerYield, schedulerWaitRead, schedulerWaitWrite, schedulerCurrent, schedulerRunToCompletion
}

fn greenRead(fd: i32, buf: &[u8; 4096], size: i64): i64 {
    while true {
        let n = read(fd, buf, size)
        if n < 0 && getErrno() == eagain() {
            schedulerWaitRead(fd)
            continue
        }
        return n
    }
    return -1 as i64
}

fn greenWrite(fd: i32, data: &string): i64 {
    while true {
        let n = write(fd, data, data.len)
        if n < 0 && getErrno() == eagain() {
            schedulerWaitWrite(fd)
            continue
        }
        return n
    }
    return -1 as i64
}

fn doClient(port: u16, id: i32): void {
    let AF_INET: i32 = 2
    let SOCK_STREAM: i32 = 1
    let fd = socket(AF_INET, SOCK_STREAM, 0)
    var addr2 = makeSockaddr(port, 16777343)
    connectIn(fd, addr2)
    setNonblocking(fd)
    print("client ", id, " connected")
    let msg = format("hello from ", id)
    greenWrite(fd, msg)
    var buf: [u8; 4096] = [0; 4096]
    let n = greenRead(fd, buf, 4096)
    if n > 0 {
        var resp: string = ""
        var i: i64 = 0
        while i < n {
            resp.push(buf[i])
            i = i + 1
        }
        print(resp)
    }
    close(fd)
}

fn main(): i32 {
    let AF_INET: i32 = 2
    let SOCK_STREAM: i32 = 1

    let serverFd = socket(AF_INET, SOCK_STREAM, 0)
    var one: i32 = 1
    setsockopt(serverFd, solSocket(), soReuseaddr(), one, 4)
    var addr = makeSockaddr(0 as u16, 0)
    bindIn(serverFd, addr)
    listen(serverFd, 128)

    // family-agnostic: sin_port and sin6_port both sit at offset 2
    let port = getSockPort(serverFd)

    setNonblocking(serverFd)
    print("server ready")

    // spawn server accept loop
    Task.spawn(move(): void => {
        var handled = 0
        while handled < 2 {
            // storage-sized: accept lets the kernel pick the peer's family, and a v6
            // peer does not fit a 16-byte sockaddr_in
            var clientAddr = makeZeroedSockaddrStorage()
            var addrlen: u32 = sockAddrStorageLen()
            let clientFd = accept(serverFd, clientAddr, addrlen)
            if clientFd < 0 {
                if getErrno() == eagain() {
                    schedulerWaitRead(serverFd)
                    continue
                }
                continue
            }
            setNonblocking(clientFd)
            let fd = clientFd
            Task.spawn(move(): void => {
                var buf: [u8; 4096] = [0; 4096]
                let n = greenRead(fd, buf, 4096)
                if n > 0 {
                    var msg: string = ""
                    var i: i64 = 0
                    while i < n {
                        msg.push(buf[i])
                        i = i + 1
                    }
                    let resp = "echo: " + msg
                    greenWrite(fd, resp)
                }
                close(fd)
            }
            )
            handled = handled + 1
        }
        close(serverFd)
    }
    )

    // run clients sequentially so output order is deterministic
    Task.spawn(move(): void => {
        doClient(port as u16, 1)
        doClient(port as u16, 2)
    }
    )

    print("done")
    schedulerRunToCompletion()
    return 0
}
