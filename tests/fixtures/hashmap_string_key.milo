// @expect: len: 2
// @expect: has hello: true
// @expect: has nope: false
// @expect: got hello: 42

fn main(): i32 {
    var m: HashMap<string, i32> = HashMap.new()
    m.insert("hello", 42)
    m.insert("world", 99)

    print("len: %ld\n", m.len)
    if m.contains("hello") {
        print("has hello: true\n")
    } else {
        print("has hello: false\n")
    }
    if m.contains("nope") {
        print("has nope: true\n")
    } else {
        print("has nope: false\n")
    }

    let r = m.get("hello")
    if let Option.Some(v) = r {
        print("got hello: %d\n", v)
    } else {
        print("hello not found\n")
    }
    return 0
}
