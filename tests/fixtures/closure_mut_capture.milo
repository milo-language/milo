// closure mutating a captured var — visible outside

fn call_it(f: () => void) {
    f()
}

fn main(): i32 {
    var count: i32 = 0
    call_it(() => { count = count + 1 })
    call_it(() => { count = count + 1 })
    call_it(() => { count = count + 1 })
    print("%d\n", count)
    return 0
}
// @expect: 3
