// @expect: transitivity: proven
// @expect: clamp: proven
// @expect: case-split: proven
// @expect: bound: violated x0=0
// @expect: strict-int-gap: unknown
//
// Exercises std/smt — the QF_LIA decision procedure written in Milo — through
// its public builder API. Each case builds the SAT query for a proof
// obligation (assumptions ∧ ¬goal) and asks decide() whether it is UNSAT
// (goal proven), SAT with a witness (goal violated), or rational-only (unknown).

from "std/smt" import {
    SmtProblem, Verdict, newProblem, addAtom, nAtom, nNot, nAnd, nOr, decide
}
from "std/math" import {
    absI64
}

pub fn reportVerdict(label: &string, v: &Verdict) {
    match v {
        Verdict.Proven => {
            print(label, "proven")
        }
        Verdict.Unknown => {
            print(label, "unknown")
        }
        Verdict.Violated(w) => {
            var s: string = ""
            var j: i64 = 0
            while j < w.len {
                if j > 0 {
                    s = s + " "
                }
                s = s + "x" + i64ToString(j) + "=" + i64ToString(w[j])
                j = j + 1
            }
            print(label, "violated ", s)
        }
    }
}

pub fn i64ToString(n: i64): string {
    if n == 0 {
        return "0"
    }
    let neg: bool = n < 0
    var m = absI64(n)
    var digits: string = ""
    while m > 0 {
        digits = digitChar(m % 10) + digits
        m = m / 10
    }
    if neg {
        return "-" + digits
    }
    return digits
}

pub fn digitChar(d: i64): string {
    if d == 1 {
        return "1"
    }
    if d == 2 {
        return "2"
    }
    if d == 3 {
        return "3"
    }
    if d == 4 {
        return "4"
    }
    if d == 5 {
        return "5"
    }
    if d == 6 {
        return "6"
    }
    if d == 7 {
        return "7"
    }
    if d == 8 {
        return "8"
    }
    if d == 9 {
        return "9"
    }
    return "0"
}

pub fn main(): i32 {
    // 1) transitivity: a<=b, b<=c |- a<=c   (vars a=0 b=1 c=2)
    //    query: (a-b<=0) & (b-c<=0) & !(a-c<=0)
    var t = newProblem(3)
    let tA = nAtom(t, addAtom(t, [1, -1, 0], 0, false))
    let tB = nAtom(t, addAtom(t, [0, 1, -1], 0, false))
    let tGoal = addAtom(t, [1, 0, -1], 0, false)
    var tKids: Vec<i64> = []
    tKids.push(tA)
    tKids.push(tB)
    tKids.push(nNot(t, nAtom(t, tGoal)))
    reportVerdict("transitivity: ", decide(t, nAnd(t, tKids)))

    // 2) clamp pass-through: lo<=hi, lo<=value, value<=hi |- lo<=value & value<=hi
    //    (vars lo=0 hi=1 value=2)
    var c = newProblem(3)
    let cLoHi = nAtom(c, addAtom(c, [1, -1, 0], 0, false))
    let aLoV = addAtom(c, [1, 0, -1], 0, false)
    let aVHi = addAtom(c, [0, -1, 1], 0, false)
    var negGoal: Vec<i64> = []
    negGoal.push(nNot(c, nAtom(c, aLoV)))
    negGoal.push(nNot(c, nAtom(c, aVHi)))
    var cKids: Vec<i64> = []
    cKids.push(cLoHi)
    cKids.push(nAtom(c, aLoV))
    cKids.push(nAtom(c, aVHi))
    cKids.push(nOr(c, negGoal))
    reportVerdict("clamp: ", decide(c, nAnd(c, cKids)))

    // 3) case-split: (x<=-1 | x>=1) |- x != 0    (var x=0)
    //    query: (x+1<=0 | 1-x<=0) & (x<=0) & (-x<=0)   [x==0 as x<=0 & x>=0]
    var s = newProblem(1)
    var branch: Vec<i64> = []
    branch.push(nAtom(s, addAtom(s, [1], 1, false)))
    branch.push(nAtom(s, addAtom(s, [-1], 1, false)))
    var sKids: Vec<i64> = []
    sKids.push(nOr(s, branch))
    sKids.push(nAtom(s, addAtom(s, [1], 0, false)))
    sKids.push(nAtom(s, addAtom(s, [-1], 0, false)))
    reportVerdict("case-split: ", decide(s, nAnd(s, sKids)))

    // 4) violable: x>=0 |- x>=5   (var x=0)  -> counterexample x=0
    var b = newProblem(1)
    var bKids: Vec<i64> = []
    bKids.push(nAtom(b, addAtom(b, [-1], 0, false)))
    bKids.push(nNot(b, nAtom(b, addAtom(b, [-1], 5, false))))
    reportVerdict("bound: ", decide(b, nAnd(b, bKids)))

    // 5) x<y |- x+1<=y : holds over integers but not rationals; Tier 1 finds no
    //    integer witness in the box and honestly returns unknown. (vars x=0 y=1)
    var g = newProblem(2)
    var gKids: Vec<i64> = []
    gKids.push(nAtom(g, addAtom(g, [1, -1], 0, true)))
    gKids.push(nNot(g, nAtom(g, addAtom(g, [1, -1], 1, false))))
    reportVerdict("strict-int-gap: ", decide(g, nAnd(g, gKids)))

    return 0
}
