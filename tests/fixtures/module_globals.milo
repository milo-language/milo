pub let MAX_SIZE: i32 = 100

pub let PI: f64 = 3.14159

pub var counter: i32 = 0

pub fn increment() {
    counter = counter + 1
}

pub fn main(): i32 {
    print(MAX_SIZE)
    print(PI)
    print(counter)
    increment()
    print(counter)
    increment()
    increment()
    print(counter)
    return 0
}

// @expect: 100
// @expect: 3.14159
// @expect: 0
// @expect: 1
// @expect: 3
