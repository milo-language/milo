// @expect: connected: fd=42
// @expect: closing connection 42
extern fn printf(fmt: *u8, ...): i32

struct Connection {
    name: string,
    fd: i32,
}

impl Drop for Connection {
    fn drop(self: &mut Self): void {
        printf("closing connection %d\n", self.fd)
    }
}

fn main(): i32 {
    let c = Connection { name: "db", fd: 42 }
    printf("connected: fd=%d\n", c.fd)
    return 0
}
