// JSON conformance: json.org JSON_checker suite (via CPython), RFC 8259 expectations.
// Generated by scripts/gen-json-conformance.ts. Excluded (known deviations): none.
// @expect: conformance fails=0

from "std/json" import {
    jsonParse
}

pub fn ck(input: string, want: bool, name: string): i64 {
    var got: bool = false
    match jsonParse(input) {
        Result.Ok(j) => {
            got = true
        }
        Result.Err(e) => {
            got = false
        }
    }
    if got != want {
        print("FAIL ", name)
        return 1
    }
    return 0
}

pub fn main(): i32 {
    var fails: i64 = 0
    fails = fails + ck("\"A JSON payload should be an object or array, not a string.\"", true, "fail1_toplevel_string")
    fails = fails + ck("[\"Unclosed array\"", false, "fail2_unclosed_array")
    fails = fails + ck("{unquoted_key: \"keys must be quoted\"}", false, "fail3_unquoted_key")
    fails = fails + ck("[\"extra comma\",]", false, "fail4_extra_comma")
    fails = fails + ck("[\"double extra comma\",,]", false, "fail5_double_extra_comma")
    fails = fails + ck("[   , \"<-- missing value\"]", false, "fail6_missing_value")
    fails = fails + ck("[\"Comma after the close\"],", false, "fail7_comma_after_close")
    fails = fails + ck("[\"Extra close\"]]", false, "fail8_extra_close")
    fails = fails + ck("{\"Extra comma\": true,}", false, "fail9_trailing_comma_obj")
    fails = fails + ck("{\"Extra value after close\": true} \"misplaced quoted value\"", false, "fail10_value_after_close")
    fails = fails + ck("{\"Illegal expression\": 1 + 2}", false, "fail11_illegal_expr")
    fails = fails + ck("{\"Illegal invocation\": alert()}", false, "fail12_illegal_invocation")
    fails = fails + ck("{\"Numbers cannot have leading zeroes\": 013}", false, "fail13_leading_zero")
    fails = fails + ck("{\"Numbers cannot be hex\": 0x14}", false, "fail14_hex_number")
    fails = fails + ck("[\"Illegal backslash escape: \\x15\"]", false, "fail15_bad_escape_x")
    fails = fails + ck("[\\naked]", false, "fail16_naked_escape")
    fails = fails + ck("[\"Illegal backslash escape: \\017\"]", false, "fail17_bad_escape_octal")
    fails = fails + ck("[[[[[[[[[[[[[[[[[[[[\"Too deep\"]]]]]]]]]]]]]]]]]]]]", true, "fail18_deep_nesting")
    fails = fails + ck("{\"Missing colon\" null}", false, "fail19_missing_colon")
    fails = fails + ck("{\"Double colon\":: null}", false, "fail20_double_colon")
    fails = fails + ck("{\"Comma instead of colon\", null}", false, "fail21_comma_for_colon")
    fails = fails + ck("[\"Colon instead of comma\": false]", false, "fail22_colon_for_comma")
    fails = fails + ck("[\"Bad value\", truth]", false, "fail23_bad_value")
    fails = fails + ck("['single quote']", false, "fail24_single_quote")
    fails = fails + ck("[\"\ttab\tcharacter\tin\tstring\t\"]", false, "fail25_tab_in_string")
    fails = fails + ck("[\"tab\\   character\\   in\\  string\\  \"]", false, "fail26_escaped_tab_literal")
    fails = fails + ck("[\"line\nbreak\"]", false, "fail27_raw_newline_in_string")
    fails = fails + ck("[\"line\\\nbreak\"]", false, "fail28_escaped_newline_continuation")
    fails = fails + ck("[0e]", false, "fail29_bare_exp")
    fails = fails + ck("[0e+]", false, "fail30_exp_no_digits")
    fails = fails + ck("[0e+-1]", false, "fail31_exp_garbage")
    fails = fails + ck("{\"Comma instead if closing brace\": true,", false, "fail32_comma_no_close")
    fails = fails + ck("[\"mismatch\"}", false, "fail33_mismatch_bracket")
    fails = fails + ck("[\"A\x1fZ control characters in string\"]", false, "fail34_control_in_string")
    fails = fails + ck("{\n \"JSON Test Pattern pass3\": {\n  \"The outermost value\": \"must be an object or array.\",\n  \"In this test\": \"It is an object.\"\n }\n}", true, "pass3_nested_object")
    fails = fails + ck("[{\"integer\":1234567890,\"real\":-9876.543210,\"e\":0.123456789e-12,\"E\":1.234567890E+34,\"\":23456789012E66,\"zero\":0,\"one\":1,\"space\":\" \",\"quote\":\"\\\"\",\"backslash\":\"\\\\\",\"controls\":\"\\b\\f\\n\\r\\t\",\"slash\":\"/ & \\/\",\"unicode\":\"\\u0123\\u4567\\u89AB\",\"true\":true,\"false\":false,\"null\":null,\"array\":[],\"object\":{},\"jsontext\":\"{\\\"object with 1 member\\\":[\\\"array with 1 element\\\"]}\"}]", true, "pass1_mixed")
    print("conformance fails=", fails)
    return 0
}
