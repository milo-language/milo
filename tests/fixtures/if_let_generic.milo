// @expect: found: 7
// @expect: nothing

fn main(): i32 {
    let v: i64 = 7
    let a: i64? = Option.Some(v)
    if let Option.Some(val) = a {
        print("found: %ld\n", val)
    } else {
        print("nothing\n")
    }

    let b: i64? = Option.None
    if let Option.Some(val) = b {
        print("found: %ld\n", val)
    } else {
        print("nothing\n")
    }

    return 0
}
