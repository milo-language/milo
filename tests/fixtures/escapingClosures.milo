// @expect: add5(3) = 8
// @expect: add5(10) = 15
// @expect: double(7) = 14
// @expect: triple(7) = 21
// @expect: composed = 16

fn makeAdder(n: i32): (i32) => i32 {
    return move(x: i32): i32 => {
        return x + n
    }
}

fn makeMultiplier(factor: i32): (i32) => i32 {
    return move(x: i32): i32 => {
        return x * factor
    }
}

fn compose(f: (i32) => i32, g: (i32) => i32): (i32) => i32 {
    return move(x: i32): i32 => {
        return f(g(x))
    }
}

fn main(): i32 {
    let add5 = makeAdder(5)
    print("add5(3) = ", add5(3))
    print("add5(10) = ", add5(10))

    let double = makeMultiplier(2)
    let triple = makeMultiplier(3)
    print("double(7) = ", double(7))
    print("triple(7) = ", triple(7))

    let add5ThenDouble = compose(double, add5)
    print("composed = ", add5ThenDouble(3))

    return 0
}
