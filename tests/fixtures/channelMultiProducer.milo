// @expect: sum 100

from "std/thread" import { Thread }
from "std/sync" import { Channel }

fn main(): i32 {
    let ch = Channel<i64>.new(16)!
    var threads: Vec<Thread> = Vec.new()

    var i: i64 = 0
    while i < 4 {
        let val = (i + 1) * 10
        let t = Thread.spawn(move (): void => {
            ch.send(val)!
        })!
        threads.push(t)
        i = i + 1
    }

    var sum: i64 = 0
    i = 0
    while i < 4 {
        let v = ch.recv()!
        sum = sum + v
        i = i + 1
    }

    i = 0
    while i < 4 {
        threads[i].join()!
        i = i + 1
    }

    ch.destroy()
    print("sum ", sum)
    return 0
}
