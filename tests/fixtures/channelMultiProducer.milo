// @expect: sum 100

from "std/thread" import { Thread, spawn, threadJoin }
from "std/sync" import { channelDestroy, channelNew, channelRecv, channelSend }

fn main(): i32 {
    let ch = channelNew(16)!
    var threads: Vec<Thread> = Vec.new()

    var i: i64 = 0
    while i < 4 {
        let val = (i + 1) * 10
        let t = spawn(move (): void => {
            channelSend(ch, val)!
        })!
        threads.push(t)
        i = i + 1
    }

    var sum: i64 = 0
    i = 0
    while i < 4 {
        let v = channelRecv(ch)!
        sum = sum + v
        i = i + 1
    }

    i = 0
    while i < 4 {
        threadJoin(threads[i])!
        i = i + 1
    }

    channelDestroy(ch)
    print("sum ", sum)
    return 0
}
