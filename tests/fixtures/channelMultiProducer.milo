// @expect: sum 100

from "std/runtime" import {
    Promise
}
from "std/sync" import {
    Channel
}

fn main(): i32 {
    let ch = Channel<i64>.new(16)!
    var workers: Vec<Promise<i64>> = Vec.new()

    var i: i64 = 0
    while i < 4 {
        let val = (i + 1) * 10
        let t = Promise<i64>.blocking(move(): i64 => {
            ch.send(val)!
            return 0
        }
        )
        workers.push(t)
        i = i + 1
    }

    var sum: i64 = 0
    i = 0
    while i < 4 {
        let v = ch.recv()!
        sum = sum + v
        i = i + 1
    }

    i = 0
    while i < 4 {
        workers[i].await()!
        i = i + 1
    }

    ch.destroy()
    print("sum ", sum)
    return 0
}
