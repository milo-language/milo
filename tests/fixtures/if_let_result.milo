// @expect: ok: 99
// @expect: err: -1

enum Result {
    Ok(i32),
    Err(i32),
}

fn main(): i32 {
    let a = Result.Ok(99)
    if let Result.Ok(v) = a {
        print("ok: %d\n", v)
    } else {
        print("err branch\n")
    }

    let b = Result.Err(-1)
    if let Result.Ok(v) = b {
        print("ok branch\n")
    } else {
        print("err: %d\n", -1)
    }

    return 0
}
