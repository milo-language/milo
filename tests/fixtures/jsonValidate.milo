// @expect: invalid
// @expect: invalid
// @expect: invalid
// @expect: invalid

fn isWs(ch: u8): bool {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn isDigit(ch: u8): bool {
    return ch >= '0' && ch <= '9'
}

fn isHex(ch: u8): bool {
    return isDigit(ch) || (ch >= 'A' && ch <= 'F') || (ch >= 'a' && ch <= 'f')
}

fn skipWs(s: &string, pos: &mut i64) {
    while pos < s.len && isWs(s[pos]) {
        pos = pos + 1
    }
}

fn parseValue(s: &string, pos: &mut i64): bool {
    skipWs(s, pos)
    if pos >= s.len {
        return false
    }
    let ch = s[pos]
    if ch == '"' {
        return parseString(s, pos)
    }
    if ch == '{' {
        return parseObject(s, pos)
    }
    if ch == '[' {
        return parseArray(s, pos)
    }
    if ch == 't' {
        return expectChars(s, pos, "true")
    }
    if ch == 'f' {
        return expectChars(s, pos, "false")
    }
    if ch == 'n' {
        return expectChars(s, pos, "null")
    }
    if ch == '-' || isDigit(ch) {
        return parseNumber(s, pos)
    }
    return false
}

fn parseString(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '"' {
        return false
    }
    pos = pos + 1
    while pos < s.len {
        let ch = s[pos]
        if ch == '"' {
            pos = pos + 1
            return true
        } else if ch == '\\' {
            pos = pos + 1
            if pos >= s.len {
                return false
            }
            let esc = s[pos]
            if esc == 'u' {
                pos = pos + 1
                var i: i64 = 0
                while i < 4 {
                    if pos >= s.len || !isHex(s[pos]) {
                        return false
                    }
                    pos = pos + 1
                    i = i + 1
                }
            } else if esc == '"' || esc == '\\' || esc == '/' || esc == 'b' || esc == 'f' || esc == 'n' || esc == 'r' || esc == 't' {
                pos = pos + 1
            } else {
                return false
            }
        } else {
            pos = pos + 1
        }
    }
    return false
}

fn parseNumber(s: &string, pos: &mut i64): bool {
    if pos >= s.len {
        return false
    }
    if s[pos] == '-' {
        pos = pos + 1
        if pos >= s.len {
            return false
        }
    }
    if s[pos] == '0' {
        pos = pos + 1
    } else if isDigit(s[pos]) {
        while pos < s.len && isDigit(s[pos]) {
            pos = pos + 1
        }
    } else {
        return false
    }
    if pos < s.len && s[pos] == '.' {
        pos = pos + 1
        if pos >= s.len || !isDigit(s[pos]) {
            return false
        }
        while pos < s.len && isDigit(s[pos]) {
            pos = pos + 1
        }
    }
    if pos < s.len && (s[pos] == 'e' || s[pos] == 'E') {
        pos = pos + 1
        if pos >= s.len {
            return false
        }
        if s[pos] == '+' || s[pos] == '-' {
            pos = pos + 1
        }
        if pos >= s.len || !isDigit(s[pos]) {
            return false
        }
        while pos < s.len && isDigit(s[pos]) {
            pos = pos + 1
        }
    }
    return true
}

fn parseArray(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '[' {
        return false
    }
    pos = pos + 1
    skipWs(s, pos)
    if pos < s.len && s[pos] == ']' {
        pos = pos + 1
        return true
    }
    if !parseValue(s, pos) {
        return false
    }
    skipWs(s, pos)
    while pos < s.len {
        if s[pos] == ']' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parseValue(s, pos) {
                return false
            }
            skipWs(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parseObject(s: &string, pos: &mut i64): bool {
    if pos >= s.len || s[pos] != '{' {
        return false
    }
    pos = pos + 1
    skipWs(s, pos)
    if pos < s.len && s[pos] == '}' {
        pos = pos + 1
        return true
    }
    if !parseKv(s, pos) {
        return false
    }
    skipWs(s, pos)
    while pos < s.len {
        if s[pos] == '}' {
            pos = pos + 1
            return true
        } else if s[pos] == ',' {
            pos = pos + 1
            if !parseKv(s, pos) {
                return false
            }
            skipWs(s, pos)
        } else {
            return false
        }
    }
    return false
}

fn parseKv(s: &string, pos: &mut i64): bool {
    skipWs(s, pos)
    if !parseString(s, pos) {
        return false
    }
    skipWs(s, pos)
    if pos >= s.len || s[pos] != ':' {
        return false
    }
    pos = pos + 1
    return parseValue(s, pos)
}

fn expectChars(s: &string, pos: &mut i64, expected: &string): bool {
    var i: i64 = 0
    while i < expected.len {
        if pos >= s.len || s[pos] != expected[i] {
            return false
        }
        pos = pos + 1
        i = i + 1
    }
    return true
}

fn validate(json: string): bool {
    var pos: i64 = 0
    if !parseValue(json, pos) {
        return false
    }
    skipWs(json, pos)
    return pos == json.len
}

fn check(json: string, expected: bool) {
    let result = validate(json)
    if result == expected {
        if expected {
            print("valid")
        } 
        else {
            print("invalid")
        }
    } else {
        print("ERROR")
    }
}

fn main(): i32 {
    check("null", true)
    check("42", true)
    check("\"hello\"", true)
    check("[1, 2, 3]", true)
    check("{\"a\": 1}", true)
    check("{\"a\": [true, null]}", true)
    check("3.14e-2", true)
    check("  { \"x\" : { \"y\" : [] } }  ", true)
    check("", false)
    check("[1,]", false)
    check("\"abc", false)
    check("{\"a\" 1}", false)
    return 0
}
