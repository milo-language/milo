// @expect: 18
// @expect: 2
// A block whose tail is a statement-form if/else still yields that if's value
// in if-expression context: nested `if { if {..} else {..} } else {..}` arms
// typecheck and codegen as values instead of collapsing to void.
pub fn main(): i32 {
    let c1 = true
    let c2 = false
    var fc: i64 = if c1 {
        if c2 {
            6
        } else {
            2
        }
    } else {
        if c2 {
            5
        } else {
            1
        }
    }
    print($"{fc | 0x10}")

    let v: i64 = 100
    var gc = if c1 {
        if c2 {
            v
        } else {
            2
        }
    } else {
        1
    }
    print($"{gc}")
    return 0
}
