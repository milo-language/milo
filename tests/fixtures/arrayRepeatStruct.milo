// @expect: hello
// @expect: 42
// @expect: hello
// @expect: 42

pub struct Entry {
    name: string,
    value: i32,
}

pub fn makeEntry(): Entry {
    var s = "hello"
    return Entry {
        name: s, value: 42
    }
}

pub fn main() {
    let entries = [makeEntry(); 3]
    print(entries[0].name)
    print(entries[0].value)
    print(entries[1].name)
    print(entries[2].value)
}
