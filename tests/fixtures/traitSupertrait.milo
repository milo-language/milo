// @expect: equal
// @expect: less

trait Eq {
    fn eq(self: &Self, other: &Self): bool
}

trait Ord: Eq {
    fn less(self: &Self, other: &Self): bool
}

struct Score {
    val: i32
}

impl Eq for Score {
    fn eq(self: &Self, other: &Self): bool {
        return self.val == other.val
    }
}

impl Ord for Score {
    fn less(self: &Self, other: &Self): bool {
        return self.val < other.val
    }
}

fn main(): i32 {
    let a = Score {
        val: 5
    }
    let b = Score {
        val: 5
    }
    let c = Score {
        val: 10
    }
    if a.eq(b) {
        print("equal")
    }
    if a.less(c) {
        print("less")
    }
    return 0
}

