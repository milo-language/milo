// @expect: 10
// @expect: 20
// @expect: 30
// @expect: done

import "std/thread"
import "std/sync"

fn main(): i32 {
    let ch = channelNew(8)!

    let t = spawn(move (): void => {
        channelSend(ch, 10)!
        channelSend(ch, 20)!
        channelSend(ch, 30)!
        channelSend(ch, 0)!
    })!

    while true {
        let val = channelRecv(ch)!
        if val == 0 {
            break
        }
        print(val)
    }

    threadJoin(t)!
    channelDestroy(ch)
    print("done")
    return 0
}
