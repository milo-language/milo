// @expect: 10
// @expect: 20
// @expect: 30
// @expect: done

from "std/thread" import {
    Thread
}
from "std/sync" import {
    Channel
}

fn main(): i32 {
    let ch = Channel<i64>.new(8)!

    let t = Thread.spawn(move(): void => {
        ch.send(10)!
        ch.send(20)!
        ch.send(30)!
        ch.send(0)!
    }
    )!

    while true {
        let val = ch.recv()!
        if val == 0 {
            break
        }
        print(val)
    }

    t.join()!
    ch.destroy()
    print("done")
    return 0
}
