// @expect: 10
// @expect: 20
// @expect: 30
// @expect: done

from "std/runtime" import {
    Promise
}
from "std/sync" import {
    Channel
}

pub fn main(): i32 {
    let ch = Channel<i64>.new(8)!

    let t = Promise<i64>.blocking(move(): i64 => {
        ch.send(10)!
        ch.send(20)!
        ch.send(30)!
        ch.send(0)!
        return 0
    }
    )

    while true {
        let val = ch.recv()!
        if val == 0 {
            break
        }
        print(val)
    }

    t.await()!
    ch.destroy()
    print("done")
    return 0
}
