// @expect: 10
// @expect: 20
// @expect: 30
// @expect: done

import "std/thread"
import "std/sync"

fn producer(arg: *u8): *u8 {
    channelSendPtr(arg, 10)!
    channelSendPtr(arg, 20)!
    channelSendPtr(arg, 30)!
    channelSendPtr(arg, 0)!
    unsafe { return 0 as *u8 }
}

fn main(): i32 {
    var ch = channelNew(8)!
    unsafe {
        let t = threadSpawn(producer as *u8, (&ch) as *u8)!
        while true {
            let val = channelRecv(ch)!
            if val == 0 {
                break
            }
            print(val)
        }
        threadJoin(t)!
    }
    channelDestroy(ch)
    print("done")
    return 0
}
