// @expect: true
// @expect: false
// @expect: true
// @expect: 10
// @expect: 99

pub fn find(x: i64): Option<i64> {
    if x > 0 {
        return Option.Some(x * 2)
    }
    return Option.None
}

pub fn main(): i32 {
    let a = find(5)
    let b = find(-1)
    print(a.isSome()) // true
    print(a.isNone()) // false
    print(b.isNone()) // true
    print(a.unwrapOr(0)) // 10 (Some(10))
    print(b.unwrapOr(99)) // 99 (None → default)
    return 0
}
