// @expect: 30000
// @expect: 100
// @expect: -50

pub type Altitude = i32(0..50000)

pub type SmallUint = u8(0..200)

pub type Temperature = i32(-100..100)

pub fn main(): i32 {
    let alt: Altitude = 30000
    print(alt)

    let s: SmallUint = 100
    print(s)

    let t: Temperature = -50
    print(t)

    return 0
}
