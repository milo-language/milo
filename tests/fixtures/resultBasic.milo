// @expect: 42
// @expect: error: too small

fn doubleIfBig(x: i32): Result<i32> {
    if x < 10 {
        return Result.Err("too small")
    }
    return Result.Ok(x * 2)
}

fn main(): i32 {
    let a = doubleIfBig(21)
    match a {
        Result.Ok(v) => {
            print(v)
        }
        Result.Err(msg) => {
            print("error: ", msg)
        }
    }

    let b = doubleIfBig(5)
    match b {
        Result.Ok(v) => {
            print(v)
        }
        Result.Err(msg) => {
            print("error: ", msg)
        }
    }

    return 0
}
