// @expect: 600

from "std/sync" import { RwLock, AtomicI64 }
from "std/thread" import { Thread }

fn main(): i32 {
    let rw = RwLock.new()!
    let counter = AtomicI64.new(0)
    let readCount = AtomicI64.new(0)

    // 2 writer threads, each adds 100
    let w1 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            rw.write()!
            counter.add(1)
            rw.unlock()!
            i = i + 1
        }
    })!
    let w2 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            rw.write()!
            counter.add(1)
            rw.unlock()!
            i = i + 1
        }
    })!

    // 2 reader threads, each reads 200 times
    let r1 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 200 {
            rw.read()!
            let _v = counter.load()
            rw.unlock()!
            readCount.add(1)
            i = i + 1
        }
    })!
    let r2 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 200 {
            rw.read()!
            let _v = counter.load()
            rw.unlock()!
            readCount.add(1)
            i = i + 1
        }
    })!

    w1.join()!
    w2.join()!
    r1.join()!
    r2.join()!

    // readCount=400 (2 readers * 200) + counter=200 (2 writers * 100)
    print(readCount.load() + counter.load())

    counter.destroy()
    readCount.destroy()
    rw.destroy()
    return 0
}
