// @expect: 600

from "std/sync" import { rwLockNew, rwLockRead, rwLockWrite, rwLockUnlock, rwLockDestroy, atomicI64New, atomicI64Load, atomicI64Add, atomicI64Destroy }
from "std/thread" import { spawn, threadJoin }

fn main(): i32 {
    let rw = rwLockNew()!
    let counter = atomicI64New(0)
    let readCount = atomicI64New(0)

    // 2 writer threads, each adds 100
    let w1 = spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            rwLockWrite(rw)!
            atomicI64Add(counter, 1)
            rwLockUnlock(rw)!
            i = i + 1
        }
    })!
    let w2 = spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            rwLockWrite(rw)!
            atomicI64Add(counter, 1)
            rwLockUnlock(rw)!
            i = i + 1
        }
    })!

    // 2 reader threads, each reads 200 times
    let r1 = spawn(move (): void => {
        var i: i64 = 0
        while i < 200 {
            rwLockRead(rw)!
            let _v = atomicI64Load(counter)
            rwLockUnlock(rw)!
            atomicI64Add(readCount, 1)
            i = i + 1
        }
    })!
    let r2 = spawn(move (): void => {
        var i: i64 = 0
        while i < 200 {
            rwLockRead(rw)!
            let _v = atomicI64Load(counter)
            rwLockUnlock(rw)!
            atomicI64Add(readCount, 1)
            i = i + 1
        }
    })!

    threadJoin(w1)!
    threadJoin(w2)!
    threadJoin(r1)!
    threadJoin(r2)!

    // readCount=400 (2 readers * 200) + counter=200 (2 writers * 100)
    print(atomicI64Load(readCount) + atomicI64Load(counter))

    atomicI64Destroy(counter)
    atomicI64Destroy(readCount)
    rwLockDestroy(rw)
    return 0
}
