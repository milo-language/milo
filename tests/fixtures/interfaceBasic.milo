// @expect: hello from Dog
// @expect: hello from Cat

pub interface Greeter {
    fn greet(self: &Self): string
}

pub struct Dog {
}

impl Dog {
    fn greet(self: &Self): string {
        return "hello from Dog"
    }
}

pub struct Cat {
}

impl Cat {
    fn greet(self: &Self): string {
        return "hello from Cat"
    }
}

pub fn sayHello(g: &Greeter) {
    print(g.greet())
}

pub fn main(): i32 {
    let d = Dog {
    }
    let c = Cat {
    }
    sayHello(d)
    sayHello(c)
    return 0
}
