// @expect: ok: 99
// @expect: err: -1

pub enum Result {
    Ok(i32),
    Err(i32),
}

pub fn main(): i32 {
    let a = Result.Ok(99)
    if let Result.Ok(v) = a {
        print("ok: ", v)
    } else {
        print("err branch")
    }

    let b = Result.Err(-1)
    if let Result.Ok(v) = b {
        print("ok branch")
    } else {
        print("err: ", -1)
    }

    return 0
}
