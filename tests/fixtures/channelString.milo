// @expect: hello
// @expect: world
// @expect: done

from "std/runtime" import {
    Promise
}
from "std/sync" import {
    Channel
}

pub fn main(): i32 {
    let ch = Channel<string>.new(8)!

    let t = Promise<i64>.blocking(move(): i64 => {
        ch.send("hello")!
        ch.send("world")!
        ch.send("")!
        return 0
    }
    )

    while true {
        let val = ch.recv()!
        if val.len == 0 {
            break
        }
        print(val)
    }

    t.await()!
    ch.destroy()
    print("done")
    return 0
}
