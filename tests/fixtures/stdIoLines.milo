// @expect: hello
// @expect: world
// @expect: foo
// @expect: 3
// @expect: a
// @expect: b
// @expect: 2

from "std/io" import { splitLines }

fn main(): i32 {
    let lines = splitLines("hello\nworld\nfoo")
    for line in lines {
        print(line)
    }
    print(lines.len.toString())

    let crlf = splitLines("a\r\nb\r\n")
    for line in crlf {
        print(line)
    }
    print(crlf.len.toString())
    return 0
}
