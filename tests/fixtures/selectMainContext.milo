// @skip-os: win32
// the green scheduler's event loop is kqueue/epoll readiness-based; Windows
// needs the IOCP completion port rewrite (docs/roadmap.md).

// Select.wait() must return the WINNING ARM INDEX on the main context, not -1.
//
// It returned -1 for a long time: `schedulerCurrent()` is 0 on the main context, so
// `schedulerPark()` no-opped and the unclaimed -1 fell straight through to the caller.
// Select still woke at the right moment, so this looked like it worked — the demos just
// couldn't tell which arm fired and drained every arm to compensate.
//
// The fix is the shape channels already use (`_schedulerPollMain`): main can't park,
// because nobody else would drive the scheduler, so it polls a bounded tick and re-checks
// the claim. An earlier attempt that drove the poll from inside the wait lock hung.
//
// Arm 1 is a 5s timeout that must NOT win — if the poll loop ever stops making progress
// this fixture fails on the winner index rather than hanging the suite.
from "std/runtime" import {
    Task
}
from "std/sync" import {
    Channel
}
from "std/select" import {
    Select, selectRecv
}
from "std/time" import {
    sleepMs
}

fn main(): i32 {
    let ch = Channel<i64>.new(1)!

    Task.spawn(move(): void => {
        sleepMs(30)
        let _ = ch.send(99)
    }
    )

    var sel = Select.new()
    selectRecv(sel, ch) // arm 0 — the green task fires this
    sel.onTimeout(5000) // arm 1 — safety net; must not win
    let w = sel.wait()
    sel.destroy()

    // @expect: winner 0
    print("winner ", w)

    // The claim must also be usable: the value is still there to fetch per-arm.
    // @expect: got 99
    print("got ", ch.recv()!)
    return 0
}
