// @expect: 7

pub enum Shape {
    Circle(i32),
    Rectangle(i32, i32),
    Point,
}

pub fn main(): i32 {
    let s = Shape.Rectangle(3, 4)
    match s {
        Shape.Circle(r) => {
            print(r)
        }
        Shape.Rectangle(w, h) => {
            print(w + h)
        }
        Shape.Point => {
            print("0")
        }
    }
    return 0
}
