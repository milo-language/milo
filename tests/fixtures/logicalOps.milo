// @expect: both true
// @expect: one true
// @expect: neither
// @expect: short-circuit works

fn main(): i32 {
    let a = true
    let b = true
    let c = false

    if a && b {
        print("both true")
    }
    if a || c {
        print("one true")
    }
    if c && a {
        print("should not print")
    } else {
        print("neither")
    }

    // short-circuit: sideEffect should not be called
    var called: bool = false
    if c && setFlag(called) {
        print("should not print")
    }
    if !called {
        print("short-circuit works")
    }

    return 0
}

fn setFlag(x: &mut bool): bool {
    x = true
    return true
}

