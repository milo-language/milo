// @expect: got 84
// @expect: failed: negative

fn validate(x: i32): Result<i32> {
    if x < 0 {
        return Result.Err("negative")
    }
    return Result.Ok(x)
}

fn double_valid(x: i32): Result<i32> {
    let v = validate(x)?
    return Result.Ok(v * 2)
}

fn main(): i32 {
    let a = double_valid(42)
    match a {
        Result.Ok(v) => { print("got %d\n", v) }
        Result.Err(msg) => { print("failed: %s\n", msg) }
    }

    let b = double_valid(-1)
    match b {
        Result.Ok(v) => { print("got %d\n", v) }
        Result.Err(msg) => { print("failed: %s\n", msg) }
    }

    return 0
}
