// extern struct carrying a raw pointer, round-tripped through C by value
pub extern struct Span {
    ptr: *u8,
    len: i64,
}

pub extern fn make_span(): Span

pub extern fn span_len(s: Span): i64

pub extern fn span_first(s: Span): i32

pub fn main(): i32 {
    let s = make_span()
    print(span_len(s))
    print(span_first(s))
    return 0
}
// @expect: 3
// @expect: 65
