// @skip-os: win32
// std/pty has a Windows ConPTY arm (std/pty.windows.milo) and the OS-independent
// lifecycle is covered by ptyLifecycle.milo. This fixture asserts a POSIX pts detail —
// a /dev/... slave path — that ConPTY does not have (its slavePath is always "").

// @expect: pty opened
// @expect: slave path starts with /dev/

from "std/pty" import {
    Pty
}

pub fn main(): void {
    match Pty.open() {
        Result.Ok(pty) => {
            print("pty opened")
            if pty.slavePath.startsWith("/dev/") {
                print("slave path starts with /dev/")
            } else {
                print($"unexpected path: {pty.slavePath}")
            }
            pty.close()
        }
        Result.Err(msg) => {
            print($"error: {msg}")
        }
    }
}
