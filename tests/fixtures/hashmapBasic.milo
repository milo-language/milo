// @expect: len: 3
// @expect: has 1: true
// @expect: has 5: true
// @expect: has 99: false

pub fn main(): i32 {
    var m: HashMap<i32, i32> = HashMap.new()
    m.insert(1, 10)
    m.insert(5, 50)
    m.insert(42, 420)

    print("len: ", m.len)
    if m.contains(1) {
        print("has 1: true")
    } else {
        print("has 1: false")
    }
    if m.contains(5) {
        print("has 5: true")
    } else {
        print("has 5: false")
    }
    if m.contains(99) {
        print("has 99: true")
    } else {
        print("has 99: false")
    }
    return 0
}
