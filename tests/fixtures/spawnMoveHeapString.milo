// @expect: MSG: hello from heap
// @expect: done

from "std/runtime" import {
    Promise
}

fn main(): i32 {
    // heap-allocated string (cap > 0) — exercises the move-capture ownership transfer
    var msg = "hello"
    msg = msg + " from heap"

    let t = Promise<i64>.blocking(move(): i64 => {
        print("MSG: ", msg)
        return 0
    }
    )

    t.await()!
    print("done")
    return 0
}
