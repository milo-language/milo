// @expect: 16x8x3
// @expect: 1bed20a7275954e59f2ea9bc93e2ab1520cba2341cf32c081d94db569d89f1fc
from "std/png" import {
    decodePng
}
from "std/sha256" import {
    sha256
}

// PNG written by python with a different filter on each scanline (row % 5), so all
// five unfilter paths (None/Sub/Up/Average/Paeth) are exercised. The sha256 is over
// the known original pixels — an external oracle, not a self-roundtrip.
pub fn main(): i32 {
    let bytes: [i64; 198] = [137, 80, 78, 71, 13, 10, 26, 10, 0, 0, 0, 13, 73, 72, 68, 82, 0, 0, 0, 16, 0, 0, 0, 8, 8, 2, 0, 0, 0, 127, 20, 232, 192, 0, 0, 0, 141, 73, 68, 65, 84, 120, 218, 99, 96, 96, 96, 96, 231, 230, 229, 19, 147, 18, 85, 84, 151, 209, 49, 81, 54, 119, 212, 114, 242, 51, 244, 141, 182, 136, 200, 176, 79, 46, 117, 203, 107, 242, 173, 236, 15, 105, 153, 19, 221, 191, 50, 105, 214, 182, 204, 165, 135, 25, 153, 89, 5, 129, 26, 136, 71, 76, 64, 13, 164, 33, 54, 46, 37, 86, 14, 126, 226, 17, 11, 88, 31, 47, 241, 136, 129, 95, 50, 84, 76, 37, 73, 86, 63, 95, 197, 170, 70, 219, 181, 211, 40, 96, 154, 101, 244, 98, 135, 180, 13, 238, 133, 123, 253, 106, 78, 133, 182, 95, 143, 153, 244, 36, 121, 238, 199, 172, 21, 255, 10, 55, 115, 87, 236, 147, 96, 20, 146, 75, 163, 173, 167, 1, 47, 145, 45, 137, 125, 80, 237, 93, 0, 0, 0, 0, 73, 69, 78, 68, 174, 66, 96, 130]
    var src = ""
    for i in 0..198 {
        src.push(bytes[i] as u8)
    }
    match decodePng(src) {
        Result.Ok(img) => {
            print($"{img.width}x{img.height}x{img.channels}")
            print(sha256(img.pixels))
        }
        Result.Err(e) => {
            print(e)
        }
    }
    return 0
}
