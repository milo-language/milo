// @expect: 200

from "std/sync" import { AtomicI64 }
from "std/thread" import { Thread }

fn main(): i32 {
    let counter = AtomicI64.new(0)

    let t1 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            counter.add(1)
            i = i + 1
        }
    })!
    let t2 = Thread.spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            counter.add(1)
            i = i + 1
        }
    })!

    t1.join()!
    t2.join()!
    print(counter.load())
    counter.destroy()
    return 0
}
