// @expect: 200

from "std/sync" import { atomicI64New, atomicI64Load, atomicI64Add, atomicI64Destroy }
from "std/thread" import { spawn, threadJoin }

fn main(): i32 {
    let counter = atomicI64New(0)

    let t1 = spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            atomicI64Add(counter, 1)
            i = i + 1
        }
    })!
    let t2 = spawn(move (): void => {
        var i: i64 = 0
        while i < 100 {
            atomicI64Add(counter, 1)
            i = i + 1
        }
    })!

    threadJoin(t1)!
    threadJoin(t2)!
    print(atomicI64Load(counter))
    atomicI64Destroy(counter)
    return 0
}
