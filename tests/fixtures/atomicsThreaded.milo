// @expect: 200

from "std/sync" import {
    AtomicI64
}
from "std/runtime" import {
    Promise
}

fn main(): i32 {
    let counter = AtomicI64.new(0)

    let t1 = Promise<i64>.blocking(move(): i64 => {
        var i: i64 = 0
        while i < 100 {
            counter.add(1)
            i = i + 1
        }
        return 0
    }
    )
    let t2 = Promise<i64>.blocking(move(): i64 => {
        var i: i64 = 0
        while i < 100 {
            counter.add(1)
            i = i + 1
        }
        return 0
    }
    )

    t1.await()!
    t2.await()!
    print(counter.load())
    counter.destroy()
    return 0
}
