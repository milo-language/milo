// Promise(fn) syntax with type inference

// @expect: 42
// @expect: hello
// @expect: done

from "std/runtime" import {
    Task, Promise
}

fn main(): i32 {
    // Promise(fn) desugars to Promise<T>.run(fn) with T inferred
    let a = Promise((): i64 => {
        return 42
    }
    )
    let b = Promise((): string => {
        return "hello"
    }
    )

    let valA = a.await()!
    let valB = b.await()!
    print(valA)
    print(valB)
    print("done")
    return 0
}
