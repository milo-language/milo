// @expect: spawned 1000
// @expect: all done

from "std/runtime" import { Task, schedulerRunToCompletion }

fn main(): i32 {
    var i = 0
    while i < 1000 {
        Task.spawn(move (): void => {
            let x = 1 + 1
        })
        i = i + 1
    }
    print("spawned 1000")
    schedulerRunToCompletion()
    print("all done")
    return 0
}
