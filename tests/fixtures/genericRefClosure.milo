// @expect: 9
// Regression: a generic fn taking a `&T` closure param used to collapse `&T`
// to value `T` during monomorphization, passing a struct where the closure
// expected a ptr — segfault. See substituteMiloType ref-preservation.
pub struct P {
    x: i64
}

pub fn applyG<T>(p: &T, f: (&T) => i64): i64 {
    return f(p)
}

pub fn main(): i32 {
    let q = P {
        x: 9
    }
    print(applyG(q, (r: &P): i64 => r.x))
    return 0
}
