// @expect: got 3
// @expect: none

pub fn getName(ok: bool): string? {
    if !ok {
        return Option.None
    }
    return Option.Some("abc")
}

pub fn nameLen(ok: bool): i32? {
    let s = getName(ok)?
    return Option.Some(s.len as i32)
}

pub fn main(): i32 {
    match nameLen(true) {
        Option.Some(n) => {
            print("got ", n)
        }
        Option.None => {
            print("none")
        }
    }
    match nameLen(false) {
        Option.Some(n) => {
            print("got ", n)
        }
        Option.None => {
            print("none")
        }
    }
    return 0
}
