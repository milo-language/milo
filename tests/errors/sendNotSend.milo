// @error: type does not implement Send

from "std/thread" import {
    Thread
}

struct Dangerous {
    _ptr: *u8,
}

fn main(): i32 {
    unsafe {
        let d = Dangerous {
            _ptr: 0 as *u8
        }
        let _t = Thread.spawn(move(): void => {
            let _x = d._ptr
        }
        )!
    }
    return 0
}
