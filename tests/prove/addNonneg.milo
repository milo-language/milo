// @proven: 4
// @failed: 0
// Counts include call-site preconditions: the prover now proves each caller
// satisfies the callee's `requires`, not just that the callee keeps its `ensures`.
// Two postconditions, both discharged: the sum of two non-negatives dominates
// each operand.
pub fn addNonneg(a: i64, b: i64): i64
requires a >= 0
requires b >= 0
ensures result >= a
ensures result >= b
{
    return a + b
}

pub fn main(): i32 {
    print(addNonneg(3, 4))
    return 0
}
