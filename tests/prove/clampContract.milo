// @proven: 2
// @failed: 0
// Counts include call-site preconditions: the prover now proves each caller
// satisfies the callee's `requires`, not just that the callee keeps its `ensures`.
// clamp's result is provably within [lo, hi] on every path.
pub fn clamp(value: i64, lo: i64, hi: i64): i64
requires lo <= hi
ensures result >= lo && result <= hi
{
    if value < lo {
        return lo
    }
    if value > hi {
        return hi
    }
    return value
}

pub fn main(): i32 {
    print(clamp(5, 0, 9))
    return 0
}
