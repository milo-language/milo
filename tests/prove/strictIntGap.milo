// @proven: 1
// @failed: 0
// @unknown: 1
// Counts include call-site preconditions: the prover now proves each caller
// satisfies the callee's `requires`, not just that the callee keeps its `ensures`.
// x < y implies x+1 <= y over the INTEGERS, but not over the rationals
// (y = x + 0.5). The Tier-1 core reasons over rationals + a bounded integer
// witness search, finds no integer counterexample, and honestly returns
// unknown rather than falsely claiming proven. Locks that honesty.
pub fn tighten(x: i64, y: i64): i64
requires x < y
ensures result <= y
{
    return x + 1
}

pub fn main(): i32 {
    print(tighten(2, 5))
    return 0
}
