// @proven: 4
// @failed: 1
// Counts include call-site preconditions: the prover now proves each caller
// satisfies the callee's `requires`, not just that the callee keeps its `ensures`.
// A one-sided index guard (checks idx < len but not idx >= 0), modeled from the
// self-hosted lexer's peekCharAt. The prover proves result < len but REFUTES
// result >= 0 with a counterexample (pos=0, offset=-1) — locking that the
// counterexample path stays live, not just the proving path.
fn peekAtAsWritten(pos: i64, offset: i64, len: i64): i64
requires pos >= 0
requires pos < len
requires pos + offset < len
ensures result >= 0
ensures result < len
{
    return pos + offset
}

fn main(): i32 {
    print(peekAtAsWritten(0, 1, 5))
    return 0
}
