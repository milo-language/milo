{
  "name": "milo-lang",
  "displayName": "Milo Language",
  "description": "Language support for Milo — syntax highlighting, diagnostics, hover, go-to-definition",
  "publisher": "milo",
  "version": "0.2.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:milo"],
  "contributes": {
    "languages": [{
      "id": "milo",
      "aliases": ["Milo", "milo"],
      "extensions": [".milo"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "milo",
      "scopeName": "source.milo",
      "path": "./syntaxes/milo.tmLanguage.json"
    }],
    "configurationDefaults": {
      "[milo]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "milo.milo-lang"
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "typescript": "^5.0.0"
  }
}
