{
  "scopeName": "source.milo",
  "name": "Milo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#chars" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#fn-def" },
    { "include": "#fn-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [{
        "name": "comment.line.double-slash.milo",
        "match": "//.*$"
      }]
    },
    "chars": {
      "patterns": [{
        "name": "string.quoted.single.milo",
        "match": "'(\\\\[nrt0\\\\'\"]|\\\\x[0-9a-fA-F]{2}|[^'\\\\])'",
        "captures": {
          "0": { "name": "constant.character.milo" }
        }
      }]
    },
    "strings": {
      "patterns": [{
        "name": "string.quoted.double.milo",
        "begin": "\"",
        "end": "\"",
        "patterns": [{
          "name": "constant.character.escape.milo",
          "match": "\\\\[nrt0\\\\\"']"
        }]
      }]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.milo", "match": "\\b0x[0-9a-fA-F_]+\\b" },
        { "name": "constant.numeric.float.milo", "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b" },
        { "name": "constant.numeric.integer.milo", "match": "\\b[0-9][0-9_]*\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.milo",
          "match": "\\b(if|else|while|for|match|return|break|continue|in|parallel|unsafe)\\b"
        },
        {
          "name": "keyword.control.import.milo",
          "match": "\\b(import)\\b"
        },
        {
          "name": "storage.type.fn.milo",
          "match": "\\b(fn)\\b"
        },
        {
          "name": "storage.modifier.milo",
          "match": "\\b(let|var|mut|extern|pub|impl)\\b"
        },
        {
          "name": "keyword.declaration.milo",
          "match": "\\b(struct|enum|interface)\\b"
        },
        {
          "name": "keyword.operator.cast.milo",
          "match": "\\b(as|is)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [{
        "name": "constant.language.milo",
        "match": "\\b(true|false|null)\\b"
      }]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.milo",
          "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|void|char)\\b"
        },
        {
          "name": "support.type.builtin.milo",
          "match": "\\b(String|Heap|Vec|HashMap|Option|Result|Some|None|Ok|Err)\\b"
        },
        {
          "name": "entity.name.type.milo",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "fn-def": {
      "patterns": [{
        "match": "\\b(fn)\\s+([a-z_][a-zA-Z0-9_]*)",
        "captures": {
          "1": { "name": "storage.type.fn.milo" },
          "2": { "name": "entity.name.function.milo" }
        }
      }]
    },
    "fn-call": {
      "patterns": [{
        "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=[(<])",
        "captures": {
          "1": { "name": "entity.name.function.call.milo" }
        }
      }]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.milo", "match": "=>" },
        { "name": "keyword.operator.comparison.milo", "match": "==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.logical.milo", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.try.milo", "match": "\\?\\?|\\?" },
        { "name": "keyword.operator.assignment.milo", "match": "=" },
        { "name": "keyword.operator.arithmetic.milo", "match": "[+\\-*/%]" },
        { "name": "keyword.operator.reference.milo", "match": "&" }
      ]
    }
  }
}
